---
import '~/styles/global.css';
// Self-hosted variable fonts served from same CDN, no external connection needed
import '@fontsource-variable/inter/standard.css';
import '@fontsource-variable/fraunces/opsz.css';
import '@fontsource-variable/fraunces/opsz-italic.css';
import { ViewTransitions } from 'astro:transitions';
import SEO from '~/components/seo/SEO.astro';
import CurrencyWidget from '~/components/CurrencyWidget.astro';

export interface Props {
 title?: string;
 description?: string;
 image?: string;
 canonical?: string;
 noindex?: boolean;
 type?: 'website' | 'article' | 'product';
}

const { title, description, image, canonical, noindex, type } = Astro.props;
---

<!doctype html>
<html lang="en">
 <head>
   <meta charset="UTF-8" />
   <meta name="viewport" content="width=device-width, initial-scale=1.0" />
   <meta name="theme-color" content="#0A0A0A" />
   <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
   <link rel="manifest" href="/manifest.json" />
   <link rel="alternate" type="text/plain" title="LLMs.txt" href="/llms.txt" />
   <link rel="preconnect" href="https://cdn.amplitude.com" crossorigin />
   <link rel="preconnect" href="https://js-client-cfg.amplitude.com" crossorigin />
   <link rel="preconnect" href="https://ipapi.co" crossorigin />
   <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
   <SEO {title} {description} {image} {canonical} {noindex} {type} />
   <meta name="p:domain_verify" content="b67adec8e95df905da2edeb90955d806" />
   <slot name="head" />
   <ViewTransitions />
 </head>
 <body>
   <a
     href="#main-content"
     class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-brand-black focus:text-white focus:px-4 focus:py-2 focus:rounded"
   >
     Skip to content
   </a>
   <slot />
   <CurrencyWidget />

   <script>
     const observer = new IntersectionObserver(
       (entries) => {
         entries.forEach((e) => {
           if (e.isIntersecting) {
             e.target.classList.add('in-view');
             observer.unobserve(e.target);
           }
         });
       },
       { threshold: 0.15 },
     );

     function bind() {
       document.querySelectorAll('.scroll-fade:not(.in-view)').forEach((el) => observer.observe(el));
     }
     bind();
     document.addEventListener('astro:page-load', bind);
   </script>

   <!-- Currency detection + conversion runs after DOM ready -->
   <script>
     import '~/scripts/currency.ts';
   </script>

   <!-- Amplitude — loaded after idle to avoid blocking LCP (was 1870ms render-block) -->
   <script>
     function _loadAmp() {
       import('~/lib/amplitude').then(({ initAmplitude }) => initAmplitude());
     }
     if ('requestIdleCallback' in window) {
       requestIdleCallback(_loadAmp, { timeout: 4000 });
     } else {
       setTimeout(_loadAmp, 3000);
     }
     document.addEventListener('astro:page-load', function() {
       if ('requestIdleCallback' in window) {
         requestIdleCallback(_loadAmp, { timeout: 4000 });
       }
     });
   </script>

   <!-- Microsoft Clarity — deferred after idle to avoid blocking LCP -->
   <script is:inline>
   (function(){
     function _loadClarity(){
       if(window._clarityLoaded) return;
       window._clarityLoaded = true;
       (function(c,l,a,r,i,t,y){
         c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
         t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i+"?ref=bwt";
         y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
       })(window,document,"clarity","script","xg6u657oh8");
     }
     if('requestIdleCallback' in window){
       requestIdleCallback(_loadClarity,{timeout:4000});
     } else {
       setTimeout(_loadClarity,3000);
     }
   })();
   </script>

   <!-- GTM + Conversion tracking — all deferred until after load to avoid TBT -->
   <script is:inline>
   (function(){
     // GTM setup — minimal inline, actual script loads 2s after load
     window.dataLayer = window.dataLayer || [];
     function gtag(){dataLayer.push(arguments);}
     window.gtag = gtag;
     gtag('js', new Date());
     gtag('config', 'G-4XMEM7DE1B', { send_page_view: false });

     function _loadGTM() {
       if (window._gtmLoaded) return;
       window._gtmLoaded = true;
       var s = document.createElement('script');
       s.src = 'https://www.googletagmanager.com/gtag/js?id=G-4XMEM7DE1B';
       s.async = true;
       document.head.appendChild(s);
       gtag('event', 'page_view', { page_path: location.pathname });
       // Track UTM source when visitor arrives from social media
       var params = new URLSearchParams(location.search);
       var utmSource = params.get('utm_source');
       if (utmSource) {
         gtag('event', 'social_visit', {
           utm_source:   utmSource,
           utm_medium:   params.get('utm_medium') || '',
           utm_campaign: params.get('utm_campaign') || '',
           utm_content:  params.get('utm_content') || '',
           page_path:    location.pathname,
         });
       }
     }

     function _initTracking() {
       var _scrollTrack = null;

       function track(eventName, params) {
         if (typeof gtag !== 'undefined') gtag('event', eventName, params);
       }

       // CTA clicks — event delegation, safe to add once
       if (!window._ctaTrackBound) {
         window._ctaTrackBound = true;
         document.addEventListener('click', function(e) {
           var el = e.target.closest('a, button');
           if (!el) return;
           var href = el.getAttribute('href') || '';
           var text = (el.innerText || el.textContent || '').trim().slice(0, 60);
           if (href.includes('welcome') || text.toLowerCase().includes('audit') || text.toLowerCase().includes('book')) {
             track('cta_click', { cta_text: text, destination: href, page: location.pathname });
           }
           if (href.includes('demo') || text.toLowerCase().includes('demo')) {
             track('demo_click', { cta_text: text, page: location.pathname });
           }
           if (href.includes('contact') || href.includes('mailto')) {
             track('contact_click', { cta_text: text, page: location.pathname });
           }
         });
         document.addEventListener('submit', function(e) {
           var form = e.target;
           if (form && form.closest('[role="dialog"]')) {
             track('popup_form_submit', { page: location.pathname });
           }
         });
       }

       // Scroll depth + time on page — reset on each navigation
       function initPageTracking() {
         if (_scrollTrack) window.removeEventListener('scroll', _scrollTrack);
         var milestones = { 25: false, 50: false, 75: false, 90: false };
         _scrollTrack = function() {
           var h = document.body.scrollHeight - window.innerHeight;
           if (h <= 0) return;
           var scrolled = Math.round((window.scrollY / h) * 100);
           Object.keys(milestones).forEach(function(pct) {
             if (!milestones[pct] && scrolled >= parseInt(pct)) {
               milestones[pct] = true;
               track('scroll_depth', { percent: parseInt(pct), page: location.pathname });
             }
           });
         };
         window.addEventListener('scroll', _scrollTrack, { passive: true });
         [15, 30, 60].forEach(function(sec) {
           setTimeout(function() {
             track('time_on_page', { seconds: sec, page: location.pathname });
           }, sec * 1000);
         });
       }

       initPageTracking();
       document.addEventListener('astro:page-load', function() {
         gtag('event', 'page_view', { page_path: location.pathname });
         initPageTracking();
       });
     }

     // Load GTM + tracking after load event + 2s delay → zero impact on LCP/TBT
     function _boot() {
       setTimeout(function() {
         _loadGTM();
         _initTracking();
       }, 2000);
     }

     if (document.readyState === 'complete') { _boot(); }
     else { window.addEventListener('load', _boot); }
   })();
   </script>
 </body>
</html>
