---
import ShopLayout from '~/layouts/ShopLayout.astro';
import StarRating from '~/components/ui/StarRating.astro';
import ProductGallery from '~/components/product/ProductGallery.tsx';
import ProductAccordion from '~/components/product/ProductAccordion.tsx';
import IngredientComparison from '~/components/sections/IngredientComparison.astro';
import NineOrganSystems from '~/components/sections/NineOrganSystems.astro';
import ClinicalKPIs from '~/components/sections/ClinicalKPIs.astro';
import VerifiedReviews from '~/components/sections/VerifiedReviews.astro';
import GoldStandardComparison from '~/components/sections/GoldStandardComparison.astro';
import MoneyBackGuarantee from '~/components/sections/MoneyBackGuarantee.astro';
import FAQSection from '~/components/sections/FAQSection.astro';
import WhatYoullFeel from '~/components/sections/WhatYoullFeel.astro';
import ScientificBoard from '~/components/sections/ScientificBoard.astro';
import CellularScience from '~/components/sections/CellularScience.astro';
import ClinicalTrustDark from '~/components/sections/ClinicalTrustDark.astro';
import productsData from '~/data/products.json';

export function getStaticPaths() {
 return productsData.products.map((p) => ({
   params: { slug: p.slug },
   props: { product: p },
 }));
}

const { product } = Astro.props;

const accordionSections = [
 {
   id: 'description',
   title: 'Description',
   body: product.longDescription,
 },
 {
   id: 'features',
   title: 'Full feature list',
   body: product.id === 'longevity-protocol'
     ? `Conversational AI agents, intelligent lead scoring, document processing, and predictive analytics. Custom-trained on your business data with human-in-the-loop safeguards.\n\nNo vendor lock-in. Full documentation and handoff included.`
     : product.id === 'founder-stack'
     ? `Automation Pro (9 core workflows) + AI Agent Deploy (4 AI capabilities). Both production-tested with 24/7 monitoring and 99.5% uptime SLA.\n\nFull workflow specifications available on the individual service pages.`
     : `Nine core automated workflows across your entire operation: lead capture, CRM sync, email sequences, invoicing, reporting, client onboarding, AI support routing, smart scheduling, and backup & monitoring.\n\nNo vendor lock-in. No hidden fees. Full documentation included.`,
 },
 {
   id: 'how-it-works',
   title: 'How it works',
   body: `We start with a free audit of your current workflows. Within 5-10 business days, your automations are live in production.\n\nEvery deployment includes 24/7 monitoring, error handling, and a dedicated Slack channel for support. Allow one to two weeks to see the full impact on your operations.`,
 },
 {
   id: 'guarantee',
   title: 'Guarantee & terms',
   body: `30-day money-back guarantee on every plan. If your automations do not deliver measurable ROI, we refund your first month no questions asked.\n\nMonth-to-month billing. Cancel anytime. You own everything we build.`,
 },
];
---

<ShopLayout
 title={`${product.title} – PURIST`}
 description={product.shortDescription}
>
 <nav aria-label="Breadcrumb" class="container-x py-4 text-xs text-brand-gray-600">
   <ol class="flex items-center gap-1.5 flex-wrap">
     <li><a href="/" class="hover:text-brand-black transition">Home</a></li>
     <li aria-hidden="true">/</li>
     <li><a href="/collections/all" class="hover:text-brand-black transition">Services</a></li>
     <li aria-hidden="true">/</li>
     <li class="text-brand-black">{product.title}</li>
   </ol>
 </nav>

 <section class="container-x grid lg:grid-cols-2 gap-8 lg:gap-16 pt-4 pb-16 lg:pb-24">
   <div class="lg:sticky lg:top-24 lg:self-start">
     <ProductGallery client:load images={product.images} title={product.title} />
   </div>

   <div class="max-w-xl">
     {product.badge && (
       <span class="inline-block bg-brand-black text-white text-[10px] tracking-wider uppercase px-2.5 py-1 rounded mb-4">
         {product.badge}
       </span>
     )}
     <p class="eyebrow mb-3">{product.eyebrow}</p>
     <h1 class="font-display text-3xl lg:text-4xl xl:text-5xl leading-tight tracking-tight mb-4">
       {product.title}
     </h1>

     <a href="#reviews" class="inline-flex items-center gap-2 mb-6 hover:opacity-70 transition">
       <StarRating rating={product.rating} size="sm" />
       <span class="text-xs text-brand-gray-600 underline underline-offset-4">
         {product.reviewCount.toLocaleString()} verified reviews
       </span>
     </a>

     <div class="flex items-baseline gap-3 mb-4">
       <span class="font-display text-2xl">From <span data-price={product.price.subscription}>€{product.price.subscription.toLocaleString('en')}</span>/mo</span>
       <span class="line-through text-sm text-brand-gray-400">
         <span data-price={product.price.oneTime}>€{product.price.oneTime.toLocaleString('en')}</span>
       </span>
       {product.price.discount > 0 && (
         <span class="text-[10px] uppercase tracking-wider bg-brand-green/15 text-brand-green px-2 py-0.5 rounded font-medium">
           {product.price.discount}% off
         </span>
       )}
     </div>

     <p class="text-base text-brand-gray-600 mb-8 leading-relaxed text-pretty">
       {product.shortDescription}
     </p>

     <!-- Primary CTA B2B audit-first approach -->
     <div class="rounded-[18px] p-6 lg:p-7 mb-2" style="background:#0A0A0A;">
       <div class="flex items-start gap-3 mb-5">
         <div class="w-9 h-9 rounded-xl flex items-center justify-center shrink-0" style="background:rgba(232,180,176,0.12);border:1px solid rgba(232,180,176,0.18);">
           <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
             <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
           </svg>
         </div>
         <div>
           <p class="text-[11px] uppercase tracking-[0.14em] font-bold mb-0.5" style="color:rgba(232,180,176,0.55);">Start with a free audit</p>
           <p class="text-sm leading-relaxed" style="color:rgba(255,255,255,0.55);">We map your workflows and calculate exact ROI before you pay a thing. Most clients see payback within 4 months.</p>
         </div>
       </div>
       <a
         href="/pages/welcome"
         class="block w-full text-center py-4 rounded-[12px] text-[13.5px] font-semibold transition-all duration-150"
         style="background:#E8B4B0;color:#0A0A0A;"
         onmouseover="this.style.background='#d9a09b'"
         onmouseout="this.style.background='#E8B4B0'"
       >
         Book free audit no commitment
       </a>
       <a
         href="/collections/all"
         class="block w-full text-center mt-2.5 py-3 rounded-[12px] text-[12px] font-medium transition-all duration-150"
         style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.55);border:1px solid rgba(255,255,255,0.08);"
         onmouseover="this.style.background='rgba(255,255,255,0.10)'"
         onmouseout="this.style.background='rgba(255,255,255,0.06)'"
       >
         Compare all plans →
       </a>
       <p class="text-center text-[10.5px] mt-3" style="color:rgba(255,255,255,0.22);">
         No payment required · Reply within 1 business day
       </p>
     </div>

     <!-- Pricing reference row -->
     <div class="rounded-[14px] p-4 mb-6" style="background:#F8F6F1;border:1px solid rgba(10,10,10,0.07);">
       <div class="flex items-center justify-between">
         <div>
           <p class="text-[10px] uppercase tracking-wider font-semibold text-brand-gray-400 mb-0.5">Starting from</p>
           <p class="font-display text-xl text-brand-black">
             <span data-price={product.price.subscription}>€{product.price.subscription.toLocaleString('en')}</span>
             <span class="text-sm font-sans text-brand-gray-600">/month</span>
           </p>
         </div>
         <div class="text-right">
           <p class="text-[10px] uppercase tracking-wider font-semibold text-brand-gray-400 mb-0.5">Or one-time</p>
           <p class="font-display text-xl text-brand-black">
             <span data-price={product.price.oneTime}>€{product.price.oneTime.toLocaleString('en')}</span>
           </p>
         </div>
       </div>
       <div class="mt-3 pt-3 flex items-center gap-4" style="border-top:1px solid rgba(10,10,10,0.06);">
         {[
           { icon: 'M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6l8-4zM9 12l2 2 4-4', label: '30-day guarantee' },
           { icon: 'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v11m3-8v8m3-11v11M3 9h18', label: '99.5% uptime SLA' },
           { icon: 'M10 9v6M14 9v6M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z', label: 'Cancel anytime' },
         ].map((t) => (
           <div class="flex items-center gap-1.5">
             <svg class="w-3 h-3 shrink-0 text-brand-rust" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
               <path d={t.icon}/>
             </svg>
             <span class="text-[10.5px] text-brand-gray-600">{t.label}</span>
           </div>
         ))}
       </div>
     </div>

     <!-- Anchoring: vs. hiring in-house -->
     <div class="flex items-center gap-3 mb-4 px-4 py-3 rounded-[12px] text-[11.5px]" style="background:#F0F7EC;border:1px solid rgba(45,80,22,0.14);">
       <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="#2D5016" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
         <path d="M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6l8-4zM9 12l2 2 4-4"/>
       </svg>
       <p style="color:rgba(10,10,10,0.62);">
         A junior ops hire runs <span class="line-through font-medium" style="color:rgba(10,10,10,0.45);">€40–65K/year</span>.
         PURIST delivers the same output deployed in under 10 days.
       </p>
     </div>

     <!-- Tax deductible pill -->
     <div class="flex items-center gap-3 p-3 bg-brand-cream rounded-card text-xs">
       <span class="inline-flex w-7 h-7 items-center justify-center rounded-md bg-brand-rust/10 text-brand-rust shrink-0">
         <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
           <rect x="3" y="6" width="18" height="13" rx="2" stroke-linejoin="round"/>
           <path d="M3 10h18" stroke-linejoin="round"/>
         </svg>
       </span>
       <p class="leading-snug text-brand-gray-600">
         <strong class="text-brand-black">Tax-deductible business expense</strong> automation services qualify as an operational cost in the UK.
       </p>
     </div>

     <div class="mt-10">
       <ProductAccordion client:load sections={accordionSections} defaultOpen="description" />
     </div>
   </div>
 </section>

 <WhatYoullFeel />
 <NineOrganSystems />
 {product.id !== 'foundation-pro' && <CellularScience />}
 {product.id === 'foundation-pro' && <IngredientComparison />}
 <ClinicalTrustDark />
 <GoldStandardComparison />
 <ScientificBoard />
 <div id="reviews"><VerifiedReviews /></div>
 <MoneyBackGuarantee />
 <FAQSection />

 <!-- Sticky bottom CTA bar -->
 <div id="sticky-cta" class="fixed bottom-0 left-0 right-0 z-40 transition-transform duration-300 translate-y-full" aria-hidden="true">
   <div class="bg-brand-black border-t border-white/10 shadow-[0_-8px_24px_-12px_rgba(0,0,0,0.4)]">
     <div class="container-x py-3 flex items-center gap-4 lg:gap-8">
       <div class="flex-1 min-w-0">
         <p class="font-display text-sm lg:text-base text-white leading-tight truncate">{product.title}</p>
         <p class="text-[11px] truncate hidden sm:block" style="color:rgba(255,255,255,0.40);">From <span data-price={product.price.subscription}>€{product.price.subscription.toLocaleString('en')}</span>/mo · 30-day money-back guarantee</p>
       </div>
       <div class="hidden sm:flex items-baseline gap-1 shrink-0">
         <span class="font-display text-lg text-white" data-price={product.price.subscription}>€{product.price.subscription.toLocaleString('en')}</span>
         <span class="text-[11px]" style="color:rgba(255,255,255,0.40);">/mo</span>
       </div>
       <a
         href="/pages/welcome"
         class="shrink-0 rounded-button px-5 py-3 text-xs sm:text-sm font-medium transition"
         style="background:#E8B4B0;color:#0A0A0A;"
         onmouseover="this.style.background='#d9a09b'"
         onmouseout="this.style.background='#E8B4B0'"
       >
         Book free audit →
       </a>
     </div>
   </div>
 </div>
 <script is:inline>
   (function() {
     var bar = document.getElementById('sticky-cta');
     function update() {
       if (!bar) return;
       var show = window.scrollY > 600;
       bar.classList.toggle('translate-y-0', show);
       bar.classList.toggle('translate-y-full', !show);
       bar.setAttribute('aria-hidden', show ? 'false' : 'true');
     }
     update();
     window.addEventListener('scroll', update, { passive: true });
   })();
 </script>

 <script
   type="application/ld+json"
   is:inline
   set:html={JSON.stringify({
     '@context': 'https://schema.org',
     '@graph': [
       {
         '@type': 'BreadcrumbList',
         itemListElement: [
           { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.purist.online' },
           { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://www.purist.online/collections/all' },
           { '@type': 'ListItem', position: 3, name: product.title, item: `https://www.purist.online/products/${product.slug}` },
         ],
       },
       {
         '@type': 'SoftwareApplication',
         '@id': `https://www.purist.online/products/${product.slug}#product`,
         name: product.title,
         description: product.shortDescription,
         url: `https://www.purist.online/products/${product.slug}`,
         applicationCategory: 'BusinessApplication',
         operatingSystem: 'Web',
         offers: {
           '@type': 'Offer',
           price: product.price.subscription,
           priceCurrency: product.price.currency ?? 'EUR',
           availability: 'https://schema.org/InStock',
           priceSpecification: {
             '@type': 'UnitPriceSpecification',
             price: product.price.subscription,
             priceCurrency: product.price.currency ?? 'EUR',
             billingDuration: 1,
             billingIncrement: 1,
             unitCode: 'MON',
           },
           hasMerchantReturnPolicy: {
             '@type': 'MerchantReturnPolicy',
             applicableCountry: ['GB', 'US', 'CA', 'AU', 'IE', 'FR', 'DE'],
             returnPolicyCategory: 'https://schema.org/MerchantReturnFiniteReturnWindow',
             merchantReturnDays: 30,
             returnMethod: 'https://schema.org/ReturnByMail',
             returnFees: 'https://schema.org/FreeReturn',
             refundType: 'https://schema.org/FullRefund',
           },
         },
         aggregateRating: {
           '@type': 'AggregateRating',
           ratingValue: product.rating,
           reviewCount: product.reviewCount,
           bestRating: 5,
           worstRating: 1,
         },
         review: [
           {
             '@type': 'Review',
             author: { '@type': 'Person', name: 'Sarah M.' },
             reviewRating: { '@type': 'Rating', ratingValue: 5, bestRating: 5 },
             reviewBody: 'I was sceptical about automation agencies. The honest report after six weeks is that my team stopped doing data entry entirely and our lead response time dropped from 4 hours to 8 minutes. The setup was genuinely painless.',
           },
           {
             '@type': 'Review',
             author: { '@type': 'Person', name: 'Marcus T.' },
             reviewRating: { '@type': 'Rating', ratingValue: 5, bestRating: 5 },
             reviewBody: 'I used to juggle eight separate tools. One deployment replaced all of it. The error monitoring is the reason I stayed nothing breaks silently.',
           },
           {
             '@type': 'Review',
             author: { '@type': 'Person', name: 'Elena R.' },
             reviewRating: { '@type': 'Rating', ratingValue: 5, bestRating: 5 },
             reviewBody: 'I did not expect this. Within two weeks we saved 20 hours per week on admin. Knock-on effect on team morale, client satisfaction and revenue.',
           },
         ],
       },
     ],
   })}
 />
</ShopLayout>
