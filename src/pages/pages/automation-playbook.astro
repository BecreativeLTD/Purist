var currentPb = 'dental';

function complexityColor(c) {
  if (c === 'Low')    return '#4ade80';
  if (c === 'Medium') return '#C89840';
  return '#ef4444';
}
function priorityStyle(p) {
  if (p === 'P1') return 'background:rgba(232,180,176,0.12);color:#E8B4B0;';
  if (p === 'P2') return 'background:rgba(123,104,238,0.10);color:#7B68EE;';
  return 'background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.35);';
}

function renderPlaybook(id) {
  currentPb = id;
  var pb = PLAYBOOKS[id];
  if (!pb) return;
  var col = pb.accentColor;

  var statsHtml = pb.stats.map(function(s) {
    return '<div class="text-center">' +
      '<p class="font-display text-[1.8rem] leading-none mb-0.5" style="color:' + col + ';">' + s[0] + '</p>' +
      '<p class="text-[9px] uppercase tracking-wider" style="color:rgba(255,255,255,0.25);">' + s[1] + '</p>' +
    '</div>';
  }).join('');

  var toolsHtml = pb.tools.map(function(t) {
    return '<span class="px-2.5 py-1 rounded-full text-[10px] font-medium" style="background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.45);border:1px solid rgba(255,255,255,0.07);">' + t + '</span>';
  }).join('');

  var wfHtml = pb.workflows.map(function(wf, i) {
    var stepsHtml = wf.steps.map(function(step, si) {
      return '<div class="flex items-start gap-2">' +
        '<span class="w-5 h-5 rounded-full shrink-0 flex items-center justify-center text-[9px] font-bold mt-0.5" style="background:' + col + '15;color:' + col + ';">' + (si+1) + '</span>' +
        '<p class="text-[11px] leading-relaxed" style="color:rgba(255,255,255,0.45);">' + step + '</p>' +
      '</div>';
    }).join('');

    // Implementation timeline indicator
    var timelineHtml =
      '<div class="mt-5 pt-4" style="border-top:1px solid rgba(255,255,255,0.05);">' +
        '<p class="text-[9px] uppercase tracking-wider font-bold mb-3" style="color:rgba(255,255,255,0.18);">Implementation timeline</p>' +
        '<div class="flex items-center gap-0">' +
          '<div class="flex flex-col items-center">' +
            '<div class="w-2 h-2 rounded-full" style="background:' + col + ';"></div>' +
            '<p class="text-[9px] mt-1.5 text-center" style="color:rgba(255,255,255,0.35);">Day 0<br/>Audit</p>' +
          '</div>' +
          '<div class="flex-1 h-px mx-1" style="background:linear-gradient(90deg,' + col + '60,rgba(255,255,255,0.10));"></div>' +
          '<div class="flex flex-col items-center">' +
            '<div class="w-2 h-2 rounded-full" style="background:' + col + '80;"></div>' +
            '<p class="text-[9px] mt-1.5 text-center" style="color:rgba(255,255,255,0.35);">Day 1–' + wf.days + '<br/>Build</p>' +
          '</div>' +
          '<div class="flex-1 h-px mx-1" style="background:linear-gradient(90deg,rgba(255,255,255,0.10),' + col + '60);"></div>' +
          '<div class="flex flex-col items-center">' +
            '<div class="w-2 h-2 rounded-full" style="background:' + col + ';box-shadow:0 0 6px ' + col + '80;"></div>' +
            '<p class="text-[9px] mt-1.5 text-center" style="color:rgba(255,255,255,0.35);">Day ' + (wf.days+1) + '<br/>Live</p>' +
          '</div>' +
        '</div>' +
      '</div>';

    var mostDeployedBadge = wf.priority === 'P1'
      ? '<span class="text-[9px] font-semibold px-2 py-0.5 rounded-full" style="background:rgba(255,210,0,0.10);color:#FFD200;">⭐ Most deployed</span>'
      : '';

    return '<div class="pb-workflow-card rounded-[20px] border overflow-hidden" style="background:rgba(255,255,255,0.02);border-color:rgba(255,255,255,0.07);">' +
      '<div class="h-0.5" style="background:linear-gradient(90deg,' + col + ' 0%,transparent 70%);"></div>' +
      '<div class="p-5 lg:p-6">' +
        '<div class="flex items-start gap-4 mb-4">' +
          '<div class="w-10 h-10 rounded-[12px] shrink-0 flex items-center justify-center" style="background:' + col + '12;">' +
            '<svg class="w-5 h-5" style="color:' + col + ';" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="' + wf.icon + '"/></svg>' +
          '</div>' +
          '<div class="flex-1 min-w-0">' +
            '<div class="flex items-center gap-2 mb-1 flex-wrap">' +
              '<span class="text-[9px] font-bold px-2 py-0.5 rounded-full" style="' + priorityStyle(wf.priority) + '">' + wf.priority + '</span>' +
              mostDeployedBadge +
              '<span class="text-[9px] font-semibold px-2 py-0.5 rounded-full" style="background:' + complexityColor(wf.complexity) + '15;color:' + complexityColor(wf.complexity) + ';">' + wf.complexity + ' complexity</span>' +
              '<span class="text-[9px]" style="color:rgba(255,255,255,0.20);">· Deploy in ' + wf.days + ' day' + (wf.days>1?'s':'') + '</span>' +
            '</div>' +
            '<h3 class="text-[15px] font-semibold text-white leading-snug">' + wf.name + '</h3>' +
          '</div>' +
        '</div>' +
        '<p class="text-[12px] leading-relaxed mb-5" style="color:rgba(255,255,255,0.50);">' + wf.desc + '</p>' +

        '<div class="grid grid-cols-1 lg:grid-cols-2 gap-4">' +
          // Metrics first on mobile, last on desktop
          '<div class="space-y-3 order-first lg:order-last">' +
            '<div class="rounded-[14px] p-4" style="background:rgba(239,68,68,0.05);border:1px solid rgba(239,68,68,0.10);">' +
              '<p class="text-[9px] uppercase tracking-wider font-bold mb-1" style="color:rgba(239,68,68,0.50);">Manual time cost</p>' +
              '<p class="text-[14px] font-semibold" style="color:rgba(255,255,255,0.70);">' + wf.time + '</p>' +
            '</div>' +
            '<div class="rounded-[14px] p-4" style="background:rgba(74,222,128,0.05);border:1px solid rgba(74,222,128,0.12);">' +
              '<p class="text-[9px] uppercase tracking-wider font-bold mb-1" style="color:rgba(74,222,128,0.50);">Projected impact</p>' +
              '<p class="text-[14px] font-semibold" style="color:rgba(255,255,255,0.70);">' + wf.roi + '</p>' +
            '</div>' +
          '</div>' +
          // Steps last on mobile, first on desktop
          '<div class="rounded-[14px] p-4 order-last lg:order-first" style="background:rgba(255,255,255,0.025);border:1px solid rgba(255,255,255,0.05);">' +
            '<p class="text-[9px] uppercase tracking-wider font-bold mb-3" style="color:rgba(255,255,255,0.20);">Workflow steps</p>' +
            '<div class="space-y-2.5">' + stepsHtml + '</div>' +
          '</div>' +
        '</div>' +

        timelineHtml +

      '</div>' +
    '</div>';
  }).join('');

  var html = '<div style="animation:pb-in 0.35s ease-out;">' +

    // Header
    '<div class="mb-8">' +
      '<div class="flex items-end justify-between gap-4 flex-wrap mb-6">' +
        '<div>' +
          '<p class="text-[9px] uppercase tracking-[0.2em] font-bold mb-2" style="color:' + col + 'AA;">' + pb.label + ' playbook</p>' +
          '<h2 class="font-display text-[1.8rem] text-white leading-tight">' + pb.headline + '</h2>' +
        '</div>' +
      '</div>' +
      '<p class="text-[13px] leading-relaxed mb-6" style="color:rgba(255,255,255,0.45);">' + pb.intro + '</p>' +
      '<div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">' + statsHtml + '</div>' +
      '<div>' +
        '<p class="text-[9px] uppercase tracking-wider font-bold mb-2" style="color:rgba(255,255,255,0.20);">Tools required</p>' +
        '<div class="flex flex-wrap gap-1.5">' + toolsHtml + '</div>' +
      '</div>' +
    '</div>' +

    // ROI total banner
    '<div class="rounded-[16px] mb-6 p-5" style="background:linear-gradient(135deg,rgba(255,255,255,0.04) 0%,' + col + '08 100%);border:1px solid ' + col + '20;">' +
      '<p class="text-[9px] uppercase tracking-[0.2em] font-bold mb-4" style="color:' + col + '90;">Total impact if all 5 deployed</p>' +
      '<div class="grid grid-cols-3 gap-3">' +
        '<div class="text-center">' +
          '<p class="font-display text-[1.4rem] leading-none mb-1" style="color:' + col + ';">' + pb.totalHrs + '</p>' +
          '<p class="text-[9px] uppercase tracking-wider" style="color:rgba(255,255,255,0.25);">recovered/week</p>' +
        '</div>' +
        '<div class="text-center" style="border-left:1px solid rgba(255,255,255,0.07);border-right:1px solid rgba(255,255,255,0.07);">' +
          '<p class="font-display text-[1.4rem] leading-none mb-1" style="color:#4ade80;">' + pb.totalROI + '</p>' +
          '<p class="text-[9px] uppercase tracking-wider" style="color:rgba(255,255,255,0.25);">projected ROI</p>' +
        '</div>' +
        '<div class="text-center">' +
          '<p class="font-display text-[1.4rem] leading-none mb-1 text-white">' + pb.totalDays + '</p>' +
          '<p class="text-[9px] uppercase tracking-wider" style="color:rgba(255,255,255,0.25);">full deployment</p>' +
        '</div>' +
      '</div>' +
    '</div>' +

    // Search
    '<input type="text" id="pb-search" placeholder="Filter workflows by tool or keyword..." ' +
      'class="w-full px-4 py-2.5 rounded-xl border text-[13px] mb-5" ' +
      'style="background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.08);color:rgba(255,255,255,0.7);outline:none;" />' +

    // Workflows
    '<div class="space-y-5" id="pb-workflows-list">' +
      '<p class="text-[9px] uppercase tracking-[0.2em] font-bold" style="color:rgba(255,255,255,0.25);">Workflows — ordered by ROI priority</p>' +
      wfHtml +
    '</div>' +

  '</div>';

  document.getElementById('pb-content').innerHTML = html;

  // Update nav buttons
  document.querySelectorAll('.pb-ind').forEach(function(btn) {
    if (btn.dataset.pbid === id) {
      btn.style.background = col;
      btn.style.color = '#0A0A0A';
      btn.style.borderColor = col;
    } else {
      btn.style.background = 'rgba(255,255,255,0.05)';
      btn.style.color = 'rgba(255,255,255,0.50)';
      btn.style.borderColor = 'rgba(255,255,255,0.10)';
    }
  });
}

document.querySelectorAll('.pb-ind').forEach(function(btn) {
  btn.addEventListener('click', function() {
    renderPlaybook(this.dataset.pbid);
    var target = document.getElementById('pb-content');
    if (target) {
      window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - 80, behavior: 'smooth' });
    }
  });
});

document.addEventListener('input', function(e) {
  if (e.target && e.target.id === 'pb-search') {
    var q = e.target.value.toLowerCase().trim();
    document.querySelectorAll('.pb-workflow-card').forEach(function(card) {
      if (!q || card.textContent.toLowerCase().indexOf(q) !== -1) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });
  }
});

renderPlaybook('dental');

document.addEventListener('astro:page-load', function() {
  renderPlaybook('dental');
});

})();
</script>
