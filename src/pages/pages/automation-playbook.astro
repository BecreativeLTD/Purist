---
import ShopLayout from '~/layouts/ShopLayout.astro';
---

<ShopLayout
  title="Automation Playbooks by Industry — Exact Workflows, Tools & ROI | PURIST"
  description="Production-ready automation playbooks for Dental, Agency, E-commerce, Real Estate, SaaS and Finance. Exact workflows, tools required, implementation timeline and ROI benchmarks."
  canonical="https://www.purist.online/pages/automation-playbook"
>

<!-- Hero -->
<section class="bg-brand-black text-white pt-20 pb-14 lg:pt-28 relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 50% 0%,rgba(232,180,176,0.07) 0%,transparent 60%);"></div>
  <div class="container-x relative z-10">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border mb-6" style="border-color:rgba(232,180,176,0.25);background:rgba(232,180,176,0.06);">
        <span class="text-[10px] uppercase tracking-[0.18em] font-semibold" style="color:rgba(232,180,176,0.80);">Production-ready · Based on 312+ deployments</span>
      </div>
      <h1 class="font-display text-[2.2rem] lg:text-[3rem] leading-[1.06] tracking-[-0.025em] text-white mb-4">
        Automation playbooks<br/><em class="font-medium" style="color:#E8B4B0;">by industry.</em>
      </h1>
      <p class="text-[15px] leading-relaxed mb-8 max-w-xl mx-auto" style="color:rgba(255,255,255,0.45);">
        Not theory. Not case studies. Exact workflows, the tools that connect them, implementation order, and the real ROI numbers — from live deployments.
      </p>
      <div class="pb-ind-container flex gap-2 overflow-x-auto pb-2 -mx-4 px-4 lg:mx-0 lg:px-0 lg:flex-wrap lg:justify-center">
        {[
          ['dental',     'Dental & Healthcare'],
          ['agency',     'Agency & Consulting'],
          ['ecom',       'E-commerce'],
          ['realestate', 'Real Estate'],
          ['saas',       'SaaS / Tech'],
          ['finance',    'Finance & Legal'],
        ].map(([id, label], i) => (
          <button class="pb-ind whitespace-nowrap shrink-0 px-4 py-2 rounded-full text-[11px] font-semibold border transition-all" data-pbid={id}
            style={i===0
              ? 'background:#E8B4B0;color:#0A0A0A;border-color:#E8B4B0;'
              : 'background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.50);border-color:rgba(255,255,255,0.10);'}>
            {label}
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Playbook content -->
<section class="bg-[#0C0C0A] py-14 lg:py-20">
  <div class="container-x">
    <div class="max-w-5xl mx-auto" id="pb-content">
      <!-- injected by JS -->
    </div>
  </div>
</section>

<!-- How PURIST deploys -->
<section class="bg-white py-16 lg:py-20 border-t border-brand-gray-100">
  <div class="container-x">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12 scroll-fade">
        <p class="eyebrow mb-3">Our deployment method</p>
        <h2 class="font-display text-h2 mb-3">From playbook to production in 7 days</h2>
        <p class="text-sm text-brand-gray-600 max-w-lg mx-auto">Every playbook is deployed using the same precision process.</p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-4">
        {[
          { day:'Day 0',  title:'Free audit call',      desc:'We map your exact processes, confirm the tools in your stack, and prioritise by ROI.', col:'#E8B4B0', deliverables:['Stack audit doc','Priority matrix','Fixed quote'] },
          { day:'Day 1–2',title:'Architecture',          desc:'We design the full workflow graph, define data schemas, and set up your n8n environment.', col:'#7B68EE', deliverables:['Workflow graph doc','Data schema definitions','n8n environment live'] },
          { day:'Day 3–5',title:'Build & test',          desc:'Workflows are built, tested with real data in sandbox, edge cases handled.', col:'#C89840', deliverables:['All workflows deployed to sandbox','Edge case test report','Sign-off checklist'] },
          { day:'Day 6–7',title:'Go live + handover',   desc:'Deploy to production, team walkthrough, monitoring set up, 30-day support included.', col:'#4ade80', deliverables:['Production deployment','Team walkthrough recording','30-day support access'] },
        ].map(({day,title,desc,col,deliverables})=>(
          <div class="rounded-[16px] border border-brand-gray-100 p-5 scroll-fade">
            <div class="text-[9px] uppercase tracking-wider font-bold mb-3" style={`color:${col};`}>{day}</div>
            <p class="font-semibold text-[14px] text-brand-black mb-2">{title}</p>
            <p class="text-[12px] text-brand-gray-600 leading-relaxed mb-3">{desc}</p>
            <div class="pt-3 border-t border-brand-gray-100">
              <p class="text-[9px] uppercase tracking-wider font-bold text-brand-gray-400 mb-1.5">Deliverables</p>
              <p class="text-[11px] text-brand-gray-500">{deliverables.join(' · ')}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="bg-brand-black py-16 border-t" style="border-color:rgba(255,255,255,0.06);">
  <div class="container-x">
    <div class="max-w-xl mx-auto text-center scroll-fade">
      <h2 class="font-display text-[1.8rem] text-white mb-3">Want us to deploy your playbook?</h2>
      <p class="text-[14px] mb-8" style="color:rgba(255,255,255,0.40);">We'll assess your stack, confirm which playbook fits best, and give you a fixed-price quote. Zero commitment.</p>
      <a href="/pages/welcome"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-button text-[14px] font-bold transition"
        style="background:#E8B4B0;color:#0A0A0A;">
        Book my free playbook audit →
        <svg class="w-4 h-4" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M2 7h10M8 3l4 4-4 4"/></svg>
      </a>
    </div>
  </div>
</section>

</ShopLayout>

<style is:global>
  @keyframes pb-in { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
  .pb-workflow-card { animation: pb-in 0.4s ease-out both; }
  .pb-workflow-card:nth-child(1){animation-delay:0.05s}
  .pb-workflow-card:nth-child(2){animation-delay:0.12s}
  .pb-workflow-card:nth-child(3){animation-delay:0.19s}
  .pb-workflow-card:nth-child(4){animation-delay:0.26s}
  .pb-workflow-card:nth-child(5){animation-delay:0.33s}
  .pb-workflow-card:nth-child(6){animation-delay:0.40s}
  .pb-ind-container { scrollbar-width: none; -ms-overflow-style: none; }
  .pb-ind-container::-webkit-scrollbar { display: none; }
</style>

