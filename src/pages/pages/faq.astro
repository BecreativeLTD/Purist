---
import ShopLayout from '~/layouts/ShopLayout.astro';
import FAQSection from '~/components/sections/FAQSection.astro';
import Button from '~/components/ui/Button.astro';
---

<ShopLayout
 title="FAQs – PURIST"
 description="Answers to common questions about PURIST automation services, pricing, deployment timelines, and the 30-day money-back guarantee."
>
 <header class="bg-brand-cream">
   <div class="container-x py-16 lg:py-20 max-w-3xl mx-auto text-center">
     <p class="eyebrow mb-4">FAQs</p>
     <h1 class="font-display text-4xl lg:text-5xl xl:text-6xl leading-tight tracking-tight mb-6 text-balance">
       Questions, answered <em class="font-medium">straight.</em>
     </h1>
     <p class="text-base text-brand-gray-600">
       Cannot find what you need below? <a href="/pages/contact-us" class="underline underline-offset-4 hover:opacity-70">Email the team</a>. We reply within one business day.
     </p>
   </div>
 </header>

 <FAQSection />

 <section class="bg-brand-beige py-16 lg:py-20 text-center">
   <div class="container-x max-w-2xl">
     <h2 class="font-display text-3xl lg:text-4xl mb-6 leading-tight text-balance">
       Still have questions?
     </h2>
     <div class="flex flex-wrap justify-center gap-3">
       <Button href="/pages/contact-us" size="lg">Contact support →</Button>
       <Button href="/pages/track" variant="secondary" size="lg">Check project status</Button>
     </div>
   </div>
 </section>
</ShopLayout>
