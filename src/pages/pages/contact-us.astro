---
import ShopLayout from '~/layouts/ShopLayout.astro';
import Button from '~/components/ui/Button.astro';

const topics = [
  { id: 'project', label: 'My project or deployment' },
  { id: 'subscription', label: 'Manage my plan' },
  { id: 'service', label: 'Service or workflow question' },
  { id: 'enterprise', label: 'Enterprise or multi-location' },
  { id: 'press', label: 'Press or media' },
  { id: 'other', label: 'Something else' },
];
---

<ShopLayout
  title="Contact us – PURIST"
  description="Reach the team. We reply within one business day."
>
  <section class="container-x py-16 lg:py-20 grid lg:grid-cols-12 gap-12 lg:gap-16">
    <div class="lg:col-span-5">
      <p class="eyebrow mb-4">Contact us</p>
      <h1 class="font-display text-4xl lg:text-5xl leading-tight tracking-tight mb-6 text-balance">
        Real humans. <em class="font-medium">One business day.</em>
      </h1>
      <p class="text-base text-brand-gray-600 mb-10 leading-relaxed">
        Every email lands with a real member of the PURIST team. Most replies go out the
        same day; the longest you should ever wait is one business day.
      </p>

      <div class="space-y-6 text-sm">
        <div>
          <p class="eyebrow mb-1">Support</p>
          <a href="mailto:hello@purist.example" class="hover:opacity-70 transition link-underline">hello@purist.example</a>
        </div>
        <div>
          <p class="eyebrow mb-1">Press</p>
          <a href="mailto:press@purist.example" class="hover:opacity-70 transition link-underline">press@purist.example</a>
        </div>
        <div>
          <p class="eyebrow mb-1">Enterprise</p>
          <a href="mailto:enterprise@purist.example" class="hover:opacity-70 transition link-underline">enterprise@purist.example</a>
        </div>
        <div>
          <p class="eyebrow mb-1">Hours</p>
          <p class="text-brand-gray-600">Mon – Fri · 9:00 – 18:00 CET</p>
        </div>
      </div>
    </div>

    <form class="lg:col-span-7 bg-brand-cream rounded-card p-6 lg:p-10 space-y-5" onsubmit="event.preventDefault(); this.querySelector('[data-success]').classList.remove('hidden'); this.querySelector('button[type=submit]').disabled = true;">
      <h2 class="font-display text-xl mb-2">Send us a message</h2>

      <div class="grid sm:grid-cols-2 gap-4">
        <label class="block">
          <span class="block text-xs text-brand-gray-600 mb-1.5">First name</span>
          <input type="text" required class="w-full bg-white border border-brand-gray-200 rounded-button px-4 py-3 text-sm focus:border-brand-black focus:outline-none transition" />
        </label>
        <label class="block">
          <span class="block text-xs text-brand-gray-600 mb-1.5">Last name</span>
          <input type="text" required class="w-full bg-white border border-brand-gray-200 rounded-button px-4 py-3 text-sm focus:border-brand-black focus:outline-none transition" />
        </label>
      </div>

      <label class="block">
        <span class="block text-xs text-brand-gray-600 mb-1.5">Email</span>
        <input type="email" required class="w-full bg-white border border-brand-gray-200 rounded-button px-4 py-3 text-sm focus:border-brand-black focus:outline-none transition" />
      </label>

      <label class="block">
        <span class="block text-xs text-brand-gray-600 mb-1.5">Topic</span>
        <select class="w-full bg-white border border-brand-gray-200 rounded-button px-4 py-3 text-sm focus:border-brand-black focus:outline-none transition">
          {topics.map((t) => <option value={t.id}>{t.label}</option>)}
        </select>
      </label>

      <label class="block">
        <span class="block text-xs text-brand-gray-600 mb-1.5">Project ID (if relevant)</span>
        <input type="text" placeholder="PUR-XXXXXX" class="w-full bg-white border border-brand-gray-200 rounded-button px-4 py-3 text-sm focus:border-brand-black focus:outline-none transition" />
      </label>

      <label class="block">
        <span class="block text-xs text-brand-gray-600 mb-1.5">Message</span>
        <textarea rows="5" required class="w-full bg-white border border-brand-gray-200 rounded-button px-4 py-3 text-sm focus:border-brand-black focus:outline-none transition resize-y"></textarea>
      </label>

      <Button type="submit" full>Send message →</Button>

      <p data-success class="hidden bg-brand-green/15 text-brand-green text-sm p-4 rounded-card">
        ✓ Demo mode — message captured client-side only. Connect a real form handler in production.
      </p>
    </form>
  </section>
</ShopLayout>
