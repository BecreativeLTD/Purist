---
import ShopLayout from '~/layouts/ShopLayout.astro';
---

<ShopLayout
  title="Hermes AI Agent Setup and Automation — Deployed on Your Own Server | PURIST"
  description="PURIST deploys Hermes Agent on your Hostinger VPS — private, self-hosted AI that automates your workflows 24/7. No SaaS subscriptions. Your data stays yours."
  canonical="https://www.purist.online/pages/hermes-agent"
>

<script type="application/ld+json" is:inline>{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Hermes AI Agent Setup and Automation",
  "description": "PURIST deploys and configures Hermes Agent on Hostinger VPS for US and European businesses. Private, self-hosted AI automation without SaaS subscriptions.",
  "provider": { "@type": "Organization", "name": "PURIST", "url": "https://www.purist.online" },
  "serviceType": "AI Agent Deployment",
  "areaServed": [{ "@type": "Country", "name": "United States" }, { "@type": "Country", "name": "United Kingdom" }],
  "url": "https://www.purist.online/pages/hermes-agent"
})}</script>

<!-- HERO -->
<section style="background:#0A0A0A;color:#F8F6F1;padding:5rem 0 4rem;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 70% 60% at 50% 0%,rgba(232,180,176,0.09) 0%,transparent 65%);"></div>
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:1;">
    <div style="max-width:800px;">
      <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.375rem 0.875rem;border-radius:999px;border:1px solid rgba(232,180,176,0.3);background:rgba(232,180,176,0.07);margin-bottom:1.5rem;">
        <span style="width:6px;height:6px;border-radius:50%;background:#E8B4B0;animation:pulse 2s infinite;display:inline-block;"></span>
        <span style="font-size:10px;text-transform:uppercase;letter-spacing:0.16em;font-weight:600;color:rgba(232,180,176,0.85);">New Service · Hermes Agent · Self-Hosted AI · Powered by Nous Research</span>
      </div>
      <h1 style="font-family:Georgia,serif;font-size:clamp(2.2rem,5vw,3.6rem);line-height:1.08;letter-spacing:-0.025em;color:#F8F6F1;margin-bottom:1.25rem;">
        Your own private AI agent.<br/>
        <em style="font-style:italic;color:#E8B4B0;">Running 24/7 on your server.</em>
      </h1>
      <p style="font-size:1.0625rem;line-height:1.8;color:rgba(248,246,241,0.5);max-width:660px;margin-bottom:1rem;">
        We deploy <strong style="color:rgba(248,246,241,0.85);">Hermes Agent by Nous Research</strong> on your Hostinger VPS. A private, self-hosted AI that automates your workflows, manages your communications, and learns your business. No ChatGPT subscription. No SaaS fees. Your data never leaves your server.
      </p>
      <p style="font-size:0.9375rem;line-height:1.7;color:rgba(248,246,241,0.35);max-width:620px;margin-bottom:2.5rem;">
        Hermes Agent is <strong style="color:rgba(248,246,241,0.5);">100% free and open source</strong> (MIT License). You pay us for the setup, configuration, business training, and automation workflows we build on top. The software itself costs nothing.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:1rem;margin-bottom:3.5rem;">
        <a href="/pages/welcome" style="display:inline-block;background:#E8B4B0;color:#0A0A0A;padding:1rem 2rem;border-radius:10px;font-size:0.875rem;font-weight:600;text-decoration:none;">Get your agent deployed</a>
        <a href="#install" style="display:inline-block;background:rgba(255,255,255,0.06);color:rgba(248,246,241,0.7);border:1px solid rgba(255,255,255,0.12);padding:1rem 2rem;border-radius:10px;font-size:0.875rem;font-weight:500;text-decoration:none;">See install command</a>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:3rem;">
        {[
          ['$5/mo','Your VPS cost (Hostinger)'],
          ['Free','Hermes Agent software (MIT)'],
          ['7 days','Full deployment timeline'],
          ['24/7','Agent runs unattended'],
        ].map(([n,l]) => (
          <div>
            <p style="font-family:Georgia,serif;font-size:1.75rem;line-height:1;margin-bottom:0.25rem;color:#E8B4B0;">{n}</p>
            <p style="font-size:10px;text-transform:uppercase;letter-spacing:0.12em;color:rgba(248,246,241,0.3);">{l}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- INSTALL COMMAND -->
<section id="install" style="background:#111;border-top:1px solid rgba(232,180,176,0.1);border-bottom:1px solid rgba(232,180,176,0.1);padding:3rem 0;">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;">
      <div>
        <p style="font-size:10px;text-transform:uppercase;letter-spacing:0.18em;font-weight:700;color:rgba(232,180,176,0.5);margin-bottom:0.75rem;">One command. That is all it takes.</p>
        <h2 style="font-family:Georgia,serif;font-size:1.5rem;color:#F8F6F1;margin-bottom:0.75rem;">Install Hermes Agent yourself</h2>
        <p style="font-size:0.875rem;line-height:1.7;color:rgba(248,246,241,0.4);">Hermes Agent installs with a single command on any Linux VPS. What takes most businesses days to configure — model selection, memory setup, channel connections, automation workflows — is what PURIST handles for you.</p>
      </div>
      <div>
        <div style="background:#0A0A0A;border:1px solid rgba(232,180,176,0.15);border-radius:12px;overflow:hidden;">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:0.75rem 1rem;border-bottom:1px solid rgba(255,255,255,0.06);">
            <div style="display:flex;gap:0.375rem;">
              <span style="width:10px;height:10px;border-radius:50%;background:#ff5f57;display:inline-block;"></span>
              <span style="width:10px;height:10px;border-radius:50%;background:#ffbd2e;display:inline-block;"></span>
              <span style="width:10px;height:10px;border-radius:50%;background:#28ca41;display:inline-block;"></span>
            </div>
            <span style="font-size:10px;color:rgba(255,255,255,0.2);font-family:monospace;">bash</span>
          </div>
          <div style="padding:1.25rem 1.25rem 1.5rem;">
            <p style="font-family:monospace;font-size:13px;color:#E8B4B0;margin-bottom:0.5rem;white-space:nowrap;">curl -fsSL https://install.hermes-agent.ai | bash</p>
            <p style="font-family:monospace;font-size:11px;color:rgba(255,255,255,0.2);margin-top:0.75rem;"># Or via Docker on Hostinger VPS</p>
            <p style="font-family:monospace;font-size:13px;color:rgba(248,246,241,0.6);white-space:nowrap;">docker pull nousresearch/hermes-agent</p>
          </div>
        </div>
        <p style="font-size:11px;color:rgba(248,246,241,0.25);margin-top:0.75rem;text-align:center;">Hostinger offers a one-click Hermes Agent template in their VPS marketplace</p>
      </div>
    </div>
  </div>
</section>

<!-- WHY PAY PURIST IF IT'S FREE -->
<section style="background:#F8F6F1;padding:5rem 0;border-bottom:1px solid rgba(10,10,10,0.06);">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <div style="max-width:600px;margin:0 auto 3rem;text-align:center;">
      <p style="font-size:10px;text-transform:uppercase;letter-spacing:0.18em;font-weight:700;color:rgba(10,10,10,0.3);margin-bottom:1rem;">The honest breakdown</p>
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.5rem,3vw,2.2rem);color:#0A0A0A;margin-bottom:1rem;">The software is free. The setup is where businesses get stuck.</h2>
      <p style="font-size:0.9375rem;line-height:1.75;color:rgba(10,10,10,0.5);">Installing Hermes takes 5 minutes. Getting it to actually run your business automatically — connected to your tools, trained on your workflows, answering your clients — takes expertise.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1rem;">
      {[
        { title:'What is free', items:['Hermes Agent software (MIT License)','Nous Research Hermes 3 model','All future updates and features','Community support on Discord'] },
        { title:'What PURIST handles', items:['Hostinger VPS provisioning and security','Docker setup and container hardening','Business memory and context training','Channel integrations (Telegram, Slack, email)','n8n workflow automation on top','30 to 90 day monitoring and support'] },
        { title:'What you get', items:['A working agent from day one','Automations specific to your industry','Your team trained to use and expand it','Full documentation and source access','No lock-in — you own everything'] },
      ].map(col => (
        <div style={`background:${col.title === 'What PURIST handles' ? '#0A0A0A' : 'white'};border:1px solid rgba(10,10,10,0.08);border-radius:16px;padding:1.75rem;`}>
          <p style={`font-size:10px;text-transform:uppercase;letter-spacing:0.14em;font-weight:700;margin-bottom:1.25rem;${col.title === 'What PURIST handles' ? 'color:rgba(232,180,176,0.7)' : 'color:rgba(10,10,10,0.35)'}`}>{col.title}</p>
          <div style="display:flex;flex-direction:column;gap:0.625rem;">
            {col.items.map(item => (
              <div style="display:flex;align-items:flex-start;gap:0.625rem;">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="flex-shrink:0;margin-top:2px;">
                  <circle cx="7" cy="7" r="7" fill={col.title === 'What PURIST handles' ? 'rgba(232,180,176,0.15)' : 'rgba(10,10,10,0.06)'}/>
                  <polyline points="4,7 6,9 10,5" stroke={col.title === 'What PURIST handles' ? '#E8B4B0' : 'rgba(10,10,10,0.4)'} stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span style={`font-size:0.8125rem;line-height:1.5;${col.title === 'What PURIST handles' ? 'color:rgba(248,246,241,0.6)' : 'color:rgba(10,10,10,0.55)'}`}>{item}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- WHAT IS HERMES -->
<section style="background:#F8F6F1;padding:3rem 0 5rem;border-bottom:1px solid rgba(10,10,10,0.06);">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;">
      <div>
        <h2 style="font-family:Georgia,serif;font-size:clamp(1.5rem,3vw,2.2rem);color:#0A0A0A;margin-bottom:1.25rem;">Not a chatbot. An agent that acts.</h2>
        <p style="font-size:0.9375rem;line-height:1.8;color:rgba(10,10,10,0.55);margin-bottom:1.25rem;">
          Hermes Agent by <strong style="color:#0A0A0A;">Nous Research</strong> runs continuously on your infrastructure. It connects to your tools, executes tasks on its own, remembers everything it learns, and works through every channel you already use.
        </p>
        <p style="font-size:0.9375rem;line-height:1.8;color:rgba(10,10,10,0.55);margin-bottom:2rem;">
          The model underneath, <strong style="color:#0A0A0A;">Hermes 3</strong>, scores 91% on the Berkeley Function-Calling Benchmark — matching GPT-4 and Claude 3 Sonnet — at zero licensing cost. It runs entirely on your $5/mo VPS.
        </p>
        <div style="display:flex;flex-direction:column;gap:0.625rem;">
          {[
            'Connects to Telegram, Slack, WhatsApp, email, Discord',
            'Browses the web, writes code, executes files',
            'Persistent memory that grows with your business',
            'Runs unattended 24/7 without any input from you',
            'Multi-agent pipelines for complex workflows',
            '91% Berkeley Function-Calling Benchmark score',
          ].map(item => (
            <div style="display:flex;align-items:flex-start;gap:0.75rem;">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:2px;"><circle cx="8" cy="8" r="8" fill="rgba(232,180,176,0.2)"/><polyline points="4.5,8 7,10.5 11.5,5.5" stroke="#c4847e" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span style="font-size:0.875rem;color:rgba(10,10,10,0.6);line-height:1.5;">{item}</span>
            </div>
          ))}
        </div>
      </div>
      <div style="background:#0A0A0A;border-radius:16px;padding:1.75rem;">
        <p style="font-size:10px;text-transform:uppercase;letter-spacing:0.16em;font-weight:700;color:rgba(232,180,176,0.6);margin-bottom:1rem;">Hermes Agent vs ChatGPT Plus</p>
        <div style="display:flex;flex-direction:column;gap:0;">
          {[
            ['Your data stays on your server','Sent to OpenAI servers'],
            ['$5/mo VPS cost. You own it.','$20/mo forever, own nothing'],
            ['Runs 24/7 unattended','Only active when you chat'],
            ['Connects to all your tools','Limited integrations'],
            ['Learns your business permanently','Resets between sessions'],
            ['Open source · full control','Closed black box'],
          ].map(([good, bad]) => (
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.05);">
              <div style="display:flex;align-items:flex-start;gap:0.5rem;">
                <span style="color:#E8B4B0;font-size:11px;margin-top:1px;">✓</span>
                <span style="font-size:11.5px;color:rgba(248,246,241,0.75);line-height:1.4;">{good}</span>
              </div>
              <div style="display:flex;align-items:flex-start;gap:0.5rem;">
                <span style="color:rgba(255,255,255,0.2);font-size:11px;margin-top:1px;">✗</span>
                <span style="font-size:11.5px;color:rgba(248,246,241,0.25);line-height:1.4;">{bad}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT WE DO -->
<section style="background:#0A0A0A;padding:5rem 0;">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <div style="max-width:600px;margin:0 auto 3.5rem;text-align:center;">
      <p style="font-size:10px;text-transform:uppercase;letter-spacing:0.18em;font-weight:700;color:rgba(232,180,176,0.5);margin-bottom:1rem;">What PURIST delivers</p>
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.5rem,3vw,2.2rem);color:#F8F6F1;margin-bottom:1rem;">We handle everything. You get the agent.</h2>
      <p style="font-size:0.9375rem;line-height:1.75;color:rgba(248,246,241,0.4);">From VPS provisioning to live workflows — we set up, configure, and train your Hermes agent on your business, then hand it to you running.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.25rem;">
      {[
        { n:'01', title:'Hostinger VPS Setup', body:'We provision your VPS, install Docker, deploy Hermes Agent, and configure all security settings. Your agent runs on dedicated infrastructure you own outright.', tag:'Infrastructure' },
        { n:'02', title:'Model and Memory Configuration', body:'We configure the Hermes 3 model with your business context: your tone, your processes, your FAQs, your products. The agent starts knowing your business from day one.', tag:'Configuration' },
        { n:'03', title:'Channel Integrations', body:'We connect your agent to Telegram, Slack, email, WhatsApp, or Discord. It receives messages, takes action, and responds across every channel you already use.', tag:'Integration' },
        { n:'04', title:'Workflow Automation Build', body:'We build the specific automations your business needs using n8n combined with Hermes — lead follow-up, appointment booking, reporting, client onboarding, and more.', tag:'Automation' },
        { n:'05', title:'24/7 Monitoring and Uptime', body:'We monitor your agent continuously. Error alerts fire within 90 seconds. You get a dedicated Slack channel for direct access. Your agent never goes down silently.', tag:'Monitoring' },
        { n:'06', title:'Training and Handover', body:'We train your team to interact with the agent, add new skills, and expand its capabilities. Full documentation, video walkthrough, and source code access included.', tag:'Training' },
      ].map(s => (
        <div style="border:1px solid rgba(232,180,176,0.1);border-radius:16px;padding:1.75rem;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
            <span style="font-family:Georgia,serif;font-size:1.5rem;color:rgba(255,255,255,0.08);">{s.n}</span>
            <span style="font-size:9px;text-transform:uppercase;letter-spacing:0.14em;font-weight:700;color:rgba(232,180,176,0.6);background:rgba(232,180,176,0.08);border:1px solid rgba(232,180,176,0.15);padding:0.25rem 0.625rem;border-radius:999px;">{s.tag}</span>
          </div>
          <h3 style="font-family:Georgia,serif;font-size:1.0625rem;color:#F8F6F1;margin-bottom:0.625rem;">{s.title}</h3>
          <p style="font-size:0.875rem;line-height:1.75;color:rgba(248,246,241,0.4);margin:0;">{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- USE CASES BY INDUSTRY -->
<section style="background:#F8F6F1;padding:5rem 0;border-bottom:1px solid rgba(10,10,10,0.06);">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <div style="max-width:560px;margin:0 auto 3rem;text-align:center;">
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.5rem,3vw,2.2rem);color:#0A0A0A;margin-bottom:0.75rem;">What your agent does for your business</h2>
      <p style="font-size:0.9375rem;color:rgba(10,10,10,0.45);line-height:1.7;">Specific automations for each industry. Not generic templates.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:1rem;">
      {[
        { industry:'Real Estate Agency', tasks:['Qualifies every inbound lead via WhatsApp in 90 seconds','Schedules viewings without human input','Sends automated follow-up sequences over 90 days','Monitors Zillow and Realtor listings and alerts agents','Generates weekly market reports automatically'] },
        { industry:'Dental and Medical Practice', tasks:['Confirms appointments via SMS and email instantly','Sends pre-appointment instructions and intake forms','Handles recall campaigns for 6-month checkups','Follows up post-visit for reviews at day 3 and day 7','Answers FAQs on WhatsApp and Telegram 24/7'] },
        { industry:'Law Firm', tasks:['Qualifies new client inquiries and routes to the right attorney','Sends automated document checklists and reminders','Tracks missing signatures and follows up every 48 hours','Generates billing summaries and sends to clients','Books consultations without any receptionist involvement'] },
        { industry:'E-commerce and Shopify', tasks:['Handles order status questions automatically via email','Sends abandoned cart recovery sequences','Monitors competitor pricing and alerts the team','Generates daily sales reports and inventory alerts','Manages post-purchase review and upsell flows'] },
        { industry:'Marketing Agency', tasks:['Researches briefs and generates first draft content','Monitors client brand mentions across the web daily','Sends automated client reporting every Monday','Manages lead qualification from website and socials','Tracks competitor campaigns and summarises weekly'] },
        { industry:'SaaS and Tech', tasks:['Qualifies and routes inbound trials to the right onboarding flow','Monitors product usage and triggers churn prevention','Sends automated onboarding email sequences','Summarises support tickets and tags by priority','Generates weekly product usage reports for founders'] },
      ].map(uc => (
        <div style="background:white;border:1px solid rgba(10,10,10,0.07);border-radius:16px;padding:1.75rem;">
          <h3 style="font-family:Georgia,serif;font-size:1rem;color:#0A0A0A;margin-bottom:1.25rem;">{uc.industry}</h3>
          <div style="display:flex;flex-direction:column;gap:0.625rem;">
            {uc.tasks.map(t => (
              <div style="display:flex;align-items:flex-start;gap:0.625rem;">
                <span style="color:#E8B4B0;font-size:12px;margin-top:2px;flex-shrink:0;">→</span>
                <span style="font-size:0.8125rem;color:rgba(10,10,10,0.55);line-height:1.5;">{t}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- TIMELINE -->
<section id="how-it-works" style="background:#0A0A0A;padding:5rem 0;">
  <div style="max-width:800px;margin:0 auto;padding:0 1.5rem;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.5rem,3vw,2.2rem);color:#F8F6F1;">From zero to live agent in 7 days.</h2>
    </div>
    <div style="display:flex;flex-direction:column;">
      {[
        { day:'Day 1',   title:'Discovery call and infrastructure audit', body:'We review your tools, workflows, and communication channels. We define exactly what your agent will automate from day one.' },
        { day:'Day 2',   title:'VPS provisioning and Hermes deployment',  body:'We set up your Hostinger VPS, deploy Docker, install Hermes Agent, and configure all security. Your infrastructure is live and private.' },
        { day:'Day 3-4', title:'Business configuration and memory seeding', body:'We feed your agent your business context: products, FAQs, tone of voice, processes, team structure. It starts knowing who you are.' },
        { day:'Day 5',   title:'Channel and tool integrations',           body:'We connect your agent to Telegram, Slack, email, WhatsApp, and your existing tools including CRM, calendar, and n8n workflows.' },
        { day:'Day 6',   title:'Automation workflows built and tested',   body:'We build and test every automation in staging first. Lead follow-up, appointment booking, reporting, content drafts. Nothing goes live untested.' },
        { day:'Day 7',   title:'Go live and team handover',              body:'Your agent goes live. We walk your team through interacting with it, adding skills, and expanding capabilities. Full docs included.' },
      ].map(s => (
        <div style="display:flex;gap:1.5rem;align-items:flex-start;padding:1.25rem 0;border-bottom:1px solid rgba(255,255,255,0.05);">
          <div style="flex-shrink:0;width:64px;">
            <span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:#E8B4B0;background:rgba(232,180,176,0.1);border:1px solid rgba(232,180,176,0.2);padding:0.2rem 0.5rem;border-radius:999px;white-space:nowrap;">{s.day}</span>
          </div>
          <div>
            <h3 style="font-family:Georgia,serif;font-size:1.0625rem;color:#F8F6F1;margin-bottom:0.375rem;">{s.title}</h3>
            <p style="font-size:0.875rem;line-height:1.7;color:rgba(248,246,241,0.4);margin:0;">{s.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- TECH STACK -->
<section style="background:#F8F6F1;padding:4rem 0;border-bottom:1px solid rgba(10,10,10,0.06);">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <p style="font-size:10px;text-transform:uppercase;letter-spacing:0.18em;font-weight:700;color:rgba(10,10,10,0.3);margin-bottom:1.5rem;text-align:center;">The stack we deploy</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:0.875rem;">
      {[
        { name:'Hermes Agent', role:'AI agent runtime', by:'Nous Research · Open source MIT' },
        { name:'Hermes 3 Model', role:'LLM engine', by:'91% function-call benchmark' },
        { name:'Hostinger VPS', role:'Private cloud server', by:'From $5/month · You own it' },
        { name:'Docker', role:'Container deployment', by:'Isolated and secure' },
        { name:'n8n', role:'Workflow orchestration', by:'Self-hosted · Open source' },
        { name:'Telegram · Slack · Email', role:'Communication layer', by:'Your existing channels' },
