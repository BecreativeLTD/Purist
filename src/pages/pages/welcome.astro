---
import ShopLayout from '~/layouts/ShopLayout.astro';
import MoneyBackGuarantee from '~/components/sections/MoneyBackGuarantee.astro';
---

<ShopLayout
 title="Book your free audit – PURIST"
 description="Book your free automation audit. We map your workflows and show you exactly what time and money automation will save, before any commitment."
>

<!-- ═══════════════════════════════════════════════
    HERO STRIP
════════════════════════════════════════════════ -->
<header class="relative overflow-hidden" style="background:#0A0A0A;">
 <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 70% 90% at 20% 50%,rgba(232,180,176,0.07) 0%,transparent 65%);"/>
 <div class="container-x relative z-10 py-14 lg:py-20">
   <div class="max-w-2xl">
     <p class="text-[9px] uppercase tracking-[0.28em] font-bold mb-5" style="color:rgba(232,180,176,0.60);">Free automation audit</p>
     <h1 class="font-display text-[2.4rem] lg:text-[3.2rem] leading-[1.08] tracking-[-0.025em] text-white mb-5 text-balance">
       See exactly what automation<br/>
       <em class="font-medium" style="color:#E8B4B0;">will save your business.</em>
     </h1>
     <p class="text-[15px] lg:text-base leading-relaxed max-w-xl mb-10" style="color:rgba(255,255,255,0.40);">
       Before you commit to anything, we audit your exact workflows. We'll know the precise time and cost savings you can expect before signing a thing.
     </p>
     <div class="flex flex-wrap gap-10 lg:gap-14">
       {[
         { n: '312',  l: 'Audits completed'     },
         { n: '£168K', l: 'Avg. first-year savings' },
         { n: '5-10d', l: 'To first live workflow' },
       ].map(b => (
         <div>
           <p class="font-display text-[2rem] text-white font-medium leading-none">{b.n}</p>
           <p class="text-[10px] uppercase tracking-[0.16em] mt-1.5" style="color:rgba(255,255,255,0.30);">{b.l}</p>
         </div>
       ))}
     </div>
   </div>
 </div>
</header>

<!-- ═══════════════════════════════════════════════
    COST OF INACTION STRIP Loss Aversion
════════════════════════════════════════════════ -->
<div style="background:#111;border-top:1px solid rgba(232,180,176,0.12);">
 <div class="container-x py-5">
   <div class="flex flex-wrap items-center gap-6 lg:gap-12">
     <div class="flex items-center gap-3">
       <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0" style="background:rgba(232,180,176,0.10);border:1px solid rgba(232,180,176,0.18);">
         <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
           <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
         </svg>
       </div>
       <p class="text-[12.5px] leading-snug" style="color:rgba(255,255,255,0.55);">
         Based on 312 audits, the average team loses
         <strong class="text-white">£512/week</strong> to manual workflows
           that's <strong class="text-white">£26,624/year</strong> of recoverable time.
       </p>
     </div>
     <div class="flex items-center gap-6 ml-auto shrink-0">
       {[
         { n: '4 weeks', l: 'avg. payback period' },
         { n: '9.4×', l: 'avg. first-year ROI' },
       ].map(s => (
         <div class="text-center">
           <p class="font-display text-base font-medium leading-none" style="color:#E8B4B0;">{s.n}</p>
           <p class="text-[9px] uppercase tracking-[0.14em] mt-1" style="color:rgba(255,255,255,0.28);">{s.l}</p>
         </div>
       ))}
     </div>
   </div>
 </div>
</div>

<!-- ═══════════════════════════════════════════════
    FORM + LEFT COPY
════════════════════════════════════════════════ -->
<section class="py-16 lg:py-24" style="background:#F8F6F1;">
 <div class="container-x">
   <div class="grid lg:grid-cols-[360px_1fr] xl:grid-cols-[400px_1fr] gap-12 xl:gap-20 items-start">

     <!-- ── LEFT: HOW IT WORKS + PROOF ───────────── -->
     <div class="lg:sticky lg:top-28">

       <p class="text-[9.5px] uppercase tracking-[0.22em] font-semibold mb-3" style="color:rgba(10,10,10,0.32);">How it works</p>
       <h2 class="font-display text-2xl lg:text-[1.8rem] leading-tight tracking-[-0.015em] mb-8 text-balance">
         No commitment.<br/>Just clarity.
       </h2>

       <div class="space-y-5 mb-10">
         {[
           {
             step: '01',
             title: 'Submit your details',
             body: 'We review your business type and current workflows within one business day.',
           },
           {
             step: '02',
             title: 'Free 45-min audit call',
             body: 'We map your biggest time-sinks and calculate a precise ROI figure for you.',
           },
           {
             step: '03',
             title: 'You receive a proposal',
             body: 'Custom roadmap, timeline, and fixed cost. Fixed cost, delivered before you sign anything.',
           },
           {
             step: '04',
             title: 'Live in 5-10 business days',
             body: 'Once approved, we build and deploy your first automations live.',
           },
         ].map(s => (
           <div class="flex gap-4 items-start">
             <span class="font-display text-[10px] font-semibold tabular-nums pt-0.5 shrink-0 w-6 text-right" style="color:rgba(10,10,10,0.20);">{s.step}</span>
             <div>
               <p class="text-[13.5px] font-semibold text-brand-black leading-snug">{s.title}</p>
               <p class="text-[12.5px] leading-relaxed mt-0.5" style="color:rgba(10,10,10,0.48);">{s.body}</p>
             </div>
           </div>
         ))}
       </div>

       <!-- Testimonial card -->
       <div class="rounded-[18px] p-5 lg:p-6" style="background:#fff;border:1px solid rgba(10,10,10,0.07);">
         <div class="flex gap-0.5 mb-3">
           {Array.from({length:5}).map(() => (
             <svg class="w-3 h-3" viewBox="0 0 12 12" fill="#E8B4B0" aria-hidden="true">
               <path d="M6 1l1.2 3.6H11L8.2 6.8l1.2 3.6L6 8.2l-3.4 2.2 1.2-3.6L1 4.6h3.8z"/>
             </svg>
           ))}
         </div>
         <p class="text-[13px] leading-relaxed italic mb-4" style="color:rgba(10,10,10,0.62);">
           "The audit alone identified 14 hours a week of manual work we didn't realise we had. We had the first workflow live within a week."
         </p>
         <div class="flex items-center gap-2.5">
           <div class="w-8 h-8 rounded-full flex items-center justify-center text-[10px] font-bold shrink-0" style="background:rgba(232,180,176,0.14);border:1px solid rgba(232,180,176,0.22);color:#E8B4B0;">SK</div>
           <div>
             <p class="text-[11.5px] font-semibold" style="color:rgba(10,10,10,0.72);">Sarah K.</p>
             <p class="text-[10px]" style="color:rgba(10,10,10,0.38);">Practice Manager · Dental Group</p>
           </div>
         </div>
       </div>

       <!-- Trust signals -->
       <div class="mt-6 pt-6 flex flex-wrap gap-4" style="border-top:1px solid rgba(10,10,10,0.07);">
         {[
           'No credit card required',
           'Reply within 1 business day',
           'Fully confidential',
         ].map(t => (
           <div class="flex items-center gap-1.5">
             <svg class="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="none" stroke="#2D5016" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
               <polyline points="2,6 5,9 10,3"/>
             </svg>
             <span class="text-[11px]" style="color:rgba(10,10,10,0.50);">{t}</span>
           </div>
         ))}
       </div>

     </div>

     <!-- ── RIGHT: FORM CARD ───────────────────── -->
     <div id="form-card" class="rounded-[24px] overflow-hidden" style="background:#fff;border:1px solid rgba(10,10,10,0.08);box-shadow:0 2px 24px rgba(10,10,10,0.05);">

       <!-- Card header -->
       <div class="px-7 lg:px-10 pt-7 pb-6" style="border-bottom:1px solid rgba(10,10,10,0.06);">
         <p class="text-[9px] uppercase tracking-[0.22em] font-bold mb-1.5" style="color:rgba(10,10,10,0.30);">Free consultation · No payment</p>
         <h3 class="font-display text-xl lg:text-2xl leading-snug tracking-[-0.015em]">Tell us about your business.</h3>
         <!-- Skill context banner shown by JS if ?skill= param present -->
         <div id="skill-context-banner" class="hidden mt-4 flex items-center gap-2.5 px-3.5 py-2.5 rounded-[10px]" style="background:rgba(232,180,176,0.10);border:1px solid rgba(196,132,126,0.18);">
           <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="#c4847e" stroke-width="2" stroke-linecap="round"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
           <p class="text-[11.5px]" style="color:rgba(10,10,10,0.60);">
             Interested in: <strong id="skill-context-name" class="text-brand-black"></strong>
           </p>
         </div>
       </div>

       <!-- THE FORM -->
       <form id="audit-form" class="px-7 lg:px-10 py-8" novalidate>

         <!-- ① Industry -->
         <fieldset class="mb-7">
           <legend class="f-section-label mb-3">
             Your industry <span class="req">*</span>
           </legend>
           <div class="grid grid-cols-2 sm:grid-cols-4 gap-2" id="biz-grid">
             {[
               { id: 'dental',   label: 'Dental / Medical',   icon: 'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v11m3-11v11m3-11v11M3 9h18' },
               { id: 'legal',    label: 'Law Firm / Legal',    icon: 'M3 6l9-4 9 4v6c0 5.5-4 10-9 12C7 22 3 17.5 3 12V6z' },
               { id: 'agency',   label: 'Agency / Creative',   icon: 'M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z' },
               { id: 'ecommerce', label: 'E-commerce',          icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z' },
               { id: 'realestate', label: 'Real Estate',         icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10' },
               { id: 'saas',     label: 'SaaS / Tech',         icon: 'M16 18l6-6-6-6M8 6l-6 6 6 6' },
               { id: 'finance',  label: 'Finance / Accounting', icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z' },
               { id: 'other',    label: 'Other',               icon: 'M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z' },
             ].map(t => (
               <label class="biz-card relative flex flex-col items-center gap-2 p-3 pt-3.5 rounded-xl cursor-pointer text-center transition-all duration-100">
                 <input type="radio" name="business_type" value={t.id} class="sr-only" required/>
                 <svg class="biz-icon w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                   <path d={t.icon}/>
                 </svg>
                 <span class="biz-label text-[10.5px] font-medium leading-tight">{t.label}</span>
               </label>
             ))}
           </div>
         </fieldset>

         <div class="field-divider mb-7"/>

         <!-- ② Contact details -->
         <div class="mb-7 space-y-4">
           <p class="f-section-label">Your details</p>
           <div class="grid sm:grid-cols-2 gap-4">
             <div class="field-wrap">
               <label class="f-label">Full name <span class="req">*</span></label>
               <input type="text" name="name" placeholder="James Whitfield" required class="f-input"/>
             </div>
             <div class="field-wrap">
               <label class="f-label">Work email <span class="req">*</span></label>
               <input type="email" name="email" placeholder="you@company.com" required class="f-input"/>
             </div>
           </div>
           <div class="field-wrap">
             <label class="f-label">Phone <span class="f-optional">(optional)</span></label>
             <input type="tel" name="phone" placeholder="+44 7700 900000" class="f-input"/>
           </div>
         </div>

         <div class="field-divider mb-7"/>

         <!-- ③ Company -->
         <div class="mb-7 space-y-4">
           <p class="f-section-label">Your business</p>
           <div class="grid sm:grid-cols-2 gap-4">
             <div class="field-wrap">
               <label class="f-label">Company name <span class="req">*</span></label>
               <input type="text" name="company" placeholder="Acme Ltd." required class="f-input"/>
             </div>
             <div class="field-wrap">
               <label class="f-label">Team size <span class="req">*</span></label>
               <select name="team_size" required class="f-input f-select">
                 <option value="" disabled selected>Select a range</option>
                 <option value="1-5">1–5 people</option>
                 <option value="6-15">6–15 people</option>
                 <option value="16-50">16–50 people</option>
                 <option value="50+">50+ people</option>
               </select>
             </div>
           </div>
         </div>

         <div class="field-divider mb-7"/>

         <!-- ④ Pain point + tools -->
         <div class="mb-7 space-y-4">
           <p class="f-section-label">Your workflows</p>
           <div class="field-wrap">
             <label class="f-label">Biggest operational challenge <span class="req">*</span></label>
             <select name="pain_point" required class="f-input f-select">
               <option value="" disabled selected>What slows you down most?</option>
               <option value="data-entry">Manual data entry & reporting</option>
               <option value="client-comms">Client communication & follow-ups</option>
               <option value="crm">Lead tracking & CRM updates</option>
               <option value="billing">Invoice & billing workflows</option>
               <option value="documents">Document generation & contracts</option>
               <option value="scheduling">Scheduling & appointment management</option>
               <option value="onboarding">Client or staff onboarding</option>
               <option value="other">Something else</option>
             </select>
           </div>
           <div class="field-wrap">
             <label class="f-label">Tools you currently use <span class="f-optional">(optional)</span></label>
             <input type="text" name="tools" placeholder="e.g. HubSpot, Google Workspace, Xero, Salesforce…" class="f-input"/>
           </div>
         </div>

         <div class="field-divider mb-7"/>

         <!-- ⑤ Budget pills -->
         <fieldset class="mb-7">
           <legend class="f-section-label mb-3">Monthly automation budget</legend>
           <div class="flex flex-wrap gap-2">
             {[
               { v: 'under-2k', l: 'Under £2K' },
               { v: '2k-5k',   l: '£2K – £5K' },
               { v: '5k-10k',  l: '£5K – £10K' },
               { v: '10k-plus', l: '£10K+'      },
               { v: 'unknown', l: 'Not sure yet' },
             ].map(b => (
               <label class="budget-pill cursor-pointer transition-all duration-100 text-[11.5px] font-medium px-4 py-2 rounded-full">
                 <input type="radio" name="budget" value={b.v} class="sr-only"/>
                 {b.l}
               </label>
             ))}
           </div>
         </fieldset>

         <!-- ⑥ Message -->
         <div class="mb-8 field-wrap">
           <label class="f-label">Additional context <span class="f-optional">(optional)</span></label>
           <textarea name="message" rows="3"
             placeholder="Describe your current workflow, specific bottlenecks, or the outcome you're aiming for…"
             class="f-input resize-none"></textarea>
         </div>

         <!-- ⑦ Submit -->
         <button type="submit" id="submit-btn"
           class="w-full flex items-center justify-center gap-2.5 px-6 py-4 rounded-[14px] text-[13.5px] font-semibold transition-all duration-150"
           style="background:#0A0A0A;color:#fff;"
         >
           <span id="submit-label">Get my free audit</span>
           <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
             <path d="M3 8h10M9 4l4 4-4 4"/>
           </svg>
         </button>
         <p id="form-error" class="hidden text-center text-[11px] mt-2 text-red-600 font-medium"></p>
         <p class="text-center text-[10.5px] mt-3" style="color:rgba(10,10,10,0.30);">
           No payment required · We respond within 1 business day
         </p>

       </form>

       <!-- ══════════════════════════════════════════
            SUCCESS STATE — Personalised Audit Preview
       ══════════════════════════════════════════ -->
       <div id="form-success" class="hidden">

         <!-- ① Confirmation header -->
         <div style="background:#0A0A0A;padding:24px 28px 20px;display:flex;align-items:center;gap:14px;">
           <div style="width:36px;height:36px;border-radius:50%;background:rgba(74,222,128,0.14);border:1px solid rgba(74,222,128,0.30);flex-shrink:0;display:flex;align-items:center;justify-content:center;">
             <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4ADE80" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
           </div>
           <div style="flex:1;min-width:0;">
             <p style="font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-bottom:2px;">Audit confirmed</p>
             <p id="success-headline" style="font-family:'Fraunces',Georgia,serif;font-size:17px;color:#fff;font-weight:400;line-height:1.3;"></p>
           </div>
           <div style="text-align:right;flex-shrink:0;">
             <p id="success-ref" style="font-size:10px;color:rgba(255,255,255,0.25);font-family:monospace;"></p>
             <p style="font-size:9px;color:rgba(255,255,255,0.18);margin-top:1px;">Keep for reference</p>
           </div>
         </div>

         <!-- ② ROI Snapshot — 3 key numbers -->
         <div style="background:#F8F6F1;border-bottom:1px solid rgba(10,10,10,0.07);padding:20px 28px;">
           <p style="font-size:9px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:rgba(10,10,10,0.30);margin-bottom:14px;">Your preliminary ROI estimate</p>
           <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;" id="roi-grid">
             <div style="background:#fff;border:1px solid rgba(10,10,10,0.08);border-radius:12px;padding:14px 12px;text-align:center;">
               <p id="roi-hours" style="font-family:'Fraunces',Georgia,serif;font-size:26px;font-weight:400;color:#0A0A0A;line-height:1;">—</p>
               <p style="font-size:9.5px;color:rgba(10,10,10,0.40);margin-top:4px;line-height:1.3;">hours saved<br/>per week</p>
             </div>
             <div style="background:#0A0A0A;border-radius:12px;padding:14px 12px;text-align:center;">
               <p id="roi-annual" style="font-family:'Fraunces',Georgia,serif;font-size:26px;font-weight:400;color:#E8B4B0;line-height:1;">—</p>
               <p style="font-size:9.5px;color:rgba(255,255,255,0.35);margin-top:4px;line-height:1.3;">estimated<br/>annual savings</p>
             </div>
             <div style="background:#fff;border:1px solid rgba(10,10,10,0.08);border-radius:12px;padding:14px 12px;text-align:center;">
               <p id="roi-payback" style="font-family:'Fraunces',Georgia,serif;font-size:26px;font-weight:400;color:#0A0A0A;line-height:1;">—</p>
               <p style="font-size:9.5px;color:rgba(10,10,10,0.40);margin-top:4px;line-height:1.3;">avg. payback<br/>period</p>
             </div>
           </div>
           <p style="font-size:9px;color:rgba(10,10,10,0.28);margin-top:10px;line-height:1.5;">
             * Preliminary estimate based on industry benchmarks for your team size and pain point. Exact figures confirmed on your audit call.
           </p>
         </div>

         <!-- ③ What happens next — timeline -->
         <div style="padding:20px 28px;border-bottom:1px solid rgba(10,10,10,0.07);">
           <p style="font-size:9px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:rgba(10,10,10,0.30);margin-bottom:14px;">What happens next</p>
           <div style="display:flex;flex-direction:column;gap:0;">
             {[
               { day:'Today',    icon:'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', title:'Request received', body:'Your submission has been logged and routed to our automation team.' },
               { day:'Day 1',    icon:'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title:'Calendar link sent', body:'We review your details and send a booking link to schedule your 45-min call.' },
               { day:'Day 2–3',  icon:'M15 10l4.553-2.069A1 1 0 0121 8.87V15a2 2 0 01-2 2H5a2 2 0 01-2-2V8.87a1 1 0 01.447-.862L8 10m7 0l-7 0m7 0V4a1 1 0 00-1-1H9a1 1 0 00-1 1v6', title:'Free 45-min audit call', body:'We map your workflows, identify the top 3 automation wins, and calculate your exact ROI.' },
               { day:'Day 4–6',  icon:'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title:'Custom proposal delivered', body:'Fixed cost, full scope, timeline, and measurable KPIs — before you sign anything.' },
               { day:'Day 5–10', icon:'M13 10V3L4 14h7v7l9-11h-7z', title:'First workflow goes live', body:'Once approved, we build and deploy. You see it working before the second invoice.' },
             ].map((s, i) => (
               <div style="display:flex;gap:12px;align-items:flex-start;padding:10px 0;position:relative;">
                 <div style="display:flex;flex-direction:column;align-items:center;flex-shrink:0;width:32px;">
                   <div style="width:28px;height:28px;border-radius:50%;background:#0A0A0A;display:flex;align-items:center;justify-content:center;z-index:1;">
                     <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={s.icon}/></svg>
                   </div>
                   {i < 4 && <div style="width:1px;height:100%;min-height:24px;background:rgba(10,10,10,0.08);margin-top:4px;"></div>}
                 </div>
                 <div style="flex:1;padding-bottom:8px;">
                   <div style="display:flex;align-items:center;gap:8px;margin-bottom:2px;">
                     <span style="font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#E8B4B0;background:#0A0A0A;padding:2px 7px;border-radius:100px;">{s.day}</span>
                     <span style="font-size:12px;font-weight:600;color:#0A0A0A;">{s.title}</span>
                   </div>
                   <p style="font-size:11px;color:rgba(10,10,10,0.48);line-height:1.5;">{s.body}</p>
                 </div>
               </div>
             ))}
           </div>
         </div>

         <!-- ④ Two-column: prep checklist + submission summary -->
         <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-bottom:1px solid rgba(10,10,10,0.07);">

           <!-- Prep checklist -->
           <div style="padding:18px 18px 18px 28px;border-right:1px solid rgba(10,10,10,0.07);">
             <p style="font-size:9px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:rgba(10,10,10,0.30);margin-bottom:12px;">Prepare for your call</p>
             <div style="display:flex;flex-direction:column;gap:8px;">
               {[
                 'List of all tools/software your team uses daily',
                 'Rough estimate of hours spent on repetitive tasks',
                 'Your top 2–3 workflow bottlenecks',
                 'Average fully-loaded salary (for ROI calc)',
                 'Any past automation attempts (succeeded or failed)',
               ].map(item => (
                 <div style="display:flex;align-items:flex-start;gap:8px;">
                   <div style="width:16px;height:16px;border-radius:4px;border:1.5px solid rgba(10,10,10,0.15);flex-shrink:0;margin-top:1px;"></div>
                   <span style="font-size:11px;color:rgba(10,10,10,0.60);line-height:1.4;">{item}</span>
                 </div>
               ))}
             </div>
           </div>

           <!-- Submission summary -->
           <div style="padding:18px 28px 18px 18px;">
             <p style="font-size:9px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:rgba(10,10,10,0.30);margin-bottom:12px;">Your submission</p>
             <div style="display:flex;flex-direction:column;gap:7px;" id="summary-grid">
               <!-- populated by JS -->
             </div>
           </div>

         </div>

         <!-- ⑤ Industry insight -->
         <div id="industry-insight" style="padding:16px 28px;background:#F8F6F1;border-bottom:1px solid rgba(10,10,10,0.07);">
           <div style="display:flex;gap:10px;align-items:flex-start;">
             <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#c4847e" stroke-width="1.8" stroke-linecap="round" style="flex-shrink:0;margin-top:1px;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
             <p id="industry-insight-text" style="font-size:11.5px;color:rgba(10,10,10,0.60);line-height:1.6;"></p>
           </div>
         </div>

         <!-- ⑥ Resources + CTA buttons -->
         <div style="padding:20px 28px 24px;">
           <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:space-between;align-items:center;">
             <div style="display:flex;flex-wrap:wrap;gap:8px;">
               <a href="/pages/dashboard" style="display:inline-flex;align-items:center;gap:6px;font-size:11.5px;font-weight:600;padding:10px 18px;border-radius:10px;background:#0A0A0A;color:#fff;text-decoration:none;">
                 Explore dashboard
                 <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7h10M8 3l4 4-4 4"/></svg>
               </a>
               <a href="/pages/blog" style="display:inline-flex;align-items:center;gap:6px;font-size:11.5px;font-weight:600;padding:10px 18px;border-radius:10px;background:#F8F6F1;color:#0A0A0A;border:1px solid rgba(10,10,10,0.10);text-decoration:none;">
                 Read the blog
               </a>
             </div>
             <a id="linkedin-share" href="#" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:500;padding:8px 14px;border-radius:8px;border:1px solid rgba(10,10,10,0.10);color:rgba(10,10,10,0.55);text-decoration:none;">
               <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
               Share on LinkedIn
             </a>
           </div>
           <p style="font-size:9.5px;color:rgba(10,10,10,0.28);margin-top:10px;">
             Check your inbox — we'll send a calendar link within 1 business day. Mark <strong style="color:rgba(10,10,10,0.45);">hello@purist.online</strong> as a contact so we don't land in spam.
           </p>
         </div>

       </div>

     </div><!-- end form-card -->

   </div>
 </div>
</section>

