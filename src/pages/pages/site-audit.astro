      <h2 style="font-family:Georgia,serif;font-size:1.6rem;font-weight:400;">Three steps. Zero friction.</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0;position:relative;">
      <!-- connector line -->
      <div style="position:absolute;top:28px;left:16.66%;right:16.66%;height:1px;background:linear-gradient(to right,transparent,rgba(232,180,176,0.2),rgba(232,180,176,0.2),transparent);"></div>
      <div style="text-align:center;position:relative;">
        <div style="width:56px;height:56px;border-radius:50%;background:rgba(232,180,176,0.08);border:1px solid rgba(232,180,176,0.15);display:inline-flex;align-items:center;justify-content:center;margin-bottom:1.2rem;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="1.5" stroke-linecap="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        </div>
