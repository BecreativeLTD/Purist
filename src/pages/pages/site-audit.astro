</section>

<!-- ── How it works ─────────────────────────────────────────────────── -->
<section style="background:#0A0A0A;color:#F8F6F1;padding:5rem 0;">
  <div style="max-width:900px;margin:0 auto;padding:0 1.5rem;">
    <div style="text-align:center;margin-bottom:3.5rem;">
