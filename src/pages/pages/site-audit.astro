---
import ShopLayout from '~/layouts/ShopLayout.astro';
import AuditEngine from '~/components/audit/AuditEngine.tsx';
---

<ShopLayout
  title="Free Website Audit — AI-Powered Analysis in 30 Seconds | PURIST"
  description="Get an instant, comprehensive audit of your website. SEO, performance, security, tracking and UX — scored by AI. Free, no sign-up required."
  canonical="https://www.purist.online/pages/site-audit"
>

<script type="application/ld+json" is:inline>{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "PURIST Site Audit",
  "description": "Free AI-powered website audit tool. Analyses SEO, performance, security, tracking, and UX in under 30 seconds.",
  "url": "https://www.purist.online/pages/site-audit",
  "applicationCategory": "WebApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "GBP" },
  "provider": { "@type": "Organization", "name": "PURIST", "url": "https://www.purist.online" }
})}</script>

<!-- ── Hero ─────────────────────────────────────────────────────────── -->
<section style="padding:6rem 0 3rem;text-align:center;background:#0A0A0A;color:#F8F6F1;">
  <div style="max-width:760px;margin:0 auto;padding:0 1.5rem;">
    <p style="font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;opacity:0.5;margin-bottom:1rem;">Free Diagnostic Tool</p>
    <h1 style="font-family:Georgia,serif;font-size:clamp(2rem,5vw,3.2rem);line-height:1.15;margin-bottom:1.25rem;font-weight:400;">
      Your website, <em style="font-style:italic;color:#E8B4B0;">audited by AI</em>
    </h1>
    <p style="font-size:1.05rem;line-height:1.7;opacity:0.7;max-width:560px;margin:0 auto 0.5rem;">
      Enter any URL. In 30 seconds our AI analyses SEO, performance, security, tracking and UX — then delivers a prioritised action plan.
    </p>
  </div>
</section>

<!-- ── Audit Engine ─────────────────────────────────────────────────── -->
<section style="background:#F8F6F1;padding:3rem 0 5rem;">
  <div style="max-width:880px;margin:0 auto;padding:0 1.5rem;">
    <AuditEngine client:idle />
  </div>
</section>

<!-- ── Trust bar ────────────────────────────────────────────────────── -->
<section style="background:#0A0A0A;color:#F8F6F1;padding:3.5rem 0;text-align:center;">
  <div style="max-width:900px;margin:0 auto;padding:0 1.5rem;">
    <p style="font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;opacity:0.4;margin-bottom:2rem;">Why trust our audit</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2rem;">
      <div>
        <p style="font-family:Georgia,serif;font-size:1.8rem;margin-bottom:0.3rem;">30+</p>
        <p style="font-size:0.85rem;opacity:0.6;">Technical signals checked</p>
      </div>
      <div>
        <p style="font-family:Georgia,serif;font-size:1.8rem;margin-bottom:0.3rem;">5</p>
        <p style="font-size:0.85rem;opacity:0.6;">Audit categories scored</p>
      </div>
      <div>
        <p style="font-family:Georgia,serif;font-size:1.8rem;margin-bottom:0.3rem;">&lt; 30s</p>
        <p style="font-size:0.85rem;opacity:0.6;">Full report delivery</p>
      </div>
      <div>
        <p style="font-family:Georgia,serif;font-size:1.8rem;margin-bottom:0.3rem;">Free</p>
        <p style="font-size:0.85rem;opacity:0.6;">No sign-up required</p>
      </div>
    </div>
  </div>
</section>

<!-- ── How it works ─────────────────────────────────────────────────── -->
<section style="background:#F8F6F1;padding:4rem 0;">
  <div style="max-width:760px;margin:0 auto;padding:0 1.5rem;text-align:center;">
    <p style="font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;opacity:0.4;margin-bottom:1rem;">How it works</p>
    <h2 style="font-family:Georgia,serif;font-size:1.6rem;font-weight:400;margin-bottom:3rem;">Three steps, zero friction</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2.5rem;text-align:left;">
      <div>
        <p style="font-family:Georgia,serif;font-size:2rem;color:#E8B4B0;margin-bottom:0.5rem;">01</p>
        <p style="font-weight:600;font-size:0.95rem;margin-bottom:0.4rem;">Paste your URL</p>
        <p style="font-size:0.85rem;opacity:0.6;line-height:1.6;">Any live website — yours, a competitor's, a prospect's.</p>
      </div>
      <div>
        <p style="font-family:Georgia,serif;font-size:2rem;color:#E8B4B0;margin-bottom:0.5rem;">02</p>
        <p style="font-weight:600;font-size:0.95rem;margin-bottom:0.4rem;">AI scans &amp; scores</p>
        <p style="font-size:0.85rem;opacity:0.6;line-height:1.6;">We fetch the page, extract 30+ signals, and run an AI analysis across 5 categories.</p>
      </div>
      <div>
        <p style="font-family:Georgia,serif;font-size:2rem;color:#E8B4B0;margin-bottom:0.5rem;">03</p>
        <p style="font-weight:600;font-size:0.95rem;margin-bottom:0.4rem;">Get your action plan</p>
        <p style="font-size:0.85rem;opacity:0.6;line-height:1.6;">A prioritised report with specific fixes. Know exactly what to improve first.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── CTA ──────────────────────────────────────────────────────────── -->
<section style="background:#0A0A0A;color:#F8F6F1;padding:4rem 0;text-align:center;">
  <div style="max-width:560px;margin:0 auto;padding:0 1.5rem;">
    <h2 style="font-family:Georgia,serif;font-size:1.5rem;font-weight:400;margin-bottom:1rem;">Need help fixing what the audit found?</h2>
    <p style="font-size:0.9rem;opacity:0.6;line-height:1.7;margin-bottom:2rem;">Our team builds production-grade automation and AI systems. We'll turn your audit findings into a working action plan.</p>
    <a href="/pages/welcome" style="display:inline-block;background:#F8F6F1;color:#0A0A0A;padding:0.85rem 2.2rem;font-size:0.8rem;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;font-weight:600;">Book a Free Consultation</a>
  </div>
</section>

</ShopLayout>
