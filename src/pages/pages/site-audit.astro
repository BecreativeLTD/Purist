---
import ShopLayout from '~/layouts/ShopLayout.astro';
import AuditEngine from '~/components/audit/AuditEngine.tsx';
---

<ShopLayout
  title="Free Website Audit — AI-Powered Analysis in 30 Seconds | PURIST"
  description="Get an instant, comprehensive audit of your website. SEO, performance, security, tracking and UX — scored by AI. Free, no sign-up required."
  canonical="https://www.purist.online/pages/site-audit"
>

<script type="application/ld+json" is:inline>{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "PURIST Site Audit",
  "description": "Free AI-powered website audit tool. Analyses SEO, performance, security, tracking, and UX in under 30 seconds.",
  "url": "https://www.purist.online/pages/site-audit",
  "applicationCategory": "WebApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "GBP" },
  "provider": { "@type": "Organization", "name": "PURIST", "url": "https://www.purist.online" }
})}</script>

<!-- ── Hero + Audit Engine ──────────────────────────────────────────── -->
<section style="background:#0A0A0A;color:#F8F6F1;padding:5rem 0 4rem;position:relative;overflow:hidden;">
  <!-- Subtle grid pattern background -->
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(232,180,176,0.03) 1px,transparent 1px);background-size:32px 32px;pointer-events:none;"></div>

  <div style="position:relative;max-width:760px;margin:0 auto;padding:0 1.5rem;text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 16px;background:rgba(232,180,176,0.08);border:1px solid rgba(232,180,176,0.15);border-radius:999px;margin-bottom:1.5rem;">
      <span style="width:6px;height:6px;border-radius:50%;background:#16A34A;animation:audit-live-dot 2s ease-in-out infinite;"></span>
      <span style="font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(248,246,241,0.6);">Live · AI-Powered Audit</span>
    </div>
    <h1 style="font-family:Georgia,serif;font-size:clamp(2.2rem,5.5vw,3.5rem);line-height:1.12;margin-bottom:1.25rem;font-weight:400;">
      Your website, <em style="font-style:italic;color:#E8B4B0;">audited by AI</em>
    </h1>
    <p style="font-size:1.05rem;line-height:1.7;opacity:0.5;max-width:560px;margin:0 auto 2.5rem;">
      Paste any URL. Get a full business and technical audit — SEO, performance, security, content quality, accessibility, conversion signals, brand trust and tracking. 8 categories. Real data. Actionable fixes.
    </p>
  </div>

  <div style="position:relative;max-width:880px;margin:0 auto;padding:0 1.5rem;">
    <AuditEngine client:idle />
  </div>
</section>

<!-- ── What we analyse (live signal grid) ──────────────────────────── -->
<section style="background:#F8F6F1;padding:5rem 0;border-top:1px solid rgba(10,10,10,0.06);">
  <div style="max-width:960px;margin:0 auto;padding:0 1.5rem;">
    <div style="text-align:center;margin-bottom:3rem;">
      <p style="font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;opacity:0.35;margin-bottom:0.8rem;">What we check</p>
      <h2 style="font-family:Georgia,serif;font-size:1.6rem;font-weight:400;">30+ signals across 5 categories</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1px;background:rgba(10,10,10,0.06);border-radius:20px;overflow:hidden;">
      <!-- SEO -->
      <div style="background:#F8F6F1;padding:2rem;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:1rem;">
          <div style="width:36px;height:36px;border-radius:10px;background:rgba(232,180,176,0.12);display:flex;align-items:center;justify-content:center;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="1.8" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          </div>
          <h3 style="font-family:Georgia,serif;font-size:1.05rem;font-weight:400;">SEO & Indexability</h3>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:6px;">
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Title tag & meta description</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Canonical URL & robots directives</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>H1/H2 heading structure</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Open Graph & Schema.org markup</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Image alt text coverage</li>
        </ul>
      </div>
      <!-- Technical -->
      <div style="background:#F8F6F1;padding:2rem;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:1rem;">
          <div style="width:36px;height:36px;border-radius:10px;background:rgba(232,180,176,0.12);display:flex;align-items:center;justify-content:center;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="1.8" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
          </div>
          <h3 style="font-family:Georgia,serif;font-size:1.05rem;font-weight:400;">Technical & Performance</h3>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:6px;">
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Response time & HTML size</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Tech stack & framework detection</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>JavaScript & CSS file count</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Inline style analysis</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Viewport & charset configuration</li>
        </ul>
      </div>
      <!-- Security -->
      <div style="background:#F8F6F1;padding:2rem;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:1rem;">
          <div style="width:36px;height:36px;border-radius:10px;background:rgba(232,180,176,0.12);display:flex;align-items:center;justify-content:center;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="1.8" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 style="font-family:Georgia,serif;font-size:1.05rem;font-weight:400;">Security & Headers</h3>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:6px;">
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>HTTPS enforcement</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>HSTS & Content Security Policy</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>X-Frame-Options protection</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>X-Content-Type-Options</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Server disclosure audit</li>
        </ul>
      </div>
      <!-- Tracking -->
      <div style="background:#F8F6F1;padding:2rem;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:1rem;">
          <div style="width:36px;height:36px;border-radius:10px;background:rgba(232,180,176,0.12);display:flex;align-items:center;justify-content:center;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="1.8" stroke-linecap="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3 style="font-family:Georgia,serif;font-size:1.05rem;font-weight:400;">Tracking & Analytics</h3>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:6px;">
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Google Analytics / GTM</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Meta, TikTok & LinkedIn pixels</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Hotjar, Clarity & heatmap tools</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>CRM integrations (HubSpot, Intercom)</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Privacy-first analytics (Plausible)</li>
        </ul>
      </div>
      <!-- UX -->
      <div style="background:#F8F6F1;padding:2rem;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:1rem;">
          <div style="width:36px;height:36px;border-radius:10px;background:rgba(232,180,176,0.12);display:flex;align-items:center;justify-content:center;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="1.8" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3 style="font-family:Georgia,serif;font-size:1.05rem;font-weight:400;">UX & Conversion</h3>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:6px;">
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Mobile viewport optimisation</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Language declaration</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Call-to-action signals</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Content hierarchy quality</li>
          <li style="font-size:0.8rem;opacity:0.55;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(10,10,10,0.2);"></span>Social proof presence</li>
        </ul>
      </div>
      <!-- Bonus: live stats -->
      <div style="background:#0A0A0A;padding:2rem;color:#F8F6F1;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;">
        <p style="font-family:Georgia,serif;font-size:2.8rem;line-height:1;margin-bottom:0.5rem;color:#E8B4B0;">100%</p>
        <p style="font-size:0.75rem;opacity:0.5;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:0.3rem;">Free forever</p>
        <p style="font-size:0.75rem;opacity:0.35;line-height:1.5;">No credit card. No email gate.<br/>Just paste and go.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── How it works ─────────────────────────────────────────────────── -->
<section style="background:#0A0A0A;color:#F8F6F1;padding:6rem 0;">
  <div style="max-width:960px;margin:0 auto;padding:0 1.5rem;">
    <div style="text-align:center;margin-bottom:4rem;">
      <p class="hiw-label">How it works</p>
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.5rem,3vw,2rem);font-weight:400;">Three steps. Zero friction.</h2>
    </div>
    <div class="hiw-grid">
      <!-- Animated connector -->
      <div class="hiw-connector"><div class="hiw-connector-fill"></div></div>

      <!-- Step 1 -->
      <div class="hiw-step hiw-step-1">
        <div class="hiw-number">01</div>
        <div class="hiw-icon-wrap">
          <div class="hiw-icon-ring"></div>
          <div class="hiw-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5" stroke="#E8B4B0"/>
              <path d="M15 3h6v6" stroke="#E8B4B0"/>
              <path d="M10 14L21 3" stroke="#E8B4B0"/>
            </svg>
          </div>
        </div>
        <h3 class="hiw-title">Paste your URL</h3>
        <p class="hiw-desc">Any live website — yours, a competitor's, a prospect's. No sign-up required.</p>
      </div>

      <!-- Step 2 -->
      <div class="hiw-step hiw-step-2">
        <div class="hiw-number">02</div>
        <div class="hiw-icon-wrap">
          <div class="hiw-icon-ring"></div>
          <div class="hiw-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3C7.03 3 3 7.03 3 12s4.03 9 9 9 9-4.03 9-9" stroke="#E8B4B0"/>
              <path d="M12 3a9 9 0 019 9" stroke="#E8B4B0" stroke-dasharray="4 3"/>
              <circle cx="12" cy="12" r="3" stroke="#E8B4B0"/>
              <path d="M12 1v2M12 21v2M1 12h2M21 12h2" stroke="rgba(232,180,176,0.3)"/>
            </svg>
          </div>
        </div>
        <h3 class="hiw-title">AI scans & scores</h3>
        <p class="hiw-desc">30+ signals extracted across 10 categories. Claude AI analyses in real-time.</p>
      </div>

      <!-- Step 3 -->
      <div class="hiw-step hiw-step-3">
        <div class="hiw-number">03</div>
        <div class="hiw-icon-wrap">
          <div class="hiw-icon-ring"></div>
          <div class="hiw-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke="#E8B4B0"/>
              <rect x="9" y="3" width="6" height="4" rx="1" stroke="#E8B4B0"/>
              <path d="M9 12l2 2 4-4" stroke="#E8B4B0"/>
              <path d="M9 17h6" stroke="rgba(232,180,176,0.4)"/>
            </svg>
          </div>
        </div>
        <h3 class="hiw-title">Get your action plan</h3>
        <p class="hiw-desc">Prioritised findings, code-level fixes, and automation workflows. Downloadable as PDF.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── Comparison with paid tools ──────────────────────────────────── -->
<section style="background:#F8F6F1;padding:5rem 0;">
  <div style="max-width:800px;margin:0 auto;padding:0 1.5rem;">
    <div style="text-align:center;margin-bottom:3rem;">
      <p style="font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;opacity:0.35;margin-bottom:0.8rem;">Why this tool</p>
      <h2 style="font-family:Georgia,serif;font-size:1.6rem;font-weight:400;">What you'd usually pay for — free.</h2>
    </div>
    <div style="border:1px solid rgba(10,10,10,0.08);border-radius:16px;overflow:hidden;">
      <table style="width:100%;border-collapse:collapse;font-size:0.85rem;">
        <thead>
          <tr style="border-bottom:1px solid rgba(10,10,10,0.08);">
            <th style="padding:14px 20px;text-align:left;font-weight:500;opacity:0.4;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.1em;">Feature</th>
            <th style="padding:14px 20px;text-align:center;font-weight:500;opacity:0.4;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.1em;">Paid tools</th>
            <th style="padding:14px 20px;text-align:center;font-weight:600;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.1em;color:#E8B4B0;">PURIST Audit</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom:1px solid rgba(10,10,10,0.05);">
            <td style="padding:12px 20px;">SEO analysis</td>
            <td style="padding:12px 20px;text-align:center;opacity:0.5;">$99–299/mo</td>
            <td style="padding:12px 20px;text-align:center;font-weight:600;">Free</td>
          </tr>
          <tr style="border-bottom:1px solid rgba(10,10,10,0.05);">
            <td style="padding:12px 20px;">Security header audit</td>
            <td style="padding:12px 20px;text-align:center;opacity:0.5;">Separate tool</td>
            <td style="padding:12px 20px;text-align:center;font-weight:600;">Included</td>
          </tr>
          <tr style="border-bottom:1px solid rgba(10,10,10,0.05);">
            <td style="padding:12px 20px;">Tech stack detection</td>
            <td style="padding:12px 20px;text-align:center;opacity:0.5;">$49/mo+</td>
            <td style="padding:12px 20px;text-align:center;font-weight:600;">Included</td>
          </tr>
          <tr style="border-bottom:1px solid rgba(10,10,10,0.05);">
            <td style="padding:12px 20px;">Tracking pixel audit</td>
            <td style="padding:12px 20px;text-align:center;opacity:0.5;">Manual</td>
            <td style="padding:12px 20px;text-align:center;font-weight:600;">Automated</td>
          </tr>
          <tr style="border-bottom:1px solid rgba(10,10,10,0.05);">
            <td style="padding:12px 20px;">AI-generated action plan</td>
            <td style="padding:12px 20px;text-align:center;opacity:0.5;">Not available</td>
            <td style="padding:12px 20px;text-align:center;font-weight:600;">Included</td>
          </tr>
          <tr>
            <td style="padding:12px 20px;">Sign-up required</td>
            <td style="padding:12px 20px;text-align:center;opacity:0.5;">Yes + credit card</td>
            <td style="padding:12px 20px;text-align:center;font-weight:600;">No</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- ── Use cases ────────────────────────────────────────────────────── -->
<section style="background:#0A0A0A;color:#F8F6F1;padding:5rem 0;">
  <div style="max-width:900px;margin:0 auto;padding:0 1.5rem;">
    <div style="text-align:center;margin-bottom:3rem;">
      <p style="font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;opacity:0.35;margin-bottom:0.8rem;">Use cases</p>
      <h2 style="font-family:Georgia,serif;font-size:1.6rem;font-weight:400;">Who uses the free audit?</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px;">
      <div style="padding:2rem;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:16px;">
        <p style="font-family:Georgia,serif;font-size:1.2rem;margin-bottom:0.6rem;">Founders</p>
        <p style="font-size:0.82rem;opacity:0.45;line-height:1.65;">"I built my site on Webflow but I don't know if SEO is set up right. The audit showed 4 critical issues I had no idea about."</p>
      </div>
      <div style="padding:2rem;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:16px;">
        <p style="font-family:Georgia,serif;font-size:1.2rem;margin-bottom:0.6rem;">Agencies</p>
        <p style="font-size:0.82rem;opacity:0.45;line-height:1.65;">"We run audits on prospect sites before sales calls. The report gives us talking points and makes us look like experts."</p>
