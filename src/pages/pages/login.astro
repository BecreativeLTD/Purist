---
import ShopLayout from '~/layouts/ShopLayout.astro';
---

<ShopLayout title="Sign in — PURIST" description="Sign in to your PURIST client account.">

  <div class="min-h-[calc(100vh-4rem)] bg-brand-cream flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">

      <!-- Card -->
      <div class="bg-white rounded-[20px] shadow-[0_4px_40px_rgba(10,10,10,0.07)] px-8 py-10 sm:px-10 sm:py-12">

        <!-- Logo -->
        <div class="text-center mb-8">
          <a href="/" class="inline-block font-display text-2xl font-medium tracking-tight text-brand-black">PURIST</a>
          <p class="mt-2 text-sm text-brand-gray-600">Sign in to your client account</p>
        </div>

        <!-- OAuth providers -->
        <div class="space-y-3 mb-8">

          <!-- Google -->
          <button
            type="button"
            class="w-full flex items-center justify-center gap-3 h-12 rounded-button border border-brand-gray-200 bg-white hover:bg-brand-cream transition text-sm font-medium text-brand-black"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Continue with Google
          </button>

          <!-- Apple -->
          <button
            type="button"
            class="w-full flex items-center justify-center gap-3 h-12 rounded-button border border-brand-gray-200 bg-white hover:bg-brand-cream transition text-sm font-medium text-brand-black"
          >
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.7 9.05 7.4c1.32.07 2.23.73 2.99.78 1.12-.26 2.19-.96 3.39-.85 1.44.15 2.52.72 3.24 1.82-2.96 1.8-2.25 5.78.53 6.91-.6 1.52-1.38 3.01-2.15 4.22zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
            </svg>
            Continue with Apple
          </button>

          <!-- Facebook -->
          <button
            type="button"
            class="w-full flex items-center justify-center gap-3 h-12 rounded-button border border-brand-gray-200 bg-white hover:bg-brand-cream transition text-sm font-medium text-brand-black"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2" aria-hidden="true">
              <path d="M24 12.073C24 5.404 18.629 0 12 0S0 5.404 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.235 2.686.235v2.97h-1.513c-1.491 0-1.956.93-1.956 1.884v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
            Continue with Facebook
          </button>

        </div>

        <!-- Divider -->
        <div class="relative mb-8">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-brand-gray-200"></div>
          </div>
          <div class="relative flex justify-center">
            <span class="bg-white px-4 text-xs text-brand-gray-600 uppercase tracking-widest">or</span>
          </div>
        </div>

        <!-- Email form -->
        <form class="space-y-4" onsubmit="event.preventDefault()">
          <div>
            <label for="email" class="block text-xs font-medium text-brand-black mb-1.5 tracking-wide">Email address</label>
            <input
              id="email"
              type="email"
              autocomplete="email"
              placeholder="you@company.com"
              required
              class="w-full h-12 rounded-button border border-brand-gray-200 bg-white px-4 text-sm outline-none focus:border-brand-black transition placeholder:text-brand-gray-400"
            />
          </div>
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label for="password" class="text-xs font-medium text-brand-black tracking-wide">Password</label>
              <a href="#" class="text-xs text-brand-gray-600 hover:text-brand-black transition">Forgot password?</a>
            </div>
            <input
              id="password"
              type="password"
              autocomplete="current-password"
              placeholder="••••••••"
              required
              class="w-full h-12 rounded-button border border-brand-gray-200 bg-white px-4 text-sm outline-none focus:border-brand-black transition placeholder:text-brand-gray-400"
            />
          </div>

          <button
            type="submit"
            class="w-full h-12 rounded-button bg-brand-black text-white text-sm font-medium hover:bg-brand-gray-900 transition mt-2"
          >
            Sign in
          </button>
        </form>

        <!-- Footer links -->
        <p class="text-center text-xs text-brand-gray-600 mt-8">
          New client?
          <a href="/pages/welcome" class="text-brand-black font-medium hover:underline underline-offset-4 ml-1">Get started →</a>
        </p>
        <p class="text-center text-xs text-brand-gray-600 mt-3">
          <a href="/pages/onboarding" class="hover:text-brand-black transition">Client onboarding</a>
          <span class="mx-2 opacity-40">·</span>
          <a href="/pages/contact-us" class="hover:text-brand-black transition">Need help?</a>
        </p>

      </div>

      <!-- Trust signals -->
      <div class="flex items-center justify-center gap-6 mt-8 text-[11px] text-brand-gray-600 opacity-70">
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          256-bit encrypted
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M9 12l2 2 4-4"/>
          </svg>
          SOC 2 compliant
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0110 0v4"/>
          </svg>
          GDPR ready
        </span>
      </div>

    </div>
  </div>

</ShopLayout>
