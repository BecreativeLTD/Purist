---
import ShopLayout from '~/layouts/ShopLayout.astro';
---

<ShopLayout
  title="Automation Maturity Score — Where Does Your Business Stand? | PURIST"
  description="Take the 5-dimension Automation Maturity Assessment. Get your score, see exactly where you are on the path to autonomous operations, and receive a personalised roadmap."
  canonical="https://purist.online/pages/automation-maturity"
>

<!-- Hero -->
<section class="bg-brand-black text-white pt-20 pb-14 lg:pt-28 relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 55% at 50% 0%,rgba(123,104,238,0.09) 0%,transparent 60%);"></div>
  <div class="container-x relative z-10">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border mb-6" style="border-color:rgba(123,104,238,0.30);background:rgba(123,104,238,0.07);">
        <span class="text-[10px] uppercase tracking-[0.18em] font-semibold" style="color:rgba(123,104,238,0.85);">Free · 3 minutes · No signup</span>
      </div>
      <h1 class="font-display text-[2.2rem] lg:text-[3rem] leading-[1.06] tracking-[-0.025em] text-white mb-4">
        Your Automation<br/><em class="font-medium" style="color:#7B68EE;">Maturity Score</em>
      </h1>
      <p class="text-[15px] leading-relaxed mb-8 max-w-xl mx-auto" style="color:rgba(255,255,255,0.45);">
        5 dimensions. 15 questions. A precise diagnosis of where your business stands on the path to autonomous operations — and exactly what to do next.
      </p>
      <div class="flex flex-wrap justify-center gap-8 text-[10px]" style="color:rgba(255,255,255,0.25);">
        {[['5','Maturity levels'],['15','Questions'],['847','Businesses assessed'],['4.2 min','Avg completion time']].map(([n,l])=>(
          <div class="text-center">
            <p class="font-display text-2xl leading-none mb-1" style="color:rgba(123,104,238,0.75);">{n}</p>
            <p class="uppercase tracking-wider">{l}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Assessment -->
<section class="bg-[#0C0C0A] py-14 lg:py-20">
  <div class="container-x">
    <div class="max-w-2xl mx-auto">

      <!-- Progress bar -->
      <div class="mb-8">
        <div class="flex items-center justify-between mb-3">
          <p class="text-[10px] uppercase tracking-[0.16em] font-bold" style="color:rgba(255,255,255,0.25);">Assessment progress</p>
          <p class="text-[10px] font-semibold" style="color:rgba(123,104,238,0.70);" id="am-progress-label">Question 1 of 15</p>
        </div>
        <div class="h-1 rounded-full overflow-hidden" style="background:rgba(255,255,255,0.06);">
          <div id="am-progress-bar" class="h-full rounded-full transition-all duration-500" style="width:6.66%;background:linear-gradient(90deg,#7B68EE,rgba(123,104,238,0.50));"></div>
        </div>
        <!-- Dimension dots -->
        <div class="flex gap-0 mt-3">
          {[
            {label:'Data',color:'#E8B4B0'},
            {label:'Process',color:'#7B68EE'},
            {label:'Tools',color:'#C89840'},
            {label:'Team',color:'#4ade80'},
            {label:'Results',color:'#ef4444'},
          ].map((d,i)=>(
            <div class="flex-1 text-center">
              <div class="am-dim-bar h-1 mx-0.5 rounded-full transition-all duration-500" id={`am-dim-${i}`} style={`background:rgba(255,255,255,0.06);`}></div>
              <p class="text-[8px] mt-1 uppercase tracking-wider" style="color:rgba(255,255,255,0.18);">{d.label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Question card -->
      <div id="am-question-wrap">
        <div id="am-card" class="rounded-[24px] overflow-hidden border" style="background:rgba(255,255,255,0.025);border-color:rgba(255,255,255,0.07);">
          <!-- Dimension header -->
          <div id="am-dim-header" class="px-6 pt-5 pb-3 border-b" style="border-color:rgba(255,255,255,0.05);">
            <p class="text-[9px] uppercase tracking-[0.2em] font-bold" id="am-dim-label" style="color:rgba(123,104,238,0.55);">Dimension 1 · Data & Integration</p>
          </div>
          <!-- Question -->
          <div class="px-6 pt-6 pb-4">
            <p class="text-[18px] font-display text-white leading-snug mb-6" id="am-q-text">How connected are your business tools right now?</p>
            <div id="am-answers" class="space-y-2"></div>
          </div>
        </div>

        <!-- Nav -->
        <div class="flex items-center justify-between mt-5">
          <button id="am-back-btn" onclick="amBack()"
            class="flex items-center gap-2 text-[11px] font-medium transition"
            style="color:rgba(255,255,255,0.30);">
            <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M10 7H2M5 4l-3 3 3 3"/></svg>
            Back
          </button>
          <p class="text-[10px]" style="color:rgba(255,255,255,0.18);">Select an answer to continue</p>
        </div>
      </div>

      <!-- Result (hidden until done) -->
      <div id="am-result" class="hidden"></div>

    </div>
  </div>
</section>

<!-- Maturity levels explained -->
<section class="bg-[#0C0C0A] py-16 lg:py-20 border-t" style="border-color:rgba(255,255,255,0.06);">
  <div class="container-x">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12 scroll-fade">
        <p class="text-[9px] uppercase tracking-[0.2em] font-bold mb-3" style="color:rgba(123,104,238,0.50);">The framework</p>
        <h2 class="font-display text-[1.8rem] text-white mb-3">The 5 Maturity Levels</h2>
        <p class="text-[14px] max-w-lg mx-auto" style="color:rgba(255,255,255,0.40);">Every business falls somewhere on this spectrum. Knowing your level is the first step to moving up it.</p>
      </div>
      <div class="space-y-3">
        {[
          { level:1, name:'Manual Business',       pct:'0–20%',  fillPct:20,  col:'#ef4444', desc:'Everything is done by hand. No automation. Maximum cost, maximum risk of error. Average 20+ hours/week lost.' },
          { level:2, name:'Automation Aware',       pct:'21–40%', fillPct:40,  col:'#C89840', desc:'You know automation exists but use only basic tools. Some spreadsheets, maybe one integration. Significant untapped potential.' },
          { level:3, name:'Partially Automated',   pct:'41–60%', fillPct:60,  col:'#E8B4B0', desc:'Key processes are automated but in silos. Tools don\'t talk to each other. You\'re saving time but leaving money on the table.' },
          { level:4, name:'Automation-First',      pct:'61–80%', fillPct:80,  col:'#7B68EE', desc:'Most processes are automated and connected. Data flows between systems. Your team focuses on high-value work.' },
          { level:5, name:'Autonomous Operations', pct:'81–100%',fillPct:100, col:'#4ade80', desc:'Your business runs itself. AI agents handle exceptions. You have full visibility, near-zero manual admin, maximum ROI.' },
        ].map(({level,name,pct,fillPct,col,desc})=>(
          <div class="flex gap-5 p-5 rounded-[16px] border scroll-fade" style="background:rgba(255,255,255,0.025);border-color:rgba(255,255,255,0.07);">
            <div class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center font-display text-lg font-bold" style={`background:${col}18;color:${col};`}>{level}</div>
            <div class="flex-1">
              <div class="flex items-center justify-between mb-1 flex-wrap gap-2">
                <p class="font-semibold text-[14px] text-white">{name}</p>
                <span class="text-[10px] font-bold px-2.5 py-0.5 rounded-full" style={`background:${col}15;color:${col};`}>{pct}</span>
              </div>
              <p class="text-[12px] leading-relaxed mb-2" style="color:rgba(255,255,255,0.45);">{desc}</p>
              <div class="h-1.5 rounded-full overflow-hidden" style="background:rgba(255,255,255,0.06);">
                <div class="h-full rounded-full" style={`width:${fillPct}%;background:${col};opacity:0.55;`}></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

</ShopLayout>

<style is:global>
  @keyframes am-slide-in { from{opacity:0;transform:translateX(20px)} to{opacity:1;transform:translateX(0)} }
  @keyframes am-slide-out { from{opacity:1;transform:translateX(0)} to{opacity:0;transform:translateX(-20px)} }
  @keyframes am-result-in { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
  #am-card { animation: am-slide-in 0.35s ease-out; }
</style>

<script is:inline>
(function(){

var BENCHMARKS = {
  dental:      { avg: 38, top25: 62, label: 'Dental / Healthcare' },
  agency:      { avg: 45, top25: 70, label: 'Agency / Consulting' },
  ecom:        { avg: 42, top25: 68, label: 'E-commerce' },
  realestate:  { avg: 35, top25: 58, label: 'Real Estate' },
  saas:        { avg: 55, top25: 78, label: 'SaaS / Tech' },
  finance:     { avg: 40, top25: 65, label: 'Finance / Legal' },
  default:     { avg: 42, top25: 65, label: 'your industry' },
};

var INDUSTRY_OPTIONS = [
  { key: 'dental',     label: 'Dental / Healthcare', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>' },
  { key: 'agency',     label: 'Agency / Consulting',  icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="14" width="4" height="7" rx="1"/><rect x="9" y="9" width="4" height="12" rx="1"/><rect x="16" y="4" width="4" height="17" rx="1"/></svg>' },
  { key: 'ecom',       label: 'E-commerce',            icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>' },
  { key: 'realestate', label: 'Real Estate',            icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>' },
  { key: 'saas',       label: 'SaaS / Tech',            icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>' },
  { key: 'finance',    label: 'Finance / Legal',        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>' },
];

var selectedIndustry = null;

var QUESTIONS = [
  // Dimension 0: Data & Integration
  { dim:0, dimLabel:'Dimension 1 · Data & Integration', dimColor:'#E8B4B0',
    text:'How connected are your core business tools right now?',
    opts:[
      { text:'Completely siloed — no integrations between tools', score:0 },
      { text:'2–3 tools connected manually (CSV exports, copy-paste)', score:1 },
      { text:'Some basic integrations (Zapier/Make with simple zaps)', score:2 },
      { text:'Most tools are connected with automated data flows', score:3 },
    ]},
  { dim:0, dimLabel:'Dimension 1 · Data & Integration', dimColor:'#E8B4B0',
    text:'When a new lead comes in, what happens to their data?',
    opts:[
      { text:'Manually entered into a spreadsheet or CRM', score:0 },
      { text:'Auto-saved in one place but not synced elsewhere', score:1 },
      { text:'Goes to CRM + triggers one or two notifications', score:2 },
      { text:'Triggers a full multi-step automated sequence', score:3 },
    ]},
  { dim:0, dimLabel:'Dimension 1 · Data & Integration', dimColor:'#E8B4B0',
    text:'How many of your key business metrics update automatically?',
    opts:[
      { text:'None — we pull reports manually', score:0 },
      { text:'1–2 dashboards with semi-manual updates', score:1 },
      { text:'Most metrics update daily via integrations', score:2 },
      { text:'Live dashboards, everything real-time', score:3 },
    ]},

  // Dimension 1: Process Documentation
  { dim:1, dimLabel:'Dimension 2 · Process Documentation', dimColor:'#7B68EE',
    text:'How well documented are your business processes?',
    opts:[
      { text:'Nothing written down — it\'s all in people\'s heads', score:0 },
      { text:'Some informal notes or email threads', score:1 },
      { text:'Written SOPs for most processes', score:2 },
      { text:'Full process maps with decision trees and edge cases', score:3 },
    ]},
  { dim:1, dimLabel:'Dimension 2 · Process Documentation', dimColor:'#7B68EE',
    text:'What happens when a key team member is on holiday?',
    opts:[
      { text:'Things fall through the cracks — it\'s a real problem', score:0 },
      { text:'Someone covers but it\'s stressful and inconsistent', score:1 },
      { text:'Documented handover process, mostly works', score:2 },
      { text:'Automation handles most of it, minimal disruption', score:3 },
    ]},
  { dim:1, dimLabel:'Dimension 2 · Process Documentation', dimColor:'#7B68EE',
    text:'How do you handle onboarding a new client or customer?',
    opts:[
      { text:'Ad-hoc — different every time', score:0 },
      { text:'Rough checklist that we sometimes forget', score:1 },
      { text:'Standard process but still heavily manual', score:2 },
      { text:'Automated sequence: contracts, access, comms, follow-up', score:3 },
    ]},

  // Dimension 2: Current Automation
  { dim:2, dimLabel:'Dimension 3 · Current Automation Level', dimColor:'#C89840',
    text:'Which of these do you currently have automated?',
    opts:[
      { text:'Nothing — everything is done manually', score:0 },
      { text:'1–2 things (e.g. email autoresponder, basic Zapier)', score:1 },
      { text:'5–8 workflows running reliably', score:2 },
      { text:'10+ interconnected workflows, monitored 24/7', score:3 },
    ]},
  { dim:2, dimLabel:'Dimension 3 · Current Automation Level', dimColor:'#C89840',
    text:'How much of your billing/invoicing is automated?',
    opts:[
      { text:'100% manual — we create and send each invoice ourselves', score:0 },
      { text:'Partly — templates exist but sending is manual', score:1 },
      { text:'Mostly automated, chase sequences are manual', score:2 },
      { text:'Fully automated: generate, send, chase, reconcile', score:3 },
    ]},
  { dim:2, dimLabel:'Dimension 3 · Current Automation Level', dimColor:'#C89840',
    text:'Do you use any AI-powered automation in your business?',
    opts:[
      { text:'No AI automation at all', score:0 },
      { text:'Experimenting but nothing in production', score:1 },
      { text:'AI for 1–2 tasks (e.g. support responses, content)', score:2 },
      { text:'AI agents handling multiple business functions', score:3 },
    ]},

  // Dimension 3: Team Readiness
  { dim:3, dimLabel:'Dimension 4 · Team & Culture', dimColor:'#4ade80',
    text:'How does your team feel about automation?',
    opts:[
      { text:'Resistant — worried about job security or change', score:0 },
      { text:'Mixed — some open, some skeptical', score:1 },
      { text:'Generally positive, open to trying new things', score:2 },
      { text:'Actively request automation, identify opportunities themselves', score:3 },
    ]},
  { dim:3, dimLabel:'Dimension 4 · Team & Culture', dimColor:'#4ade80',
    text:'When a process repeatedly breaks or causes errors, what happens?',
    opts:[
      { text:'We deal with each instance manually and move on', score:0 },
      { text:'Someone notes it but we rarely fix the root cause', score:1 },
      { text:'We review it periodically and sometimes improve it', score:2 },
      { text:'Immediate root-cause analysis + permanent fix or automation', score:3 },
    ]},
  { dim:3, dimLabel:'Dimension 4 · Team & Culture', dimColor:'#4ade80',
    text:'How many hours per week does your leadership team spend on admin?',
    opts:[
      { text:'8+ hours — it\'s a significant time drain', score:0 },
      { text:'4–7 hours — too much but hard to fix', score:1 },
      { text:'1–3 hours — it\'s under control', score:2 },
      { text:'Under 1 hour — almost all admin is automated', score:3 },
    ]},

  // Dimension 4: ROI Awareness
  { dim:4, dimLabel:'Dimension 5 · ROI & Measurement', dimColor:'#ef4444',
    text:'Do you know how much time your team spends on manual tasks weekly?',
    opts:[
      { text:'No idea — never measured it', score:0 },
      { text:'Rough guess but no real data', score:1 },
      { text:'We\'ve measured it once or twice', score:2 },
      { text:'We track it continuously and benchmark against targets', score:3 },
    ]},
  { dim:4, dimLabel:'Dimension 5 · ROI & Measurement', dimColor:'#ef4444',
    text:'How do you evaluate whether an automation is worth building?',
    opts:[
      { text:'We don\'t — we just try things and see', score:0 },
      { text:'Gut feeling and team consensus', score:1 },
      { text:'Rough time-saving estimate before we start', score:2 },
      { text:'Full ROI model: hours saved × rate × frequency vs build cost', score:3 },
    ]},
  { dim:4, dimLabel:'Dimension 5 · ROI & Measurement', dimColor:'#ef4444',
    text:'What\'s your biggest automation priority right now?',
    opts:[
      { text:'We haven\'t thought about it yet', score:0 },
      { text:'Reduce admin overhead for the team', score:1 },
      { text:'Specific process: lead follow-up / invoicing / onboarding', score:2 },
      { text:'Full-stack: connect all tools, deploy AI agents, maximise ROI', score:3 },
    ]},
];

var DIM_COLORS = ['#E8B4B0','#7B68EE','#C89840','#4ade80','#ef4444'];
var DIM_NAMES  = ['Data & Integration','Process Documentation','Current Automation','Team & Culture','ROI & Measurement'];

var answers = [];
var current = 0;

function renderIndustrySelect() {
  document.getElementById('am-result').classList.add('hidden');
  var wrap = document.getElementById('am-question-wrap');
  wrap.classList.remove('hidden');

  // Reset progress bar to "industry step"
  document.getElementById('am-progress-bar').style.width = '0%';
  document.getElementById('am-progress-label').textContent = 'Step 1 of 16 — Industry';
  for (var d = 0; d < 5; d++) {
    var bar = document.getElementById('am-dim-' + d);
    if (bar) bar.style.background = 'rgba(255,255,255,0.06)';
  }

  var card = document.getElementById('am-card');
  card.style.animation = '';
  document.getElementById('am-dim-label').textContent = 'Tell us about your business';
  document.getElementById('am-dim-label').style.color = 'rgba(123,104,238,0.55)';
  document.getElementById('am-q-text').textContent = 'What type of business are you?';

  var wrap2 = document.getElementById('am-answers');
  wrap2.innerHTML = '';

  var grid = document.createElement('div');
  grid.style.cssText = 'display:grid;grid-template-columns:1fr 1fr;gap:10px;';

  INDUSTRY_OPTIONS.forEach(function(opt) {
    var btn = document.createElement('button');
    btn.style.cssText = 'background:rgba(255,255,255,0.025);border:1px solid rgba(255,255,255,0.07);color:rgba(255,255,255,0.75);border-radius:14px;padding:18px 14px;text-align:center;font-size:13px;line-height:1.35;cursor:pointer;transition:all 0.18s;min-height:72px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;animation:am-slide-in 0.3s ease-out both;';
    btn.innerHTML = '<span style="display:flex;align-items:center;justify-content:center;opacity:0.70;margin-bottom:4px;">' + opt.icon + '</span><span style="font-weight:600;">' + opt.label + '</span>';
    btn.onmouseover = function(){ this.style.background='rgba(123,104,238,0.10)'; this.style.borderColor='rgba(123,104,238,0.30)'; this.style.color='#fff'; };
    btn.onmouseout  = function(){
      if (selectedIndustry !== opt.key) {
        this.style.background='rgba(255,255,255,0.025)'; this.style.borderColor='rgba(255,255,255,0.07)'; this.style.color='rgba(255,255,255,0.75)';
      }
    };
    btn.addEventListener('click', function() {
      selectedIndustry = opt.key;
      // Highlight selected
      grid.querySelectorAll('button').forEach(function(b){ b.style.opacity='0.4'; b.style.background='rgba(255,255,255,0.025)'; b.style.borderColor='rgba(255,255,255,0.07)'; });
      btn.style.background='rgba(123,104,238,0.18)';
      btn.style.borderColor='rgba(123,104,238,0.45)';
      btn.style.color='#fff';
      btn.style.opacity='1';
      setTimeout(function(){
        card.style.animation = 'am-slide-out 0.2s ease-in forwards';
        setTimeout(function() {
          card.style.animation = '';
          renderQuestion(0);
        }, 220);
      }, 320);
    });
    grid.appendChild(btn);
  });

  wrap2.appendChild(grid);

  // Back button hidden on industry screen
  document.getElementById('am-back-btn').style.opacity = '0.2';
  document.getElementById('am-back-btn').style.pointerEvents = 'none';
}

function renderQuestion(idx) {
  if (idx >= QUESTIONS.length) { showResult(); return; }
  var q = QUESTIONS[idx];

  // Progress
  var pct = Math.round(((idx) / QUESTIONS.length) * 100);
  document.getElementById('am-progress-bar').style.width = Math.max(6, pct) + '%';
  document.getElementById('am-progress-label').textContent = 'Question ' + (idx+1) + ' of ' + QUESTIONS.length;

  // Dimension bars (fill completed dims)
  for (var d = 0; d < 5; d++) {
    var bar = document.getElementById('am-dim-' + d);
    if (!bar) continue;
    if (d < q.dim) bar.style.background = DIM_COLORS[d];
    else if (d === q.dim) bar.style.background = 'rgba(255,255,255,0.25)';
    else bar.style.background = 'rgba(255,255,255,0.06)';
  }

  // Dim header
  document.getElementById('am-dim-label').textContent = q.dimLabel;
  document.getElementById('am-dim-label').style.color = q.dimColor + 'AA';

  // Question text
  document.getElementById('am-q-text').textContent = q.text;

  // Answers
  var wrap = document.getElementById('am-answers');
  wrap.innerHTML = '';
  q.opts.forEach(function(opt, i) {
    var btn = document.createElement('button');
    btn.className = 'am-ans w-full text-left px-4 py-3.5 rounded-[14px] border transition-all';
    btn.style.cssText = 'background:rgba(255,255,255,0.025);border-color:rgba(255,255,255,0.07);color:rgba(255,255,255,0.65);font-size:13px;line-height:1.45;min-height:52px;animation:am-slide-in 0.3s ease-out ' + (i*0.06) + 's both;';
    btn.textContent = opt.text;
    btn.onmouseover = function(){ this.style.background='rgba(123,104,238,0.08)'; this.style.borderColor='rgba(123,104,238,0.25)'; this.style.color='rgba(255,255,255,0.90)'; };
    btn.onmouseout  = function(){ this.style.background='rgba(255,255,255,0.025)'; this.style.borderColor='rgba(255,255,255,0.07)'; this.style.color='rgba(255,255,255,0.65)'; };
    btn.addEventListener('click', function() {
      answers[idx] = opt.score;
      // Highlight selected
      document.querySelectorAll('.am-ans').forEach(function(b){ b.style.opacity='0.4'; });
      btn.style.background = 'rgba(123,104,238,0.18)';
      btn.style.borderColor = 'rgba(123,104,238,0.45)';
      btn.style.color = '#fff';
      btn.style.opacity = '1';
      setTimeout(function(){
        current = idx + 1;
        var card = document.getElementById('am-card');
        if (card) { card.style.animation = 'am-slide-out 0.2s ease-in forwards'; }
        setTimeout(function() {
          if (card) { card.style.animation = ''; }
          renderQuestion(current);
        }, 220);
      }, 320);
    });
    wrap.appendChild(btn);
  });

  // Back button
  document.getElementById('am-back-btn').style.opacity = idx === 0 ? '0.2' : '1';
  document.getElementById('am-back-btn').style.pointerEvents = idx === 0 ? 'none' : 'auto';
}

window.amBack = function() {
  if (current > 0) { current--; answers.splice(current, 1); renderQuestion(current); }
};

var QUICK_WINS_DATA = [
  ['Connect your CRM, email and calendar into one data pipeline', 'Build a live dashboard pulling real-time metrics from all tools'],
  ['Document your top 5 processes with decision trees and edge cases', 'Deploy a fully automated client onboarding flow (contract → access → comms)'],
  ['Automate invoice creation, sending and payment chase sequences', 'Set up appointment reminders + cancellation rebooking automation'],
  ['Run a 2-hour "automation opportunities" workshop with the team', 'Create a shared automation backlog the team actively contributes to'],
  ['Set up time tracking this week to baseline your manual work hours', 'Build a live ROI dashboard showing hours and cost saved per workflow'],
];

function buildRadar(dimPcts) {
  var cx = 100, cy = 100, maxR = 68, n = 5;
  var dimCols = ['#E8B4B0','#7B68EE','#C89840','#4ade80','#ef4444'];
  var dimLbls = ['Data','Process','Tools','Team','ROI'];
  function ptXY(i, pct) {
    var a = -Math.PI/2 + (2*Math.PI/n)*i;
    var r = maxR * Math.max(0.05, pct/100);
    return { x: cx + r*Math.cos(a), y: cy + r*Math.sin(a) };
  }
  var grid = '';
  [33,66,100].forEach(function(p) {
    var pts = [];
    for (var i=0; i<n; i++) { var pt=ptXY(i,p); pts.push(pt.x.toFixed(1)+','+pt.y.toFixed(1)); }
    grid += '<polygon points="'+pts.join(' ')+'" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="0.8"/>';
  });
  var spokes = '';
  for (var i=0; i<n; i++) {
    var ep = ptXY(i,100);
    spokes += '<line x1="'+cx+'" y1="'+cy+'" x2="'+ep.x.toFixed(1)+'" y2="'+ep.y.toFixed(1)+'" stroke="rgba(255,255,255,0.07)" stroke-width="0.8"/>';
  }
  var scorePts = [];
  for (var i=0; i<n; i++) { var sp=ptXY(i,dimPcts[i]); scorePts.push(sp.x.toFixed(1)+','+sp.y.toFixed(1)); }
  var fill = '<polygon points="'+scorePts.join(' ')+'" fill="rgba(123,104,238,0.18)" stroke="#7B68EE" stroke-width="1.5" stroke-linejoin="round"/>';
  var dots = '';
  for (var i=0; i<n; i++) {
    var dp = ptXY(i,dimPcts[i]);
    dots += '<circle cx="'+dp.x.toFixed(1)+'" cy="'+dp.y.toFixed(1)+'" r="3" fill="'+dimCols[i]+'"/>';
  }
  var lbls = '';
  for (var i=0; i<n; i++) {
    var lp = ptXY(i,132);
    lbls += '<text x="'+lp.x.toFixed(1)+'" y="'+(lp.y+2).toFixed(1)+'" text-anchor="middle" fill="'+dimCols[i]+'" font-size="9" font-weight="600" opacity="0.85">'+dimLbls[i]+'</text>';
    lbls += '<text x="'+lp.x.toFixed(1)+'" y="'+(lp.y+12).toFixed(1)+'" text-anchor="middle" fill="rgba(255,255,255,0.45)" font-size="7.5">'+dimPcts[i]+'%</text>';
  }
  return '<svg viewBox="-32 -32 264 264" width="100%" height="auto" style="max-width:190px;display:block;margin:0 auto;">'+grid+spokes+fill+dots+lbls+'</svg>';
}

function showResult() {
  document.getElementById('am-question-wrap').classList.add('hidden');
  var res = document.getElementById('am-result');
  res.classList.remove('hidden');

  // Score per dimension
  var dimScores = [0,0,0,0,0];
  var dimCounts = [0,0,0,0,0];
  answers.forEach(function(score, i) {
    var d = QUESTIONS[i].dim;
    dimScores[d] += score;
    dimCounts[d]++;
  });

  var totalScore = 0;
  var maxScore = 0;
  for (var d = 0; d < 5; d++) {
    totalScore += dimScores[d];
    maxScore += dimCounts[d] * 3;
  }
  var pct = Math.round((totalScore / maxScore) * 100);

  // Maturity level
  var level, levelName, levelColor, levelDesc, actions;
  if (pct <= 20) {
    level=1; levelName='Manual Business'; levelColor='#ef4444';
    levelDesc='Your business is running almost entirely on manual effort. You\'re losing significant time and money every week — but the good news is the opportunity is massive.';
    actions=['Map your 5 most time-consuming processes','Identify which tools you use daily','Book a free automation audit — we\'ll prioritise the highest-ROI fixes first'];
  } else if (pct <= 40) {
    level=2; levelName='Automation Aware'; levelColor='#C89840';
    levelDesc='You\'ve started thinking about automation but haven\'t connected the dots yet. A few targeted workflows could transform your efficiency in under 2 weeks.';
    actions=['Connect your CRM to your email tool','Automate your invoice creation and chase','Set up a lead capture → notification workflow'];
  } else if (pct <= 60) {
    level=3; levelName='Partially Automated'; levelColor='#E8B4B0';
    levelDesc='Good foundations. You\'ve automated some things but they\'re not connected. The next step is building a unified automation layer that ties everything together.';
    actions=['Audit your existing workflows for redundancy','Build an inter-tool data pipeline (one source of truth)','Add AI triage to your support or lead qualification'];
  } else if (pct <= 80) {
    level=4; levelName='Automation-First'; levelColor='#7B68EE';
    levelDesc='Strong automation posture. Most of your standard processes are handled. The focus now is AI agents for exception handling and closing the remaining manual gaps.';
    actions=['Deploy AI agents for Tier-1 support + lead qualification','Build predictive triggers (e.g. churn risk, inventory alerts)','Implement a real-time KPI dashboard across all systems'];
  } else {
    level=5; levelName='Autonomous Operations'; levelColor='#4ade80';
    levelDesc='You\'re operating at the top of the maturity curve. Your business is largely self-running. The opportunity now is maximising ROI and preparing for AI-native growth.';
    actions=['Explore agentic AI for complex decision-making','Build proprietary data loops that compound over time','Share your stack — become a case study'];
  }

  // Dimension breakdown HTML
  var dimHtml = '';
  for (var d = 0; d < 5; d++) {
    var dpct = dimCounts[d] > 0 ? Math.round((dimScores[d] / (dimCounts[d] * 3)) * 100) : 0;
    dimHtml += '<div>' +
      '<div class="flex justify-between text-[10px] mb-1.5" style="color:rgba(255,255,255,0.35);">' +
        '<span>' + DIM_NAMES[d] + '</span><span style="color:' + DIM_COLORS[d] + ';">' + dpct + '%</span>' +
      '</div>' +
      '<div class="h-1.5 rounded-full overflow-hidden" style="background:rgba(255,255,255,0.06);">' +
        '<div class="h-full rounded-full transition-all duration-700" style="width:' + dpct + '%;background:' + DIM_COLORS[d] + ';transition-delay:' + (d*0.1) + 's;"></div>' +
      '</div>' +
    '</div>';
  }

  // Benchmark data
  var bKey = selectedIndustry || 'default';
  var bench = BENCHMARKS[bKey] || BENCHMARKS['default'];
  var benchLabel = bench.label;
  var benchAvg = bench.avg;
  var benchTop = bench.top25;

  var benchCompare = '';
  if (pct > benchAvg) {
    var ahead = Math.round(((pct - benchAvg) / (100 - benchAvg)) * 100);
    benchCompare = 'You\'re ahead of approximately ' + ahead + '% of ' + benchLabel + ' businesses.';
  } else if (pct < benchAvg) {
    var below = benchAvg - pct;
    benchCompare = 'You\'re ' + below + '% below the ' + benchLabel + ' average — but that\'s fixable.';
  } else {
    benchCompare = 'You\'re right at the ' + benchLabel + ' average. There\'s clear room to move up.';
  }

  // Benchmark bar positions (clamped 0-100)
  var avgPos   = Math.min(100, Math.max(0, benchAvg));
  var top25Pos = Math.min(100, Math.max(0, benchTop));
  var scorePos = Math.min(100, Math.max(0, pct));

  var benchHtml =
    '<div class="rounded-[20px] p-6 border mb-5" style="background:rgba(255,255,255,0.025);border-color:rgba(255,255,255,0.07);">' +
      '<p class="text-[9px] uppercase tracking-[0.18em] font-bold mb-1" style="color:rgba(255,255,255,0.25);">Industry benchmark</p>' +
      '<p class="text-[12px] mb-4" style="color:rgba(255,255,255,0.50);">You scored <strong style="color:#fff;">' + pct + '%</strong> — the ' + benchLabel + ' average is <strong style="color:rgba(255,255,255,0.75);">' + benchAvg + '%</strong></p>' +
      '<div class="relative h-3 rounded-full overflow-visible mb-5" style="background:rgba(255,255,255,0.06);">' +
        // Filled bar to score
        '<div class="absolute left-0 top-0 h-full rounded-full" style="width:' + scorePos + '%;background:linear-gradient(90deg,' + levelColor + '99,' + levelColor + ');transition:width 1s ease;"></div>' +
        // Avg marker
        '<div class="absolute top-1/2 -translate-y-1/2 w-0.5 h-5" style="left:' + avgPos + '%;background:rgba(255,255,255,0.35);transform:translateY(-50%);" title="Industry avg"></div>' +
        // Top 25% marker
        '<div class="absolute top-1/2 -translate-y-1/2 w-0.5 h-5" style="left:' + top25Pos + '%;background:#7B68EE;transform:translateY(-50%);" title="Top 25%"></div>' +
      '</div>' +
      '<div class="flex justify-between text-[9px] mb-3" style="color:rgba(255,255,255,0.30);">' +
        '<span>0%</span>' +
        '<span style="position:relative;left:' + (avgPos - 50) * 0.5 + '%;color:rgba(255,255,255,0.40);">Avg ' + benchAvg + '%</span>' +
        '<span style="color:rgba(123,104,238,0.70);">Top 25% · ' + benchTop + '%</span>' +
        '<span>100%</span>' +
      '</div>' +
      '<p class="text-[11px]" style="color:rgba(255,255,255,0.40);">' + benchCompare + '</p>' +
    '</div>';

  // Roadmap path title
  var nextLevelNames = ['','Manual Business','Automation Aware','Partially Automated','Automation-First','Autonomous Operations'];
  var nextLevelDescs = [
    '',
    'Start small: one automated workflow changes everything.',
    'Connect your tools and let data flow without manual effort.',
    'Unify your automations into a single connected system.',
    'Deploy AI agents to handle exceptions and edge cases.',
    'You\'re already at the top — compound your advantage.',
  ];
  var nextLevel = Math.min(5, level + 1);
  var roadmapHtml = '';
  if (level < 5) {
    roadmapHtml =
      '<div class="mb-3 pb-3 border-b" style="border-color:rgba(255,255,255,0.07);">' +
        '<p class="text-[11px] font-bold mb-0.5" style="color:' + levelColor + ';">Your path: Level ' + level + ' → Level ' + nextLevel + ' · ' + nextLevelNames[nextLevel] + '</p>' +
        '<p class="text-[11px]" style="color:rgba(255,255,255,0.35);">' + nextLevelDescs[nextLevel] + '</p>' +
      '</div>';
  }

  // Actions HTML
  var actHtml = actions.map(function(a, i) {
    return '<div class="flex items-start gap-3" style="animation:am-result-in 0.4s ease-out ' + (0.6 + i*0.1) + 's both;">' +
      '<span class="mt-0.5 shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold" style="background:' + levelColor + '18;color:' + levelColor + ';">' + (i+1) + '</span>' +
      '<p class="text-[12px] leading-relaxed" style="color:rgba(255,255,255,0.65);">' + a + '</p>' +
    '</div>';
  }).join('');

  // Copy score text
  var copyText = 'My Automation Maturity Score: Level ' + level + ' \u2014 ' + levelName + ' (' + pct + '/100)\nAssessed by PURIST | purist.online/pages/automation-maturity';

  // Calculate dimension percentages for radar
  var dimPctsForRadar = [];
  for (var d = 0; d < 5; d++) {
    dimPctsForRadar.push(dimCounts[d] > 0 ? Math.round((dimScores[d]/(dimCounts[d]*3))*100) : 0);
  }

  // Annual cost estimate
  var hrsLost = Math.round(2 + 18 * (1 - pct/100));
  var annualCost = Math.round(hrsLost * 35 * 52 / 100) * 100;
  var annualSaving = Math.round(annualCost * 0.60 / 100) * 100;
  var annualCostHtml =
    '<div class="rounded-[20px] p-5 border mb-4" style="background:rgba(239,68,68,0.04);border-color:rgba(239,68,68,0.18);animation:am-result-in 0.5s ease-out 0.15s both;">' +
      '<p class="text-[9px] uppercase tracking-[0.18em] font-bold mb-3" style="color:rgba(239,68,68,0.55);">Estimated annual manual work cost at your level</p>' +
      '<div class="flex flex-wrap items-end gap-4 mb-3">' +
        '<p class="font-display text-[2rem] text-white leading-none">£' + annualCost.toLocaleString('en-GB') + '<span class="text-sm ml-1 opacity-40">/yr</span></p>' +
        '<p class="text-[11px] pb-1" style="color:rgba(255,255,255,0.35);">~' + hrsLost + 'h/wk lost · £35/hr blended rate</p>' +
      '</div>' +
      '<div class="h-1.5 rounded-full overflow-hidden mb-2" style="background:rgba(239,68,68,0.10);">' +
        '<div class="h-full rounded-full" style="width:' + (100-pct) + '%;background:linear-gradient(90deg,#ef4444,rgba(239,68,68,0.40));transition:width 1.2s ease 0.3s;"></div>' +
      '</div>' +
      '<p class="text-[10px]" style="color:rgba(255,255,255,0.25);">Automating 60% of this returns <strong style="color:rgba(239,68,68,0.75);">£' + annualSaving.toLocaleString('en-GB') + ' back per year</strong></p>' +
    '</div>';

  // Quick wins from 2 weakest dimensions
  var dimPctsRanked = [];
  for (var d = 0; d < 5; d++) dimPctsRanked.push({ d:d, pct:dimPctsForRadar[d] });
  dimPctsRanked.sort(function(a,b){ return a.pct - b.pct; });
  var quickWinsHtml =
    '<div class="rounded-[20px] p-5 border mb-4" style="background:rgba(255,255,255,0.025);border-color:rgba(255,255,255,0.07);animation:am-result-in 0.5s ease-out 0.40s both;">' +
      '<p class="text-[9px] uppercase tracking-[0.18em] font-bold mb-4" style="color:rgba(255,255,255,0.25);">Quick wins — your 2 weakest dimensions</p>' +
      '<div class="space-y-3">';
  [dimPctsRanked[0], dimPctsRanked[1]].forEach(function(dim) {
    var wins = QUICK_WINS_DATA[dim.d];
    quickWinsHtml +=
      '<div class="rounded-[12px] border p-4" style="background:rgba(255,255,255,0.02);border-color:' + DIM_COLORS[dim.d] + '28;">' +
        '<p class="text-[9px] font-bold uppercase tracking-wider mb-2" style="color:' + DIM_COLORS[dim.d] + ';">' + DIM_NAMES[dim.d] + ' · ' + dim.pct + '%</p>' +
        '<p class="text-[11px] leading-relaxed" style="color:rgba(255,255,255,0.55);">→ ' + wins[0] + '</p>' +
        '<p class="text-[11px] leading-relaxed mt-1.5" style="color:rgba(255,255,255,0.55);">→ ' + wins[1] + '</p>' +
      '</div>';
  });
  quickWinsHtml += '</div></div>';

  res.innerHTML = '<div class="max-w-2xl mx-auto" style="animation:am-result-in 0.5s ease-out;">' +

    // Score hero + radar chart
    '<div class="rounded-[24px] p-6 border mb-4 relative overflow-hidden" style="background:rgba(255,255,255,0.025);border-color:rgba(255,255,255,0.07);">' +
      '<div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 50% 0%,' + levelColor + '10 0%,transparent 60%);"></div>' +
      '<p class="text-[9px] uppercase tracking-[0.22em] font-bold mb-5 text-center relative" style="color:' + levelColor + 'AA;">Your automation maturity score</p>' +
      '<div class="grid md:grid-cols-2 gap-6 items-center relative">' +

        // Left: ring + level
        '<div class="text-center">' +
          '<div class="relative inline-flex items-center justify-center w-28 h-28 mx-auto mb-4">' +
            '<svg class="absolute inset-0 w-full h-full -rotate-90" viewBox="0 0 100 100">' +
              '<circle cx="50" cy="50" r="44" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="8"/>' +
              '<circle cx="50" cy="50" r="44" fill="none" stroke="' + levelColor + '" stroke-width="8" stroke-linecap="round" stroke-dasharray="276.46" stroke-dashoffset="' + (276.46 - (276.46 * pct / 100)) + '" style="transition:stroke-dashoffset 1.5s ease;"/>' +
            '</svg>' +
            '<div class="text-center">' +
              '<p class="font-display text-3xl leading-none" style="color:' + levelColor + ';">' + pct + '</p>' +
              '<p class="text-[8px] uppercase tracking-wider mt-0.5" style="color:rgba(255,255,255,0.25);">/ 100</p>' +
            '</div>' +
          '</div>' +
          '<p class="font-display text-xl text-white mb-1">Level ' + level + ' · ' + levelName + '</p>' +
          '<p class="text-[12px] max-w-[220px] mx-auto leading-relaxed" style="color:rgba(255,255,255,0.40);">' + levelDesc + '</p>' +
        '</div>' +

        // Right: radar chart
        '<div>' +
          '<p class="text-[8px] uppercase tracking-[0.16em] font-bold text-center mb-3" style="color:rgba(255,255,255,0.20);">5-dimension breakdown</p>' +
          buildRadar(dimPctsForRadar) +
        '</div>' +

      '</div>' +
    '</div>' +

    // Annual cost estimate
    annualCostHtml +

    // Benchmark
    '<div style="animation:am-result-in 0.5s ease-out 0.25s both;">' + benchHtml + '</div>' +

    // Dimension breakdown bars
    '<div class="rounded-[20px] p-5 border mb-4" style="background:rgba(255,255,255,0.025);border-color:rgba(255,255,255,0.07);animation:am-result-in 0.5s ease-out 0.35s both;">' +
      '<p class="text-[9px] uppercase tracking-[0.18em] font-bold mb-5" style="color:rgba(255,255,255,0.25);">Score by dimension</p>' +
      '<div class="space-y-4">' + dimHtml + '</div>' +
    '</div>' +

    // Quick wins
    quickWinsHtml +

    // Actions with roadmap path header
    '<div class="rounded-[20px] p-5 border mb-4" style="background:rgba(255,255,255,0.025);border-color:rgba(255,255,255,0.07);animation:am-result-in 0.5s ease-out 0.50s both;">' +
      roadmapHtml +
      '<p class="text-[9px] uppercase tracking-[0.18em] font-bold mb-5" style="color:rgba(255,255,255,0.25);">Your 3 highest-impact next actions</p>' +
      '<div class="space-y-3">' + actHtml + '</div>' +
    '</div>' +

    // CTA
    '<div class="rounded-[20px] p-6 border mb-4 text-center" style="background:rgba(232,180,176,0.04);border-color:rgba(232,180,176,0.15);animation:am-result-in 0.5s ease-out 0.60s both;">' +
      '<p class="text-[13px] mb-2 text-white font-medium">Want a personalised roadmap for Level ' + level + ' → Level ' + Math.min(5,level+1) + '?</p>' +
      '<p class="text-[11px] mb-5" style="color:rgba(255,255,255,0.35);">In 45 minutes, we\'ll map your exact workflow gaps and show you the 3 automations that will move your score the most.</p>' +
      '<a href="/pages/welcome" class="inline-flex items-center justify-center gap-2 w-full py-3.5 rounded-button text-[13px] font-bold transition mb-2" style="background:#E8B4B0;color:#0A0A0A;">Book my free automation audit →</a>' +
      '<button onclick="amCopyScore()" id="am-copy-btn" class="text-[11px] w-full py-2.5 rounded-[10px] border mt-2 transition font-medium" style="color:rgba(255,255,255,0.50);border-color:rgba(255,255,255,0.10);background:rgba(255,255,255,0.03);">Copy my score</button>' +
      '<button onclick="amRestart()" class="text-[11px] w-full text-center mt-2 transition" style="color:rgba(255,255,255,0.25);">Retake the assessment</button>' +
    '</div>' +

  '</div>';

  // Store copy text on window for the button
  window._amCopyText = copyText;

  // Animate the circle
  setTimeout(function() {
    var circle = res.querySelector('circle:last-child');
    if (circle) {
      circle.style.strokeDashoffset = (276.46 - (276.46 * pct / 100));
    }
  }, 100);
}

window.amCopyScore = function() {
  var btn = document.getElementById('am-copy-btn');
  if (!btn) return;
  var text = window._amCopyText || '';
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(text).then(function() {
      btn.textContent = 'Copied!';
      btn.style.color = '#7B68EE';
      btn.style.borderColor = 'rgba(123,104,238,0.40)';
      setTimeout(function(){ btn.textContent = 'Copy my score'; btn.style.color='rgba(255,255,255,0.50)'; btn.style.borderColor='rgba(255,255,255,0.10)'; }, 2000);
    });
  } else {
    // Fallback
    var ta = document.createElement('textarea');
    ta.value = text; ta.style.position='fixed'; ta.style.opacity='0';
    document.body.appendChild(ta); ta.select();
    try { document.execCommand('copy'); } catch(e) {}
    document.body.removeChild(ta);
    btn.textContent = 'Copied!';
    btn.style.color = '#7B68EE';
    setTimeout(function(){ btn.textContent = 'Copy my score'; btn.style.color='rgba(255,255,255,0.50)'; }, 2000);
  }
};

window.amRestart = function() {
  answers = [];
  current = 0;
  selectedIndustry = null;
  document.getElementById('am-result').classList.add('hidden');
  document.getElementById('am-question-wrap').classList.remove('hidden');
  renderIndustrySelect();
};

document.addEventListener('astro:page-load', function(){
  answers = [];
  current = 0;
  selectedIndustry = null;
  renderIndustrySelect();
});

renderIndustrySelect();

})();
</script>
