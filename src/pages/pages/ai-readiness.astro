<style>
  @keyframes rq-pulse { 0%,100%{opacity:0.5;transform:scale(1)} 50%{opacity:1;transform:scale(1.4)} }
  .quiz-opt.selected { background:#0A0A0A; color:#fff; border-color:#0A0A0A; }
  .quiz-opt:focus { outline: 2px solid #E8B4B0; outline-offset: 2px; }
</style>

<script is:inline>
(function () {
  var answers = {};
  var totalSteps = 8;

  // Industry data: [avg score, top-25% score, label, avg_hours_saved, testimonial text, testimonial attr]
  var IND_DATA = {
    1: [68, 82, 'Dental / Medical', 18, '"We went from 23 hours of manual work per week to 4. The first automation paid for itself in 11 days."', '— Dental practice, Sydney · Score: 74/100'],
    2: [55, 72, 'Real Estate', 12, '"Rent statements, viewing reminders, and lease renewals — all automated in 3 weeks. Saved my whole Monday."', '— Property manager, London · Score: 61/100'],
    3: [60, 76, 'Agency / Creative', 14, '"Client onboarding went from 2 hours to 8 minutes. Our clients think we\'re magic."', '— Creative agency, Manchester · Score: 67/100'],
    4: [63, 79, 'E-commerce', 16, '"Order processing, reviews, restock alerts — all automated. Revenue up 22% on the same headcount."', '— E-commerce brand, Auckland · Score: 71/100'],
    5: [58, 75, 'SaaS / Tech', 11, '"Churn early warning and trial-to-paid flows. Saved a net churn of £42k in the first quarter."', '— SaaS founder, Dublin · Score: 65/100'],
    6: [52, 70, 'Finance', 10, '"Month-end reporting dropped from 2 days to 4 hours. Auditors love the clean data trail too."', '— Finance firm, Singapore · Score: 59/100'],
    7: [57, 73, 'Law Firm', 12, '"Court deadline tracking and client status emails. Freed up 12 hours every week for billable work."', '— Law firm, Melbourne · Score: 63/100'],
    8: [58, 74, 'Business', 14, '"First automation was a simple lead follow-up sequence. Closed 3 extra deals in month one."', '— Consulting firm, Cape Town · Score: 62/100'],
  };

  // Team-size multiplier for ROI calc [hrs_week, blended_rate]
  var TEAM_HRS = { 1: 5, 2: 12, 3: 22, 4: 35 };

  var RECS = {
    1: [
      { text: 'Lead capture → CRM sync', saving: '4h/wk' },
      { text: 'Proposal follow-up sequence', saving: '3h/wk' },
      { text: 'Invoice chase automation', saving: '5h/wk' },
    ],
    2: [
      { text: 'Rent statement automation', saving: '4h/wk' },
      { text: 'Viewing reminder sequences', saving: '3h/wk' },
      { text: 'Offer letter generation', saving: '2h/wk' },
    ],
    3: [
      { text: 'Client report automation', saving: '5h/wk' },
      { text: 'Invoice generation pipeline', saving: '3h/wk' },
      { text: 'New client onboarding sequence', saving: '6h/wk' },
    ],
    4: [
      { text: 'Order processing automation', saving: '7h/wk' },
      { text: 'Inventory sync across channels', saving: '4h/wk' },
      { text: 'Review request sequences', saving: '2h/wk' },
    ],
    5: [
      { text: 'Trial-to-paid conversion flows', saving: '∞ value' },
      { text: 'Churn risk early warning', saving: '∞ value' },
      { text: 'Failed payment recovery', saving: '3h/wk' },
    ],
    6: [
      { text: 'Budget variance alerts', saving: '3h/wk' },
      { text: 'Month-end close automation', saving: '8h/wk' },
      { text: 'Expense approval workflow', saving: '4h/wk' },
    ],
    7: [
      { text: 'Court deadline tracking', saving: '3h/wk' },
      { text: 'Document drafting automation', saving: '5h/wk' },
      { text: 'Client status update emails', saving: '4h/wk' },
    ],
    8: [
      { text: 'Support ticket triage + AI routing', saving: '10h/wk' },
      { text: 'CSAT survey pipeline', saving: '3h/wk' },
      { text: 'Onboarding sequence automation', saving: '6h/wk' },
    ],
  };

  function updateProgress(step) {
    var pct = Math.round(((step - 1) / totalSteps) * 100);
    document.getElementById('q-bar').style.width = pct + '%';
    document.getElementById('q-pct').textContent = pct + '%';
    document.getElementById('q-label').textContent = 'Question ' + step + ' of ' + totalSteps;
  }

  function showStep(step) {
    document.querySelectorAll('.quiz-step').forEach(function (el) { el.classList.add('hidden'); });
    var next = document.querySelector('.quiz-step[data-step="' + step + '"]');
    if (next) { next.classList.remove('hidden'); updateProgress(step); }
    else { showResult(); }
  }

  document.querySelectorAll('.quiz-opt').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var step = parseInt(this.dataset.step);
      var val  = parseInt(this.dataset.val);
      answers[step] = val;

      document.querySelectorAll('.quiz-opt[data-step="' + step + '"]').forEach(function (b) { b.classList.remove('selected'); });
      this.classList.add('selected');

      setTimeout(function () { showStep(step + 1); }, 220);
    });
  });

  function calcScore() {
    var maxes   = [4,8,4,4,4,4,5,4];
    var weights = [10,5,25,15,20,10,10,5];
    var score = 0;
    for (var q = 1; q <= totalSteps; q++) {
      var ans = answers[q] || 1;
      var max = maxes[q-1];
      var norm = Math.min(ans / Math.min(max, 4), 1);
      score += norm * weights[q-1];
    }
    return Math.round(Math.min(score, 100));
  }

  function fmt(n) {
    return n >= 1000 ? '£' + Math.round(n/1000) + 'k' : '£' + n;
  }

  function showResult() {
    document.getElementById('q-bar').style.width = '100%';
    document.getElementById('q-pct').textContent = '100%';
    document.getElementById('q-label').textContent = 'Complete';
    document.getElementById('quiz-container').classList.add('hidden');
    document.getElementById('quiz-result').classList.remove('hidden');

    var score = calcScore();
    var ind   = answers[2] || 1;
    var indData = IND_DATA[ind] || IND_DATA[8];

    // Score arc animate
    setTimeout(function () {
      var offset = 364 - (score / 100) * 364;
      document.getElementById('score-arc').style.strokeDashoffset = offset;
      // Peer avg arc
      var peerOffset = 364 - (indData[0] / 100) * 364;
      document.getElementById('peer-arc').style.strokeDashoffset = peerOffset;
      // Count-up
      var el = document.getElementById('score-val');
      var el2 = document.getElementById('score-val-2');
      var start = null;
      function step(ts) {
        if (!start) start = ts;
        var p = Math.min((ts - start) / 1200, 1);
        var v = Math.round(p * score);
        el.textContent = v;
        el2.textContent = v;
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }, 100);

    var title, desc, color;
    if (score >= 75) {
      title = 'Automation-Ready'; desc = 'Your operations are complex, your manual load is high, and your team is ripe for transformation. You should see 10–18h/wk reclaimed within the first month.'; color = '#E8B4B0';
    } else if (score >= 50) {
      title = 'High Potential'; desc = 'Significant manual work and tool fragmentation mean automation will deliver fast, measurable impact. Most clients at this level save 8–14h/wk.'; color = '#C89840';
    } else if (score >= 25) {
      title = 'Good Foundation'; desc = 'You have some processes worth automating now. Start with your top 3 workflows and expand as you see results. Expect 4–8h/wk saved initially.'; color = '#2D5016';
    } else {
      title = 'Early Stage'; desc = 'You\'re earlier in your automation journey. A free audit will identify your first quick win — even one automation often saves 3–5h/wk immediately.'; color = '#7B68EE';
    }

    document.getElementById('score-title').textContent = title;
    document.getElementById('score-desc').textContent = desc;
    document.getElementById('score-arc').style.stroke = color;

    // Peer pill
    var peerPct = score > indData[0] ? 'above' : 'below';
    var peerDiff = Math.abs(score - indData[0]);
    document.getElementById('peer-pill').textContent = peerDiff === 0
      ? 'Exactly at your industry average'
      : 'You score ' + peerDiff + ' pts ' + peerPct + ' the ' + indData[2] + ' average';

    // Industry benchmark
    document.getElementById('ind-badge').textContent = indData[2];
    document.getElementById('ind-avg').textContent = indData[0] + '/100';
    document.getElementById('ind-top').textContent = indData[1] + '/100';
    document.getElementById('bench-bar').style.width = score + '%';
    document.getElementById('avg-marker').style.left = indData[0] + '%';
    var rel = score >= indData[1]
      ? 'You\'re in the top 25% of ' + indData[2] + ' businesses.'
      : score >= indData[0]
      ? 'You\'re above average for ' + indData[2] + '. Top 25% starts at ' + indData[1] + '/100.'
      : 'You\'re below the ' + indData[2] + ' average. Automation will close this gap fast.';
    document.getElementById('bench-label').textContent = rel;

    // ROI Projection
    var teamIdx = answers[1] || 1;
    var manualHrs = answers[3] || 1;
    var hrsMap = { 1: 3, 2: 10, 3: 22, 4: 35 };
    var weekHrs = hrsMap[manualHrs] || 10;
    var rate = 35;
    var annualCost = Math.round(weekHrs * rate * 52);
    var savingPct = [0.50, 0.65, 0.72, 0.80][manualHrs - 1] || 0.65;
    var annualSaving = Math.round(annualCost * savingPct);
    var invEst = 2400; // rough PURIST engagement cost
    var roiMult = Math.round((annualSaving / invEst) * 10) / 10;
    document.getElementById('roi-cost').textContent = fmt(annualCost) + '/yr';
    document.getElementById('roi-saving').textContent = fmt(annualSaving) + '/yr';
    document.getElementById('roi-multiple').textContent = roiMult + '×';

    // Breakdown bars
    var breakdown = [
      { label: 'Manual work volume',  score: Math.min(100, (answers[3]||1) * 25), color: '#E8B4B0', context: 'How much time is at stake — the bigger the number, the faster your payback.' },
      { label: 'Error & rework cost', score: Math.min(100, (answers[5]||1) * 25), color: '#C89840', context: 'Data errors create compounding downstream costs: re-work, refunds, lost trust.' },
      { label: 'Tool fragmentation',  score: Math.min(100, (answers[4]||1) * 25), color: '#7B68EE', context: 'More disconnected tools = more manual handoffs, more errors, more time lost.' },
      { label: 'Automation maturity', score: Math.min(100, (answers[6]||1) * 25), color: '#2D5016', context: 'Higher maturity means faster deployment — you already understand the concepts.' },
    ];
    var bkEl = document.getElementById('score-breakdown');
    bkEl.innerHTML = '';
    breakdown.forEach(function (b) {
      bkEl.innerHTML += '<div class="bg-white rounded-[12px] border border-brand-gray-100 p-4">' +
        '<div class="flex items-center justify-between mb-2"><span class="text-[12px] font-semibold text-brand-black">' + b.label + '</span><span class="text-[13px] font-bold" style="color:' + b.color + ';">' + b.score + '%</span></div>' +
        '<div class="h-1.5 bg-brand-gray-100 rounded-full overflow-hidden mb-2"><div class="h-full rounded-full transition-all duration-700" style="width:0%;background:' + b.color + ';" data-target="' + b.score + '"></div></div>' +
        '<p class="text-[10px] text-brand-gray-500 leading-snug">' + b.context + '</p>' +
        '</div>';
    });
    setTimeout(function () {
      bkEl.querySelectorAll('[data-target]').forEach(function (bar) { bar.style.width = bar.dataset.target + '%'; });
    }, 300);

    // Recommendations
    var recs = RECS[ind] || RECS[1];
    var recsEl = document.getElementById('score-recs-list');
    recsEl.innerHTML = '';
    recs.forEach(function (r) {
      recsEl.innerHTML += '<li class="flex items-start gap-3">' +
        '<span class="mt-0.5 w-5 h-5 rounded-full flex items-center justify-center shrink-0 text-white text-[10px]" style="background:#2D5016;">✓</span>' +
        '<div><span class="text-sm font-medium text-brand-black">' + r.text + '</span>' +
        '<span class="ml-2 text-[10px] font-bold px-2 py-0.5 rounded-full" style="background:rgba(45,80,22,0.10);color:#2D5016;">' + r.saving + '</span></div>' +
        '</li>';
    });

    // Testimonial
    document.getElementById('testimonial-text').textContent = indData[4];
    document.getElementById('testimonial-attr').textContent = indData[5];
  }

  document.getElementById('retake-btn').addEventListener('click', function () {
    answers = {};
    document.querySelectorAll('.quiz-opt').forEach(function (b) { b.classList.remove('selected'); });
    document.getElementById('quiz-result').classList.add('hidden');
    document.getElementById('quiz-container').classList.remove('hidden');
    showStep(1);
  });

  updateProgress(1);
})();
</script>
