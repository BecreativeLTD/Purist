---
import ShopLayout from '~/layouts/ShopLayout.astro';
---

<ShopLayout
  title="Automation & AI Agency Services | PURIST"
  description="Production-grade workflow automation and AI agent services for UK businesses. n8n agency, automation consultancy, AI agent development and Zapier migration. Free audit."
  canonical="https://www.purist.online/pages/services"
>

<script type="application/ld+json" is:inline>{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "PURIST — Business Automation & AI Agent Services",
  "description": "Production-grade workflow automation and AI agent development for UK businesses. 500+ deployments. Free audit.",
  "url": "https://www.purist.online/pages/services",
  "provider": { "@type": "Organization", "name": "PURIST", "url": "https://www.purist.online" },
  "areaServed": ["GB", "US", "EU"],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "PURIST Service Catalogue",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "n8n Agency UK", "url": "https://www.purist.online/pages/n8n-agency" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Automation Consultant", "url": "https://www.purist.online/pages/automation-consultant" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Workflow Automation Services", "url": "https://www.purist.online/pages/workflow-automation-services" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AI Agent Development", "url": "https://www.purist.online/pages/ai-agent-development" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Zapier Alternative Agency", "url": "https://www.purist.online/pages/zapier-alternative-agency" }}
    ]
  }
})}</script>

<style>
  .service-card:hover .service-card-inner {
    transform: translateY(-3px);
    box-shadow: 0 16px 48px rgba(10,10,10,0.12);
  }
  .service-card-inner {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  @media (max-width: 767px) {
    .services-grid { grid-template-columns: 1fr !important; }
    .hero-stats { gap: 1.5rem !important; }
    .hero-h1 { font-size: 2rem !important; }
  }
</style>

<!-- ── HERO ── -->
<section style="background:#0A0A0A;padding:5rem 0 4.5rem;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;pointer-events:none;">
    <div style="position:absolute;top:-20%;right:-10%;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(232,180,176,0.06) 0%,transparent 70%);"></div>
    <div style="position:absolute;bottom:-10%;left:-5%;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(232,180,176,0.04) 0%,transparent 70%);"></div>
  </div>
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:1;text-align:center;">

    <!-- Breadcrumb -->
    <nav style="display:flex;justify-content:center;gap:8px;align-items:center;margin-bottom:2rem;">
      <a href="/" style="font-size:10px;color:rgba(255,255,255,0.28);text-decoration:none;letter-spacing:0.08em;">Home</a>
      <span style="color:rgba(255,255,255,0.15);font-size:10px;">/</span>
      <span style="font-size:10px;color:rgba(255,255,255,0.45);letter-spacing:0.08em;">Services</span>
    </nav>

    <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.3rem 0.875rem;border-radius:999px;border:1px solid rgba(232,180,176,0.25);background:rgba(232,180,176,0.06);margin-bottom:1.5rem;">
      <span style="width:5px;height:5px;border-radius:50%;background:#E8B4B0;display:inline-block;"></span>
      <span style="font-size:9.5px;text-transform:uppercase;letter-spacing:0.2em;font-weight:600;color:rgba(232,180,176,0.8);">500+ Businesses Automated · 99.97% Uptime SLA</span>
    </div>

    <h1 class="hero-h1" style="font-family:Georgia,serif;font-size:clamp(2rem,5vw,3.5rem);line-height:1.08;letter-spacing:-0.028em;color:#F8F6F1;margin-bottom:1.25rem;max-width:820px;margin-left:auto;margin-right:auto;">
      Every Service We Offer.<br/>
      <em style="font-style:italic;color:#E8B4B0;">One Team. One Deployment.</em>
    </h1>
    <p style="font-size:1.0625rem;line-height:1.75;color:rgba(248,246,241,0.48);max-width:580px;margin:0 auto 3rem;">
      From your first workflow audit to a fully autonomous operation stack — PURIST handles every layer of your automation. Pick the service that fits where you are today.
    </p>

    <!-- Stats row -->
    <div class="hero-stats" style="display:flex;flex-wrap:wrap;justify-content:center;gap:3rem;">
      {[['500+','Workflows in production'],['7 days','Avg. deployment time'],['14h','Saved per client / week'],['9.4×','Average ROI in 60 days']].map(([n,l]) => (
        <div>
          <p style="font-family:Georgia,serif;font-size:1.875rem;line-height:1;color:#E8B4B0;margin-bottom:0.3rem;">{n}</p>
          <p style="font-size:9.5px;text-transform:uppercase;letter-spacing:0.14em;color:rgba(248,246,241,0.28);">{l}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── TOP RULE ── -->
<div style="background:#F8F6F1;padding:0.75rem 0;border-bottom:1px solid rgba(10,10,10,0.06);">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;display:flex;flex-wrap:wrap;gap:1.5rem;align-items:center;justify-content:center;">
    {['n8n Certified','Make Certified','Zapier Certified','Claude AI Partner','ISO-aligned processes'].map(b => (
      <span style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.14em;color:rgba(10,10,10,0.35);">{b}</span>
    ))}
  </div>
</div>

<!-- ── 5 SERVICE CARDS ── -->
<section style="background:#F8F6F1;padding:5rem 0;">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">

    <div style="max-width:640px;margin:0 auto 3.5rem;text-align:center;">
      <p style="font-size:9.5px;text-transform:uppercase;letter-spacing:0.22em;font-weight:600;color:rgba(10,10,10,0.3);margin-bottom:0.625rem;">Our expertise</p>
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.6rem,3.5vw,2.4rem);color:#0A0A0A;letter-spacing:-0.02em;margin-bottom:1rem;">Five specialist services.<br/>One seamless operation.</h2>
      <p style="font-size:0.9375rem;line-height:1.75;color:rgba(10,10,10,0.5);">Each service is a distinct entry point depending on where your business is in the automation journey — from first audit to full AI agent stack.</p>
    </div>

    <div class="services-grid" style="display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;">

      <!-- Card 1 — n8n Agency -->
      <a href="/pages/n8n-agency" class="service-card" style="text-decoration:none;display:block;">
        <div class="service-card-inner" style="background:#0A0A0A;border-radius:20px;overflow:hidden;height:100%;">
          <!-- Accent bar -->
          <div style="height:3px;background:linear-gradient(90deg,#E8B4B0,rgba(232,180,176,0.3));"></div>
          <div style="padding:2rem 2rem 2.5rem;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.5rem;">
              <div style="width:44px;height:44px;border-radius:12px;background:rgba(232,180,176,0.1);border:1px solid rgba(232,180,176,0.2);display:flex;align-items:center;justify-content:center;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h4M9 15h6"/></svg>
              </div>
              <span style="font-size:9px;text-transform:uppercase;letter-spacing:0.18em;font-weight:700;padding:4px 10px;border-radius:999px;background:rgba(232,180,176,0.1);color:#E8B4B0;">Most Popular</span>
            </div>
            <p style="font-size:9.5px;text-transform:uppercase;letter-spacing:0.18em;font-weight:600;color:rgba(232,180,176,0.5);margin-bottom:0.5rem;">n8n Development</p>
            <h3 style="font-family:Georgia,serif;font-size:1.4rem;color:#F8F6F1;margin-bottom:0.875rem;letter-spacing:-0.015em;line-height:1.2;">n8n Agency UK</h3>
            <p style="font-size:0.875rem;line-height:1.7;color:rgba(248,246,241,0.45);margin-bottom:1.5rem;">Production-grade n8n workflows built by certified engineers. Architecture, custom nodes, 24/7 monitoring and full documentation — deployed in 7 days.</p>
            <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.75rem;">
              {['Custom workflows','Error handling','99.97% uptime','24/7 monitoring'].map(t => (
                <span style="font-size:10px;padding:3px 9px;border-radius:999px;border:1px solid rgba(232,180,176,0.15);color:rgba(248,246,241,0.4);">{t}</span>
              ))}
            </div>
            <div style="display:flex;align-items:center;gap:0.5rem;color:#E8B4B0;font-size:0.875rem;font-weight:600;">
              Learn more <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Card 2 — Automation Consultant -->
      <a href="/pages/automation-consultant" class="service-card" style="text-decoration:none;display:block;">
        <div class="service-card-inner" style="background:white;border:1px solid rgba(10,10,10,0.08);border-radius:20px;overflow:hidden;height:100%;">
          <div style="height:3px;background:linear-gradient(90deg,#0A0A0A,rgba(10,10,10,0.15));"></div>
          <div style="padding:2rem 2rem 2.5rem;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.5rem;">
              <div style="width:44px;height:44px;border-radius:12px;background:rgba(10,10,10,0.04);border:1px solid rgba(10,10,10,0.08);display:flex;align-items:center;justify-content:center;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 8v4l3 3"/></svg>
              </div>
              <span style="font-size:9px;text-transform:uppercase;letter-spacing:0.18em;font-weight:700;padding:4px 10px;border-radius:999px;background:rgba(74,222,128,0.1);color:#2D5016;">Free First</span>
            </div>
            <p style="font-size:9.5px;text-transform:uppercase;letter-spacing:0.18em;font-weight:600;color:rgba(10,10,10,0.3);margin-bottom:0.5rem;">Strategy & Audit</p>
            <h3 style="font-family:Georgia,serif;font-size:1.4rem;color:#0A0A0A;margin-bottom:0.875rem;letter-spacing:-0.015em;line-height:1.2;">Automation Consultant</h3>
            <p style="font-size:0.875rem;line-height:1.7;color:rgba(10,10,10,0.5);margin-bottom:1.5rem;">30-min free workflow audit. We map your operations, calculate the exact hours being wasted and produce a written ROI blueprint — before you spend a penny.</p>
            <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.75rem;">
              {['Free audit','ROI blueprint','Workflow mapping','48h turnaround'].map(t => (
                <span style="font-size:10px;padding:3px 9px;border-radius:999px;border:1px solid rgba(10,10,10,0.1);color:rgba(10,10,10,0.4);">{t}</span>
              ))}
            </div>
            <div style="display:flex;align-items:center;gap:0.5rem;color:#0A0A0A;font-size:0.875rem;font-weight:600;">
              Learn more <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Card 3 — Workflow Automation Services -->
      <a href="/pages/workflow-automation-services" class="service-card" style="text-decoration:none;display:block;">
        <div class="service-card-inner" style="background:white;border:1px solid rgba(10,10,10,0.08);border-radius:20px;overflow:hidden;height:100%;">
          <div style="height:3px;background:linear-gradient(90deg,#0A0A0A,rgba(10,10,10,0.15));"></div>
          <div style="padding:2rem 2rem 2.5rem;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.5rem;">
              <div style="width:44px;height:44px;border-radius:12px;background:rgba(10,10,10,0.04);border:1px solid rgba(10,10,10,0.08);display:flex;align-items:center;justify-content:center;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
              </div>
              <span style="font-size:9px;text-transform:uppercase;letter-spacing:0.18em;font-weight:700;padding:4px 10px;border-radius:999px;background:rgba(10,10,10,0.05);color:rgba(10,10,10,0.45);">End-to-end</span>
            </div>
            <p style="font-size:9.5px;text-transform:uppercase;letter-spacing:0.18em;font-weight:600;color:rgba(10,10,10,0.3);margin-bottom:0.5rem;">Full Service</p>
            <h3 style="font-family:Georgia,serif;font-size:1.4rem;color:#0A0A0A;margin-bottom:0.875rem;letter-spacing:-0.015em;line-height:1.2;">Workflow Automation Services</h3>
            <p style="font-size:0.875rem;line-height:1.7;color:rgba(10,10,10,0.5);margin-bottom:1.5rem;">From discovery to deployment in 5–10 days. 12 core workflow categories. n8n, Make, Zapier and Claude AI — whichever stack suits your operation.</p>
            <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.75rem;">
              {['n8n · Make · Zapier','12 workflow types','5–10 day deploy','Full handoff'].map(t => (
                <span style="font-size:10px;padding:3px 9px;border-radius:999px;border:1px solid rgba(10,10,10,0.1);color:rgba(10,10,10,0.4);">{t}</span>
              ))}
            </div>
            <div style="display:flex;align-items:center;gap:0.5rem;color:#0A0A0A;font-size:0.875rem;font-weight:600;">
              Learn more <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Card 4 — AI Agent Development -->
      <a href="/pages/ai-agent-development" class="service-card" style="text-decoration:none;display:block;">
        <div class="service-card-inner" style="background:#0A0A0A;border-radius:20px;overflow:hidden;height:100%;">
          <div style="height:3px;background:linear-gradient(90deg,#E8B4B0,rgba(232,180,176,0.3));"></div>
          <div style="padding:2rem 2rem 2.5rem;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.5rem;">
              <div style="width:44px;height:44px;border-radius:12px;background:rgba(232,180,176,0.1);border:1px solid rgba(232,180,176,0.2);display:flex;align-items:center;justify-content:center;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
              </div>
              <span style="font-size:9px;text-transform:uppercase;letter-spacing:0.18em;font-weight:700;padding:4px 10px;border-radius:999px;background:rgba(232,180,176,0.1);color:#E8B4B0;">Claude AI</span>
            </div>
            <p style="font-size:9.5px;text-transform:uppercase;letter-spacing:0.18em;font-weight:600;color:rgba(232,180,176,0.5);margin-bottom:0.5rem;">Intelligence Layer</p>
            <h3 style="font-family:Georgia,serif;font-size:1.4rem;color:#F8F6F1;margin-bottom:0.875rem;letter-spacing:-0.015em;line-height:1.2;">AI Agent Development</h3>
            <p style="font-size:0.875rem;line-height:1.7;color:rgba(248,246,241,0.45);margin-bottom:1.5rem;">Custom Claude AI agents for lead qualification, support triage, document processing and smart scheduling — integrated into your existing CRM and tools.</p>
            <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.75rem;">
              {['Claude AI','Lead qualification','Support agents','Free POC'].map(t => (
                <span style="font-size:10px;padding:3px 9px;border-radius:999px;border:1px solid rgba(232,180,176,0.15);color:rgba(248,246,241,0.4);">{t}</span>
              ))}
            </div>
            <div style="display:flex;align-items:center;gap:0.5rem;color:#E8B4B0;font-size:0.875rem;font-weight:600;">
              Learn more <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Card 5 — Zapier Alternative (full width) -->
      <a href="/pages/zapier-alternative-agency" class="service-card" style="text-decoration:none;display:block;grid-column:1/-1;">
        <div class="service-card-inner" style="background:white;border:1px solid rgba(10,10,10,0.08);border-radius:20px;overflow:hidden;">
          <div style="height:3px;background:linear-gradient(90deg,#0A0A0A,rgba(10,10,10,0.15));"></div>
          <div style="padding:2rem 2.5rem;display:grid;grid-template-columns:1fr auto;gap:2rem;align-items:center;">
            <div>
              <div style="display:flex;align-items:center;gap:0.875rem;margin-bottom:1rem;">
                <div style="width:44px;height:44px;border-radius:12px;background:rgba(10,10,10,0.04);border:1px solid rgba(10,10,10,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
                <div>
                  <p style="font-size:9.5px;text-transform:uppercase;letter-spacing:0.18em;font-weight:600;color:rgba(10,10,10,0.3);">Migration</p>
                  <h3 style="font-family:Georgia,serif;font-size:1.4rem;color:#0A0A0A;letter-spacing:-0.015em;line-height:1.2;">Switch From Zapier to n8n</h3>
                </div>
              </div>
              <p style="font-size:0.875rem;line-height:1.7;color:rgba(10,10,10,0.5);max-width:560px;">n8n costs 70% less than Zapier with no task limits. We migrate your entire Zapier stack — every zap, every trigger, every action — to n8n in under 14 days, with zero downtime.</p>
              <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:1rem;">
                {['70% cost saving','14-day migration','Zero downtime','Full zap mapping'].map(t => (
                  <span style="font-size:10px;padding:3px 9px;border-radius:999px;border:1px solid rgba(10,10,10,0.1);color:rgba(10,10,10,0.4);">{t}</span>
                ))}
              </div>
            </div>
            <div style="text-align:center;flex-shrink:0;">
              <div style="background:#0A0A0A;border-radius:14px;padding:1.25rem 2rem;">
                <p style="font-family:Georgia,serif;font-size:2rem;color:#E8B4B0;margin-bottom:0.25rem;">70%</p>
                <p style="font-size:9px;text-transform:uppercase;letter-spacing:0.14em;color:rgba(248,246,241,0.3);">Cost saving vs Zapier</p>
              </div>
            </div>
          </div>
        </div>
      </a>

    </div>
  </div>
</section>

<!-- ── HOW IT CONNECTS ── -->
<section style="background:#0A0A0A;padding:5rem 0;">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <div style="max-width:640px;margin:0 auto 3.5rem;text-align:center;">
      <p style="font-size:9.5px;text-transform:uppercase;letter-spacing:0.22em;font-weight:600;color:rgba(232,180,176,0.4);margin-bottom:0.625rem;">The journey</p>
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.6rem,3.5vw,2.4rem);color:#F8F6F1;letter-spacing:-0.02em;margin-bottom:1rem;">From audit to autonomous operation</h2>
      <p style="font-size:0.9375rem;line-height:1.75;color:rgba(248,246,241,0.38);">Most clients start with the free audit and graduate to a full automation stack within 90 days.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:0;position:relative;">
      {[
        { step:'01', label:'Free Audit', desc:'Map your workflows. Identify waste. Get a written ROI estimate.', href:'/pages/automation-consultant', color:'#E8B4B0' },
        { step:'02', label:'Workflow Build', desc:'12 core workflows deployed in 5–10 days on your stack.', href:'/pages/workflow-automation-services', color:'#E8B4B0' },
        { step:'03', label:'n8n Infrastructure', desc:'Dedicated instance, monitoring, docs and training.', href:'/pages/n8n-agency', color:'#E8B4B0' },
        { step:'04', label:'AI Agents', desc:'Claude AI layer handles qualification, support and scheduling.', href:'/pages/ai-agent-development', color:'#E8B4B0' },
        { step:'05', label:'Autonomous Ops', desc:'Your business runs itself. You scale. We monitor.', href:'/pages/welcome', color:'#E8B4B0' },
      ].map(({ step, label, desc, href, color }, i) => (
        <a href={href} style="text-decoration:none;padding:2rem 1.5rem;border-left:1px solid rgba(232,180,176,0.08);position:relative;display:block;transition:background 0.2s;" onmouseover="this.style.background='rgba(232,180,176,0.04)'" onmouseout="this.style.background='transparent'">
          <p style={`font-family:Georgia,serif;font-size:3rem;line-height:1;color:rgba(232,180,176,0.08);margin-bottom:0.875rem;`}>{step}</p>
          <p style="font-size:0.875rem;font-weight:600;color:#F8F6F1;margin-bottom:0.5rem;">{label}</p>
          <p style="font-size:0.8125rem;line-height:1.6;color:rgba(248,246,241,0.35);">{desc}</p>
        </a>
      ))}
    </div>
  </div>
</section>

