<script is:inline>
// ── Hide announcement bar + fix dashboard shell top offset ────────────────
(function() {
 // Hide global shop header elements that conflict with dashboard full-screen layout
 var header = document.querySelector('header');
 if (header && header.previousElementSibling) {
   header.previousElementSibling.style.display = 'none';
 }
 // Also hide the footer on dashboard
 var footer = document.querySelector('footer');
 if (footer) footer.style.display = 'none';
 // Hide scroll-to-top button
 var scrollTop = document.getElementById('scroll-top');
 if (scrollTop) scrollTop.style.display = 'none';
 // Position shell below the header
 var shell = document.getElementById('dashboard-shell');
 if (shell && header) {
   var headerH = header.getBoundingClientRect().height || 64;
   shell.style.top = headerH + 'px';
 }
})();

</script>

