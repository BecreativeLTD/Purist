<script>
 // ── View switching ─────────────────────────────────────────────────────
 const navBtns = document.querySelectorAll<HTMLButtonElement>('.sidebar-nav');
 const views = document.querySelectorAll<HTMLElement>('.view-section');

 function activateView(viewId: string) {
   navBtns.forEach(btn => {
     const active = btn.dataset.view === viewId;
     btn.classList.toggle('is-active', active);
     const indicator = btn.querySelector<HTMLElement>('.nav-indicator');
     if (indicator) indicator.style.opacity = active ? '1' : '0';
     const iconTile = btn.querySelector<HTMLElement>('.sb-icon-tile');
     const svgEl  = btn.querySelector<SVGElement>('svg');
     const labelEl = btn.querySelector<HTMLElement>('.sb-nav-label');
     if (active) {
       btn.style.background = 'linear-gradient(135deg,rgba(232,180,176,0.13),rgba(196,132,126,0.06))';
       btn.style.borderColor = 'rgba(232,180,176,0.18)';
       if (iconTile) iconTile.style.background = 'rgba(232,180,176,0.18)';
       if (svgEl)  svgEl.style.color        = '#E8B4B0';
       if (labelEl) labelEl.style.color       = 'rgba(255,255,255,0.95)';
     } else {
       btn.style.background = '';
       btn.style.borderColor = 'transparent';
       if (iconTile) iconTile.style.background = 'rgba(255,255,255,0.05)';
       if (svgEl)  svgEl.style.color        = 'rgba(255,255,255,0.42)';
       if (labelEl) labelEl.style.color       = 'rgba(255,255,255,0.48)';
     }
   });
   views.forEach(v => {
     v.classList.toggle('hidden', v.dataset.section !== viewId);
   });
   // Update mobile bottom nav active state
   document.querySelectorAll<HTMLElement>('.mobile-nav-btn').forEach(btn => {
     const active = btn.dataset.view === viewId;
     btn.style.color = active ? '#E8B4B0' : 'rgba(255,255,255,0.35)';
   });
   // Scroll the content pane (not window) back to top
   const contentPane = document.querySelector<HTMLElement>('#dashboard-shell > div:last-child');
   if (contentPane) contentPane.scrollTop = 0;
 }

 (window as any).activateView = activateView;
 navBtns.forEach(btn => {
   btn.addEventListener('click', () => {
     activateView(btn.dataset.view!);
     // Close sidebar on mobile after navigation
     if (window.innerWidth < 1024) closeSidebar();
   });
 });

 // ── Mobile sidebar toggle ─────────────────────────────────────────────
 const sidebar = document.getElementById('sidebar');
 const backdrop = document.getElementById('sidebar-backdrop');
 let sidebarOpen = false;

 function toggleSidebar() {
   sidebarOpen ? closeSidebar() : openSidebar();
 }
 function openSidebar() {
   sidebarOpen = true;
   if (sidebar) sidebar.style.transform = 'translateX(0)';
   if (backdrop) { backdrop.style.opacity = '1'; backdrop.style.pointerEvents = 'auto'; backdrop.style.background = 'rgba(0,0,0,0.75)'; }
 }
 function closeSidebar() {
   sidebarOpen = false;
   if (sidebar) sidebar.style.transform = 'translateX(-110%)';
   if (backdrop) { backdrop.style.opacity = '0'; backdrop.style.pointerEvents = 'none'; }
 }
