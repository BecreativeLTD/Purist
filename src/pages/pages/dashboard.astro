 (window as any).downloadReport = function(type: string) {
   if (type === 'csv') { (window as any).downloadCSV(); return; }
   if (type === 'json') { (window as any).downloadJSON(); return; }
   const win = window.open('', '_blank');
   if (!win) return;
   const html = type === 'performance' ? buildPerformanceReport() : buildROIReport();
   win.document.write(html);
   win.document.close();
 };

