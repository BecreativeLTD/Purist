 (window as any).openConnectorModal = function(name: string, color: string, synced: string) {
   const backdrop = document.getElementById('connector-modal-backdrop') as HTMLElement;
   const modal  = document.getElementById('connector-modal') as HTMLElement;
   const data   = CM_DATA[name] || {};
   const events = CM_EVENTS[name] || [];
   (document.getElementById('cm-name') as HTMLElement).textContent = name;
   (document.getElementById('cm-synced') as HTMLElement).textContent = synced + ' synced';
   (document.getElementById('cm-uptime') as HTMLElement).textContent = data.uptime || ' ';
   (document.getElementById('cm-p50') as HTMLElement).textContent  = data.p50 || ' ';
   (document.getElementById('cm-p95') as HTMLElement).textContent  = data.p95 || ' ';
   (document.getElementById('cm-key-label') as HTMLElement).textContent = data.keyLabel || 'API Key';
   const keyInput = document.getElementById('cm-api-key') as HTMLInputElement;
   keyInput.value = data.key || '';
   keyInput.type = 'password';
   (document.getElementById('cm-toggle-btn') as HTMLElement).textContent = 'Show';
   const whRow = document.getElementById('cm-webhook-row') as HTMLElement;
   if (data.webhook) { whRow.style.display = 'block'; (document.getElementById('cm-webhook') as HTMLInputElement).value = data.webhook; }
   else            { whRow.style.display = 'none'; }
   const scopesEl = document.getElementById('cm-scopes') as HTMLElement;
   scopesEl.innerHTML = (data.scopes || []).map((s: string) =>
     `<span style="font-size:9.5px;font-family:monospace;padding:3px 9px;border-radius:99px;background:#F5F5F5;border:1px solid #E8E8E6;color:#555;">${s}</span>`
   ).join('');
   const eventsEl = document.getElementById('cm-events') as HTMLElement;
   eventsEl.innerHTML = events.map((e: string[]) => {
     const dot = e[2] === 'warn' ? '#C89840' : '#2D5016';
     return `<div style="display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:1px solid #F5F5F5;"><span style="width:7px;height:7px;border-radius:50%;background:${dot};margin-top:3.5px;flex-shrink:0;"></span><p style="flex:1;font-size:11px;color:#444;margin:0;line-height:1.4;">${e[0]}</p><span style="font-size:9.5px;color:#bbb;white-space:nowrap;">${e[1]}</span></div>`;
   }).join('');
   backdrop.style.display = 'block';
   requestAnimationFrame(() => { modal.style.transform = 'translateX(0)'; });
 };

