---

<ShopLayout title="Client Dashboard PURIST" description="Real-time monitoring of your PURIST automation workflows, AI agents and system health." noindex>

<!-- Mobile sidebar backdrop -->
<div id="sidebar-backdrop" class="fixed inset-0 z-[64] bg-black/60 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden" onclick="closeSidebar()"></div>

<!-- Full-viewport dashboard shell sidebar + content own the space below the header -->
<div id="dashboard-shell" class="flex" style="position:fixed;left:0;right:0;bottom:0;top:0;z-index:65;overflow:hidden;background:#F7F4EF;">

 <!-- ══════════════════════════════════════════════════════════════ -->
 <!-- LEFT SIDEBAR                                                 -->
 <!-- ══════════════════════════════════════════════════════════════ -->
 <aside id="sidebar" class="shrink-0 flex flex-col overflow-y-auto" style="background:#0C0C0C;border-right:1px solid rgba(255,255,255,0.06);scrollbar-width:none;height:100%;position:absolute;top:0;bottom:0;left:0;z-index:50;width:100%;max-width:100%;transform:translateX(-110%);transition:transform 0.3s cubic-bezier(0.32,0.72,0,1);" data-mobile-sidebar="true">

   <!-- Mobile sidebar top bar with close button -->
   <div class="lg:hidden flex items-center justify-between px-4 py-3 shrink-0" style="background:#0C0C0C;border-bottom:1px solid rgba(255,255,255,0.08);">
     <span class="font-display text-white text-sm font-semibold tracking-[0.2em] opacity-80">PURIST</span>
     <button type="button" onclick="closeSidebar()" class="w-8 h-8 flex items-center justify-center rounded-lg" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.10);" aria-label="Close menu">
       <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" stroke-linecap="round"><path d="M3 3l10 10M13 3L3 13"/></svg>
     </button>
   </div>

   <!-- Pink accent strip -->
   <div class="h-[2px] w-full shrink-0" style="background:linear-gradient(90deg,#E8B4B0 0%,#c4847e 50%,transparent 100%);"/>

   <!-- ① Client identity -->
   <div class="px-5 pt-5 pb-4 shrink-0">
     <div class="flex items-start gap-3 mb-4">
       <!-- Square avatar -->
       <div class="w-10 h-10 rounded-xl shrink-0 flex items-center justify-center relative overflow-hidden" style="background:linear-gradient(135deg,rgba(232,180,176,0.15),rgba(196,132,126,0.08));border:1px solid rgba(232,180,176,0.2);">
         <span class="font-display text-[13px] font-semibold tracking-wide" style="color:#E8B4B0;">{client.avatar}</span>
       </div>
       <!-- Identity text -->
       <div class="flex-1 min-w-0 pt-0.5">
         <p class="text-[13px] font-semibold text-white leading-snug truncate tracking-[-0.02em]">{client.name}</p>
         <div class="flex items-center gap-1.5 mt-1">
           <span class="text-[9px] font-semibold tracking-[0.06em] uppercase leading-none px-2 py-1 rounded-full" style="background:rgba(232,180,176,0.12);color:#E8B4B0;border:1px solid rgba(232,180,176,0.2);">{client.plan}</span>
         </div>
         {userEmail && <p class="text-[9px] truncate mt-0.5" style="color:rgba(255,255,255,0.30);">{userEmail}</p>}
       </div>
       <!-- Logout -->
       <form method="POST" action="/api/auth/signout">
         <button type="submit" title="Sign out" class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 transition" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);" onmouseover="this.style.background='rgba(255,255,255,0.10)'" onmouseout="this.style.background='rgba(255,255,255,0.04)'">
           <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="rgba(255,255,255,0.45)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
             <path d="M4.5 6h6M8 3.5l2.5 2.5L8 8.5"/><path d="M7 1.5H2a.5.5 0 00-.5.5v8a.5.5 0 00.5.5h5"/>
           </svg>
         </button>
       </form>
     </div>
     <!-- System status bar -->
     <div class="flex items-center gap-2.5 px-3 py-2 rounded-xl" style="background:rgba(74,222,128,0.06);border:1px solid rgba(74,222,128,0.14);">
       <span class="relative flex h-2 w-2 shrink-0">
         <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-40" style="background:#4ade80;"/>
         <span class="relative inline-flex rounded-full h-2 w-2" style="background:#4ade80;"/>
       </span>
       <span class="text-[10px] font-medium flex-1 leading-none" style="color:rgba(74,222,128,0.9);">All systems operational</span>
       <span class="text-[9px] tabular-nums font-medium" style="color:rgba(74,222,128,0.45);">5s</span>
     </div>
   </div>

   <!-- Divider -->
   <div class="mx-5 h-px shrink-0" style="background:rgba(255,255,255,0.06);"/>

   <!-- ② Navigation -->
   <nav class="px-3 py-3.5 space-y-px shrink-0">
     <p class="text-[9px] uppercase tracking-[0.2em] font-bold px-2 pb-2" style="color:rgba(255,255,255,0.2);">Menu</p>
     {navItems.map((item, i) => (
       <button
         type="button"
         class={`sidebar-nav sb-nav-item relative w-full flex items-center gap-3 px-2.5 py-2.5 rounded-xl text-left transition-all duration-150 ${i === 0 ? 'is-active' : ''}`}
         data-view={item.id}
         style={i === 0
           ? 'background:linear-gradient(135deg,rgba(232,180,176,0.13),rgba(196,132,126,0.06));border:1px solid rgba(232,180,176,0.18);'
           : 'border:1px solid transparent;'}
       >
         <!-- Active pink indicator -->
         <span class="nav-indicator absolute left-0 inset-y-2.5 w-[3px] rounded-r-full transition-opacity duration-200" style={`background:linear-gradient(180deg,#E8B4B0,#c4847e);opacity:${i===0?1:0};`}/>
         <!-- Icon tile -->
         <span class="sb-icon-tile w-7 h-7 rounded-lg flex items-center justify-center shrink-0 transition-all duration-150" style={i===0 ? 'background:rgba(232,180,176,0.18);' : 'background:rgba(255,255,255,0.05);'}>
           <svg class="w-[15px] h-[15px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style={i===0 ? 'color:#E8B4B0;' : 'color:rgba(255,255,255,0.42);'}>
             <path d={item.icon}/>
           </svg>
         </span>
         <!-- Label -->
         <span class="sb-nav-label text-[12.5px] font-medium flex-1 leading-none tracking-[-0.01em] transition-colors duration-150" style={i===0 ? 'color:rgba(255,255,255,0.95);' : 'color:rgba(255,255,255,0.48);'}>{item.label}</span>
         {item.badge !== undefined && item.badge > 0 && (
           <span class="text-[8px] font-bold tabular-nums px-1.5 py-0.5 rounded-full" style="background:#E8B4B0;color:#0C0C0C;">{item.badge}</span>
         )}
       </button>
     ))}
   </nav>

   <!-- Divider -->
   <div class="mx-5 h-px shrink-0" style="background:rgba(255,255,255,0.06);"/>

   <!-- ③ Project milestones -->
   <div class="px-5 py-4 shrink-0">
     <div class="flex items-center justify-between mb-3">
       <p class="text-[9px] uppercase tracking-[0.2em] font-bold" style="color:rgba(255,255,255,0.2);">Project</p>
       <div class="flex items-center gap-1.5">
         <span class="text-[11px] font-bold tabular-nums" style="color:#E8B4B0;">4</span>
         <span class="text-[10px]" style="color:rgba(255,255,255,0.25);">/ 6 done</span>
       </div>
     </div>
     <!-- Progress bar -->
     <div class="h-1.5 rounded-full overflow-hidden mb-3.5" style="background:rgba(255,255,255,0.07);">
       <div class="h-full rounded-full" style="width:66.6%;background:linear-gradient(90deg,#E8B4B0 0%,#c4847e 100%);box-shadow:0 0 8px rgba(232,180,176,0.35);"/>
