 let refreshInterval: ReturnType<typeof setInterval> | null = null;
 const toggle = document.getElementById('refresh-toggle');
 const knob = document.getElementById('refresh-knob');
 let refreshOn = false;

 toggle?.addEventListener('click', () => {
   refreshOn = !refreshOn;
   if (knob) {
     knob.style.transform = refreshOn ? 'translateX(18px)' : 'translateX(2px)';
     knob.style.background = refreshOn ? '#4ade80' : 'rgba(255,255,255,0.4)';
   }
   if (toggle) toggle.style.background = refreshOn ? 'rgba(74,222,128,0.25)' : 'rgba(255,255,255,0.09)';
   if (refreshOn) refreshInterval = setInterval(() => {}, 30000);
   else if (refreshInterval) clearInterval(refreshInterval);
 });

