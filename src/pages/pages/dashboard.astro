 (window as any).switchSettingsTab = function(target: string) {
   const map: Record<string,string> = {general:'st-general',api:'st-api',notif:'st-notif',reports:'st-reports'};
   Object.keys(map).forEach(k => {
     const id  = map[k];
     const btn = document.getElementById('st-tab-' + k) as HTMLElement;
     const panel = document.getElementById(id) as HTMLElement;
     const active = id === target;
     if (btn) { btn.style.borderBottomColor = active ? '#E8B4B0' : 'transparent'; btn.style.color = active ? 'rgba(255,255,255,0.90)' : 'rgba(255,255,255,0.35)'; }
     if (panel) { panel.classList[active ? 'remove' : 'add']('hidden'); }
   });
 };

