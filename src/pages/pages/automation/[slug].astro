---
import ShopLayout from '~/layouts/ShopLayout.astro';
import { professions } from '~/data/automations';

export async function getStaticPaths() {
  return professions.map(p => ({
    params: { slug: p.slug },
    props: { profession: p }
  }));
}

const { profession: p } = Astro.props;

// Related professions — same category, exclude current
const related = professions
  .filter(r => r.category === p.category && r.slug !== p.slug)
  .slice(0, 5);

const categoryAnchor = p.category.toLowerCase().replace(/[^a-z0-9]/g, '-');

const svgIcons: Record<string, string> = {
  workflow: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="12" r="2"/><circle cx="19" cy="5" r="2"/><circle cx="19" cy="19" r="2"/><path d="M7 12h10M17 6.5l-10 4M17 17.5l-10-4"/></svg>`,
  clock: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  dollar: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  check: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
  alert: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
  rocket: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>`,
};
---

<ShopLayout
  title={`${p.name} Automation — n8n Workflows & AI Agents | PURIST`}
  description={`Automate your ${p.name.toLowerCase()} business with production-grade n8n workflows and Claude AI agents. ${p.stats.timeSaved} saved per week. Deploy in ${p.stats.deploymentDays} days.`}
  canonical={`https://www.purist.online/pages/automation/${p.slug}`}
>

<!-- JSON-LD: Service -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `${p.name} Automation — PURIST`,
  "description": `Production-grade n8n workflow automation for ${p.name.toLowerCase()} businesses. ${p.stats.timeSaved} saved per week.`,
  "url": `https://www.purist.online/pages/automation/${p.slug}`,
  "provider": { "@type": "Organization", "name": "PURIST", "url": "https://www.purist.online" },
  "areaServed": "US",
  "serviceType": `${p.name} Workflow Automation`,
  "offers": { "@type": "Offer", "priceCurrency": "USD", "price": "997", "availability": "https://schema.org/InStock" }
})}></script>

<!-- JSON-LD: BreadcrumbList -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.purist.online" },
    { "@type": "ListItem", "position": 2, "name": "Automation by Industry", "item": "https://www.purist.online/pages/automation" },
    { "@type": "ListItem", "position": 3, "name": p.category, "item": `https://www.purist.online/pages/automation#${categoryAnchor}` },
    { "@type": "ListItem", "position": 4, "name": `${p.name} Automation`, "item": `https://www.purist.online/pages/automation/${p.slug}` }
  ]
})}></script>

<!-- JSON-LD: FAQPage -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": p.faq.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a }
  }))
})}></script>

<!-- Breadcrumb -->
<div style="background:#F8F6F1;padding:0.75rem 0;border-bottom:1px solid rgba(10,10,10,0.06);">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <p style="font-size:0.8125rem;color:rgba(10,10,10,0.4);margin:0;">
      <a href="/pages/automation" style="color:rgba(10,10,10,0.4);text-decoration:none;">All Industries</a>
      <span style="margin:0 0.5rem;">→</span>
      <span style="color:rgba(10,10,10,0.5);">{p.category}</span>
      <span style="margin:0 0.5rem;">→</span>
      <span style="color:#0A0A0A;">{p.name} Automation</span>
    </p>
  </div>
</div>

<!-- Hero -->
<section style="background:#0A0A0A;color:#F8F6F1;padding:5rem 0 4rem;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 55% 50% at 50% 0%,rgba(232,180,176,0.08) 0%,transparent 65%);"></div>
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:1;">
    <div style="max-width:800px;margin:0 auto;text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.375rem 0.875rem;border-radius:999px;border:1px solid rgba(232,180,176,0.3);background:rgba(232,180,176,0.07);margin-bottom:1.5rem;">
        <span style="font-size:10px;text-transform:uppercase;letter-spacing:0.16em;font-weight:600;color:rgba(232,180,176,0.85);">{p.category} · n8n + Claude AI Automation</span>
      </div>
      <h1 style="font-family:Georgia,serif;font-size:clamp(2rem,5vw,3.2rem);line-height:1.1;letter-spacing:-0.025em;color:#F8F6F1;margin-bottom:1.25rem;">
        {p.name} Automation:<br/>
        <em style="font-style:italic;color:#E8B4B0;">Save {p.stats.timeSaved} Every Week</em>
      </h1>
      <p style="font-size:1.0625rem;line-height:1.75;color:rgba(248,246,241,0.55);max-width:640px;margin:0 auto 2.5rem;">{p.tagline}</p>
      <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;margin-bottom:3rem;">
        <a href="/pages/welcome" style="display:inline-block;background:#E8B4B0;color:#0A0A0A;padding:1rem 2rem;border-radius:10px;font-size:0.875rem;font-weight:600;text-decoration:none;">Book free automation audit →</a>
        <a href="/pages/pricing" style="display:inline-block;background:rgba(255,255,255,0.06);color:rgba(248,246,241,0.7);border:1px solid rgba(255,255,255,0.12);padding:1rem 2rem;border-radius:10px;font-size:0.875rem;font-weight:500;text-decoration:none;">View plans</a>
      </div>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:2.5rem;">
        {[
          [p.stats.timeSaved, 'Saved per week'],
          [p.stats.revenueImpact, 'Revenue impact'],
          [`${p.stats.deploymentDays} days`, 'To go live'],
          [`${p.stats.roiMonths} months`, 'To full ROI'],
        ].map(([n, l]) => (
          <div style="text-align:center;">
            <p style="font-family:Georgia,serif;font-size:1.6rem;line-height:1;margin-bottom:0.25rem;color:#E8B4B0;">{n}</p>
            <p style="font-size:10px;text-transform:uppercase;letter-spacing:0.12em;color:rgba(248,246,241,0.3);">{l}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Pain Points -->
<section style="background:#F8F6F1;padding:4.5rem 0;">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <div style="max-width:680px;margin:0 auto 3rem;text-align:center;">
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.5rem,3vw,2.2rem);color:#0A0A0A;margin-bottom:1rem;">Why {p.name}s Lose Hours Every Week</h2>
      <p style="font-size:0.9375rem;line-height:1.75;color:rgba(10,10,10,0.55);">{p.description}</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem;max-width:900px;margin:0 auto;">
      {p.painPoints.map(point => (
        <div style="background:white;border:1px solid rgba(10,10,10,0.07);border-radius:14px;padding:1.5rem;display:flex;gap:0.875rem;align-items:flex-start;">
          <div style="flex-shrink:0;width:32px;height:32px;border-radius:8px;background:rgba(160,82,45,0.08);display:flex;align-items:center;justify-content:center;color:#A0522D;" set:html={svgIcons.alert}/>
          <p style="font-size:0.875rem;line-height:1.65;color:rgba(10,10,10,0.65);margin:0;">{point}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Workflows -->
<section style="background:#0A0A0A;padding:5rem 0;">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <div style="max-width:660px;margin:0 auto 3rem;text-align:center;">
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.5rem,3vw,2.2rem);color:#F8F6F1;margin-bottom:1rem;">The {p.name} Automation System</h2>
      <p style="font-size:0.9375rem;line-height:1.75;color:rgba(248,246,241,0.45);">Production-grade n8n workflows built specifically for {p.name.toLowerCase()} businesses. Every workflow handles edge cases, retries on failure, and alerts you when something needs attention.</p>
    </div>
    <div style="display:flex;flex-direction:column;gap:1.25rem;">
      {p.workflows.map((wf, i) => (
        <div class="wf-card" style="background:rgba(255,255,255,0.03);border:1px solid rgba(232,180,176,0.12);border-radius:16px;padding:2rem;">
          <div>
            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.875rem;">
              <span style="font-family:Georgia,serif;font-size:0.875rem;color:rgba(232,180,176,0.4);font-style:italic;">0{i + 1}</span>
              <h3 style="font-family:Georgia,serif;font-size:1.125rem;color:#F8F6F1;margin:0;">{wf.name}</h3>
            </div>
            <p style="font-size:0.9rem;line-height:1.75;color:rgba(248,246,241,0.5);margin:0;">{wf.description}</p>
          </div>
          <div class="wf-stats">
            <div style="background:rgba(45,80,22,0.2);border:1px solid rgba(45,80,22,0.3);border-radius:8px;padding:0.625rem 0.875rem;">
              <p style="font-size:10px;text-transform:uppercase;letter-spacing:0.1em;color:rgba(248,246,241,0.35);margin:0 0 0.25rem;">Time saved</p>
              <p style="font-size:0.875rem;font-weight:600;color:#F8F6F1;margin:0;">{wf.timeSaved}</p>
            </div>
            <div style="background:rgba(232,180,176,0.08);border:1px solid rgba(232,180,176,0.15);border-radius:8px;padding:0.625rem 0.875rem;">
              <p style="font-size:10px;text-transform:uppercase;letter-spacing:0.1em;color:rgba(248,246,241,0.35);margin:0 0 0.25rem;">Impact</p>
              <p style="font-size:0.8125rem;font-weight:500;color:#E8B4B0;margin:0;">{wf.impact}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Tools + Why PURIST -->
<section style="background:#F8F6F1;padding:5rem 0;">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <div class="two-col-grid">
      <div>
        <h2 style="font-family:Georgia,serif;font-size:clamp(1.4rem,2.5vw,2rem);color:#0A0A0A;margin-bottom:1.25rem;">The Tech Stack We Use</h2>
        <p style="font-size:0.9375rem;line-height:1.75;color:rgba(10,10,10,0.55);margin-bottom:1.5rem;">Every {p.name.toLowerCase()} automation we build runs on proven, self-hosted infrastructure. No vendor lock-in. Your data stays in your systems.</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.625rem;">
          {p.tools.map(tool => (
            <span style="display:inline-block;background:#0A0A0A;color:#F8F6F1;padding:0.375rem 0.875rem;border-radius:999px;font-size:0.8125rem;font-weight:500;">{tool}</span>
          ))}
        </div>
        <div style="margin-top:2rem;padding:1.5rem;background:white;border:1px solid rgba(10,10,10,0.07);border-radius:14px;">
          <h3 style="font-family:Georgia,serif;font-size:1rem;color:#0A0A0A;margin-bottom:0.75rem;">What makes PURIST different</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.625rem;">
            {[
              'Built specifically for your profession — not generic templates',
              'Production-ready with error handling and 24/7 monitoring',
              'Deployed in 7 days, not 6 weeks',
              '100% money-back guarantee if we miss the brief',
            ].map(item => (
              <li style="display:flex;align-items:flex-start;gap:0.625rem;font-size:0.875rem;color:rgba(10,10,10,0.6);">
                <span style="color:#2D5016;flex-shrink:0;margin-top:2px;" set:html={svgIcons.check}/>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
      <div>
        <h2 style="font-family:Georgia,serif;font-size:clamp(1.4rem,2.5vw,2rem);color:#0A0A0A;margin-bottom:1.25rem;">ROI in the First 30 Days</h2>
        <p style="font-size:0.9375rem;line-height:1.75;color:rgba(10,10,10,0.55);margin-bottom:1.5rem;">Most {p.name.toLowerCase()} businesses that automate with PURIST see measurable returns before the end of the first month. Here is what changes first.</p>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          {[
            { label: 'Time recovered per week', value: p.stats.timeSaved, icon: svgIcons.clock },
            { label: 'Revenue impact', value: p.stats.revenueImpact, icon: svgIcons.dollar },
            { label: 'Days to full deployment', value: `${p.stats.deploymentDays} days`, icon: svgIcons.rocket },
          ].map(({ label, value, icon }) => (
            <div style="background:white;border:1px solid rgba(10,10,10,0.07);border-radius:12px;padding:1.25rem 1.5rem;display:flex;align-items:center;gap:1rem;">
              <div style="width:40px;height:40px;border-radius:10px;background:#F8F6F1;display:flex;align-items:center;justify-content:center;color:#2D5016;flex-shrink:0;" set:html={icon}/>
              <div>
                <p style="font-size:0.8125rem;color:rgba(10,10,10,0.4);margin:0 0 0.25rem;">{label}</p>
                <p style="font-family:Georgia,serif;font-size:1.25rem;color:#0A0A0A;margin:0;font-weight:500;">{value}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section style="background:#0A0A0A;padding:5rem 0;">
  <div style="max-width:760px;margin:0 auto;padding:0 1.5rem;">
    <h2 style="font-family:Georgia,serif;font-size:clamp(1.5rem,3vw,2.2rem);color:#F8F6F1;margin-bottom:3rem;text-align:center;">{p.name} Automation — Common Questions</h2>
    <div style="display:flex;flex-direction:column;gap:1rem;">
      {p.faq.map(({ q, a }) => (
        <div style="border:1px solid rgba(232,180,176,0.12);border-radius:14px;padding:1.75rem;">
          <h3 style="font-family:Georgia,serif;font-size:1rem;color:#F8F6F1;margin-bottom:0.75rem;">{q}</h3>
          <p style="font-size:0.875rem;line-height:1.75;color:rgba(248,246,241,0.5);margin:0;">{a}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Internal linking: related professions -->
<section style="background:#F8F6F1;padding:4rem 0;border-top:1px solid rgba(10,10,10,0.06);">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <div style="display:flex;align-items:baseline;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:2rem;">
      <div>
        <p style="font-size:10px;text-transform:uppercase;letter-spacing:0.16em;color:rgba(10,10,10,0.35);margin-bottom:0.5rem;">More in {p.category}</p>
        <h2 style="font-family:Georgia,serif;font-size:1.375rem;color:#0A0A0A;margin:0;">Related Industries We Automate</h2>
      </div>
      <a href="/pages/automation" style="font-size:0.8125rem;color:rgba(10,10,10,0.5);text-decoration:underline;text-underline-offset:3px;">View all 200 industries →</a>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.75rem;">
      {related.map(r => (
        <a href={`/pages/automation/${r.slug}`}
           style="display:block;background:white;border:1px solid rgba(10,10,10,0.07);border-radius:12px;padding:1.25rem;text-decoration:none;transition:border-color 0.15s;">
          <h3 style="font-family:Georgia,serif;font-size:0.9375rem;color:#0A0A0A;margin:0 0 0.25rem;">{r.name}</h3>
          <p style="font-size:0.75rem;color:rgba(10,10,10,0.4);margin:0;">{r.stats.timeSaved} saved/week</p>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section style="background:#E8B4B0;padding:4rem 0;">
  <div style="max-width:700px;margin:0 auto;padding:0 1.5rem;text-align:center;">
    <h2 style="font-family:Georgia,serif;font-size:clamp(1.5rem,3vw,2.2rem);color:#0A0A0A;margin-bottom:1rem;">Free {p.name} Automation Audit</h2>
    <p style="font-size:0.9375rem;line-height:1.75;color:rgba(10,10,10,0.65);margin-bottom:2rem;">We map your current workflows, show you exactly what to automate first, and give you a written ROI estimate — before you spend a dollar. Delivered within 48 hours.</p>
    <a href="/pages/welcome" style="display:inline-block;background:#0A0A0A;color:#F8F6F1;padding:1.125rem 2.5rem;border-radius:10px;font-size:0.9375rem;font-weight:600;text-decoration:none;">Book your free audit →</a>
    <p style="font-size:0.75rem;color:rgba(10,10,10,0.45);margin-top:1rem;">No commitment · 48h delivery · 100% money-back guarantee</p>
  </div>
</section>

<style>
  .wf-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: start;
  }
  .wf-stats {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    min-width: 160px;
  }
  .two-col-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  @media (max-width: 767px) {
    .wf-card {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .wf-stats {
      flex-direction: row;
      flex-wrap: wrap;
      min-width: unset;
    }
    .wf-stats > div {
      flex: 1;
      min-width: 130px;
    }
    .two-col-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
</ShopLayout>
