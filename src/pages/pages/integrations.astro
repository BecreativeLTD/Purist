---
import ShopLayout from '~/layouts/ShopLayout.astro';

const categories = [
  { cat: 'CRM & Sales', tools: ['HubSpot', 'Salesforce', 'Pipedrive', 'Close', 'Zoho CRM', 'Copper'] },
  { cat: 'Communication', tools: ['Slack', 'Gmail', 'Outlook', 'Twilio', 'WhatsApp Business', 'Intercom'] },
  { cat: 'Finance & Billing', tools: ['Stripe', 'QuickBooks', 'Xero', 'FreeAgent', 'GoCardless', 'Chargebee'] },
  { cat: 'E-commerce', tools: ['Shopify', 'WooCommerce', 'Magento', 'Klaviyo', 'Gorgias', 'Recharge'] },
  { cat: 'Forms & Data', tools: ['Typeform', 'Jotform', 'Airtable', 'Google Sheets', 'Notion', 'Monday.com'] },
  { cat: 'Documents', tools: ['DocuSign', 'PandaDoc', 'Google Docs', 'PDF generation', 'Dropbox', 'OneDrive'] },
  { cat: 'HR & Recruiting', tools: ['BambooHR', 'Workable', 'Greenhouse', 'Lever', 'Personio', 'Rippling'] },
  { cat: 'Marketing', tools: ['Mailchimp', 'ActiveCampaign', 'Brevo', 'Meta Ads', 'Google Ads', 'LinkedIn Ads'] },
  { cat: 'AI & Intelligence', tools: ['Claude Opus', 'OpenAI GPT-4', 'Perplexity', 'Whisper', 'ElevenLabs', 'Mistral'] },
  { cat: 'Infrastructure', tools: ['Webhooks', 'REST APIs', 'GraphQL', 'PostgreSQL', 'MySQL', 'Redis'] },
];
---

<ShopLayout
  title="400+ Integrations | PURIST Automation"
  description="PURIST connects your entire stack — CRM, payments, email, documents, AI. 400+ integrations, deployed in 5–10 business days."
>

  <!-- HERO — dark -->
  <section style="background:#0A0A0A; padding:100px 24px 80px;">
    <div style="max-width:720px; margin:0 auto; text-align:center;">
      <p style="font-family:'Inter',sans-serif; font-size:11px; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:rgba(232,180,176,0.70); margin-bottom:20px;">
        Integrations
      </p>
      <h1 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(40px,6vw,64px); line-height:1.05; color:#FFFFFF; margin-bottom:24px;">
        400+ tools.<br/><em>One connected stack.</em>
      </h1>
      <p style="font-family:'Inter',sans-serif; font-size:16px; color:rgba(255,255,255,0.50); line-height:1.7; max-width:520px; margin:0 auto;">
        PURIST connects your existing tools — CRM, billing, support, marketing, HR, and AI — into a single automated workflow. No rip-and-replace. No new software to learn.
      </p>
    </div>
  </section>

  <!-- STATS ROW — dark -->
  <section style="background:#0A0A0A; padding:0 24px 80px;">
    <div style="max-width:720px; margin:0 auto; display:flex; gap:16px; flex-wrap:wrap; justify-content:center;">
      {[
        { num: '400+', label: 'integrations' },
        { num: '5–10', label: 'days to deploy' },
        { num: '99.97%', label: 'uptime SLA' },
      ].map(s => (
        <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:9999px; padding:10px 24px; text-align:center;">
          <span style="font-family:'Fraunces',serif; font-weight:400; font-size:22px; color:#E8B4B0;">{s.num}</span>
          <span style="font-family:'Inter',sans-serif; font-size:12px; color:rgba(255,255,255,0.40); margin-left:8px;">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- INTEGRATION GRID — cream -->
  <section style="background:#F8F6F1; padding:80px 24px;">
    <div style="max-width:860px; margin:0 auto;">

      <p style="font-family:'Inter',sans-serif; font-size:11px; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:rgba(10,10,10,0.35); text-align:center; margin-bottom:56px;">
        Your entire stack, covered
      </p>

      <div style="display:flex; flex-direction:column; gap:40px;">
        {categories.map(c => (
          <div>
            <p style="font-family:'Inter',sans-serif; font-size:11px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:rgba(10,10,10,0.35); margin-bottom:14px;">
              {c.cat}
            </p>
            <div style="display:flex; flex-wrap:wrap; gap:8px;">
              {c.tools.map(t => (
                <span style="font-family:'Inter',sans-serif; font-size:13px; font-weight:500; padding:7px 16px; border-radius:9999px; background:rgba(232,180,176,0.10); border:1px solid rgba(196,132,126,0.20); color:#0A0A0A;">
                  {t}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Don't see your tool -->
      <div style="margin-top:56px; background:#FFFFFF; border:1px solid #E5E7EB; border-radius:18px; padding:32px; text-align:center;">
        <p style="font-family:'Fraunces',serif; font-weight:400; font-size:22px; color:#0A0A0A; margin-bottom:10px;">
          Don't see your tool?
        </p>
        <p style="font-family:'Inter',sans-serif; font-size:14px; color:rgba(10,10,10,0.55); line-height:1.6;">
          If it has an API, we connect it. Book a free audit and we confirm compatibility on the call.
        </p>
      </div>

    </div>
  </section>

  <!-- CTA — dark -->
  <section style="background:#0A0A0A; padding:80px 24px 100px;">
    <div style="max-width:600px; margin:0 auto; text-align:center;">
      <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(28px,4vw,42px); line-height:1.1; color:#FFFFFF; margin-bottom:16px;">
        Tell us your stack.<br/><em style="color:#E8B4B0;">We build the automation.</em>
      </h2>
      <p style="font-family:'Inter',sans-serif; font-size:15px; color:rgba(255,255,255,0.45); line-height:1.7; margin-bottom:36px; max-width:480px; margin-left:auto; margin-right:auto;">
        In the free audit we map every tool you use today and design the workflow that saves the most time first.
      </p>
      <a
        href="/pages/welcome"
        style="display:inline-flex; align-items:center; gap:8px; background:#F8F6F1; color:#0A0A0A; font-family:'Inter',sans-serif; font-size:14px; font-weight:500; padding:14px 28px; border-radius:9999px; text-decoration:none; transition:opacity 0.2s;"
      >
        Get my free automation plan →
      </a>
      <div style="margin-top:20px; display:flex; justify-content:center; gap:20px; flex-wrap:wrap;">
        {['No credit card', 'Deployed in 5–10 days', '30-day guarantee'].map(t => (
          <span style="font-family:'Inter',sans-serif; font-size:11px; color:rgba(255,255,255,0.35); display:flex; align-items:center; gap:5px;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4ADE80" stroke-width="2.5" stroke-linecap="round"><path d="M5 12l5 5L20 7"/></svg>
            {t}
          </span>
        ))}
      </div>
    </div>
  </section>

</ShopLayout>
