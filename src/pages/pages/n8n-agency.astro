---
import ShopLayout from '~/layouts/ShopLayout.astro';
---

<ShopLayout
  title="n8n Automation Agency USA — Production Workflows Deployed in 7 Days | PURIST"
  description="America's leading n8n automation agency. 500+ production workflows deployed for agencies, home services, healthcare and e-commerce businesses. Free audit included."
  canonical="https://www.purist.online/pages/n8n-agency"
>

<!-- JSON-LD Schema -->
<script type="application/ld+json" is:inline>{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "n8n Automation Agency USA — PURIST",
  "description": "America's leading n8n automation agency. 500+ production workflows deployed for agencies, home services, healthcare and e-commerce businesses.",
  "url": "https://www.purist.online/pages/n8n-agency",
  "provider": {
    "@type": "Organization",
    "name": "PURIST",
    "url": "https://www.purist.online"
  },
  "areaServed": "US",
  "serviceType": "n8n Workflow Automation",
  "offers": {
    "@type": "Offer",
    "priceCurrency": "USD",
    "price": "997",
    "availability": "https://schema.org/InStock"
  }
})}</script>

<!-- Hero -->
<section style="background:#0A0A0A;color:#F8F6F1;padding:5rem 0 4rem;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 55% 50% at 50% 0%,rgba(232,180,176,0.08) 0%,transparent 65%);"></div>
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:1;">
    <div style="max-width:780px;margin:0 auto;text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.375rem 0.875rem;border-radius:999px;border:1px solid rgba(232,180,176,0.3);background:rgba(232,180,176,0.07);margin-bottom:1.5rem;">
        <span style="font-size:10px;text-transform:uppercase;letter-spacing:0.16em;font-weight:600;color:rgba(232,180,176,0.85);">Certified n8n Agency · 500+ Workflows in Production</span>
      </div>
      <h1 style="font-family:Georgia,serif;font-size:clamp(2.2rem,5vw,3.4rem);line-height:1.08;letter-spacing:-0.025em;color:#F8F6F1;margin-bottom:1.25rem;">
        The n8n Automation Agency<br/><em style="font-style:italic;color:#E8B4B0;">Built for American Business</em>
      </h1>
      <p style="font-size:1.0625rem;line-height:1.7;color:rgba(248,246,241,0.55);max-width:600px;margin:0 auto 2.5rem;">
        We design, build and maintain production-grade n8n workflows for US businesses. From initial audit to live deployment in 7 days. No templates — every workflow is built for your exact stack and your exact operation.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;margin-bottom:3rem;">
        <a href="/pages/welcome" style="display:inline-block;background:#E8B4B0;color:#0A0A0A;padding:1rem 2rem;border-radius:10px;font-size:0.875rem;font-weight:600;text-decoration:none;">Book free n8n audit →</a>
        <a href="/pages/pricing" style="display:inline-block;background:rgba(255,255,255,0.06);color:rgba(248,246,241,0.7);border:1px solid rgba(255,255,255,0.12);padding:1rem 2rem;border-radius:10px;font-size:0.875rem;font-weight:500;text-decoration:none;">View service plans</a>
      </div>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:2.5rem;">
        {[['500+','Workflows in production'],['7 days','Average deployment'],['99.97%','Uptime SLA'],['26h','Saved per week per client']].map(([n,l]) => (
          <div style="text-align:center;">
            <p style="font-family:Georgia,serif;font-size:1.75rem;line-height:1;margin-bottom:0.25rem;color:#E8B4B0;">{n}</p>
            <p style="font-size:10px;text-transform:uppercase;letter-spacing:0.12em;color:rgba(248,246,241,0.3);">{l}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- What we do -->
<section style="background:#F8F6F1;padding:5rem 0;">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <div style="max-width:680px;margin:0 auto 3rem;text-align:center;">
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.6rem,3.5vw,2.4rem);color:#0A0A0A;margin-bottom:1rem;">What a Specialist n8n Agency Actually Does</h2>
      <p style="font-size:0.9375rem;line-height:1.75;color:rgba(10,10,10,0.6);">Most businesses hit a wall with n8n templates. We go further — designing the full automation architecture, handling edge cases, building error-handling loops and monitoring every workflow 24/7 so you never lose a lead, a job, or a dollar to a broken process.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;">
      {[
        {
          title: 'Workflow Architecture',
          body: 'We map your entire operation before writing a single node. Every workflow has a purpose, an owner and a fallback. Nothing is bolted together at random.',
          svg: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="12" r="2"/><circle cx="19" cy="5" r="2"/><circle cx="19" cy="19" r="2"/><path d="M7 12h10M17 6.5l-10 4M17 17.5l-10-4"/></svg>`
        },
        {
          title: 'Custom Node Development',
          body: 'When built-in nodes do not cover your API, we write custom JavaScript nodes. Your CRM, ERP, booking system — if it has an API, we connect it.',
          svg: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`
        },
        {
          title: 'Production Deployment & Monitoring',
          body: '24/7 error monitoring with Slack alerts. Every workflow has retry logic, dead-letter queues and a dedicated runbook. Nothing breaks silently.',
          svg: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`
        },
        {
          title: 'Ongoing Optimisation',
          body: 'n8n updates monthly. We test every upgrade against your workflows before it touches production. Your automation never drifts.',
          svg: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`
        },
        {
          title: 'Full Documentation Handoff',
          body: 'Every workflow we build is fully documented — logic diagrams, data dictionaries, maintenance notes. No black box. You own everything.',
          svg: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`
        },
        {
          title: 'Team Training & Enablement',
          body: 'We run a live training session with your ops team so they can extend and monitor workflows confidently without coming back to us for every change.',
          svg: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
        },
      ].map(({ title, body, svg }) => (
        <div style="background:white;border:1px solid rgba(10,10,10,0.07);border-radius:16px;padding:2rem;display:flex;flex-direction:column;gap:1rem;transition:box-shadow 0.2s;">
          <div style="width:44px;height:44px;border-radius:10px;background:#F8F6F1;display:flex;align-items:center;justify-content:center;color:#2D5016;" set:html={svg}/>
          <div>
            <h3 style="font-family:Georgia,serif;font-size:1.0625rem;color:#0A0A0A;margin-bottom:0.375rem;line-height:1.3;">{title}</h3>
            <p style="font-size:0.875rem;line-height:1.75;color:rgba(10,10,10,0.5);margin:0;">{body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Industries -->
<section style="background:#0A0A0A;padding:5rem 0;">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <div style="max-width:660px;margin:0 auto 3rem;text-align:center;">
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.6rem,3.5vw,2.4rem);color:#F8F6F1;margin-bottom:1rem;">Industries We Automate</h2>
      <p style="font-size:0.9375rem;line-height:1.75;color:rgba(248,246,241,0.45);">We have deployed production n8n workflows across four industries, each with its own compliance requirements, data models and integration landscape.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.25rem;">
      {[
        { sector: 'Agencies & Consulting', detail: 'Lead routing, client onboarding, automated reporting, invoice follow-up and team handoff workflows — built for agencies billing $500K to $5M per year.', workflows: '205+ workflows deployed' },
        { sector: 'Home Services', detail: 'Missed call recovery, automated quoting, job scheduling, Google review collection and past-customer reactivation — for plumbing, HVAC, electrical and cleaning businesses.', workflows: '120+ workflows deployed' },
        { sector: 'Healthcare & Dental', detail: 'Patient intake, appointment reminders, insurance verification, consent forms and recall campaigns — automated to HIPAA-compliant standards.', workflows: '95+ workflows deployed' },
        { sector: 'E-commerce & Retail', detail: 'Order processing, inventory sync, abandoned cart recovery, supplier PO generation, returns management and post-purchase review sequences.', workflows: '80+ workflows deployed' },
      ].map(({ sector, detail, workflows }) => (
        <div style="border:1px solid rgba(232,180,176,0.15);border-radius:16px;padding:1.75rem;">
          <p style="font-size:10px;text-transform:uppercase;letter-spacing:0.14em;color:#E8B4B0;margin-bottom:0.75rem;">{workflows}</p>
          <h3 style="font-family:Georgia,serif;font-size:1.125rem;color:#F8F6F1;margin-bottom:0.75rem;">{sector}</h3>
          <p style="font-size:0.875rem;line-height:1.7;color:rgba(248,246,241,0.45);">{detail}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Why n8n + Why PURIST -->
<section style="background:#F8F6F1;padding:5rem 0;">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;">
      <div>
        <h2 style="font-family:Georgia,serif;font-size:clamp(1.5rem,3vw,2.2rem);color:#0A0A0A;margin-bottom:1.25rem;">Why n8n Over Zapier or Make?</h2>
        <p style="font-size:0.9375rem;line-height:1.75;color:rgba(10,10,10,0.6);margin-bottom:1.5rem;">n8n is self-hosted, open-source automation infrastructure. Unlike Zapier — which charges per task and locks your data in their cloud — or Make, which caps on operations, n8n gives you unlimited executions on your own server with zero per-task cost.</p>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.75rem;">
          {[
            'No per-task pricing — unlimited executions',
            'Your data stays in your own infrastructure',
            'Full code access — no vendor lock-in',
            'Self-hosted for HIPAA and SOC 2 compliance',
            'Runs 99.97% uptime on dedicated infrastructure'
          ].map(item => (
            <li style="display:flex;align-items:flex-start;gap:0.625rem;font-size:0.875rem;color:rgba(10,10,10,0.65);">
              <span style="color:#E8B4B0;font-weight:700;margin-top:1px;">✓</span>{item}
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h2 style="font-family:Georgia,serif;font-size:clamp(1.5rem,3vw,2.2rem);color:#0A0A0A;margin-bottom:1.25rem;">Why PURIST as Your n8n Agency?</h2>
        <p style="font-size:0.9375rem;line-height:1.75;color:rgba(10,10,10,0.6);margin-bottom:1.5rem;">We are not a generalist digital agency that also does n8n. Every engineer at PURIST works exclusively on automation infrastructure. That specialisation is why our clients see 95% less manual data entry within 30 days of deployment.</p>
        <div style="background:#0A0A0A;border-radius:14px;padding:1.5rem;">
          <p style="font-size:0.8125rem;line-height:1.7;color:rgba(248,246,241,0.55);margin-bottom:1rem;font-style:italic;">"What I would have built internally if we had six months. PURIST shipped it in three weeks and monitors it 24/7. Our ops team hasn't touched a spreadsheet since."</p>
          <p style="font-size:0.75rem;color:rgba(248,246,241,0.35);">Marcus Webb, CTO — BuildStack, Austin TX</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Process -->
<section style="background:#0A0A0A;padding:5rem 0;">
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
    <div style="max-width:660px;margin:0 auto 3rem;text-align:center;">
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.6rem,3.5vw,2.4rem);color:#F8F6F1;margin-bottom:1rem;">From Audit to Live in 7 Days</h2>
      <p style="font-size:0.9375rem;line-height:1.75;color:rgba(248,246,241,0.45);">We run a tight deployment process because most businesses cannot afford to wait 6 weeks for automation that should take 6 days.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.25rem;">
      {[
        { step: '01', title: 'Free Audit', body: 'We map your current workflows and identify the 3 automations with the highest ROI. Delivered in writing within 48 hours.'},
        { step: '02', title: 'Architecture', body: 'We design the full workflow architecture — triggers, logic, error handling, integrations — before writing a single node.'},
        { step: '03', title: 'Build', body: 'Production build with full error handling, retry logic and monitoring. Tested against real data before deployment.'},
        { step: '04', title: 'Deploy & Monitor', body: '24/7 monitoring from day one. Slack alerts on every failure. Nothing breaks silently.'},
      ].map(({ step, title, body }) => (
        <div style="border:1px solid rgba(232,180,176,0.15);border-radius:16px;padding:1.75rem;">
          <p style="font-family:Georgia,serif;font-size:2rem;color:rgba(232,180,176,0.25);margin-bottom:0.75rem;line-height:1;">{step}</p>
          <h3 style="font-family:Georgia,serif;font-size:1.125rem;color:#F8F6F1;margin-bottom:0.5rem;">{title}</h3>
          <p style="font-size:0.875rem;line-height:1.7;color:rgba(248,246,241,0.45);">{body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section style="background:#E8B4B0;padding:4rem 0;">
  <div style="max-width:700px;margin:0 auto;padding:0 1.5rem;text-align:center;">
    <h2 style="font-family:Georgia,serif;font-size:clamp(1.6rem,3.5vw,2.3rem);color:#0A0A0A;margin-bottom:1rem;">Start With a Free n8n Audit</h2>
    <p style="font-size:0.9375rem;line-height:1.75;color:rgba(10,10,10,0.65);margin-bottom:2rem;">We map your current workflows, identify automation opportunities and give you a written ROI estimate — before you commit to anything. Typically delivered within 48 hours of your call.</p>
    <a href="/pages/welcome" style="display:inline-block;background:#0A0A0A;color:#F8F6F1;padding:1.125rem 2.5rem;border-radius:10px;font-size:0.9375rem;font-weight:600;text-decoration:none;">Book your free audit →</a>
    <p style="font-size:0.75rem;color:rgba(10,10,10,0.45);margin-top:1rem;">No commitment · Reply within 1 business day · 100% money-back guarantee</p>
  </div>
</section>

</ShopLayout>
