        <div><div class="spec-k">Uptime SLA</div><div class="spec-v">99.97%</div></div>
      </div>
      <div class="tools-row"><span class="tool-label">Stack:</span><span class="tool-tag">Clio</span><span class="tool-tag">Google Workspace</span><span class="tool-tag">Stripe</span><span class="tool-tag">Slack</span><span class="tool-tag">n8n</span></div>
