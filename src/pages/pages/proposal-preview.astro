---
// Internal preview — noindex
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <meta name="robots" content="noindex,nofollow"/>
  <title>Proposal Preview — PURIST Internal</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;background:#1c1c1c;color:#0A0A0A;-webkit-font-smoothing:antialiased}
    /* Meta bar */
    .meta-bar{background:#111;border-bottom:1px solid rgba(232,180,176,0.2);padding:0.875rem 1.5rem;font-size:0.75rem;color:rgba(255,255,255,0.4);display:flex;align-items:center;gap:1rem;flex-wrap:wrap}
    .meta-bar strong{color:rgba(255,255,255,0.7)}
    .meta-pill{background:rgba(232,180,176,0.1);color:#E8B4B0;padding:0.2rem 0.7rem;border-radius:99px;font-size:0.6875rem;letter-spacing:0.1em;font-weight:600}

    /* Email wrapper */
    .email-wrap{max-width:660px;margin:2rem auto;background:#F8F6F1;border-radius:16px;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,0.4)}

    /* Header */
    .hd{background:#0A0A0A;padding:2.5rem}
    .hd-logo{font-family:'DM Serif Display',Georgia,serif;font-size:1.25rem;color:white;margin-bottom:2rem}
    .hd-logo span{color:#E8B4B0}
    .hd-tag{display:inline-flex;align-items:center;gap:0.5rem;background:rgba(232,180,176,0.12);border:1px solid rgba(232,180,176,0.2);color:#E8B4B0;font-size:0.625rem;letter-spacing:0.18em;text-transform:uppercase;padding:0.35rem 0.875rem;border-radius:99px;margin-bottom:1rem;font-weight:600}
    .hd-dot{width:6px;height:6px;border-radius:50%;background:#E8B4B0;animation:pulse 2s ease-in-out infinite}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}
    .hd-h1{font-family:'DM Serif Display',Georgia,serif;font-size:2rem;color:white;line-height:1.2;font-weight:400;margin-bottom:0.75rem}
    .hd-h1 em{color:#E8B4B0;font-style:italic}
    .hd-sub{font-size:0.875rem;color:rgba(255,255,255,0.4);line-height:1.7;max-width:480px}
    .hd-chips{display:flex;gap:0.5rem;flex-wrap:wrap;margin-top:1.5rem}
    .chip{font-size:0.6875rem;background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.45);padding:0.3rem 0.75rem;border-radius:99px;border:1px solid rgba(255,255,255,0.08)}

    /* Body */
    .bd{padding:2rem 2.5rem}

    /* Section label */
    .sl{font-size:0.625rem;letter-spacing:0.2em;text-transform:uppercase;color:#E8B4B0;font-weight:700;margin-bottom:0.75rem;margin-top:2rem}
    .sl:first-child{margin-top:0}

    /* Intro */
    .intro{font-size:0.9375rem;line-height:1.8;color:#333;margin-bottom:0}
    .intro strong{color:#0A0A0A;font-weight:600}

    /* Cards */
    .card{background:white;border:1px solid #E8E5E0;border-radius:14px;padding:1.5rem;margin-top:1rem}
    .card-sm{background:white;border:1px solid #E8E5E0;border-radius:12px;padding:1.25rem;margin-top:0.75rem}

    /* Hidden cost calculator */
    .cost-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-top:1rem}
    .cost-cell{background:#fafaf8;border:1px solid #eee;border-radius:10px;padding:1rem}
    .cost-label{font-size:0.6875rem;color:#999;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.4rem;font-weight:600}
    .cost-val{font-size:1.25rem;font-weight:700;color:#0A0A0A;font-family:'DM Serif Display',Georgia,serif}
    .cost-val.red{color:#dc2626}
    .cost-sub{font-size:0.75rem;color:#aaa;margin-top:0.2rem;line-height:1.4}
    .cost-total{background:#dc2626;border-radius:10px;padding:1rem;text-align:center;margin-top:0.75rem}
    .cost-total-label{font-size:0.625rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6);margin-bottom:0.25rem;font-weight:600}
    .cost-total-val{font-size:1.75rem;font-weight:700;color:white;font-family:'DM Serif Display',Georgia,serif}
    .cost-total-sub{font-size:0.75rem;color:rgba(255,255,255,0.55);margin-top:0.2rem}

    /* Benchmark */
    .bench-row{display:flex;align-items:center;gap:1rem;padding:0.875rem 0;border-bottom:1px solid #f0ede8}
    .bench-row:last-child{border-bottom:none}
    .bench-metric{flex:1;font-size:0.875rem;color:#555}
    .bench-industry{font-size:0.875rem;font-weight:600;color:#dc2626;width:80px;text-align:center}
    .bench-top{font-size:0.875rem;font-weight:600;color:#1a7a45;width:80px;text-align:center}
    .bench-bar-wrap{width:160px;background:#f0ede8;border-radius:99px;height:6px;position:relative;overflow:hidden}
    .bench-bar{height:100%;border-radius:99px;background:linear-gradient(90deg,#dc2626,#f87171)}
    .bench-header{display:flex;align-items:center;gap:1rem;padding:0 0 0.625rem;border-bottom:1px solid #e8e5e0;margin-bottom:0}
    .bench-header-label{font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:#aaa;font-weight:600}

    /* Workflow */
    .wf{background:white;border:1px solid #E8E5E0;border-radius:14px;margin-top:0.875rem;overflow:hidden}
    .wf-head{padding:1.25rem 1.5rem 0;display:flex;justify-content:space-between;align-items:flex-start;gap:0.75rem}
    .wf-num{font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;color:#aaa;font-weight:600;margin-bottom:0.3rem}
    .wf-title{font-size:1rem;font-weight:700;color:#0A0A0A;line-height:1.3}
    .wf-save{background:#f0faf4;color:#1a7a45;font-size:0.75rem;font-weight:700;padding:0.3rem 0.75rem;border-radius:99px;border:1px solid #b6e8cc;white-space:nowrap;flex-shrink:0}
    .wf-desc{font-size:0.875rem;color:#444;line-height:1.7;padding:0.875rem 1.5rem}
    /* Steps */
    .steps{padding:0 1.5rem;margin-bottom:1rem}
    .steps-title{font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:#bbb;font-weight:600;margin-bottom:0.625rem}
    .step-item{display:flex;gap:0.75rem;align-items:flex-start;padding:0.4rem 0}
    .step-n{width:20px;height:20px;background:#0A0A0A;color:white;border-radius:50%;font-size:0.6rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:0.1rem}
    .step-text{font-size:0.8125rem;color:#555;line-height:1.5}
    /* Specs */
    .specs{background:#fafaf8;border-top:1px solid #f0ede8;padding:1rem 1.5rem;display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem}
    .spec-k{font-size:0.6rem;text-transform:uppercase;letter-spacing:0.12em;color:#bbb;margin-bottom:0.25rem;font-weight:600}
    .spec-v{font-size:0.8125rem;font-weight:600;color:#0A0A0A}
    .tools-row{padding:0.75rem 1.5rem;border-top:1px solid #f0ede8;display:flex;gap:0.4rem;flex-wrap:wrap;align-items:center}
    .tool-label{font-size:0.6rem;text-transform:uppercase;letter-spacing:0.1em;color:#bbb;margin-right:0.25rem;font-weight:600}
    .tool-tag{font-size:0.6875rem;background:#f0f0ee;color:#555;padding:0.2rem 0.65rem;border-radius:99px;border:1px solid #e5e3de}

    /* Before / After */
    .ba-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-top:1rem}
    .ba-col{border-radius:12px;padding:1.25rem}
    .ba-col.before{background:#fff5f5;border:1px solid #fecaca}
    .ba-col.after{background:#f0faf4;border:1px solid #b6e8cc}
    .ba-label{font-size:0.625rem;letter-spacing:0.15em;text-transform:uppercase;font-weight:700;margin-bottom:0.875rem}
    .ba-label.before{color:#dc2626}
    .ba-label.after{color:#1a7a45}
    .ba-item{display:flex;align-items:flex-start;gap:0.5rem;margin-bottom:0.5rem;font-size:0.8125rem;line-height:1.4}
    .ba-item span{flex-shrink:0;margin-top:0.1rem}

    /* ROI projection */
    .proj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:#E8E5E0;border-radius:12px;overflow:hidden;margin-top:1rem}
    .proj-cell{background:white;padding:1.25rem;text-align:center}
    .proj-month{font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:#aaa;font-weight:600;margin-bottom:0.5rem}
    .proj-val{font-size:1.5rem;font-family:'DM Serif Display',Georgia,serif;color:#0A0A0A;font-weight:400}
    .proj-val.green{color:#1a7a45}
    .proj-sub{font-size:0.75rem;color:#999;margin-top:0.25rem}

    /* ROI block */
    .roi{background:#0A0A0A;border-radius:14px;padding:1.75rem;margin-top:1rem}
    .roi-label{font-size:0.625rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(232,180,176,0.55);font-weight:700;margin-bottom:1.25rem}
    .roi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.25rem}
    .roi-cell{text-align:center}
    .roi-val{font-size:1.5rem;font-family:'DM Serif Display',Georgia,serif;color:white}
    .roi-val.pink{color:#E8B4B0}
    .roi-lbl{font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-top:0.25rem}
    .roi-note{font-size:0.75rem;color:rgba(255,255,255,0.25);line-height:1.65;border-top:1px solid rgba(255,255,255,0.07);padding-top:1rem}

    /* Case study */
    .case{background:white;border:1px solid #E8E5E0;border-radius:14px;padding:1.5rem;margin-top:1rem}
    .case-quote{font-size:1rem;font-family:'DM Serif Display',Georgia,serif;color:#0A0A0A;line-height:1.5;font-style:italic;margin-bottom:1rem;padding-left:1rem;border-left:3px solid #E8B4B0}
    .case-author{display:flex;align-items:center;gap:0.75rem}
    .case-avatar{width:36px;height:36px;border-radius:50%;object-fit:cover}
    .case-name{font-size:0.875rem;font-weight:600;color:#0A0A0A}
    .case-role{font-size:0.75rem;color:#999}
    .case-results{display:grid;grid-template-columns:repeat(3,1fr);gap:0.5rem;margin-top:1.25rem;background:#fafaf8;border-radius:10px;padding:1rem}
    .case-kv{text-align:center}
    .case-v{font-size:1.1rem;font-weight:700;color:#1a7a45;font-family:'DM Serif Display',Georgia,serif}
    .case-k{font-size:0.6rem;text-transform:uppercase;letter-spacing:0.1em;color:#aaa;margin-top:0.15rem;font-weight:600}

    /* Timeline */
    .tl{margin-top:1rem}
    .tl-row{display:flex;gap:1rem;padding:0.875rem 0;border-bottom:1px solid #f0ede8}
    .tl-row:last-child{border-bottom:none}
    .tl-day{font-size:0.6875rem;color:#aaa;font-weight:600;width:88px;flex-shrink:0;padding-top:0.15rem}
    .tl-title{font-size:0.875rem;font-weight:700;color:#0A0A0A;margin-bottom:0.2rem}
    .tl-desc{font-size:0.8rem;color:#777;line-height:1.55}

    /* Risk */
    .risk{background:#fff8f0;border:1px solid #fed7aa;border-radius:14px;padding:1.5rem;margin-top:1rem}
    .risk-title{font-size:0.875rem;font-weight:700;color:#c2410c;margin-bottom:0.875rem;display:flex;align-items:center;gap:0.5rem}
    .risk-row{display:flex;gap:0.75rem;margin-bottom:0.625rem;font-size:0.8375rem;color:#555;align-items:flex-start}
    .risk-icon{color:#f97316;flex-shrink:0;margin-top:0.1rem}

    /* Investment */
    .invest{background:white;border:1px solid #E8E5E0;border-radius:14px;padding:1.5rem;margin-top:1rem}
    .invest-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.25rem}
    .invest-amount{font-size:2.25rem;font-family:'DM Serif Display',Georgia,serif;color:#0A0A0A}
    .invest-note{font-size:0.8125rem;color:#aaa;margin-top:0.2rem}
    .invest-badge{background:#f0faf4;color:#1a7a45;font-size:0.75rem;font-weight:700;padding:0.4rem 0.875rem;border-radius:99px;border:1px solid #b6e8cc}
    .includes{list-style:none;display:flex;flex-direction:column;gap:0.5rem}
    .includes li{display:flex;align-items:flex-start;gap:0.65rem;font-size:0.875rem;color:#444;line-height:1.45}
    .includes li::before{content:'✓';color:#1a7a45;font-weight:700;flex-shrink:0;margin-top:0.05rem}

    /* FAQ */
    .faq{margin-top:0.75rem}
    .faq-item{border-bottom:1px solid #f0ede8;padding:0.875rem 0}
    .faq-item:last-child{border-bottom:none;padding-bottom:0}
    .faq-q{font-size:0.875rem;font-weight:600;color:#0A0A0A;margin-bottom:0.35rem}
    .faq-a{font-size:0.8125rem;color:#666;line-height:1.65}

    /* Guarantee */
    .guarantee{display:flex;gap:1rem;padding:1.25rem;background:white;border:1px solid #E8E5E0;border-radius:14px;margin-top:1rem}
    .g-icon{font-size:1.5rem;flex-shrink:0}
    .g-title{font-size:0.875rem;font-weight:700;color:#0A0A0A;margin-bottom:0.25rem}
    .g-text{font-size:0.8125rem;color:#666;line-height:1.65}

    /* CTA */
    .cta-block{background:#0A0A0A;border-radius:14px;padding:2rem;text-align:center;margin-top:1rem}
    .cta-title{font-family:'DM Serif Display',Georgia,serif;font-size:1.5rem;color:white;margin-bottom:0.5rem;font-weight:400}
    .cta-title em{color:#E8B4B0;font-style:italic}
    .cta-sub{font-size:0.875rem;color:rgba(255,255,255,0.4);margin-bottom:1.5rem;line-height:1.7}
    .cta-btn{display:inline-block;background:#E8B4B0;color:#0A0A0A;padding:1rem 2.5rem;border-radius:12px;font-size:1rem;font-weight:700;text-decoration:none;letter-spacing:-0.01em}
    .cta-or{font-size:0.8125rem;color:rgba(255,255,255,0.25);margin:0.875rem 0 0}

    /* Footer */
    .ft{background:#0A0A0A;padding:1.5rem 2.5rem;border-top:1px solid rgba(255,255,255,0.05)}
    .ft-text{font-size:0.75rem;color:rgba(255,255,255,0.2);line-height:1.7}
    .ft-text a{color:rgba(232,180,176,0.5);text-decoration:none}

    hr.div{border:none;border-top:1px solid #E8E5E0;margin:2rem 0}
  </style>
</head>
<body>

<!-- Internal bar -->
<div class="meta-bar">
  <span class="meta-pill">Internal preview</span>
  <span>Email automatically sent after welcome form submission ·</span>
  <span><strong>Example:</strong> Sarah Mitchell · Mitchell & Associates · Law Firm · 5-10 people · Pain: invoice chasing · Tools: Clio + Google Workspace · Budget: €1,500–3,000/mo</span>
</div>

<div class="email-wrap">

  <!-- ═══ HEADER ═══ -->
  <div class="hd">
    <div class="hd-logo">PURIST<span>.</span></div>
    <div class="hd-tag"><span class="hd-dot"></span>Your personalised automation analysis</div>
    <h1 class="hd-h1">Sarah, we've mapped<br/><em>your hidden costs.</em></h1>
    <p class="hd-sub">We reviewed your submission in detail. Below is a full operational analysis of Mitchell & Associates — the inefficiencies we identified, the exact automations we recommend, and the financial impact of each.</p>
    <div class="hd-chips">
      <span class="chip">Law Firm / Legal</span>
      <span class="chip">5–10 employees</span>
      <span class="chip">Clio + Google Workspace</span>
      <span class="chip">Budget: €1,500–3,000/mo</span>
    </div>
  </div>

  <!-- ═══ BODY ═══ -->
  <div class="bd">

    <!-- Intro -->
    <p class="intro">
      Thank you for your submission. We've reviewed your profile carefully — your industry, team size, the tools you use daily, and the specific challenges you described.<br/><br/>
      What follows is not a generic proposal. It's a <strong>targeted operational analysis</strong> built specifically for a law firm running Clio and Google Workspace, with a team of 5–10 people where the primary bottleneck is manual invoice management and client follow-up.<br/><br/>
      We've helped 14 similar firms in the past 18 months. The numbers below are based on that experience — conservative, verifiable, and specific to your situation.
    </p>

    <hr class="div"/>

    <!-- ═══ SECTION 1: Hidden cost ═══ -->
    <div class="sl">Section 01 — The real cost of your current situation</div>
    <div class="card">
      <p style="font-size:0.9375rem;font-weight:700;color:#0A0A0A;margin-bottom:0.5rem">What manual admin is actually costing Mitchell & Associates</p>
      <p style="font-size:0.875rem;color:#666;line-height:1.65;margin-bottom:1rem">Based on a 5–10 person firm with your profile, here is a conservative breakdown of what your current manual processes cost — before any automation.</p>
      <div class="cost-grid">
        <div class="cost-cell">
          <div class="cost-label">Invoice chasing</div>
          <div class="cost-val red">7h / week</div>
          <div class="cost-sub">Drafting reminders, tracking payments, escalating overdue accounts manually</div>
        </div>
        <div class="cost-cell">
          <div class="cost-label">Client intake</div>
          <div class="cost-val red">5h / week</div>
          <div class="cost-sub">Intake forms, conflict checks, matter creation, welcome emails — all done by hand</div>
        </div>
        <div class="cost-cell">
          <div class="cost-label">Deadline tracking</div>
          <div class="cost-val red">4h / week</div>
          <div class="cost-sub">Manually checking calendars, sending reminders, following up on acknowledgements</div>
        </div>
        <div class="cost-cell">
          <div class="cost-label">Late payment impact</div>
          <div class="cost-val red">€8,400 / yr</div>
          <div class="cost-sub">Average cash flow loss from invoices paid 30+ days late at your firm size</div>
        </div>
      </div>
      <div class="cost-total">
        <div class="cost-total-label">Total annual cost of inaction</div>
        <div class="cost-total-val">€66,560 per year</div>
        <div class="cost-total-sub">16 hours/week × €80 average fully-loaded cost × 52 weeks</div>
      </div>
    </div>

    <hr class="div"/>

    <!-- ═══ SECTION 2: Benchmark ═══ -->
    <div class="sl">Section 02 — Where you stand vs. top law firms in Europe</div>
    <div class="card">
      <p style="font-size:0.875rem;color:#666;line-height:1.65;margin-bottom:1rem">We benchmarked your profile against 14 similar firms (5–15 people, Clio or equivalent, UK/EU). Here's where Mitchell & Associates sits today, and where automated firms operate.</p>
      <div class="bench-header">
        <div style="flex:1;font-size:0.6875rem;color:#999;font-weight:600">Metric</div>
        <div class="bench-header-label" style="width:80px;text-align:center">You today</div>
        <div class="bench-header-label" style="width:80px;text-align:center">Automated firms</div>
        <div class="bench-header-label" style="width:160px;text-align:center">Gap</div>
      </div>
      <div class="bench-row">
        <div class="bench-metric">Invoice-to-payment cycle</div>
        <div class="bench-industry">38 days</div>
        <div class="bench-top">12 days</div>
        <div class="bench-bar-wrap"><div class="bench-bar" style="width:70%"></div></div>
      </div>
      <div class="bench-row">
        <div class="bench-metric">Client intake time</div>
        <div class="bench-industry">45 min</div>
        <div class="bench-top">4 min</div>
        <div class="bench-bar-wrap"><div class="bench-bar" style="width:85%"></div></div>
      </div>
      <div class="bench-row">
        <div class="bench-metric">Missed deadline incidents / year</div>
        <div class="bench-industry">3–5</div>
        <div class="bench-top">0</div>
        <div class="bench-bar-wrap"><div class="bench-bar" style="width:90%"></div></div>
      </div>
      <div class="bench-row">
        <div class="bench-metric">Admin hours as % of total hours</div>
        <div class="bench-industry">28%</div>
        <div class="bench-top">7%</div>
        <div class="bench-bar-wrap"><div class="bench-bar" style="width:75%"></div></div>
      </div>
      <div class="bench-row">
        <div class="bench-metric">Late payment rate</div>
        <div class="bench-industry">34%</div>
        <div class="bench-top">6%</div>
        <div class="bench-bar-wrap"><div class="bench-bar" style="width:80%"></div></div>
      </div>
    </div>

    <hr class="div"/>

    <!-- ═══ SECTION 3: Workflows ═══ -->
    <div class="sl">Section 03 — Your 3 automations, ranked by ROI</div>
    <p style="font-size:0.875rem;color:#666;line-height:1.65;margin-bottom:0">Each workflow below was selected specifically for your tool stack (Clio + Google Workspace), your team size, and your primary pain point. They are ranked by time recovered and financial impact.</p>

    <!-- W1 -->
    <div class="wf">
      <div class="wf-head">
        <div>
          <div class="wf-num">Workflow 01 — Deploy first · Highest ROI</div>
          <div class="wf-title">Automated Invoice Dispatch, Chasing & Escalation</div>
        </div>
        <div class="wf-save">Saves 7h / wk</div>
      </div>
      <div class="wf-desc">
        Every invoice in your Clio workflow triggers an automated sequence. The invoice is generated, formatted, and sent. If unpaid at day 7, a personalised reminder goes out — referencing the matter by name, not a generic template. At day 14, a firmer notice with payment link. At day 30, your billing partner receives a fully drafted final notice ready to send. Every step is logged, auditable, and stops the moment payment is received.
      </div>
      <div class="steps">
        <div class="steps-title">Exact steps — what happens automatically</div>
        <div class="step-item"><div class="step-n">1</div><div class="step-text">Billing milestone reached in Clio → invoice auto-generated with correct matter reference, fee earner name, and bank details</div></div>
