---
// Internal preview — noindex
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <meta name="robots" content="noindex,nofollow"/>
  <title>Proposal Preview · PURIST Internal</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;background:#111;color:#0A0A0A;-webkit-font-smoothing:antialiased;line-height:1}

    /* Meta bar */
    .meta-bar{background:#0A0A0A;border-bottom:1px solid rgba(232,180,176,0.15);padding:0.75rem 1.5rem;font-size:0.75rem;color:rgba(255,255,255,0.35);display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;position:sticky;top:0;z-index:10}
    .meta-pill{background:rgba(232,180,176,0.12);color:#E8B4B0;padding:0.2rem 0.75rem;border-radius:99px;font-size:0.625rem;letter-spacing:0.14em;font-weight:600;text-transform:uppercase}

    /* Email wrapper */
    .email-wrap{max-width:680px;margin:2.5rem auto;border-radius:20px;overflow:hidden;box-shadow:0 24px 80px rgba(0,0,0,0.6);position:relative}

    /* BG logo watermark */
    .bg-logo{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'DM Serif Display',Georgia,serif;font-size:18rem;font-weight:400;color:rgba(232,180,176,0.035);pointer-events:none;white-space:nowrap;letter-spacing:-0.04em;line-height:1;z-index:0;user-select:none}

    /* All content above watermark */
    .email-content{position:relative;z-index:1}

    /* Header */
    .hd{background:#0A0A0A;padding:2.75rem 2.5rem 2.25rem}
    .hd-logo{font-family:'DM Serif Display',Georgia,serif;font-size:1.375rem;color:white;margin-bottom:2.25rem;letter-spacing:-0.02em}
    .hd-logo span{color:#E8B4B0}
    .hd-tag{display:inline-flex;align-items:center;gap:0.5rem;background:rgba(232,180,176,0.1);border:1px solid rgba(232,180,176,0.18);color:#E8B4B0;font-size:0.625rem;letter-spacing:0.18em;text-transform:uppercase;padding:0.4rem 1rem;border-radius:99px;margin-bottom:1.25rem;font-weight:600}
    .hd-dot{width:5px;height:5px;border-radius:50%;background:#E8B4B0;animation:pulse 2s ease-in-out infinite;flex-shrink:0}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:0.35}}
    .hd-h1{font-family:'DM Serif Display',Georgia,serif;font-size:2.125rem;color:white;line-height:1.18;font-weight:400;margin-bottom:1rem}
    .hd-h1 em{color:#E8B4B0;font-style:italic}
    .hd-sub{font-size:0.875rem;color:rgba(255,255,255,0.38);line-height:1.72;max-width:500px}
    .hd-chips{display:flex;gap:0.4rem;flex-wrap:wrap;margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid rgba(255,255,255,0.06)}
    .chip{font-size:0.6875rem;background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.4);padding:0.3rem 0.8rem;border-radius:99px;border:1px solid rgba(255,255,255,0.08)}

    /* Progress bar */
    .progress{background:#0A0A0A;padding:0 2.5rem 2rem;display:flex;gap:0;border-bottom:1px solid rgba(255,255,255,0.05)}
    .prog-step{flex:1;text-align:center}
    .prog-line{height:2px;background:rgba(255,255,255,0.06);position:relative;margin-bottom:0.5rem}
    .prog-line.active{background:linear-gradient(90deg,#E8B4B0,rgba(232,180,176,0.3))}
    .prog-label{font-size:0.5625rem;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.2);font-weight:600}
    .prog-label.active{color:rgba(232,180,176,0.7)}

    /* Body */
    .bd{background:#F8F6F1;padding:2.25rem 2.5rem;}
    .signature{background:#0A0A0A;padding:1.5rem 2.5rem 0;overflow:hidden;}
    .signature-logo{
      font-family:'DM Serif Display',Georgia,serif;
      font-size:clamp(5rem,18vw,12rem);
      font-weight:500;
      letter-spacing:-0.02em;
      line-height:0.85;
      user-select:none;
      pointer-events:none;
      background:linear-gradient(115deg,rgba(232,180,176,0.55) 0%,rgba(255,255,255,0.75) 25%,rgba(164,139,250,0.55) 50%,rgba(232,180,176,0.55) 75%,rgba(255,255,255,0.7) 100%);
      background-size:300% 300%;
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
      background-clip:text;
      animation:footer-shimmer 8s ease-in-out infinite;
    }
    @keyframes footer-shimmer{
      0%{background-position:0% 50%}
      50%{background-position:100% 50%}
      100%{background-position:0% 50%}
    }

    /* Divider */
    .div{border:none;border-top:1px solid rgba(10,10,10,0.07);margin:2.25rem 0}

    /* Section label */
    .sl{font-size:0.5625rem;letter-spacing:0.22em;text-transform:uppercase;color:#E8B4B0;font-weight:700;margin-bottom:0.875rem;display:flex;align-items:center;gap:0.75rem}
    .sl::after{content:'';flex:1;height:1px;background:rgba(232,180,176,0.2)}

    /* Intro */
    .intro{font-size:0.9375rem;line-height:1.8;color:#444;margin-bottom:0}
    .intro strong{color:#0A0A0A;font-weight:600}

    /* Cards */
    .card{background:white;border:1px solid rgba(10,10,10,0.07);border-radius:16px;padding:1.625rem;margin-top:1rem}
    .card-dark{background:#0A0A0A;border-radius:16px;padding:1.625rem;margin-top:1rem}

    /* Cost grid */
    .cost-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-top:1rem}
    .cost-cell{background:#F8F6F1;border:1px solid rgba(10,10,10,0.07);border-radius:12px;padding:1rem 1.125rem}
    .cost-label{font-size:0.5625rem;letter-spacing:0.14em;text-transform:uppercase;color:#999;font-weight:700;margin-bottom:0.5rem}
    .cost-val{font-size:1.25rem;font-weight:700;color:#0A0A0A;font-family:'DM Serif Display',Georgia,serif}
    .cost-val.muted{color:#C97B6A}
    .cost-sub{font-size:0.75rem;color:#aaa;margin-top:0.35rem;line-height:1.45}
    .cost-total{background:#0A0A0A;border-radius:12px;padding:1.25rem 1.5rem;margin-top:0.75rem;display:flex;justify-content:space-between;align-items:center;gap:1rem}
    .cost-total-left{}
    .cost-total-label{font-size:0.5625rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.3);font-weight:600;margin-bottom:0.35rem}
    .cost-total-val{font-size:1.75rem;font-family:'DM Serif Display',Georgia,serif;color:white}
    .cost-total-note{font-size:0.75rem;color:rgba(255,255,255,0.25);line-height:1.5;max-width:200px;text-align:right}

    /* Benchmark */
    .bench-head{display:grid;grid-template-columns:1fr 90px 90px 150px;gap:0.5rem;padding:0 0 0.625rem;border-bottom:1px solid rgba(10,10,10,0.07);margin-bottom:0}
    .bench-head span{font-size:0.5625rem;letter-spacing:0.12em;text-transform:uppercase;color:#bbb;font-weight:700;text-align:center}
    .bench-head span:first-child{text-align:left}
    .bench-row{display:grid;grid-template-columns:1fr 90px 90px 150px;gap:0.5rem;align-items:center;padding:0.75rem 0;border-bottom:1px solid rgba(10,10,10,0.05)}
    .bench-row:last-child{border-bottom:none}
    .bench-metric{font-size:0.8375rem;color:#555;line-height:1.3}
    .bench-you{font-size:0.875rem;font-weight:700;color:#C97B6A;text-align:center}
    .bench-top{font-size:0.875rem;font-weight:700;color:#0A0A0A;text-align:center}
    .bench-bar-wrap{height:6px;background:#F0EDE8;border-radius:99px;overflow:hidden;position:relative}
    .bench-bar{height:100%;border-radius:99px;background:linear-gradient(90deg,#E8B4B0,rgba(232,180,176,0.4))}

    /* Workflow */
    .wf{background:white;border:1px solid rgba(10,10,10,0.07);border-radius:16px;margin-top:0.875rem;overflow:hidden}
    .wf-head{padding:1.375rem 1.5rem 0;display:flex;justify-content:space-between;align-items:flex-start;gap:0.75rem}
    .wf-num{font-size:0.5625rem;letter-spacing:0.18em;text-transform:uppercase;color:#bbb;font-weight:700;margin-bottom:0.3rem}
    .wf-title{font-size:1rem;font-weight:700;color:#0A0A0A;line-height:1.3;font-family:'DM Serif Display',Georgia,serif}
    .wf-save{background:rgba(10,10,10,0.06);color:#0A0A0A;font-size:0.75rem;font-weight:700;padding:0.35rem 0.875rem;border-radius:99px;border:1px solid rgba(10,10,10,0.1);white-space:nowrap;flex-shrink:0}
    .wf-desc{font-size:0.875rem;color:#555;line-height:1.72;padding:0.875rem 1.5rem}
    .steps{padding:0 1.5rem;margin-bottom:1rem}
    .steps-title{font-size:0.5625rem;letter-spacing:0.14em;text-transform:uppercase;color:#ccc;font-weight:700;margin-bottom:0.625rem}
    .step-item{display:flex;gap:0.75rem;align-items:flex-start;padding:0.35rem 0}
    .step-n{width:18px;height:18px;background:#0A0A0A;color:white;border-radius:50%;font-size:0.5625rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:0.15rem}
    .step-text{font-size:0.8125rem;color:#555;line-height:1.55}
    .specs{background:#F8F6F1;border-top:1px solid rgba(10,10,10,0.06);padding:1rem 1.5rem;display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem}
    .spec-k{font-size:0.5625rem;text-transform:uppercase;letter-spacing:0.12em;color:#bbb;margin-bottom:0.3rem;font-weight:700}
    .spec-v{font-size:0.8125rem;font-weight:700;color:#0A0A0A}
    .tools-row{padding:0.75rem 1.5rem;border-top:1px solid rgba(10,10,10,0.06);display:flex;gap:0.4rem;flex-wrap:wrap;align-items:center}
    .tool-label{font-size:0.5625rem;text-transform:uppercase;letter-spacing:0.1em;color:#bbb;margin-right:0.25rem;font-weight:700}
    .tool-tag{font-size:0.6875rem;background:#F0EDE8;color:#666;padding:0.2rem 0.65rem;border-radius:99px;border:1px solid rgba(10,10,10,0.08)}

    /* Before / After — brand colors */
    .ba-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-top:1rem}
    .ba-col{border-radius:14px;padding:1.375rem}
    .ba-col.before{background:rgba(10,10,10,0.04);border:1px solid rgba(10,10,10,0.08)}
    .ba-col.after{background:rgba(232,180,176,0.08);border:1px solid rgba(232,180,176,0.2)}
    .ba-label{font-size:0.5625rem;letter-spacing:0.15em;text-transform:uppercase;font-weight:700;margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem}
    .ba-label.before{color:#888}
    .ba-label.after{color:#C97B6A}
    .ba-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
    .ba-dot.before{background:#bbb}
    .ba-dot.after{background:#E8B4B0}
    .ba-item{display:flex;align-items:flex-start;gap:0.625rem;margin-bottom:0.5rem;font-size:0.8125rem;line-height:1.5;color:#555}
    .ba-item.before .ba-mark{color:#bbb;flex-shrink:0;font-size:0.75rem;margin-top:0.05rem}
    .ba-item.after .ba-mark{color:#E8B4B0;flex-shrink:0;font-size:0.75rem;margin-top:0.05rem}
    .ba-total{margin-top:0.875rem;padding-top:0.875rem;border-top:1px solid rgba(10,10,10,0.07);font-size:0.8125rem;font-weight:700}
    .ba-total.before{color:#888}
    .ba-total.after{color:#0A0A0A}

    /* ROI dark block */
    .roi{background:#0A0A0A;border-radius:16px;padding:1.875rem;margin-top:1rem}
    .roi-label{font-size:0.5625rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(232,180,176,0.45);font-weight:700;margin-bottom:1.375rem}
    .roi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.375rem}
    .roi-cell{text-align:center}
    .roi-val{font-size:1.625rem;font-family:'DM Serif Display',Georgia,serif;color:white}
    .roi-val.pink{color:#E8B4B0}
    .roi-lbl{font-size:0.5625rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.25);margin-top:0.3rem}
    .roi-note{font-size:0.75rem;color:rgba(255,255,255,0.22);line-height:1.65;border-top:1px solid rgba(255,255,255,0.06);padding-top:1.125rem}

    /* Projection */
    .proj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(10,10,10,0.08);border-radius:14px;overflow:hidden;margin-top:1rem}
    .proj-cell{background:white;padding:1.375rem;text-align:center}
    .proj-month{font-size:0.5625rem;letter-spacing:0.15em;text-transform:uppercase;color:#bbb;font-weight:700;margin-bottom:0.5rem}
    .proj-val{font-size:1.5rem;font-family:'DM Serif Display',Georgia,serif;color:#0A0A0A}
    .proj-sub{font-size:0.75rem;color:#aaa;margin-top:0.3rem;line-height:1.5}

    /* Case study */
    .case{background:white;border:1px solid rgba(10,10,10,0.07);border-radius:16px;padding:1.625rem;margin-top:1rem}
    .case-quote{font-size:1rem;font-family:'DM Serif Display',Georgia,serif;color:#0A0A0A;line-height:1.55;font-style:italic;margin-bottom:1.25rem;padding-left:1.125rem;border-left:2px solid #E8B4B0}
    .case-author{display:flex;align-items:center;gap:0.875rem}
    .case-avatar{width:38px;height:38px;border-radius:50%;object-fit:cover;border:2px solid #F0EDE8}
    .case-name{font-size:0.875rem;font-weight:700;color:#0A0A0A}
    .case-role{font-size:0.75rem;color:#aaa}
    .case-results{display:grid;grid-template-columns:repeat(3,1fr);gap:0;margin-top:1.375rem;background:#F8F6F1;border-radius:12px;overflow:hidden;border:1px solid rgba(10,10,10,0.07)}
    .case-kv{text-align:center;padding:1rem;border-right:1px solid rgba(10,10,10,0.07)}
    .case-kv:last-child{border-right:none}
    .case-v{font-size:1.125rem;font-weight:700;color:#0A0A0A;font-family:'DM Serif Display',Georgia,serif}
    .case-k{font-size:0.5625rem;text-transform:uppercase;letter-spacing:0.1em;color:#bbb;margin-top:0.2rem;font-weight:700}

    /* Timeline */
    .tl{margin-top:1rem}
    .tl-row{display:flex;gap:1.25rem;padding:1rem 0;border-bottom:1px solid rgba(10,10,10,0.06)}
    .tl-row:last-child{border-bottom:none;padding-bottom:0}
    .tl-left{width:80px;flex-shrink:0}
    .tl-day{font-size:0.6875rem;color:#E8B4B0;font-weight:700}
    .tl-bar{width:1px;background:rgba(10,10,10,0.08);margin:0.35rem auto 0;height:calc(100% + 1rem)}
    .tl-title{font-size:0.9rem;font-weight:700;color:#0A0A0A;margin-bottom:0.3rem;font-family:'DM Serif Display',Georgia,serif}
    .tl-desc{font-size:0.8125rem;color:#666;line-height:1.6}

    /* Risk section */
    .risk{background:white;border:1px solid rgba(10,10,10,0.07);border-radius:16px;padding:1.625rem;margin-top:1rem}
    .risk-row{display:flex;gap:1rem;margin-bottom:0.875rem;align-items:flex-start}
    .risk-row:last-child{margin-bottom:0}
    .risk-icon-wrap{width:32px;height:32px;border-radius:8px;background:#F8F6F1;border:1px solid rgba(10,10,10,0.07);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:0.875rem}
    .risk-title{font-size:0.875rem;font-weight:700;color:#0A0A0A;margin-bottom:0.2rem}
    .risk-desc{font-size:0.8125rem;color:#666;line-height:1.6}

    /* Bonus section */
    .bonus{background:#0A0A0A;border-radius:16px;padding:1.625rem;margin-top:1rem}
    .bonus-label{font-size:0.5625rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(232,180,176,0.45);font-weight:700;margin-bottom:1.25rem}
    .bonus-item{display:flex;gap:1rem;align-items:flex-start;margin-bottom:1rem;padding-bottom:1rem;border-bottom:1px solid rgba(255,255,255,0.05)}
    .bonus-item:last-child{margin-bottom:0;padding-bottom:0;border-bottom:none}
    .bonus-badge{background:rgba(232,180,176,0.1);border:1px solid rgba(232,180,176,0.2);border-radius:8px;padding:0.5rem;flex-shrink:0;font-size:1rem;width:36px;height:36px;display:flex;align-items:center;justify-content:center}
    .bonus-title{font-size:0.875rem;font-weight:600;color:white;margin-bottom:0.2rem;display:flex;align-items:center;gap:0.5rem}
    .bonus-value{font-size:0.6875rem;color:#E8B4B0;background:rgba(232,180,176,0.1);padding:0.15rem 0.5rem;border-radius:99px;font-weight:600}
    .bonus-desc{font-size:0.8rem;color:rgba(255,255,255,0.35);line-height:1.55}

    /* Investment */
    .invest{background:white;border:1px solid rgba(10,10,10,0.07);border-radius:16px;padding:1.625rem;margin-top:1rem}
    .invest-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.375rem;gap:1rem;flex-wrap:wrap}
    .invest-amount{font-size:2.5rem;font-family:'DM Serif Display',Georgia,serif;color:#0A0A0A;line-height:1}
    .invest-note{font-size:0.8125rem;color:#aaa;margin-top:0.35rem}
    .invest-badge{background:#F0EDE8;color:#0A0A0A;font-size:0.75rem;font-weight:700;padding:0.45rem 1rem;border-radius:99px;border:1px solid rgba(10,10,10,0.1);white-space:nowrap}
    .includes{list-style:none;display:flex;flex-direction:column;gap:0.5rem}
    .includes li{display:flex;align-items:flex-start;gap:0.75rem;font-size:0.875rem;color:#444;line-height:1.5}
    .inc-check{width:16px;height:16px;border-radius:50%;background:#0A0A0A;color:white;display:flex;align-items:center;justify-content:center;font-size:0.5rem;flex-shrink:0;margin-top:0.15rem;font-weight:700}

    /* FAQ */
    .faq{margin-top:1rem}
    .faq-item{border-bottom:1px solid rgba(10,10,10,0.06);padding:1rem 0}
    .faq-item:first-child{padding-top:0}
    .faq-item:last-child{border-bottom:none;padding-bottom:0}
    .faq-q{font-size:0.875rem;font-weight:700;color:#0A0A0A;margin-bottom:0.35rem}
    .faq-a{font-size:0.8125rem;color:#666;line-height:1.68}

    /* Guarantee */
    .guarantee{background:white;border:1px solid rgba(10,10,10,0.07);border-radius:16px;padding:1.375rem;margin-top:1rem;display:flex;gap:1rem;align-items:flex-start}
    .g-icon{font-size:1.375rem;flex-shrink:0;margin-top:0.1rem}
    .g-title{font-size:0.875rem;font-weight:700;color:#0A0A0A;margin-bottom:0.3rem}
    .g-text{font-size:0.8125rem;color:#666;line-height:1.65}

    /* Social proof strip */
    .proof-strip{background:#F0EDE8;border-radius:14px;padding:1.125rem 1.5rem;margin-top:1rem;display:flex;gap:1.5rem;align-items:center;flex-wrap:wrap;justify-content:space-between}
    .proof-item{text-align:center}
    .proof-val{font-size:1.25rem;font-family:'DM Serif Display',Georgia,serif;color:#0A0A0A}
    .proof-label{font-size:0.5625rem;letter-spacing:0.12em;text-transform:uppercase;color:#aaa;margin-top:0.2rem;font-weight:600}

    /* CTA */
    .cta-block{background:#0A0A0A;border-radius:16px;padding:2.25rem;text-align:center;margin-top:1rem}
    .cta-title{font-family:'DM Serif Display',Georgia,serif;font-size:1.75rem;color:white;margin-bottom:0.625rem;font-weight:400;line-height:1.25}
    .cta-title em{color:#E8B4B0;font-style:italic}
    .cta-sub{font-size:0.875rem;color:rgba(255,255,255,0.35);margin-bottom:1.75rem;line-height:1.7;max-width:380px;margin-left:auto;margin-right:auto}
    .cta-btn{display:inline-block;background:#E8B4B0;color:#0A0A0A;padding:1rem 2.5rem;border-radius:12px;font-size:0.9375rem;font-weight:700;text-decoration:none;letter-spacing:-0.01em}
    .cta-alt{font-size:0.8rem;color:rgba(255,255,255,0.2);margin-top:1rem}
    .cta-urgency{display:inline-block;background:rgba(232,180,176,0.1);border:1px solid rgba(232,180,176,0.18);color:rgba(232,180,176,0.7);font-size:0.6875rem;padding:0.3rem 0.875rem;border-radius:99px;margin-bottom:1.25rem;letter-spacing:0.1em}

    /* Footer */
    .ft{background:#0A0A0A;padding:1.75rem 2.5rem;border-top:1px solid rgba(255,255,255,0.04)}
    .ft-logo{font-family:'DM Serif Display',Georgia,serif;font-size:1rem;color:rgba(255,255,255,0.25);margin-bottom:0.75rem}
    .ft-logo span{color:rgba(232,180,176,0.35)}
    .ft-text{font-size:0.75rem;color:rgba(255,255,255,0.15);line-height:1.7}
