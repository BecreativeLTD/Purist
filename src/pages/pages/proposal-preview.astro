        <div class="step-item"><div class="step-n">6</div><div class="step-text">Payment received → sequence stops immediately, Clio matter updated, no double messages ever</div></div>
      </div>
      <div class="specs">
        <div><div class="spec-k">Time saved</div><div class="spec-v">7h / week</div></div>
        <div><div class="spec-k">Annual value</div><div class="spec-v">€29,120</div></div>
