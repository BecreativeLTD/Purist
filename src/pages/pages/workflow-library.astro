 { industry:'agency', complexity:'Intermediate', badge:null,       time:'4h/wk', title:'Freelancer onboarding and brief',             benefit:'Contractors are productive on day 1 and legally protected from day 0.', desc:'New freelancer added to project. Workflow sends NDA for signature, project brief document, brand guidelines, tool access, and a check-in call booking link. All tracked in one place.', tools:['n8n','DocuSign','Notion'] },

 // E-commerce
 { industry:'ecommerce', complexity:'Starter',    badge:'Popular',  time:'8h/wk', title:'Abandoned cart recovery sequence',           benefit:'Recover 10-15% of abandoned baskets automatically.',        desc:'Cart abandoned triggers a 3-message sequence: reminder at 1h, social proof email at 24h, and a small incentive at 72h. Sequence stops the moment the order is placed.',                      tools:['n8n','Klaviyo','Shopify'] },
 { industry:'ecommerce', complexity:'Starter',    badge:'Popular',  time:'5h/wk', title:'Post-purchase review and upsell flow',       benefit:'Turn buyers into repeat customers and brand advocates.',      desc:'Order delivered triggers a thank-you with care instructions, a review request at day 5, and a personalised cross-sell recommendation at day 14 based on purchase history.',                   tools:['n8n','Klaviyo','Shopify'] },
 { industry:'ecommerce', complexity:'Intermediate', badge:null,       time:'6h/wk', title:'Inventory alert and reorder workflow',        benefit:'Avoid stockouts on your bestsellers. Permanently.',          desc:'Daily stock check against 30-day velocity. SKUs tracking toward zero get a reorder alert to the buyer with suggested order quantity. Low-stock badge updated on the product page automatically.', tools:['n8n','Shopify','Slack'] },
 { industry:'ecommerce', complexity:'Intermediate', badge:'AI-powered', time:'7h/wk', title:'AI product description writer',              benefit:'Launch new products in hours, not days.',                    desc:'New product created in Shopify. Claude AI reads the product specs, target audience, and brand guidelines, writes SEO-optimised title and description, and publishes directly. Consistent quality at scale.', tools:['n8n','Claude AI','Shopify'] },
 { industry:'ecommerce', complexity:'Advanced',   badge:null,       time:'10h/wk', title:'Returns and refund automation',              benefit:'Handle returns in minutes, not days. Reduce customer frustration.', desc:'Refund request received. Policy check automated. Pre-paid return label generated and sent. Refund queued in Stripe on delivery confirmation. Customer kept informed at every step.',      tools:['n8n','Shopify','Stripe'] },
 { industry:'ecommerce', complexity:'Intermediate', badge:'Popular',  time:'5h/wk', title:'VIP customer recognition programme',         benefit:'Your best customers feel known, not just served.',           desc:'Orders above a lifetime value threshold automatically upgrade the customer to VIP status: personalised welcome from the founder, early access to launches, priority support routing, and exclusive codes.', tools:['n8n','Klaviyo','Shopify'] },
 { industry:'ecommerce', complexity:'Intermediate', badge:null,       time:'5h/wk', title:'Multi-channel stock sync',                    benefit:'Avoid overselling on one channel while sitting on stock elsewhere.', desc:'Every order on any channel (Shopify, Amazon, Etsy) updates the central inventory count in real-time. Low stock on any channel triggers a reorder alert and updates the listing automatically.', tools:['n8n','Shopify','Slack'] },
 { industry:'ecommerce', complexity:'Starter',    badge:'Popular',  time:'3h/wk', title:'Back-in-stock and price drop alerts',         benefit:'Recapture customers who wanted to buy but could not.',       desc:'Customer joins waitlist for an out-of-stock item. When stock arrives or price drops, a personalised alert is sent within 5 minutes. Conversion rate 3 times higher than standard emails.',   tools:['n8n','Klaviyo','Shopify'] },
 { industry:'ecommerce', complexity:'Intermediate', badge:'AI-powered', time:'6h/wk', title:'Influencer gifting and UGC tracker',          benefit:'Turn your gifting budget into a measurable content pipeline.', desc:'Influencer added to list. Workflow sends personalised outreach, collects shipping details, triggers Shopify gift order, sets follow-up reminders for content submission, and logs posted content.', tools:['n8n','Claude AI','Shopify'] },
 { industry:'ecommerce', complexity:'Advanced',   badge:null,       time:'8h/wk', title:'Subscription lifecycle management',           benefit:'Run a subscription business on autopilot, from trial to long-term renewal.', desc:'Handles every event: trial end, first billing, payment failure retry, pause request, cancellation save attempt, reactivation, and anniversary reward. Each step has the right email and offer.', tools:['n8n','Stripe','Klaviyo'] },
];

const complexityColor: Record<string, string> = {
 'Starter':    'rgba(45,128,73,0.10)',
 'Intermediate': 'rgba(200,152,64,0.12)',
 'Advanced':   'rgba(123,104,238,0.12)',
};
const complexityText: Record<string, string> = {
 'Starter':    '#2D8049',
 'Intermediate': '#C89840',
 'Advanced':   '#7B68EE',
};
---

<ShopLayout
 title="Workflow Library 127+ Automation Templates | PURIST"
 description="127+ production-ready n8n automation workflows organised by function and industry: dental, real estate, hotels, call centres, agencies, e-commerce."
>

 <!-- Hero -->
 <section class="bg-brand-black text-white pt-20 pb-14 lg:pt-28 lg:pb-18 relative overflow-hidden">
   <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 50% 0%,rgba(232,180,176,0.07) 0%,transparent 60%);"></div>
   <div class="container-x relative z-10">
     <p class="text-[9px] uppercase tracking-[0.28em] font-bold mb-4" style="color:rgba(232,180,176,0.55);">Workflow Library</p>
     <div class="max-w-3xl mb-10">
       <h1 class="font-display text-[2.2rem] lg:text-[3rem] leading-[1.06] tracking-[-0.025em] text-white mb-4 text-balance">
         127+ production-ready workflows.<br/>
         <em class="font-medium" style="color:#E8B4B0;">Each one built around a real business outcome.</em>
       </h1>
       <p class="text-[15px] leading-relaxed max-w-2xl" style="color:rgba(255,255,255,0.45);">
         Browse by function or by industry. Every template is battle-tested across 500+ deployments. PURIST deploys any of these for you, customised to your exact stack, in days.
       </p>
     </div>

     <!-- Stats row -->
     <div class="flex flex-wrap gap-6 mb-10">
       {[
         { n: '127+', label: 'workflows' },
         { n: '6',  label: 'industries' },
         { n: '500+', label: 'deployments' },
         { n: '14h', label: 'avg saved/wk' },
       ].map(s => (
         <div>
           <p class="text-[1.4rem] font-display font-semibold text-white leading-none">{s.n}</p>
           <p class="text-[10px] mt-0.5" style="color:rgba(255,255,255,0.35);">{s.label}</p>
         </div>
       ))}
     </div>

     <!-- Search + View toggle row -->
     <div class="flex flex-col sm:flex-row sm:items-center gap-4">

       <!-- Search input -->
       <div class="relative flex-1 max-w-sm">
         <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.35)" stroke-width="1.8" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
         <input
           id="workflow-search"
           type="search"
           placeholder="Search workflows…"
           autocomplete="off"
           class="w-full pl-9 pr-4 py-2.5 rounded-full text-[12px] outline-none transition-all"
           style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.80);"
         />
       </div>
       <div id="search-count" class="hidden text-[11px]" style="color:rgba(255,255,255,0.35);"></div>

       <!-- View toggle -->
       <div class="flex items-center gap-1 p-1 rounded-full w-fit" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.10);">
         <button id="tab-function" class="view-tab px-5 py-2 rounded-full text-[12px] font-semibold transition-all" style="background:#E8B4B0;color:#0A0A0A;">By Function</button>
         <button id="tab-industry" class="view-tab px-5 py-2 rounded-full text-[12px] font-semibold transition-all" style="background:transparent;color:rgba(255,255,255,0.55);">By Industry</button>
       </div>
     </div>

   </div>
 </section>

 <!-- ═══════════════════════════════════════════════════════════
      FUNCTION VIEW
 ═══════════════════════════════════════════════════════════ -->
 <div id="view-function">

   <!-- Sticky filter bar -->
   <div class="sticky top-16 z-20 bg-brand-black border-b" style="border-color:rgba(255,255,255,0.07);">
     <div class="container-x py-3 flex flex-wrap gap-2" id="func-filters">
       <button class="func-btn active text-[11px] font-semibold px-3.5 py-1.5 rounded-full transition-all" data-cat="all"
         style="background:#E8B4B0;color:#0A0A0A;">All</button>
       {funcCategories.map(c => (
         <button class="func-btn text-[11px] font-semibold px-3.5 py-1.5 rounded-full transition-all" data-cat={c.id}
           style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.55);border:1px solid rgba(255,255,255,0.09);"
           aria-label={`Filter by ${c.label}`}>{c.label}</button>
       ))}
     </div>
   </div>

   <!-- Category cards -->
   <section class="bg-white border-b border-brand-gray-100 py-8">
     <div class="container-x grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
       {funcCategories.map(c => (
         <button class="func-card text-left p-4 rounded-[14px] border border-brand-gray-100 hover:border-brand-gray-200 hover:bg-brand-cream transition cursor-pointer" data-cat={c.id} aria-label={`Show ${c.label} workflows`}>
           <div class="flex items-start justify-between mb-3">
             <div class="w-9 h-9 rounded-[10px] flex items-center justify-center" style={`background:${c.color}18;`}>
               <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke={c.color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
             </div>
             <span class="text-[9px] font-bold text-brand-gray-400">{c.count}</span>
           </div>
           <p class="text-[12px] font-semibold text-brand-black leading-snug mb-0.5">{c.label}</p>
           <p class="text-[10px] text-brand-gray-400">{c.topStat} saved</p>
         </button>
       ))}
     </div>
   </section>

   <!-- Workflow grid -->
   <section class="bg-brand-beige py-16 lg:py-20">
     <div class="container-x">
       <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="func-grid">
         {funcWorkflows.map(w => (
           <article class="func-workflow-card bg-white rounded-card p-6 flex flex-col border border-brand-gray-100 hover:border-brand-gray-200 hover:shadow-sm transition" data-cat={w.cat}>
             <div class="flex items-center justify-between gap-3 mb-3">
               <span class="text-[10px] font-bold px-2 py-0.5 rounded-full" style={`background:${complexityColor[w.complexity]};color:${complexityText[w.complexity]};`}>{w.complexity}</span>
               <div class="flex items-center gap-2">
                 {w.n8n && (
                   <a href={w.n8n} target="_blank" rel="noopener noreferrer"
                     class="text-[9px] font-semibold px-2 py-0.5 rounded-full border transition-all"
                     style="background:rgba(232,180,176,0.10);color:#c4847e;border-color:rgba(232,180,176,0.20);"
                     onmouseover="this.style.background='rgba(232,180,176,0.22)'"
                     onmouseout="this.style.background='rgba(232,180,176,0.10)'"
                     aria-label="View template on n8n.io">n8n template ↗</a>
                 )}
                 {w.badge && (
                   <span class="text-[9px] uppercase tracking-wider font-bold px-2 py-0.5 rounded-full"
                     style={w.badge === 'AI-powered' ? 'background:rgba(123,104,238,0.10);color:#7B68EE;' : 'background:rgba(232,180,176,0.15);color:#c4847e;'}>
                     {w.badge}
                   </span>
                 )}
               </div>
             </div>
             <h3 class="font-display text-[15px] leading-snug text-brand-black mb-2">{w.title}</h3>
             <p class="text-[12px] font-semibold mb-3 leading-snug" style="color:#E8875A;">{w.benefit}</p>
             <p class="text-[12.5px] text-brand-gray-600 leading-relaxed flex-1 mb-4">{w.desc}</p>
             <div class="flex flex-wrap gap-1.5 mb-4">
               {w.tools.map(t => (
                 <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-brand-gray-50 border border-brand-gray-200 text-brand-gray-600">{t}</span>
               ))}
             </div>
             <div class="flex items-center justify-between pt-4 border-t border-brand-gray-100">
               <span class="text-[11px] font-semibold text-brand-black">{w.time} saved</span>
               <a href="/pages/welcome" class="text-[11px] font-semibold transition-all" style="color:#E8B4B0;"
                 onmouseover="this.style.color='#c4847e'" onmouseout="this.style.color='#E8B4B0'">Deploy this ↗</a>
             </div>
           </article>
         ))}
       </div>
       <div id="func-empty" class="hidden text-center py-16">
         <p class="text-brand-gray-500 text-sm">No workflows match this filter.</p>
       </div>
     </div>
   </section>

 </div>

 <!-- ═══════════════════════════════════════════════════════════
      INDUSTRY VIEW
 ═══════════════════════════════════════════════════════════ -->
 <div id="view-industry" class="hidden">

   <!-- Industry picker -->
   <div class="sticky top-16 z-20 bg-brand-black border-b" style="border-color:rgba(255,255,255,0.07);">
     <div class="container-x py-3 flex flex-wrap gap-2" id="ind-filters">
       <button class="ind-btn active text-[11px] font-semibold px-3.5 py-1.5 rounded-full transition-all" data-ind="all"
         style="background:#E8B4B0;color:#0A0A0A;">All industries</button>
       {industries.map(i => (
         <button class="ind-btn text-[11px] font-semibold px-3.5 py-1.5 rounded-full transition-all inline-flex items-center gap-1.5" data-ind={i.id}
           style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.55);border:1px solid rgba(255,255,255,0.09);"
           aria-label={`Show ${i.label} workflows`}>
           <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-3 h-3 shrink-0">
             <Fragment set:html={i.svgInner} />
           </svg>
           {i.label}
         </button>
       ))}
     </div>
   </div>

   <!-- Industry hero cards -->
   <section class="bg-white border-b border-brand-gray-100 py-8">
     <div class="container-x grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
       {industries.map(i => (
         <button class="ind-card text-left p-4 rounded-[14px] border border-brand-gray-100 hover:border-brand-gray-200 hover:bg-brand-cream transition cursor-pointer" data-ind={i.id} aria-label={`Show ${i.label} workflows`}>
           <!-- Icon + count -->
           <div class="flex items-start justify-between mb-3">
             <div class="w-10 h-10 rounded-[10px] flex items-center justify-center" style={`background:${i.color}18;`}>
               <svg viewBox="0 0 24 24" fill="none" stroke={i.color} stroke-width="1.5" class="w-5 h-5">
                 <Fragment set:html={i.svgInner} />
               </svg>
             </div>
             <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full" style={`background:${i.color}15;color:${i.color};`}>{i.workflows}</span>
           </div>
           <!-- Name + tagline -->
           <p class="text-[12.5px] font-semibold text-brand-black leading-snug">{i.label}</p>
           <!-- Key metric -->
           <p class="text-[10px] font-semibold mt-0.5 mb-2" style={`color:${i.color};`}>{i.metric}</p>
           <!-- Stat -->
           <div class="flex items-baseline gap-1 mb-2">
             <span class="text-[12px] font-bold text-brand-black">{i.stat}</span>
             <span class="text-[9px] text-brand-gray-400 leading-none">{i.statLabel}</span>
           </div>
           <!-- Desc -->
           <p class="text-[9.5px] text-brand-gray-500 leading-snug">{i.desc}</p>
         </button>
       ))}
     </div>
   </section>

   <!-- Industry workflow sections -->
   <section class="bg-brand-beige py-16 lg:py-20">
     <div class="container-x space-y-16" id="ind-sections">

       {industries.map(ind => {
         const iw = industryWorkflows.filter(w => w.industry === ind.id);
         return (
           <div class="ind-section" data-ind={ind.id}>
             <!-- Section header -->
             <div class="flex items-center gap-4 mb-8">
               <div class="w-14 h-14 rounded-[16px] flex items-center justify-center shrink-0" style={`background:${ind.color}15;`}>
                 <svg viewBox="0 0 24 24" fill="none" stroke={ind.color} stroke-width="1.4" class="w-8 h-8">
                   <Fragment set:html={ind.svgInner} />
                 </svg>
               </div>
               <div>
                 <div class="flex items-center gap-3 mb-1">
                   <h2 class="font-display text-[1.6rem] leading-snug text-brand-black">{ind.label} Automation</h2>
                   <span class="text-[10px] font-bold px-2 py-0.5 rounded-full" style={`background:${ind.color}15;color:${ind.color};`}>{iw.length} workflows</span>
                 </div>
                 <div class="flex items-center gap-4">
                   <p class="text-[13px] text-brand-gray-500">{ind.desc}</p>
                   <span class="text-[11px] font-semibold shrink-0" style={`color:${ind.color};`}>{ind.metric}</span>
                 </div>
               </div>
             </div>
             <!-- Cards -->
             <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
               {iw.map(w => (
                 <article class="bg-white rounded-card p-6 flex flex-col border border-brand-gray-100 hover:border-brand-gray-200 hover:shadow-sm transition">
                   <div class="flex items-center justify-between gap-3 mb-3">
                     <span class="text-[10px] font-bold px-2 py-0.5 rounded-full" style={`background:${complexityColor[w.complexity]};color:${complexityText[w.complexity]};`}>{w.complexity}</span>
                     {w.badge && (
                       <span class="text-[9px] uppercase tracking-wider font-bold px-2 py-0.5 rounded-full"
                         style={w.badge === 'AI-powered' ? 'background:rgba(123,104,238,0.10);color:#7B68EE;' : 'background:rgba(232,180,176,0.15);color:#c4847e;'}>
                         {w.badge}
                       </span>
                     )}
                   </div>
                   <h3 class="font-display text-[15px] leading-snug text-brand-black mb-2">{w.title}</h3>
                   <p class="text-[12px] font-semibold mb-3 leading-snug" style="color:#E8875A;">{w.benefit}</p>
                   <p class="text-[12.5px] text-brand-gray-600 leading-relaxed flex-1 mb-4">{w.desc}</p>
                   <div class="flex flex-wrap gap-1.5 mb-4">
                     {w.tools.map(t => (
                       <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-brand-gray-50 border border-brand-gray-200 text-brand-gray-600">{t}</span>
                     ))}
                   </div>
                   <div class="flex items-center justify-between pt-4 border-t border-brand-gray-100">
                     <span class="text-[11px] font-semibold text-brand-black">{w.time} saved</span>
                     <a href="/pages/welcome" class="text-[11px] font-semibold transition-all" style="color:#E8B4B0;"
                       onmouseover="this.style.color='#c4847e'" onmouseout="this.style.color='#E8B4B0'">Deploy this ↗</a>
                   </div>
                 </article>
               ))}
             </div>
           </div>
         );
       })}

     </div>
   </section>

 </div>

 <!-- n8n callout -->
 <section class="bg-white border-y border-brand-gray-100 py-12">
   <div class="container-x max-w-4xl">
     <div class="flex flex-col md:flex-row items-center gap-6 md:gap-10">
       <div class="flex-1">
         <p class="text-[9px] uppercase tracking-[0.22em] font-bold text-brand-gray-500 mb-2">Built on n8n</p>
         <h2 class="font-display text-[1.4rem] leading-snug text-brand-black mb-2">These workflows run on n8n, the open-source automation platform.</h2>
         <p class="text-[13px] text-brand-gray-600 leading-relaxed">n8n is free, open-source, and self-hostable. PURIST deploys, configures, and maintains your n8n instance so you keep full control of your data and workflows.</p>
       </div>
       <div class="flex flex-col gap-3 shrink-0">
         <a href="https://n8n.io/workflows/" target="_blank" rel="noopener noreferrer"
           class="px-5 py-2.5 rounded-[12px] text-[12px] font-semibold border border-brand-gray-200 text-brand-black hover:bg-brand-cream transition text-center">
           Browse n8n template library ↗
         </a>
         <a href="/pages/welcome"
           class="px-5 py-2.5 rounded-[12px] text-[12px] font-semibold text-center transition-all"
           style="background:#0A0A0A;color:white;"
           onmouseover="this.style.background='#1a1a1a'"
           onmouseout="this.style.background='#0A0A0A'">
           Get PURIST to deploy yours ↗
         </a>
       </div>
     </div>
   </div>
 </section>

 <!-- CTA -->
 <section class="bg-brand-black text-white py-16 lg:py-20">
   <div class="container-x text-center max-w-2xl mx-auto">
     <p class="text-[9px] uppercase tracking-[0.24em] font-bold mb-4" style="color:rgba(232,180,176,0.55);">Ready to deploy?</p>
     <h2 class="font-display text-[1.8rem] lg:text-[2.2rem] leading-[1.08] text-white mb-4 text-balance">
       We build any of these for you,<br/>
       <em class="font-medium" style="color:#E8B4B0;">customised to your exact stack.</em>
     </h2>
     <p class="text-[13px] mb-8" style="color:rgba(255,255,255,0.40);">Free 45-minute audit. We map your top 3 quick wins before you spend a penny.</p>
     <a href="/pages/welcome"
       class="inline-flex items-center gap-2.5 px-6 py-3.5 rounded-[14px] text-[13px] font-semibold transition-all"
       style="background:#E8B4B0;color:#0A0A0A;"
       onmouseover="this.style.background='#d9a09b'"
       onmouseout="this.style.background='#E8B4B0'">
       Get my free automation plan →
     </a>
   </div>
 </section>

</ShopLayout>

<script is:inline define:vars={{ funcWorkflows, industryWorkflows }}>
// Expose all workflows for search
window.__puristWorkflows = [
  ...funcWorkflows.map(function(w) { return Object.assign({}, w, { type: 'function' }); }),
  ...industryWorkflows.map(function(w) { return Object.assign({}, w, { type: 'industry' }); }),
];
</script>

<script is:inline>
(function () {

 // ── View toggle ────────────────────────────────────────────
 var tabFn = document.getElementById('tab-function');
 var tabInd = document.getElementById('tab-industry');
 var vFn  = document.getElementById('view-function');
 var vInd = document.getElementById('view-industry');

 function showView(v) {
   if (v === 'function') {
     vFn.classList.remove('hidden');
     vInd.classList.add('hidden');
     tabFn.style.background = '#E8B4B0'; tabFn.style.color = '#0A0A0A';
     tabInd.style.background = 'transparent'; tabInd.style.color = 'rgba(255,255,255,0.55)';
   } else {
     vInd.classList.remove('hidden');
     vFn.classList.add('hidden');
     tabInd.style.background = '#E8B4B0'; tabInd.style.color = '#0A0A0A';
     tabFn.style.background = 'transparent'; tabFn.style.color = 'rgba(255,255,255,0.55)';
   }
 }
 tabFn.addEventListener('click', function () { showView('function'); });
 tabInd.addEventListener('click', function () { showView('industry'); });

 // ── Function filter ────────────────────────────────────────
 function filterFunc(cat) {
   var cards = document.querySelectorAll('.func-workflow-card');
   var n = 0;
   cards.forEach(function (c) {
     var show = cat === 'all' || c.dataset.cat === cat;
     c.style.display = show ? '' : 'none';
     if (show) n++;
   });
   document.getElementById('func-empty').classList.toggle('hidden', n > 0);
   document.querySelectorAll('.func-btn').forEach(function (btn) {
     var a = btn.dataset.cat === cat;
     btn.style.background = a ? '#E8B4B0' : 'rgba(255,255,255,0.06)';
     btn.style.color    = a ? '#0A0A0A' : 'rgba(255,255,255,0.55)';
     btn.style.border   = a ? 'none'  : '1px solid rgba(255,255,255,0.09)';
   });
 }
 document.querySelectorAll('.func-btn').forEach(function (btn) {
   btn.addEventListener('click', function () { filterFunc(this.dataset.cat); });
 });
 document.querySelectorAll('.func-card').forEach(function (card) {
   card.addEventListener('click', function () {
     filterFunc(this.dataset.cat);
     document.getElementById('func-grid').scrollIntoView({ behavior:'smooth', block:'start' });
   });
 });

 // ── Industry filter ────────────────────────────────────────
 function filterInd(ind) {
   document.querySelectorAll('.ind-section').forEach(function (s) {
     s.style.display = (ind === 'all' || s.dataset.ind === ind) ? '' : 'none';
   });
   document.querySelectorAll('.ind-btn').forEach(function (btn) {
     var a = btn.dataset.ind === ind;
     btn.style.background = a ? '#E8B4B0' : 'rgba(255,255,255,0.06)';
     btn.style.color    = a ? '#0A0A0A' : 'rgba(255,255,255,0.55)';
     btn.style.border   = a ? 'none'  : '1px solid rgba(255,255,255,0.09)';
   });
 }
 document.querySelectorAll('.ind-btn').forEach(function (btn) {
   btn.addEventListener('click', function () { filterInd(this.dataset.ind); });
 });
 document.querySelectorAll('.ind-card').forEach(function (card) {
   card.addEventListener('click', function () {
     showView('industry');
     filterInd(this.dataset.ind);
     document.getElementById('ind-sections').scrollIntoView({ behavior:'smooth', block:'start' });
   });
 });

})();

// ── Search ──────────────────────────────────────────────────
(function() {
  var searchInput = document.getElementById('workflow-search');
  var searchCount = document.getElementById('search-count');
  if (!searchInput) return;

  // Build searchable index from all workflow cards (both views)
  function getAllCards() {
    return document.querySelectorAll('.workflow-card, [data-workflow-card]');
  }

  // Collect text from a card for matching
  function cardText(card) {
    return card.textContent.toLowerCase();
  }

  var searchView = document.getElementById('search-view');
  if (!searchView) {
    searchView = document.createElement('div');
    searchView.id = 'search-view';
    searchView.className = 'hidden';
    var viewFunc = document.getElementById('view-function');
    if (viewFunc) viewFunc.parentNode.insertBefore(searchView, viewFunc);
  }

  searchInput.addEventListener('input', function() {
    var query = this.value.trim().toLowerCase();

    if (!query) {
      // Restore default view
      searchView.classList.add('hidden');
      searchView.innerHTML = '';
      searchCount.classList.add('hidden');
      var activeView = document.getElementById('view-function').classList.contains('hidden') ? 'industry' : 'function';
      showView(activeView);
      return;
    }

    // Hide normal views, show search results
    document.getElementById('view-function').classList.add('hidden');
    document.getElementById('view-industry').classList.add('hidden');
    searchView.classList.remove('hidden');

    // Collect all unique workflow cards from DOM data
    var allWf = window.__puristWorkflows || [];
    var results = allWf.filter(function(w) {
      return (w.title + ' ' + w.desc + ' ' + w.benefit + ' ' + (w.tools || []).join(' ') + ' ' + (w.cat || '') + ' ' + (w.industry || '')).toLowerCase().includes(query);
    });

    searchCount.classList.remove('hidden');
    searchCount.textContent = results.length + ' workflow' + (results.length !== 1 ? 's' : '') + ' found';

    if (results.length === 0) {
      searchView.innerHTML = '<div class="container-x py-16 text-center"><p class="text-white/40 text-sm">No workflows match "<strong class=\'text-white/60\'>' + query + '</strong>".</p></div>';
      return;
    }

    var html = '<section class="bg-white py-10"><div class="container-x"><div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">';
    results.forEach(function(w) {
      var badge = w.badge ? '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wide mr-1" style="background:rgba(232,180,176,0.15);color:#E8B4B0;">' + w.badge + '</span>' : '';
      var tools = (w.tools || []).map(function(t) { return '<span class="inline-block bg-brand-cream text-brand-gray-500 text-[10px] px-2 py-0.5 rounded-full mr-1 mb-1">' + t + '</span>'; }).join('');
      html += '<div class="rounded-[16px] border border-brand-gray-100 p-5 flex flex-col gap-3 hover:border-brand-gray-200 hover:shadow-sm transition">';
      html += '<div class="flex items-start justify-between gap-2"><p class="text-[13px] font-semibold text-brand-black leading-snug flex-1">' + w.title + '</p>' + badge + '</div>';
      html += '<p class="text-[11.5px] text-brand-gray-600 leading-relaxed">' + w.benefit + '</p>';
      html += '<div class="flex flex-wrap mt-auto pt-2" style="border-top:1px solid #f0ece6;">' + tools + '</div>';
      html += '</div>';
    });
    html += '</div></div></section>';
    searchView.innerHTML = html;
  });

  // Clear on Escape
  searchInput.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { this.value = ''; this.dispatchEvent(new Event('input')); }
  });
})();
</script>
