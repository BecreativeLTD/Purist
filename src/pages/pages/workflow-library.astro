  { industry:'realestate', complexity:'Starter',      badge:null,         time:'3h/wk',  title:'Property viewing scheduler and reminder',       benefit:'Confirm more viewings with zero back-and-forth.',  desc:'Lead requests a viewing and gets a booking link. Confirmation sent. Agent notified. 24h reminder sent to both. No-show triggers an automatic re-booking offer within 30 minutes.', tools:['n8n','Calendly','Gmail'] },
  { industry:'realestate', complexity:'Intermediate', badge:'AI-powered', time:'6h/wk',  title:'AI property match and alert',                  benefit:'Send buyers the right property before they find it on Rightmove.', desc:'Claude AI matches new listings against every active buyer profile and sends a personalised alert with a tailored pitch written in the agent\'s voice. Buyers see you as the expert, not the portal.', tools:['n8n','Claude AI','HubSpot'] },
  { industry:'realestate', complexity:'Starter',      badge:'Popular',    time:'4h/wk',  title:'Offer to completion milestone tracker',         benefit:'Every party knows what is happening at every stage.',  desc:'Accepted offer triggers a complete transaction workflow: solicitor introductions, survey scheduling, mortgage deadline alerts, and automatic updates to buyer, seller, and agent throughout.', tools:['n8n','Gmail','Google Sheets'] },
  { industry:'realestate', complexity:'Intermediate', badge:null,         time:'4h/wk',  title:'Landlord rental management automation',         benefit:'Manage 50 properties with the admin of 5.',        desc:'Handles rent reminders, maintenance request routing, tenancy renewal notices, and deposit return checklists. All logged and all compliant without your team touching a spreadsheet.', tools:['n8n','Xero','Gmail'] },
  { industry:'realestate', complexity:'Intermediate', badge:null,         time:'5h/wk',  title:'Valuation to listing pipeline',                 benefit:'Go from valuation to live listing in half the time.', desc:'Valuation completed triggers photo booking, EPC scheduling, floor plan order, description draft by Claude AI, and portal upload checklist. Nothing falls through the cracks.', tools:['n8n','Claude AI','Reapit'] },

  // Hotel
  { industry:'hotel', complexity:'Starter',      badge:'Popular',    time:'5h/wk',  title:'Booking confirmation and pre-arrival sequence', benefit:'Guests arrive excited, not anxious.',             desc:'Booking confirmed triggers a welcome email, a 7-day pre-arrival message with local tips, a 24h reminder with check-in instructions, and a upsell offer for room upgrades or spa bookings.', tools:['n8n','Mailchimp','Mews'] },
  { industry:'hotel', complexity:'Starter',      badge:null,         time:'3h/wk',  title:'In-stay upsell automation',                    benefit:'Increase ancillary revenue by 15-25% per stay.',   desc:'At check-in, guests receive tailored offers based on stay duration and profile: restaurant reservation, late checkout, spa treatment, or local experiences. Sent at the moments most likely to convert.', tools:['n8n','Gmail','Stripe'] },
  { industry:'hotel', complexity:'Starter',      badge:'Popular',    time:'4h/wk',  title:'Post-checkout review and NPS',                 benefit:'More 5-star reviews on TripAdvisor and Google, consistently.', desc:'1 hour after checkout, a personalised thank-you message goes out with a review request. Guests rating 9-10 are routed to TripAdvisor. Guests rating below 7 are routed to the GM for immediate follow-up.', tools:['n8n','Gmail','HubSpot'] },
  { industry:'hotel', complexity:'Intermediate', badge:null,         time:'6h/wk',  title:'Housekeeping and maintenance scheduler',       benefit:'No room is ever left unready or unrepaired.',      desc:'Checkout triggers an automatic room cleaning task. Reported maintenance issues create a job for the right team with priority flag, and the front desk is notified when each room is ready.', tools:['n8n','Slack','Google Sheets'] },
  { industry:'hotel', complexity:'Intermediate', badge:'AI-powered', time:'5h/wk',  title:'Revenue management alert',                     benefit:'Stop leaving rooms unsold at full price when demand drops.', desc:'Daily: Claude AI monitors occupancy forecasts, competitor rates, and event calendar. If occupancy is tracking below target, a discount offer goes out to your email list and OTAs are updated automatically.', tools:['n8n','Claude AI','Mailchimp'] },
  { industry:'hotel', complexity:'Advanced',     badge:null,         time:'8h/wk',  title:'Group booking and event coordination',         benefit:'Manage complex group bookings without a dedicated coordinator.', desc:'Group enquiry triggers a proposal workflow: availability check, tailored quote generation, contract send, deposit invoice, rooming list collection, and event day briefing. All tracked in one place.', tools:['n8n','DocuSign','Xero'] },

  // Call Centre
  { industry:'callcenter', complexity:'Advanced',     badge:'AI-powered', time:'12h/wk', title:'AI call routing and intent detection',          benefit:'Route every call to the right agent in under 10 seconds.', desc:'Inbound call transcript analysed by Claude AI in real-time. Intent classified, urgency scored, and call routed to the specialist most likely to resolve it on first contact. CSAT rises, AHT drops.', tools:['n8n','Claude AI','Twilio'] },
  { industry:'callcenter', complexity:'Intermediate', badge:'AI-powered', time:'8h/wk',  title:'AI agent assist and script delivery',           benefit:'Your agents always know the right answer, every time.',   desc:'Live call context feeds Claude AI in the background. Relevant scripts, product details, compliance disclaimers, and objection responses surface on the agent\'s screen before they need them.', tools:['n8n','Claude AI','Zendesk'] },
  { industry:'callcenter', complexity:'Intermediate', badge:null,         time:'6h/wk',  title:'QA call scoring automation',                   benefit:'Review 100% of calls instead of 2%. Find issues before they escalate.', desc:'Every call transcript is scored against your QA framework by Claude AI: compliance check, tone analysis, resolution quality, and upsell attempt. Coaches get a daily digest of the lowest-scoring calls.', tools:['n8n','Claude AI','Google Sheets'] },
  { industry:'callcenter', complexity:'Starter',      badge:'Popular',    time:'4h/wk',  title:'Missed call to automatic callback queue',       benefit:'Never lose a lead because the phone rang out.',           desc:'Missed inbound call triggers an immediate SMS to the caller with an estimated callback time. Adds them to the callback queue. Agent gets a pop-up with caller history before dialling. 85% pick-up rate vs 40% cold call.', tools:['n8n','Twilio','HubSpot'] },
  { industry:'callcenter', complexity:'Advanced',     badge:'AI-powered', time:'10h/wk', title:'Post-call summary and CRM update',               benefit:'Eliminate 20 minutes of after-call work per agent per shift.', desc:'Call ends. Claude AI generates a structured summary: key points, next actions, sentiment score, and compliance flags. CRM updated, ticket created, and follow-up task assigned. Agent moves to the next call.', tools:['n8n','Claude AI','Salesforce'] },
  { industry:'callcenter', complexity:'Intermediate', badge:null,         time:'5h/wk',  title:'Agent performance dashboard',                   benefit:'Managers spend time coaching, not compiling spreadsheets.', desc:'Daily pull of calls handled, AHT, first-call resolution, CSAT, and adherence. Auto-updates the agent performance dashboard with weekly trends and flags anyone tracking outside normal range.', tools:['n8n','Google Sheets','Slack'] },

  // Agency
  { industry:'agency', complexity:'Intermediate', badge:'Popular',    time:'6h/wk',  title:'Client monthly report generator',              benefit:'Impress every client with a polished report, on time, every month.', desc:'Pulls ad performance, SEO rankings, and project delivery data from your tools. Claude AI writes the executive commentary in your agency\'s voice. Report sent to the client on the 1st, every month.', tools:['n8n','Claude AI','Google Sheets'] },
  { industry:'agency', complexity:'Starter',      badge:null,         time:'4h/wk',  title:'New brief intake and scoping workflow',         benefit:'Turn a discovery call into a signed brief in under 24 hours.', desc:'Client fills an intake form after the discovery call. Workflow creates the project in your PM tool, generates a draft scope with Claude AI based on the inputs, and sends it to the account manager for review.', tools:['n8n','Claude AI','Notion'] },
  { industry:'agency', complexity:'Intermediate', badge:'AI-powered', time:'8h/wk',  title:'Content approval pipeline',                    benefit:'Stop chasing clients for feedback on a Friday afternoon.', desc:'Draft created. Client gets a review link with a comment interface. Approved or revision requested with one click. Revisions tracked. Final approved version sent to the delivery team. All in one flow.', tools:['n8n','Claude AI','Slack'] },
  { industry:'agency', complexity:'Starter',      badge:'Popular',    time:'3h/wk',  title:'Timesheet to invoice automation',               benefit:'Bill every hour you work, not just the hours you remember.', desc:'Team timesheets submitted weekly. Workflow validates against project budgets, flags overages, generates client invoices in Xero, and sends them on the agreed billing date with a payment link.', tools:['n8n','Xero','Slack'] },
  { industry:'agency', complexity:'Advanced',     badge:'AI-powered', time:'10h/wk', title:'Client health score and churn alert',           benefit:'Save struggling client relationships before they become cancellations.', desc:'Weekly scoring across: NPS, invoice payment speed, communication responsiveness, and deliverable feedback tone. Claude AI flags at-risk clients to the account director with a suggested action.', tools:['n8n','Claude AI','HubSpot'] },
  { industry:'agency', complexity:'Intermediate', badge:null,         time:'5h/wk',  title:'Pitch and proposal tracker',                    benefit:'Never let a warm prospect go cold because you forgot to follow up.', desc:'New pitch logged triggers a structured follow-up cadence with reminders to the account lead. Win or lose, the outcome is recorded. Losses feed back into the content strategy for next quarter.', tools:['n8n','HubSpot','Slack'] },

  // E-commerce
  { industry:'ecommerce', complexity:'Starter',      badge:'Popular',    time:'8h/wk',  title:'Abandoned cart recovery sequence',             benefit:'Recover 10-15% of abandoned baskets automatically.',      desc:'Cart abandoned triggers a 3-message sequence: reminder at 1h, social proof email at 24h, and a small incentive at 72h. Sequence stops the moment the order is placed.', tools:['n8n','Klaviyo','Shopify'] },
  { industry:'ecommerce', complexity:'Starter',      badge:'Popular',    time:'5h/wk',  title:'Post-purchase review and upsell flow',         benefit:'Turn buyers into repeat customers and brand advocates.',   desc:'Order delivered triggers a thank-you with care instructions, a review request at day 5, and a personalised cross-sell recommendation at day 14 based on purchase history.', tools:['n8n','Klaviyo','Shopify'] },
  { industry:'ecommerce', complexity:'Intermediate', badge:null,         time:'6h/wk',  title:'Inventory alert and reorder workflow',          benefit:'Avoid stockouts on your bestsellers. Permanently.',        desc:'Daily stock check against 30-day velocity. SKUs tracking toward zero get a reorder alert to the buyer with suggested order quantity. Low-stock badge updated on the product page automatically.', tools:['n8n','Shopify','Slack'] },
  { industry:'ecommerce', complexity:'Intermediate', badge:'AI-powered', time:'7h/wk',  title:'AI product description writer',                benefit:'Launch new products in hours, not days.',                  desc:'New product created in Shopify. Claude AI reads the product specs, target audience, and brand guidelines, writes SEO-optimised title and description, and publishes directly. Consistent quality at scale.', tools:['n8n','Claude AI','Shopify'] },
  { industry:'ecommerce', complexity:'Advanced',     badge:null,         time:'10h/wk', title:'Returns and refund automation',                benefit:'Handle returns in minutes, not days. Reduce customer frustration.', desc:'Refund request received. Policy check automated. Pre-paid return label generated and sent. Refund queued in Stripe on delivery confirmation. Customer kept informed at every step.', tools:['n8n','Shopify','Stripe'] },
  { industry:'ecommerce', complexity:'Intermediate', badge:'Popular',    time:'5h/wk',  title:'VIP customer recognition programme',           benefit:'Your best customers feel known, not just served.',         desc:'Orders above a lifetime value threshold automatically upgrade the customer to VIP status: personalised welcome from the founder, early access to launches, priority support routing, and exclusive discount codes.', tools:['n8n','Klaviyo','Shopify'] },
];

const complexityColor: Record<string, string> = {
  'Starter':      'rgba(45,128,73,0.10)',
  'Intermediate': 'rgba(200,152,64,0.12)',
  'Advanced':     'rgba(123,104,238,0.12)',
};
const complexityText: Record<string, string> = {
  'Starter':      '#2D8049',
  'Intermediate': '#C89840',
  'Advanced':     '#7B68EE',
};
---

<ShopLayout
  title="Workflow Library — 100+ Automation Templates | PURIST"
  description="100+ production-ready n8n automation workflows organised by function and industry: dental, real estate, hotels, call centres, agencies, e-commerce."
>

  <!-- Hero -->
  <section class="bg-brand-black text-white pt-20 pb-14 lg:pt-28 lg:pb-18 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 50% 0%,rgba(232,180,176,0.07) 0%,transparent 60%);"></div>
    <div class="container-x relative z-10">
      <p class="text-[9px] uppercase tracking-[0.28em] font-bold mb-4" style="color:rgba(232,180,176,0.55);">Workflow Library</p>
      <div class="max-w-3xl mb-10">
        <h1 class="font-display text-[2.2rem] lg:text-[3rem] leading-[1.06] tracking-[-0.025em] text-white mb-4 text-balance">
          100+ production-ready workflows.<br/>
          <em class="font-medium" style="color:#E8B4B0;">Each one built around a real business outcome.</em>
        </h1>
        <p class="text-[15px] leading-relaxed max-w-2xl" style="color:rgba(255,255,255,0.45);">
          Browse by function or by industry. Every template is battle-tested across 500+ deployments. PURIST deploys any of these for you, customised to your exact stack, in days.
        </p>
      </div>

      <!-- View toggle -->
      <div class="flex items-center gap-1 p-1 rounded-full w-fit" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.10);">
        <button id="tab-function" class="view-tab px-5 py-2 rounded-full text-[12px] font-semibold transition-all" style="background:#E8B4B0;color:#0A0A0A;">By Function</button>
        <button id="tab-industry" class="view-tab px-5 py-2 rounded-full text-[12px] font-semibold transition-all" style="background:transparent;color:rgba(255,255,255,0.55);">By Industry</button>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       FUNCTION VIEW
  ═══════════════════════════════════════════════════════════ -->
  <div id="view-function">

    <!-- Sticky filter bar -->
    <div class="sticky top-16 z-20 bg-brand-black border-b" style="border-color:rgba(255,255,255,0.07);">
      <div class="container-x py-3 flex flex-wrap gap-2" id="func-filters">
        <button class="func-btn active text-[11px] font-semibold px-3.5 py-1.5 rounded-full transition-all" data-cat="all"
          style="background:#E8B4B0;color:#0A0A0A;">All</button>
        {funcCategories.map(c => (
          <button class="func-btn text-[11px] font-semibold px-3.5 py-1.5 rounded-full transition-all" data-cat={c.id}
            style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.55);border:1px solid rgba(255,255,255,0.09);"
            aria-label={`Filter by ${c.label}`}>{c.label}</button>
        ))}
      </div>
    </div>

    <!-- Category cards -->
    <section class="bg-white border-b border-brand-gray-100 py-8">
      <div class="container-x grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {funcCategories.map(c => (
          <button class="func-card text-left p-4 rounded-[14px] border border-brand-gray-100 hover:border-brand-gray-200 hover:bg-brand-cream transition cursor-pointer" data-cat={c.id} aria-label={`Show ${c.label} workflows`}>
            <div class="w-8 h-8 rounded-[10px] flex items-center justify-center mb-3" style={`background:${c.color}18;`}>
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke={c.color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
            </div>
            <p class="text-[12px] font-semibold text-brand-black leading-snug">{c.label}</p>
          </button>
        ))}
      </div>
    </section>

    <!-- Workflow grid -->
    <section class="bg-brand-beige py-16 lg:py-20">
      <div class="container-x">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="func-grid">
          {funcWorkflows.map(w => (
            <article class="func-workflow-card bg-white rounded-card p-6 flex flex-col border border-brand-gray-100 hover:border-brand-gray-200 hover:shadow-sm transition" data-cat={w.cat}>
              <div class="flex items-center justify-between gap-3 mb-3">
                <span class="text-[10px] font-bold px-2 py-0.5 rounded-full" style={`background:${complexityColor[w.complexity]};color:${complexityText[w.complexity]};`}>{w.complexity}</span>
                <div class="flex items-center gap-2">
                  {w.n8n && (
                    <a href={w.n8n} target="_blank" rel="noopener noreferrer"
                      class="text-[9px] font-semibold px-2 py-0.5 rounded-full border transition-all"
                      style="background:rgba(232,180,176,0.10);color:#c4847e;border-color:rgba(232,180,176,0.20);"
                      onmouseover="this.style.background='rgba(232,180,176,0.22)'"
                      onmouseout="this.style.background='rgba(232,180,176,0.10)'"
                      aria-label={`View template on n8n.io`}>n8n template ↗</a>
                  )}
                  {w.badge && (
                    <span class="text-[9px] uppercase tracking-wider font-bold px-2 py-0.5 rounded-full"
                      style={w.badge === 'AI-powered' ? 'background:rgba(123,104,238,0.10);color:#7B68EE;' : 'background:rgba(232,180,176,0.15);color:#c4847e;'}>
                      {w.badge}
                    </span>
                  )}
                </div>
              </div>
              <h3 class="font-display text-[15px] leading-snug text-brand-black mb-2">{w.title}</h3>
              <p class="text-[12px] font-semibold mb-3 leading-snug" style="color:#E8875A;">{w.benefit}</p>
              <p class="text-[12.5px] text-brand-gray-600 leading-relaxed flex-1 mb-4">{w.desc}</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {w.tools.map(t => (
                  <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-brand-gray-50 border border-brand-gray-200 text-brand-gray-600">{t}</span>
                ))}
              </div>
              <div class="flex items-center justify-between pt-4 border-t border-brand-gray-100">
                <span class="text-[11px] font-semibold text-brand-black">{w.time} saved</span>
                <a href="/pages/welcome" class="text-[11px] font-semibold transition-all" style="color:#E8B4B0;"
                  onmouseover="this.style.color='#c4847e'" onmouseout="this.style.color='#E8B4B0'">Deploy this ↗</a>
              </div>
            </article>
          ))}
        </div>
        <div id="func-empty" class="hidden text-center py-16">
          <p class="text-brand-gray-500 text-sm">No workflows match this filter.</p>
        </div>
      </div>
    </section>

  </div>

  <!-- ═══════════════════════════════════════════════════════════
       INDUSTRY VIEW
  ═══════════════════════════════════════════════════════════ -->
  <div id="view-industry" class="hidden">

    <!-- Industry picker -->
    <div class="sticky top-16 z-20 bg-brand-black border-b" style="border-color:rgba(255,255,255,0.07);">
      <div class="container-x py-3 flex flex-wrap gap-2" id="ind-filters">
        <button class="ind-btn active text-[11px] font-semibold px-3.5 py-1.5 rounded-full transition-all" data-ind="all"
          style="background:#E8B4B0;color:#0A0A0A;">All industries</button>
        {industries.map(i => (
          <button class="ind-btn text-[11px] font-semibold px-3.5 py-1.5 rounded-full transition-all" data-ind={i.id}
            style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.55);border:1px solid rgba(255,255,255,0.09);"
            aria-label={`Show ${i.label} workflows`}>
            {i.emoji} {i.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Industry hero cards -->
    <section class="bg-white border-b border-brand-gray-100 py-8">
      <div class="container-x grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {industries.map(i => (
          <button class="ind-card text-left p-4 rounded-[14px] border border-brand-gray-100 hover:border-brand-gray-200 hover:bg-brand-cream transition cursor-pointer" data-ind={i.id} aria-label={`Show ${i.label} workflows`}>
            <div class="text-2xl mb-2">{i.emoji}</div>
            <p class="text-[12px] font-semibold text-brand-black leading-snug mb-1">{i.label}</p>
            <p class="text-[10px] text-brand-gray-500 leading-snug">{i.desc}</p>
          </button>
        ))}
      </div>
    </section>

    <!-- Industry workflow sections -->
    <section class="bg-brand-beige py-16 lg:py-20">
      <div class="container-x space-y-16" id="ind-sections">

        {industries.map(ind => {
          const iw = industryWorkflows.filter(w => w.industry === ind.id);
          return (
            <div class="ind-section" data-ind={ind.id}>
              <!-- Section header -->
              <div class="flex items-center gap-4 mb-8">
                <div class="text-4xl">{ind.emoji}</div>
                <div>
                  <h2 class="font-display text-[1.6rem] leading-snug text-brand-black">{ind.label} Automation</h2>
                  <p class="text-[13px] text-brand-gray-500 mt-0.5">{ind.desc}</p>
                </div>
              </div>
              <!-- Cards -->
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {iw.map(w => (
                  <article class="bg-white rounded-card p-6 flex flex-col border border-brand-gray-100 hover:border-brand-gray-200 hover:shadow-sm transition">
                    <div class="flex items-center justify-between gap-3 mb-3">
                      <span class="text-[10px] font-bold px-2 py-0.5 rounded-full" style={`background:${complexityColor[w.complexity]};color:${complexityText[w.complexity]};`}>{w.complexity}</span>
                      <div class="flex items-center gap-2">
                        {w.badge && (
                          <span class="text-[9px] uppercase tracking-wider font-bold px-2 py-0.5 rounded-full"
                            style={w.badge === 'AI-powered' ? 'background:rgba(123,104,238,0.10);color:#7B68EE;' : 'background:rgba(232,180,176,0.15);color:#c4847e;'}>
                            {w.badge}
                          </span>
                        )}
                      </div>
                    </div>
                    <h3 class="font-display text-[15px] leading-snug text-brand-black mb-2">{w.title}</h3>
                    <p class="text-[12px] font-semibold mb-3 leading-snug" style="color:#E8875A;">{w.benefit}</p>
                    <p class="text-[12.5px] text-brand-gray-600 leading-relaxed flex-1 mb-4">{w.desc}</p>
                    <div class="flex flex-wrap gap-1.5 mb-4">
                      {w.tools.map(t => (
                        <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-brand-gray-50 border border-brand-gray-200 text-brand-gray-600">{t}</span>
                      ))}
                    </div>
                    <div class="flex items-center justify-between pt-4 border-t border-brand-gray-100">
                      <span class="text-[11px] font-semibold text-brand-black">{w.time} saved</span>
                      <a href="/pages/welcome" class="text-[11px] font-semibold transition-all" style="color:#E8B4B0;"
                        onmouseover="this.style.color='#c4847e'" onmouseout="this.style.color='#E8B4B0'">Deploy this ↗</a>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          );
        })}

      </div>
    </section>

  </div>

  <!-- n8n callout -->
  <section class="bg-white border-y border-brand-gray-100 py-12">
    <div class="container-x max-w-4xl">
      <div class="flex flex-col md:flex-row items-center gap-6 md:gap-10">
        <div class="flex-1">
          <p class="text-[9px] uppercase tracking-[0.22em] font-bold text-brand-gray-500 mb-2">Built on n8n</p>
          <h2 class="font-display text-[1.4rem] leading-snug text-brand-black mb-2">These workflows run on n8n, the open-source automation platform.</h2>
          <p class="text-[13px] text-brand-gray-600 leading-relaxed">n8n is free, open-source, and self-hostable. PURIST deploys, configures, and maintains your n8n instance so you keep full control of your data and workflows.</p>
        </div>
        <div class="flex flex-col gap-3 shrink-0">
          <a href="https://n8n.io/workflows/" target="_blank" rel="noopener noreferrer"
            class="px-5 py-2.5 rounded-[12px] text-[12px] font-semibold border border-brand-gray-200 text-brand-black hover:bg-brand-cream transition text-center">
            Browse n8n template library ↗
          </a>
          <a href="/pages/welcome"
            class="px-5 py-2.5 rounded-[12px] text-[12px] font-semibold text-center transition-all"
            style="background:#0A0A0A;color:white;"
            onmouseover="this.style.background='#1a1a1a'"
            onmouseout="this.style.background='#0A0A0A'">
            Get PURIST to deploy yours ↗
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-black text-white py-16 lg:py-20">
    <div class="container-x text-center max-w-2xl mx-auto">
      <p class="text-[9px] uppercase tracking-[0.24em] font-bold mb-4" style="color:rgba(232,180,176,0.55);">Ready to deploy?</p>
      <h2 class="font-display text-[1.8rem] lg:text-[2.2rem] leading-[1.08] text-white mb-4 text-balance">
        We build any of these for you,<br/>
        <em class="font-medium" style="color:#E8B4B0;">customised to your exact stack.</em>
      </h2>
      <p class="text-[13px] mb-8" style="color:rgba(255,255,255,0.40);">Free 30-minute audit. We map your top 3 quick wins before you spend a penny.</p>
      <a href="/pages/welcome"
        class="inline-flex items-center gap-2.5 px-6 py-3.5 rounded-[14px] text-[13px] font-semibold transition-all"
        style="background:#E8B4B0;color:#0A0A0A;"
