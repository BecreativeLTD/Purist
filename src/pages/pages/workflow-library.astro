const complexityColor: Record<string, string> = {
  'Starter':      'rgba(45,128,73,0.10)',
  'Intermediate': 'rgba(200,152,64,0.12)',
  'Advanced':     'rgba(123,104,238,0.12)',
};
const complexityText: Record<string, string> = {
  'Starter':      '#2D8049',
  'Intermediate': '#C89840',
  'Advanced':     '#7B68EE',
};
const totalCount = workflows.length;
---

<ShopLayout
  title="Workflow Library — 65+ Automation Templates | PURIST"
  description="65+ production-ready n8n automation workflows by category. Each template includes the business benefit, tool stack, and time saved per week."
>

  <!-- Hero -->
  <section class="bg-brand-black text-white pt-20 pb-16 lg:pt-28 lg:pb-20 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 50% 0%,rgba(232,180,176,0.07) 0%,transparent 60%);"></div>
    <div class="container-x relative z-10">
      <p class="text-[9px] uppercase tracking-[0.28em] font-bold mb-4" style="color:rgba(232,180,176,0.55);">Workflow Library</p>
      <div class="max-w-3xl mb-8">
        <h1 class="font-display text-[2.2rem] lg:text-[3rem] leading-[1.06] tracking-[-0.025em] text-white mb-4 text-balance">
          {totalCount} production-ready workflows.<br/>
          <em class="font-medium" style="color:#E8B4B0;">Each one built around a real business outcome.</em>
        </h1>
        <p class="text-[15px] leading-relaxed max-w-2xl" style="color:rgba(255,255,255,0.45);">
          Every template is battle-tested across 500+ deployments. Filter by category or complexity. PURIST deploys any of these for you — customised to your exact stack — in days.
        </p>
      </div>

      <!-- Category filters -->
      <div class="flex flex-wrap gap-2" id="cat-filters">
        <button class="cat-btn active text-[11px] font-semibold px-3.5 py-1.5 rounded-full transition-all duration-150" data-cat="all"
          style="background:#E8B4B0;color:#0A0A0A;">All ({totalCount})</button>
        {categories.map((c) => (
          <button class="cat-btn text-[11px] font-semibold px-3.5 py-1.5 rounded-full transition-all duration-150" data-cat={c.id}
            style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.55);border:1px solid rgba(255,255,255,0.09);"
            aria-label={`Filter by ${c.label}`}>
            {c.label} <span style="opacity:0.5;">({c.count})</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Category summary strip -->
  <section class="bg-white border-b border-brand-gray-100 py-8">
    <div class="container-x">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {categories.map((c) => (
          <button class="cat-card text-left p-4 rounded-[14px] border border-brand-gray-100 hover:border-brand-gray-200 hover:bg-brand-cream transition cursor-pointer" data-cat={c.id} aria-label={`Show ${c.label} workflows`}>
            <div class="w-8 h-8 rounded-[10px] flex items-center justify-center mb-3" style={`background:${c.color}18;`}>
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke={c.color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={c.icon}/>
              </svg>
            </div>
            <p class="text-[12px] font-semibold text-brand-black leading-snug mb-1">{c.label}</p>
            <p class="text-[10px] text-brand-gray-500">{c.count} workflows</p>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Workflow grid -->
  <section class="bg-brand-beige py-16 lg:py-20">
    <div class="container-x">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="workflow-grid">
        {workflows.map((w) => (
          <article class="workflow-card bg-white rounded-card p-6 flex flex-col border border-brand-gray-100 hover:border-brand-gray-200 hover:shadow-sm transition" data-cat={w.cat}>

            <!-- Badge row -->
            <div class="flex items-center justify-between gap-3 mb-3">
              <span class="text-[10px] font-bold px-2 py-0.5 rounded-full"
                style={`background:${complexityColor[w.complexity]};color:${complexityText[w.complexity]};`}>
                {w.complexity}
              </span>
              <div class="flex items-center gap-2">
                {w.n8n && (
                  <a href={w.n8n} target="_blank" rel="noopener noreferrer"
                    class="text-[9px] font-semibold px-2 py-0.5 rounded-full transition-all"
                    style="background:rgba(232,180,176,0.12);color:#c4847e;border:1px solid rgba(232,180,176,0.20);"
                    onmouseover="this.style.background='rgba(232,180,176,0.22)'"
                    onmouseout="this.style.background='rgba(232,180,176,0.12)'"
                    aria-label={`View ${w.title} template on n8n.io`}>
                    n8n template ↗
                  </a>
                )}
                {w.badge && (
                  <span class="text-[9px] uppercase tracking-wider font-bold px-2 py-0.5 rounded-full"
                    style={w.badge === 'AI-powered'
                      ? 'background:rgba(123,104,238,0.10);color:#7B68EE;'
                      : 'background:rgba(232,180,176,0.15);color:#c4847e;'}
                  >{w.badge}</span>
                )}
              </div>
            </div>

            <!-- Title -->
            <h3 class="font-display text-[15px] leading-snug text-brand-black mb-2">{w.title}</h3>

            <!-- Benefit callout -->
            <p class="text-[12px] font-semibold mb-3 leading-snug" style="color:#E8875A;">{w.benefit}</p>

            <!-- Description -->
            <p class="text-[12.5px] text-brand-gray-600 leading-relaxed flex-1 mb-4">{w.desc}</p>

            <!-- Tool chips -->
            <div class="flex flex-wrap gap-1.5 mb-4">
              {w.tools.map((t) => (
                <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-brand-gray-50 border border-brand-gray-200 text-brand-gray-600">{t}</span>
              ))}
            </div>

            <!-- Footer -->
            <div class="flex items-center justify-between pt-4 border-t border-brand-gray-100">
              <span class="text-[11px] font-semibold text-brand-black">{w.time} saved</span>
              <a href="/pages/welcome"
                class="text-[11px] font-semibold transition-all"
                style="color:#E8B4B0;"
                onmouseover="this.style.color='#c4847e'"
                onmouseout="this.style.color='#E8B4B0'">
                Deploy this →
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-16">
        <p class="text-brand-gray-500 text-sm">No workflows match this filter.</p>
      </div>
    </div>
  </section>

  <!-- n8n callout -->
  <section class="bg-white border-y border-brand-gray-100 py-12">
    <div class="container-x max-w-4xl">
      <div class="flex flex-col md:flex-row items-center gap-6 md:gap-10">
        <div class="flex-1">
          <p class="text-[9px] uppercase tracking-[0.22em] font-bold text-brand-gray-500 mb-2">Built on n8n</p>
          <h2 class="font-display text-[1.4rem] leading-snug text-brand-black mb-2">These workflows run on n8n — the open-source automation platform.</h2>
          <p class="text-[13px] text-brand-gray-600 leading-relaxed">n8n is free, open-source, and self-hostable. PURIST deploys, configures, and maintains your n8n instance — you keep full control of your data and workflows.</p>
        </div>
        <div class="flex flex-col gap-3 shrink-0">
          <a href="https://n8n.io/workflows/" target="_blank" rel="noopener noreferrer"
            class="px-5 py-2.5 rounded-[12px] text-[12px] font-semibold border border-brand-gray-200 text-brand-black hover:bg-brand-cream transition text-center">
            Browse n8n template library ↗
          </a>
          <a href="/pages/welcome"
            class="px-5 py-2.5 rounded-[12px] text-[12px] font-semibold text-center transition-all"
            style="background:#0A0A0A;color:white;"
            onmouseover="this.style.background='#1a1a1a'"
            onmouseout="this.style.background='#0A0A0A'">
            Get PURIST to deploy yours →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-black text-white py-16 lg:py-20">
    <div class="container-x text-center max-w-2xl mx-auto">
      <p class="text-[9px] uppercase tracking-[0.24em] font-bold mb-4" style="color:rgba(232,180,176,0.55);">Ready to deploy?</p>
      <h2 class="font-display text-[1.8rem] lg:text-[2.2rem] leading-[1.08] text-white mb-4 text-balance">
        We build any of these for you —<br/>
        <em class="font-medium" style="color:#E8B4B0;">customised to your exact stack.</em>
      </h2>
      <p class="text-[13px] mb-8" style="color:rgba(255,255,255,0.40);">Free 30-minute audit. We map your top 3 quick wins before you spend a penny.</p>
      <a href="/pages/welcome"
        class="inline-flex items-center gap-2.5 px-6 py-3.5 rounded-[14px] text-[13px] font-semibold transition-all"
        style="background:#E8B4B0;color:#0A0A0A;"
        onmouseover="this.style.background='#d9a09b'"
        onmouseout="this.style.background='#E8B4B0'">
        Book a free audit →
      </a>
    </div>
  </section>

</ShopLayout>

<script is:inline>
(function () {
  function filter(cat) {
    var cards = document.querySelectorAll('.workflow-card');
    var visible = 0;
    cards.forEach(function (c) {
      var show = cat === 'all' || c.dataset.cat === cat;
      c.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    document.getElementById('empty-state').classList.toggle('hidden', visible > 0);

    document.querySelectorAll('.cat-btn').forEach(function (btn) {
      var a = btn.dataset.cat === cat;
      btn.style.background = a ? '#E8B4B0' : 'rgba(255,255,255,0.06)';
      btn.style.color      = a ? '#0A0A0A' : 'rgba(255,255,255,0.55)';
      btn.style.border     = a ? 'none'    : '1px solid rgba(255,255,255,0.09)';
    });
  }

  document.querySelectorAll('.cat-btn').forEach(function (btn) {
    btn.addEventListener('click', function () { filter(this.dataset.cat); });
  });
  document.querySelectorAll('.cat-card').forEach(function (card) {
    card.addEventListener('click', function () {
      filter(this.dataset.cat);
      document.getElementById('workflow-grid').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
})();
</script>
