---
import ShopLayout from '~/layouts/ShopLayout.astro';
import Button from '~/components/ui/Button.astro';

const categories = [
  {
    id: 'crm',
    label: 'CRM & Sales',
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0',
    count: 12,
    color: '#E8B4B0',
  },
  {
    id: 'finance',
    label: 'Finance & Billing',
    icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z',
    count: 9,
    color: '#C89840',
  },
  {
    id: 'ops',
    label: 'Operations',
    icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
    count: 14,
    color: '#7B68EE',
  },
  {
    id: 'support',
    label: 'Support & CS',
    icon: 'M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z',
    count: 8,
    color: '#2D5016',
  },
  {
    id: 'marketing',
    label: 'Marketing',
    icon: 'M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z',
    count: 11,
    color: '#E8B4B0',
  },
  {
    id: 'reporting',
    label: 'Reporting & BI',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
    count: 7,
    color: '#C89840',
  },
];

const workflows = [
  // CRM & Sales
  { cat: 'crm', title: 'Lead capture → CRM sync', desc: 'New form submission instantly creates a contact, assigns to rep, and fires a personalised intro email within 90 seconds.', tools: ['n8n', 'HubSpot', 'Gmail'], time: '4h saved/wk', complexity: 'Starter', badge: null },
  { cat: 'crm', title: 'Proposal sent → Follow-up sequence', desc: 'Auto-triggers a 5-touch follow-up cadence when a proposal is opened. Stops the moment a reply is detected.', tools: ['n8n', 'PandaDoc', 'Pipedrive'], time: '3h saved/wk', complexity: 'Starter', badge: 'Popular' },
  { cat: 'crm', title: 'Lost deal win-back campaign', desc: 'Monitors closed-lost deals and re-queues them for a nurture sequence 90 days post-close with updated case studies.', tools: ['Make', 'Salesforce', 'Mailchimp'], time: '2h saved/wk', complexity: 'Intermediate', badge: null },
  { cat: 'crm', title: 'Referral tracking + reward trigger', desc: 'Detects referral source from UTM, attributes commission to partner, fires reward payment via Stripe on deal close.', tools: ['n8n', 'Stripe', 'HubSpot'], time: '5h saved/wk', complexity: 'Advanced', badge: null },

  // Finance
  { cat: 'finance', title: 'Invoice generation → payment chase', desc: 'Creates invoice from project close event, sends to client, auto-chases at day 7, 14, 30 with escalating urgency.', tools: ['n8n', 'Xero', 'Gmail'], time: '6h saved/wk', complexity: 'Starter', badge: 'Popular' },
  { cat: 'finance', title: 'Expense approval workflow', desc: 'Employee submits receipt → manager notified via Slack → approved or rejected → Xero entry created automatically.', tools: ['n8n', 'Slack', 'Xero'], time: '3h saved/wk', complexity: 'Starter', badge: null },
  { cat: 'finance', title: 'Monthly P&L report builder', desc: 'Pulls actuals from Xero, compares to budget in Google Sheets, generates PDF summary and emails to directors.', tools: ['Make', 'Xero', 'Google Sheets'], time: '4h saved/wk', complexity: 'Intermediate', badge: null },

  // Operations
  { cat: 'ops', title: 'New client onboarding sequence', desc: '14-step onboarding automation: welcome pack, contract send, kick-off scheduling, intro calls, and 30-day check-in.', tools: ['n8n', 'Calendly', 'DocuSign'], time: '8h saved/wk', complexity: 'Intermediate', badge: 'Popular' },
  { cat: 'ops', title: 'Staff onboarding checklist', desc: 'HR trigger creates accounts across 12 tools, sends welcome email, assigns buddy, schedules 30-60-90 reviews.', tools: ['n8n', 'Google Workspace', 'Slack'], time: '5h saved/wk', complexity: 'Intermediate', badge: null },
  { cat: 'ops', title: 'Contract renewal radar', desc: 'Monitors contract end dates, alerts account manager 90/60/30 days out, drafts renewal email and logs activity.', tools: ['n8n', 'Pipedrive', 'DocuSign'], time: '3h saved/wk', complexity: 'Starter', badge: null },
  { cat: 'ops', title: 'Inventory reorder trigger', desc: 'Watches stock levels in real-time, auto-creates purchase orders when below threshold, notifies supplier and logs.', tools: ['Make', 'Shopify', 'Slack'], time: '6h saved/wk', complexity: 'Intermediate', badge: null },

  // Support
  { cat: 'support', title: 'Support ticket triage + routing', desc: 'Classifies inbound tickets by type, urgency and product using Claude AI, routes to correct queue and sets SLA timer.', tools: ['n8n', 'Claude AI', 'Zendesk'], time: '10h saved/wk', complexity: 'Advanced', badge: 'AI-powered' },
  { cat: 'support', title: 'CSAT survey → insight report', desc: 'Sends CSAT after ticket close, collects responses, clusters themes with NLP, emails weekly digest to CS lead.', tools: ['n8n', 'Claude AI', 'Typeform'], time: '4h saved/wk', complexity: 'Intermediate', badge: 'AI-powered' },
  { cat: 'support', title: 'Churn risk early warning', desc: 'Monitors login frequency, support volume and NPS score. Flags at-risk accounts to CS lead 14 days before churn.', tools: ['n8n', 'HubSpot', 'Slack'], time: '∞ value', complexity: 'Advanced', badge: null },

  // Marketing
  { cat: 'marketing', title: 'Content repurposing pipeline', desc: 'Blog post published → Claude AI extracts 5 LinkedIn posts, 3 tweets, 1 newsletter section. Queued for review.', tools: ['n8n', 'Claude AI', 'Buffer'], time: '8h saved/wk', complexity: 'Intermediate', badge: 'AI-powered' },
  { cat: 'marketing', title: 'Review request sequence', desc: 'Project close triggers personalised review request. Positive reviews routed to Google/Trustpilot, negative to CS.', tools: ['n8n', 'Gmail', 'Zapier'], time: '3h saved/wk', complexity: 'Starter', badge: 'Popular' },
  { cat: 'marketing', title: 'Competitor monitor + alert', desc: 'Tracks competitor pricing, job posts, and press mentions daily. Summarises changes and delivers to Slack.', tools: ['n8n', 'Claude AI', 'Slack'], time: '5h saved/wk', complexity: 'Advanced', badge: 'AI-powered' },

  // Reporting
  { cat: 'reporting', title: 'Weekly KPI digest', desc: 'Aggregates data from CRM, finance, and ops tools every Monday 7 AM. Formats as board-ready PDF and emails to leadership.', tools: ['n8n', 'Google Sheets', 'Gmail'], time: '4h saved/wk', complexity: 'Intermediate', badge: 'Popular' },
  { cat: 'reporting', title: 'Real-time dashboard sync', desc: 'Pushes live data from 8 sources into a single Google Data Studio dashboard. Refreshes every 15 minutes.', tools: ['Make', 'Google Data Studio', 'Sheets'], time: '6h saved/wk', complexity: 'Advanced', badge: null },
];

const complexityColor: Record<string, string> = {
  'Starter':      'rgba(45,80,22,0.12)',
  'Intermediate': 'rgba(200,152,64,0.12)',
  'Advanced':     'rgba(123,104,238,0.12)',
};
const complexityText: Record<string, string> = {
  'Starter':      '#2D5016',
  'Intermediate': '#C89840',
  'Advanced':     '#7B68EE',
};
---

<ShopLayout title="Workflow Library — 60+ Automation Templates | PURIST" description="Browse 60+ production-ready automation workflows by category. Filter by industry, complexity, or tool stack.">

  <!-- Hero -->
  <section class="bg-brand-black text-white pt-20 pb-16 lg:pt-28 lg:pb-20 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 50% 0%,rgba(232,180,176,0.07) 0%,transparent 60%);"></div>
    <div class="container-x relative z-10">
      <p class="text-[9px] uppercase tracking-[0.28em] font-bold mb-4" style="color:rgba(232,180,176,0.55);">Workflow Library</p>
      <div class="max-w-3xl mb-8">
        <h1 class="font-display text-[2.2rem] lg:text-[3rem] leading-[1.06] tracking-[-0.025em] text-white mb-4 text-balance">
          60+ production-ready workflows.<br/>
          <em class="font-medium" style="color:#E8B4B0;">Deploy in days, not months.</em>
        </h1>
        <p class="text-[15px] leading-relaxed max-w-2xl" style="color:rgba(255,255,255,0.45);">
          Every template is battle-tested across 312+ deployments. Filter by category, complexity, or tool stack. PURIST deploys any of these for you — customised to your exact stack.
        </p>
      </div>

      <!-- Category filters -->
      <div class="flex flex-wrap gap-2" id="cat-filters">
        <button class="cat-btn active text-[11px] font-semibold px-3.5 py-1.5 rounded-full transition-all duration-150" data-cat="all" style="background:#E8B4B0;color:#0A0A0A;">All workflows</button>
        {categories.map((c) => (
          <button class="cat-btn text-[11px] font-semibold px-3.5 py-1.5 rounded-full transition-all duration-150" data-cat={c.id}
            style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.55);border:1px solid rgba(255,255,255,0.09);">
            {c.label} <span style="opacity:0.5;">({c.count})</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Category summary strip -->
  <section class="bg-white border-b border-brand-gray-100 py-8">
    <div class="container-x">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {categories.map((c) => (
          <button class="cat-card text-left p-4 rounded-[14px] border border-brand-gray-100 hover:border-brand-gray-200 hover:bg-brand-cream transition group cursor-pointer" data-cat={c.id}>
            <div class="w-8 h-8 rounded-[10px] flex items-center justify-center mb-3" style={`background:${c.color}18;`}>
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke={c.color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={c.icon}/>
              </svg>
            </div>
            <p class="text-[12px] font-semibold text-brand-black leading-snug mb-1">{c.label}</p>
            <p class="text-[10px] text-brand-gray-500">{c.count} workflows</p>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Workflow grid -->
  <section class="bg-brand-beige py-16 lg:py-20">
    <div class="container-x">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="workflow-grid">
        {workflows.map((w) => (
          <article class="workflow-card bg-white rounded-card p-6 flex flex-col border border-brand-gray-100 hover:border-brand-gray-200 hover:shadow-sm transition" data-cat={w.cat}>
            <!-- Header row -->
            <div class="flex items-start justify-between gap-3 mb-3">
              <h3 class="font-display text-[15px] leading-snug text-brand-black flex-1">{w.title}</h3>
              {w.badge && (
                <span class="shrink-0 text-[9px] uppercase tracking-wider font-bold px-2 py-0.5 rounded-full"
                  style={w.badge === 'AI-powered'
                    ? 'background:rgba(123,104,238,0.10);color:#7B68EE;'
                    : w.badge === 'Popular'
                    ? 'background:rgba(232,180,176,0.15);color:#c4847e;'
                    : 'background:rgba(45,80,22,0.10);color:#2D5016;'}
                >{w.badge}</span>
              )}
            </div>

            <p class="text-[12.5px] text-brand-gray-600 leading-relaxed flex-1 mb-4">{w.desc}</p>

            <!-- Tool chips -->
            <div class="flex flex-wrap gap-1.5 mb-4">
              {w.tools.map((t) => (
                <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-brand-gray-50 border border-brand-gray-200 text-brand-gray-600">{t}</span>
              ))}
            </div>

            <!-- Footer -->
            <div class="flex items-center justify-between pt-4 border-t border-brand-gray-100">
              <span class="text-[10px] font-bold px-2 py-0.5 rounded-full" style={`background:${complexityColor[w.complexity]};color:${complexityText[w.complexity]};`}>{w.complexity}</span>
              <span class="text-[11px] font-semibold text-brand-black">{w.time}</span>
            </div>
          </article>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-16">
        <p class="text-brand-gray-500 text-sm">No workflows match this filter.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-black text-white py-16 lg:py-20">
    <div class="container-x text-center max-w-2xl mx-auto">
      <p class="text-[9px] uppercase tracking-[0.24em] font-bold mb-4" style="color:rgba(232,180,176,0.55);">Ready to deploy?</p>
      <h2 class="font-display text-[1.8rem] lg:text-[2.2rem] leading-[1.08] text-white mb-4 text-balance">
        We build any of these for you —<br/>
        <em class="font-medium" style="color:#E8B4B0;">customised to your exact stack.</em>
      </h2>
      <p class="text-[13px] mb-8" style="color:rgba(255,255,255,0.40);">Free 30-minute audit. We map your top 3 quick wins before you spend a penny.</p>
      <a href="/pages/welcome" class="inline-flex items-center gap-2.5 px-6 py-3.5 rounded-[14px] text-[13px] font-semibold transition-all"
        style="background:#E8B4B0;color:#0A0A0A;"
        onmouseover="this.style.background='#d9a09b'"
        onmouseout="this.style.background='#E8B4B0'">
        Book a free audit →
      </a>
    </div>
  </section>

</ShopLayout>

<script is:inline>
(function () {
  var activecat = 'all';

  function filter(cat) {
    activecat = cat;
    var cards = document.querySelectorAll('.workflow-card');
    var visible = 0;
    cards.forEach(function (c) {
      var show = cat === 'all' || c.dataset.cat === cat;
      c.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    document.getElementById('empty-state').classList.toggle('hidden', visible > 0);

    // Update filter buttons
    document.querySelectorAll('.cat-btn').forEach(function (btn) {
      var a = btn.dataset.cat === cat;
      btn.style.background = a ? '#E8B4B0' : 'rgba(255,255,255,0.06)';
      btn.style.color = a ? '#0A0A0A' : 'rgba(255,255,255,0.55)';
      btn.style.border = a ? 'none' : '1px solid rgba(255,255,255,0.09)';
    });
  }

  document.querySelectorAll('.cat-btn').forEach(function (btn) {
    btn.addEventListener('click', function () { filter(this.dataset.cat); });
  });
  document.querySelectorAll('.cat-card').forEach(function (card) {
    card.addEventListener('click', function () {
      filter(this.dataset.cat);
      document.getElementById('workflow-grid').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
})();
</script>
