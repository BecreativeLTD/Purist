                 <line x1="14.08" y1="13.2" x2="15.88" y2="15.26" stroke="currentColor" stroke-width="1" opacity="0.45" stroke-linecap="round"/>
                 <line x1="12"    y1="14.4" x2="12"    y2="16.5" stroke="currentColor" stroke-width="1" opacity="0.45" stroke-linecap="round"/>
