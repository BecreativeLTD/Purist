                 <line x1="9.92"  y1="10.8" x2="8.12"  y2="8.74"  stroke="currentColor" stroke-width="1" opacity="0.45" stroke-linecap="round"/>`,
          },
          {
            id:'logic', label:'Logic', count:10, color:'#555', bg:'rgba(0,0,0,0.05)', border:'rgba(0,0,0,0.14)',
            // Git branch — single input, two diverging paths with terminal dots. Universal dev metaphor for branching logic
            svg:`<circle cx="12" cy="4.5" r="2"  fill="none" stroke="currentColor" stroke-width="1.3"/>
                 <circle cx="5"  cy="19.5" r="2" fill="none" stroke="currentColor" stroke-width="1.3"/>
