                 <path d="M12 11 C12 15 19 14 19 17.5" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>`,
          },
          {
            id:'connect', label:'Integration', count:13, color:'#2D5016', bg:'rgba(45,80,22,0.07)', border:'rgba(45,80,22,0.2)',
            // Two interlocked rings with a bidirectional exchange arrow — sync, bridge, connect
            svg:`<path d="M9 7H6.5A4.5 4.5 0 0 0 6.5 17H9"   fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                 <path d="M15 7h2.5A4.5 4.5 0 0 1 17.5 17H15" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                 <line x1="9"  y1="10" x2="15" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                 <line x1="15" y1="14" x2="9"  y2="14" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                 <polyline points="13,8 15,10 13,12"   fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
                 <polyline points="11,12 9,14 11,16" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>`,
          },
          {
            id:'data', label:'Data', count:9, color:'#5248b8', bg:'rgba(123,104,238,0.09)', border:'rgba(123,104,238,0.25)',
            // Database cylinder — 3 shelves, clean ellipses. The canonical data icon, executed precisely
            svg:`<ellipse cx="12" cy="5.5" rx="8.5" ry="2.8" fill="none" stroke="currentColor" stroke-width="1.2"/>
                 <path d="M3.5 5.5v5.2c0 1.55 3.81 2.8 8.5 2.8s8.5-1.25 8.5-2.8V5.5" fill="none" stroke="currentColor" stroke-width="1.2"/>
                 <path d="M3.5 10.7v5.2c0 1.55 3.81 2.8 8.5 2.8s8.5-1.25 8.5-2.8v-5.2" fill="none" stroke="currentColor" stroke-width="1.2"/>`,
          },
          {
            id:'monitor', label:'Monitor', count:10, color:'#a07830', bg:'rgba(200,152,64,0.09)', border:'rgba(200,152,64,0.25)',
            // Monitor frame + sharp EKG heartbeat + stand. Premium, identifiable, "live watching"
            svg:`<rect x="2" y="2.5" width="20" height="13.5" rx="2.2" fill="none" stroke="currentColor" stroke-width="1.2"/>
                 <polyline points="4.5,9.5 6.5,9.5 8,6 10,14 12,8 13.5,9.5 16,9.5 18,9.5" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"/>
                 <line x1="9"  y1="19.5" x2="15"  y2="19.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                 <path d="M12 16 L10.5 19.5 M12 16 L13.5 19.5" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>`,
          },
        ] as {id:string;label:string;count:number;color:string;bg:string;border:string;svg:string}[]).map((node, i, arr) => (
          <div class="flex items-center flex-1 min-w-0">
            <!-- Node -->
            <div class="shrink-0 flex flex-col items-center gap-3 mx-auto">
              <!-- Step number -->
              <span class="sdna-num text-[8px] font-mono tracking-widest" style={`color:rgba(255,255,255,0.25);animation-delay:${(i*0.45).toFixed(2)}s;`}>0{i+1}</span>
              <!-- Icon tile -->
              <div
                class="sdna-tile relative flex items-center justify-center hover:scale-110 transition-[transform] duration-300"
                style={`width:68px;height:68px;border-radius:22px;background:linear-gradient(160deg,${node.color}26 0%,${node.color}05 100%);border:1px solid rgba(255,255,255,${(0.04+i*0.014).toFixed(3)});border-top-color:rgba(255,255,255,${(0.11+i*0.018).toFixed(3)});color:${node.color};box-shadow:0 1px 0 rgba(255,255,255,0.09) inset,0 -1px 0 rgba(0,0,0,0.18) inset,0 10px 36px ${node.color}${Math.round(14+i*4).toString(16).padStart(2,'0')},0 1px 4px rgba(0,0,0,0.45);opacity:${(0.62+i*0.076).toFixed(2)};filter:brightness(${(1.05+i*0.06).toFixed(2)});backdrop-filter:blur(8px);animation-delay:${(i*0.45).toFixed(2)}s;`}
              >
                <!-- Radial glow overlay (pulses in sync with float) -->
                <div class="sdna-glow absolute inset-0 rounded-[22px] pointer-events-none" style={`background:radial-gradient(ellipse 65% 55% at 50% 35%, ${node.color}38 0%, transparent 70%);animation-delay:${(i*0.45).toFixed(2)}s;`}/>
                <!-- Expanding ring on each "beat" -->
                <div class="sdna-ring pointer-events-none" style={`position:absolute;inset:-5px;border-radius:27px;border:1px solid ${node.color};animation-delay:${(i*0.45).toFixed(2)}s;`}/>
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" class="relative z-10" set:html={node.svg}/>
              </div>
              <!-- Label + count -->
              <div class="flex flex-col items-center gap-0.5">
                <span class="text-[9px] tracking-[0.18em] uppercase font-semibold whitespace-nowrap" style={`color:${node.color};filter:brightness(1.4);`}>{node.label}</span>
                <span class="text-[8px] tabular-nums leading-none" style="color:rgba(255,255,255,0.3)">{node.count} tools</span>
              </div>
            </div>

            {i < arr.length - 1 && (
              <div class="flex-1 flex items-center pb-5 min-w-[32px] relative" style="padding-left:4px;padding-right:4px;">
                <!-- Gradient connector line -->
                <div class="flex-1 h-px relative overflow-hidden" style={`background:linear-gradient(90deg,${node.color}35,${arr[i+1].color}35);`}>
                  <!-- Static midpoint dot -->
                  <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-1 h-1 rounded-full" style={`background:linear-gradient(135deg,${node.color},${arr[i+1].color});opacity:0.45;`}/>
                  <!-- Traveling pulse dot -->
                  <div class="sdna-travel pointer-events-none absolute top-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full" style={`background:${arr[i+1].color};box-shadow:0 0 5px 2px ${arr[i+1].color}70;animation-delay:${(i*0.55).toFixed(2)}s;`}/>
                </div>
                <!-- Arrowhead -->
                <svg width="8" height="8" viewBox="0 0 8 8" fill="none" class="shrink-0 ml-0.5">
                  <path d="M1 1.5 L6 4 L1 6.5" stroke={arr[i+1].color} stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" opacity="0.65"/>
                </svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>

  <style>
    /* Float — uses standalone `translate` property so it composes with transform:scale() from hover */
    @keyframes sdna-float {
      0%, 100% { translate: 0 0px; }
      50%       { translate: 0 -5px; }
    }
    /* Glow intensity pulse (in sync with float) */
    @keyframes sdna-glow-pulse {
      0%, 100% { opacity: 0.35; }
      50%       { opacity: 0.85; }
    }
    /* Expanding ring that fades out on each beat */
    @keyframes sdna-ring-expand {
      0%   { opacity: 0; scale: 0.94; }
      18%  { opacity: 0.28; }
      100% { opacity: 0;   scale: 1.10; }
    }
    /* Step-number brightness pulse */
    @keyframes sdna-num-pulse {
      0%, 100% { opacity: 0.25; }
      50%       { opacity: 0.60; }
    }
    /* Connector travel dot */
    @keyframes sdna-travel-dot {
      0%   { left: -4px; opacity: 0; }
      8%   { opacity: 1; }
      88%  { opacity: 0.9; }
      100% { left: calc(100% + 4px); opacity: 0; }
    }

    .sdna-tile {
      animation: sdna-float 3.4s ease-in-out infinite;
      will-change: translate;
    }
    .sdna-glow {
      animation: sdna-glow-pulse 3.4s ease-in-out infinite;
    }
    .sdna-ring {
      animation: sdna-ring-expand 3.4s ease-in-out infinite;
    }
    .sdna-num {
      animation: sdna-num-pulse 3.4s ease-in-out infinite;
    }
    .sdna-travel {
      animation: sdna-travel-dot 2.2s linear infinite;
      position: absolute;
    }

    /* Respect reduced-motion preference */
    @media (prefers-reduced-motion: reduce) {
      .sdna-tile, .sdna-glow, .sdna-ring, .sdna-num, .sdna-travel {
        animation: none;
      }
    }
  </style>

