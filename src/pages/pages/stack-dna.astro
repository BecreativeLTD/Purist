<ShopLayout
  title="Stack DNA — PURIST"
  description="Every technical component behind a PURIST automation: 62 components, 6 layers, zero black boxes. Full transparency on what we deploy and why."
>

  <!-- ══════════════════════════════════════════════════════════════ -->
  <!-- HERO                                                           -->
  <!-- ══════════════════════════════════════════════════════════════ -->
  <div class="bg-brand-black text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.035]" style="background-image:linear-gradient(#fff 1px,transparent 1px),linear-gradient(90deg,#fff 1px,transparent 1px);background-size:36px 36px;"/>
    <svg class="absolute right-0 top-0 h-full opacity-[0.05] pointer-events-none" viewBox="0 0 400 500" aria-hidden="true">
      <circle cx="400" cy="250" r="180" fill="none" stroke="#E8B4B0" stroke-width="0.8" stroke-dasharray="10 7"/>
      <circle cx="400" cy="250" r="120" fill="none" stroke="#E8B4B0" stroke-width="0.5" stroke-dasharray="6 5"/>
      <circle cx="400" cy="250" r="70"  fill="none" stroke="#E8B4B0" stroke-width="0.4" stroke-dasharray="4 4"/>
      <line x1="400" y1="250" x2="400" y2="70" stroke="#E8B4B0" stroke-width="0.5"/>
      <line x1="400" y1="250" x2="244" y2="90" stroke="#E8B4B0" stroke-width="0.3"/>
      <line x1="400" y1="250" x2="220" y2="250" stroke="#E8B4B0" stroke-width="0.3"/>
    </svg>

    <div class="container-x py-20 lg:py-28 relative">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-1.5 bg-brand-pink/15 text-brand-pink text-[10px] tracking-[0.15em] uppercase px-3 py-1 rounded-full mb-7 font-medium">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-pink animate-pulse"/>
          Full-stack transparency
        </span>
        <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl leading-[1.02] mb-6 text-balance">
          Stack DNA
        </h1>
        <p class="text-white/50 text-lg leading-relaxed max-w-2xl mb-4">
          Every component behind a PURIST automation — what it does, why we chose it over alternatives, and what it delivers in production. No black boxes. No mystery tools.
        </p>
        <p class="text-white/30 text-sm mb-12">62 components · 6 layers · 500+ production deployments</p>

        <!-- KPI strip -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {([
            { v: '500+',  l: 'Workflows deployed',  sub: 'across 8 industries',      accent: '#E8B4B0' },
            { v: '142k',  l: 'Executions / month',  sub: 'avg. across all clients',   accent: '#C8B99A' },
            { v: '99.7%', l: 'Uptime SLA',           sub: 'enforced & monitored',      accent: '#7B68EE' },
            { v: '9.4×',  l: 'Average ROI',          sub: 'within 90 days',            accent: '#C89840' },
          ] as {v:string;l:string;sub:string;accent:string}[]).map(k => (
            <div class="relative rounded-xl px-5 py-5 overflow-hidden kpi-card" style={`background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);`}>
              <!-- Left accent bar -->
              <div class="absolute left-0 top-4 bottom-4 w-[2.5px] rounded-r-full" style={`background:${k.accent};opacity:0.65;`}/>
              <!-- Ambient glow -->
              <div class="absolute inset-0 pointer-events-none" style={`background:radial-gradient(ellipse 80% 60% at 0% 50%, ${k.accent}10 0%, transparent 70%);`}/>
              <div class="relative pl-3">
                <div class="font-display text-[28px] font-medium text-white leading-none mb-2 tracking-tight">{k.v}</div>
                <div class="text-white/65 text-[11px] font-medium mb-0.5">{k.l}</div>
                <div class="text-white/50 text-[9.5px] leading-relaxed">{k.sub}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════════ -->
  <!-- STACK FLOW DIAGRAM                                             -->
  <!-- ══════════════════════════════════════════════════════════════ -->
