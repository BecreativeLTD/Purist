</style>

<script>
  // ── Filter tabs ─────────────────────────────────────────────────
  const tabs     = document.querySelectorAll<HTMLButtonElement>('.layer-tab');
  const sections = document.querySelectorAll<HTMLElement>('.layer-section');

  function activateTab(tab: HTMLButtonElement) {
    const layer = tab.dataset.layer!;

    tabs.forEach(t => {
      const active = t === tab;
      const tDot   = t.dataset.dot!;

      // Border: inline style overrides Tailwind, tinted to each layer's accent
      t.style.borderBottomColor = active ? tDot : 'transparent';

      // Dot
      const dotEl = t.querySelector<HTMLElement>('span:first-child');
      if (dotEl) dotEl.style.opacity = active ? '1' : '0.35';

      // Label
      const labelEl = t.querySelectorAll('span')[1] as HTMLElement;
      if (labelEl) {
        labelEl.style.color = active ? '#0A0A0A' : '';
        labelEl.classList.toggle('text-brand-gray-400', !active);
      }

      // Count badge: tinted to layer accent when active
      const badge = t.querySelectorAll('span')[2] as HTMLElement;
      if (badge) {
        badge.style.background = active ? tDot : '';
        badge.style.color      = active ? '#fff' : '';
        badge.classList.toggle('bg-brand-gray-100',   !active);
        badge.classList.toggle('text-brand-gray-400', !active);
      }
    });

    sections.forEach(sec => {
      const show = layer === 'all' || sec.dataset.layerSection === layer;
      sec.style.display = show ? '' : 'none';
    });

    // Smooth scroll to the selected layer section
    if (layer !== 'all') {
      requestAnimationFrame(() => {
        const target = document.querySelector<HTMLElement>(`[data-layer-section="${layer}"]`);
        if (target) {
          const top = target.getBoundingClientRect().top + window.scrollY - 120;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      });
    }
  }

  tabs.forEach(tab => tab.addEventListener('click', () => activateTab(tab)));

  // ── Smooth expand / collapse ────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.expand-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling as HTMLElement;
      const icon    = btn.querySelector<HTMLElement>('.expand-icon');
      const label   = btn.querySelector<HTMLElement>('.expand-label');
      const open    = btn.getAttribute('aria-expanded') === 'true';

      btn.setAttribute('aria-expanded', String(!open));
      content.style.maxHeight = open ? '0' : content.scrollHeight + 'px';

      if (icon)  icon.style.transform = open ? '' : 'rotate(180deg)';
      if (label) label.textContent    = open ? 'Engineering depth' : 'Collapse';
    });
  });
</script>
