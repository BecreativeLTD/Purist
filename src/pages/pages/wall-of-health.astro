<!-- ═══ TIMELINE — how a deployment works ══════════════════════════ -->
<section class="bg-brand-cream py-16 lg:py-24" style="border-top:1px solid rgba(10,10,10,0.06);">
  <div class="container-x">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">

      <div>
        <p class="eyebrow mb-4">How we build this</p>
        <h2 class="font-display text-3xl lg:text-4xl leading-tight text-balance mb-6">
