---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';

const PINK = '#c4847e';
const PINK_BG = 'rgba(232,180,176,0.10)';

const results = [
  { company: 'Dental group — London', industry: 'Healthcare', time: '14 h/wk', outcome: 'Automated patient reminders, recall campaigns and billing reconciliation. Front desk now focuses on patient experience.', stat: '60%', statLabel: 'reduction in admin time' },
  { company: 'Property agency — Manchester', industry: 'Real Estate', time: '9 h/wk', outcome: 'Portal leads captured automatically into CRM, followed up within 90 seconds, viewing confirmations sent without staff input.', stat: '40%', statLabel: 'more deals closed' },
  { company: 'Marketing agency — Edinburgh', industry: 'Agency', time: '11 h/wk', outcome: 'Client onboarding, weekly reporting and invoice generation fully automated. Team eliminated three manual tools.', stat: '60%', statLabel: 'faster client delivery' },
  { company: 'E-commerce brand — Bristol', industry: 'E-commerce', time: '8 h/wk', outcome: 'Order confirmations, abandoned cart recovery and Tier-1 support handled automatically 24/7.', stat: '70%', statLabel: 'fewer support tickets' },
  { company: 'Law firm — Birmingham', industry: 'Legal', time: '12 h/wk', outcome: 'Client intake forms, document generation and deadline tracking automated end-to-end.', stat: '45%', statLabel: 'faster client intake' },
  { company: 'Recruitment firm — Leeds', industry: 'Staffing', time: '10 h/wk', outcome: 'CV parsing, candidate follow-ups and interview scheduling handled by AI agents. Consultants only touch warm leads.', stat: '3×', statLabel: 'more placements per consultant' },
];
---

<BaseLayout
  title="Client Results — Wall of Outcomes | PURIST Automation"
  description="Real results from real businesses. See how PURIST automation deployments save time, reduce costs and scale operations across healthcare, real estate, agencies and more."
>
  <Header />
  <main id="main-content">

    <div class="py-16 lg:py-20" style="background:#0A0A0A">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
        <p class="text-xs uppercase tracking-widest font-bold mb-4" style={`color:${PINK}`}>Client outcomes</p>
        <h1 class="text-3xl lg:text-5xl font-bold text-white mb-5 leading-tight">Wall of Results</h1>
        <p class="text-base lg:text-lg text-gray-400 max-w-xl mx-auto">
          Every number below is from a real deployment. Real businesses, real time saved, real ROI.
        </p>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14 lg:py-20">

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-14">
        {[
          { value: '500+', label: 'automations deployed' },
          { value: '14 h', label: 'average time saved per week' },
          { value: '9.2×', label: 'average ROI at 90 days' },
          { value: '£168k', label: 'average annual saving' },
          { value: '99.97%', label: 'uptime across all workflows' },
          { value: '< 7 days', label: 'average deployment time' },
        ].map(s => (
          <div class="rounded-xl border border-gray-200 p-5 text-center">
            <p class="text-2xl font-bold mb-1" style={`color:${PINK}`}>{s.value}</p>
            <p class="text-xs text-gray-500">{s.label}</p>
          </div>
        ))}
      </div>

      <div class="grid sm:grid-cols-2 gap-6 mb-14">
        {results.map(r => (
          <div class="rounded-2xl border border-gray-200 p-6">
            <div class="flex items-start justify-between gap-3 mb-4">
              <div>
                <p class="text-sm font-bold text-gray-900">{r.company}</p>
                <p class="text-xs text-gray-400 mt-0.5">{r.industry} · {r.time} saved per week</p>
              </div>
              <div class="text-right shrink-0">
                <p class="text-xl font-bold" style={`color:${PINK}`}>{r.stat}</p>
                <p class="text-[10px] text-gray-400 leading-tight">{r.statLabel}</p>
              </div>
            </div>
            <p class="text-sm text-gray-600 leading-relaxed">{r.outcome}</p>
          </div>
        ))}
      </div>

      <div class="rounded-2xl p-8 text-center" style={`background:${PINK_BG};border:1px solid rgba(196,132,126,0.20)`}>
        <h2 class="text-xl font-bold text-gray-900 mb-3">Your results start with a free audit.</h2>
        <p class="text-sm text-gray-600 mb-6 max-w-lg mx-auto">In 60 minutes we map your workflows, calculate your exact ROI and give you a deployment plan. No commitment.</p>
        <a href="/pages/welcome" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white transition" style={`background:${PINK}`}>Book free audit →</a>
      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>
