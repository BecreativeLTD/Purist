---
import ShopLayout from '~/layouts/ShopLayout.astro';
import testimonialsData from '~/data/testimonials.json';

const { reviews, miniTestimonials } = testimonialsData;

const cases = [
  {
    id: 'dental',
    industry: 'Healthcare',
    tag: 'DENTAL GROUP · LONDON',
    headline: '60% less admin. Same staff. Better patient experience.',
    hours: '14',
    stat: '60%',
    statLabel: 'reduction in admin time',
    detail: 'Automated patient reminders, recall campaigns and insurance billing reconciliation. Front desk team refocused entirely on patient care zero manual follow-up.',
    before: '3 FTE hours daily on reminders, recalls & billing reconciliation — 90% of it repetitive.',
    workflows: ['Appointment reminders', 'Insurance pre-auth', 'Recall campaigns', 'Billing reconciliation'],
    timeline: '6 days to deploy',
    roi: '£112k annual saving',
    roi_multiple: '12.1×',
    breakeven: '19 days',
    tools: ['n8n', 'Dentally', 'SendGrid', 'Stripe'],
    quote: 'We stopped losing patients to missed recalls. The recall rate went from 34% to 71% in 8 weeks.',
    quote_by: 'Practice Manager, Dental Group',
  },
  {
    id: 'agency',
    industry: 'Agency',
    tag: 'MARKETING AGENCY · EDINBURGH',
    headline: '45 client accounts. No additional headcount.',
    hours: '22',
    stat: '3×',
    statLabel: 'more clients per operator',
    detail: 'Client onboarding, weekly performance reporting and invoice generation fully automated. Team eliminated three manual tools and one contractor role.',
    before: '28h/week on reporting & onboarding admin. One contractor hired purely for report generation.',
    workflows: ['Client onboarding', 'Weekly reporting', 'Invoice generation', 'Project kickoff flows'],
    timeline: '8 days to deploy',
    roi: '£89k contractor savings',
    roi_multiple: '9.8×',
    breakeven: '23 days',
    tools: ['n8n', 'HubSpot', 'Xero', 'Slack'],
    quote: 'Our ops manager finally does strategy instead of admin. We scaled from 28 to 45 clients without a single hire.',
    quote_by: 'CEO, Marketing Agency',
  },
  {
    id: 'realestate',
    industry: 'Real Estate',
    tag: 'PROPERTY AGENCY · MANCHESTER',
    headline: 'Portal leads followed up in 90 seconds automatically.',
    hours: '9',
    stat: '40%',
    statLabel: 'more deals closed',
    detail: 'Portal leads captured automatically into CRM, qualified by AI, and followed up within 90 seconds. Viewing confirmations sent without any staff input.',
    before: 'Portal leads responded to in 4+ hours average. 60% of enquiries received no same-day reply.',
    workflows: ['Lead capture', 'AI qualification', 'Viewing confirmations', 'Follow-up sequences'],
    timeline: '5 days to deploy',
    roi: '£74k additional revenue',
    roi_multiple: '8.3×',
    breakeven: '18 days',
    tools: ['n8n', 'Rightmove', 'Salesforce', 'Twilio'],
    quote: "First to call wins. Now we are always first. Our conversion from enquiry to viewing went from 18% to 31%.",
    quote_by: 'Director, Property Agency',
  },
  {
    id: 'ecommerce',
    industry: 'E-commerce',
    tag: 'DTC BRAND · BRISTOL',
    headline: '70% fewer support tickets. 24/7 Tier-1 support with zero staff.',
    hours: '8',
    stat: '70%',
    statLabel: 'fewer support tickets',
    detail: 'Order confirmations, abandoned cart recovery and Tier-1 support handled automatically around the clock. Customer satisfaction score up 18 points.',
    before: 'Support team fielding 200+ tickets/day. 3-day resolution backlog. Two full-time agents on Tier-1.',
    workflows: ['Order confirmations', 'Abandoned cart', 'AI support triage', 'Return processing'],
    timeline: '7 days to deploy',
    roi: '£48k support savings',
    roi_multiple: '7.6×',
    breakeven: '31 days',
    tools: ['n8n', 'Shopify', 'Gorgias', 'Claude AI'],
    quote: 'Our support backlog went from 3 days to 2 hours. CSAT went from 61 to 79. Same headcount.',
    quote_by: 'Head of Ops, DTC Brand',
  },
  {
    id: 'legal',
    industry: 'Legal',
    tag: 'LAW FIRM · BIRMINGHAM',
    headline: 'Client intake from 14 days to 3 days.',
    hours: '12',
    stat: '78%',
    statLabel: 'faster client onboarding',
    detail: 'Client intake forms, conflict checks, engagement letter generation and deadline tracking automated end-to-end. Fee earners now touch only billable work.',
    before: 'Intake taking 14 days average. Fee earners spending 4h/week on non-billable admin. Clients lost to faster firms.',
    workflows: ['Client intake', 'Conflict checks', 'Document generation', 'Deadline tracking'],
    timeline: '9 days to deploy',
    roi: '£95k billable hours recovered',
    roi_multiple: '13.4×',
    breakeven: '21 days',
    tools: ['n8n', 'Clio', 'DocuSign', 'Claude AI'],
    quote: 'Fee earners now touch only billable work. We recovered £95K in billable hours in the first year alone.',
    quote_by: 'Managing Partner, Law Firm',
  },
  {
    id: 'staffing',
    industry: 'Staffing',
    tag: 'RECRUITMENT FIRM · LEEDS',
    headline: '3× more placements. Same team. AI handles the pipeline.',
    hours: '10',
    stat: '3×',
    statLabel: 'more placements per consultant',
    detail: 'CV parsing, candidate follow-ups and interview scheduling handled by AI agents. Consultants only ever touch warm, pre-qualified candidates.',
    before: 'Consultants spending 60% of time on CV screening, scheduling, and status emails — only 40% on actual placement activity.',
    workflows: ['CV parsing', 'AI candidate scoring', 'Interview scheduling', 'Offer coordination'],
    timeline: '7 days to deploy',
    roi: '£168k additional placements',
    roi_multiple: '11.2×',
    breakeven: '25 days',
    tools: ['n8n', 'Workable', 'Claude AI', 'Google Calendar'],
    quote: 'Our consultants finally do what they were hired to do. Placements per head went from 2.1 to 6.4 per month.',
    quote_by: 'MD, Recruitment Firm',
  },
];

const industries = ['All', 'Healthcare', 'Agency', 'Real Estate', 'E-commerce', 'Legal', 'Staffing'];

const aggregate = [
  { value: '312', suffix: '+', label: 'businesses automated' },
  { value: '14', suffix: 'h', label: 'average hours saved / week' },
  { value: '9.2', suffix: '×', label: 'average ROI at 90 days' },
  { value: '168', suffix: 'k', label: 'avg annual saving (£)' },
  { value: '99.97', suffix: '%', label: 'uptime across all workflows' },
  { value: '7', suffix: 'd', label: 'average deployment time' },
];

const benchmarks = [
  { industry: 'Healthcare', icon: 'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v11m3-11v11m3-11v11M3 9h18', hours: '18h', saving: '£112K', roi: '12.1×', payback: '19 days', deploy: '6–8 days', color: '#7B68EE' },
  { industry: 'Agency',     icon: 'M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z', hours: '22h', saving: '£89K', roi: '9.8×', payback: '23 days', deploy: '7–9 days', color: '#E8B4B0' },
  { industry: 'Real Estate', icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10', hours: '9h', saving: '£74K', roi: '8.3×', payback: '18 days', deploy: '5–6 days', color: '#C89840' },
  { industry: 'E-commerce', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z', hours: '8h', saving: '£48K', roi: '7.6×', payback: '31 days', deploy: '7–8 days', color: '#059669' },
  { industry: 'Legal',      icon: 'M3 6l9-4 9 4v6c0 5.5-4 10-9 12C7 22 3 17.5 3 12V6z', hours: '12h', saving: '£95K', roi: '13.4×', payback: '21 days', deploy: '8–10 days', color: '#dc2626' },
  { industry: 'Staffing',   icon: 'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75', hours: '10h', saving: '£168K', roi: '11.2×', payback: '25 days', deploy: '7–8 days', color: '#6366f1' },
];
---

<ShopLayout
  title="Wall of Results — Real Client Outcomes | PURIST"
  description="312+ businesses automated. Real time savings, real ROI, real outcomes. Case studies across dental, real estate, agencies, e-commerce, legal and staffing."
>

<!-- ═══ HERO ═══════════════════════════════════════════════════════ -->
<header class="relative overflow-hidden" style="background:#0A0A0A;">
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 80% 60% at 30% 50%,rgba(232,180,176,0.07) 0%,transparent 65%);"/>

  <div class="container-x relative z-10 pt-16 lg:pt-24 pb-12 lg:pb-16">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5 flex-wrap">
        <p class="text-[9px] uppercase tracking-[0.28em] font-bold" style="color:rgba(232,180,176,0.60);">Wall of Results</p>
        <span style="width:1px;height:12px;background:rgba(255,255,255,0.10);display:inline-block;"></span>
        <span style="font-size:9px;color:rgba(255,255,255,0.22);font-family:monospace;" id="last-updated">Updated June 2026</span>
        <span style="display:inline-flex;align-items:center;gap:4px;background:rgba(74,222,128,0.10);border:1px solid rgba(74,222,128,0.20);border-radius:100px;padding:2px 8px;">
          <span style="width:5px;height:5px;border-radius:50%;background:#4ADE80;"></span>
          <span style="font-size:8.5px;font-weight:600;color:#4ADE80;letter-spacing:0.10em;text-transform:uppercase;">Live data</span>
        </span>
      </div>
      <h1 class="font-display text-[2.2rem] sm:text-[3rem] lg:text-[3.8rem] leading-[1.06] tracking-[-0.025em] text-white mb-6 text-balance">
        Every number here<br/>
        <em class="font-medium" style="color:#E8B4B0;">came from a real deployment.</em>
      </h1>
      <p class="text-[15px] lg:text-base leading-relaxed max-w-xl mb-6" style="color:rgba(255,255,255,0.40);">
        Not projections. Not demos. Aggregated data from 312+ clients across dental, real estate, agencies, e-commerce, legal and staffing. Every figure independently verifiable on request.
      </p>
      <div class="flex items-center gap-2 flex-wrap">
        {['No projections — verified actuals only', 'Updated monthly', 'Anonymised with client consent'].map(t => (
          <span style="display:inline-flex;align-items:center;gap:5px;font-size:10.5px;color:rgba(255,255,255,0.30);">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#4ADE80" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            {t}
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- Animated counter strip -->
  <div class="relative z-10" style="border-top:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.02);">
    <div class="container-x py-8 lg:py-10">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6 lg:gap-0 lg:divide-x lg:divide-white/10">
        {aggregate.map((s) => (
          <div class="text-center lg:px-6">
            <p class="font-display text-2xl lg:text-3xl leading-none text-white mb-1.5"
               data-counter
               data-target={s.value}
               data-suffix={s.suffix}
               data-decimal={s.value.includes('.') ? 'true' : undefined}
            >0{s.suffix}</p>
            <p class="text-[10px] uppercase tracking-[0.14em] font-medium" style="color:rgba(255,255,255,0.28);">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</header>

<!-- ═══ INDUSTRY BENCHMARKS TABLE ══════════════════════════════════ -->
<section style="background:#0A0A0A;border-top:1px solid rgba(255,255,255,0.04);padding:56px 0 64px;">
  <div class="container-x">
    <div class="flex flex-wrap items-end justify-between gap-4 mb-8">
      <div>
        <p style="font-size:9px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:rgba(232,180,176,0.55);margin-bottom:10px;">Industry benchmarks</p>
        <h2 class="font-display text-2xl lg:text-3xl text-white leading-tight">
          How your sector<br/><em style="color:#E8B4B0;">typically performs.</em>
        </h2>
      </div>
      <p style="font-size:11px;color:rgba(255,255,255,0.25);max-width:320px;line-height:1.6;">Averages across all PURIST deployments in each vertical. Sorted by ROI multiple.</p>
    </div>

    <!-- Desktop table -->
    <div style="display:none;" id="bench-table-desktop">
      <table style="width:100%;border-collapse:collapse;font-family:'Inter',sans-serif;">
        <thead>
          <tr style="border-bottom:1px solid rgba(255,255,255,0.07);">
            {['Industry','Hours saved / wk','Annual saving','ROI multiple','Payback','Deploy time'].map(h => (
              <th style="font-size:9px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.28);padding:0 16px 14px;text-align:left;">{h}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {benchmarks.map((b, i) => (
            <tr style={`border-bottom:1px solid rgba(255,255,255,0.04);transition:background 0.15s;`}
                onmouseover="this.style.background='rgba(255,255,255,0.02)'"
                onmouseout="this.style.background=''">
              <td style="padding:14px 16px;">
                <div style="display:flex;align-items:center;gap:10px;">
                  <div style={`width:28px;height:28px;border-radius:8px;background:${b.color}18;border:1px solid ${b.color}30;display:flex;align-items:center;justify-content:center;flex-shrink:0;`}>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke={b.color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d={b.icon}/></svg>
                  </div>
                  <span style="font-size:12.5px;font-weight:600;color:#fff;">{b.industry}</span>
                </div>
              </td>
              <td style="padding:14px 16px;font-family:'Fraunces',Georgia,serif;font-size:16px;font-weight:400;color:#fff;">{b.hours}</td>
              <td style={`padding:14px 16px;font-family:'Fraunces',Georgia,serif;font-size:16px;font-weight:400;color:${b.color};`}>{b.saving}</td>
              <td style="padding:14px 16px;">
                <span style={`font-family:'Fraunces',Georgia,serif;font-size:16px;font-weight:400;color:#E8B4B0;background:rgba(232,180,176,0.08);padding:3px 10px;border-radius:100px;`}>{b.roi}</span>
              </td>
              <td style="padding:14px 16px;font-size:12px;color:rgba(255,255,255,0.55);">{b.payback}</td>
              <td style="padding:14px 16px;font-size:12px;color:rgba(255,255,255,0.55);">{b.deploy}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Mobile: cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="bench-cards-mobile">
      {benchmarks.map((b) => (
        <div style={`background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:16px 18px;`}>
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
            <div style={`width:28px;height:28px;border-radius:8px;background:${b.color}18;border:1px solid ${b.color}30;display:flex;align-items:center;justify-content:center;flex-shrink:0;`}>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke={b.color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d={b.icon}/></svg>
            </div>
            <span style="font-size:13px;font-weight:600;color:#fff;">{b.industry}</span>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            {[
              { k: 'Hours saved', v: b.hours },
              { k: 'Annual saving', v: b.saving, highlight: b.color },
              { k: 'ROI', v: b.roi, highlight: '#E8B4B0' },
              { k: 'Payback', v: b.payback },
            ].map(m => (
              <div>
                <p style="font-size:8.5px;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;color:rgba(255,255,255,0.25);margin-bottom:3px;">{m.k}</p>
                <p style={`font-family:'Fraunces',Georgia,serif;font-size:15px;color:${m.highlight || '#fff'};`}>{m.v}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <p style="font-size:10px;color:rgba(255,255,255,0.18);margin-top:16px;line-height:1.5;">All figures are averages across verified client deployments. Individual results vary based on team size, existing stack, and workflow complexity.</p>
  </div>
</section>

<!-- ═══ INDUSTRY FILTER + CASES ════════════════════════════════════ -->
<section class="bg-brand-cream py-16 lg:py-24">
  <div class="container-x">

    <div class="mb-10">
      <p class="eyebrow mb-3">Case studies</p>
      <h2 class="font-display text-2xl lg:text-3xl leading-tight text-balance">
        Real deployments.<br/><em class="font-medium">Real before and after.</em>
      </h2>
    </div>

    <!-- Filter tabs -->
    <div class="flex flex-wrap gap-2 mb-12" id="filter-bar">
      {industries.map((ind, i) => (
        <button
          data-filter={ind.toLowerCase()}
          onclick="filterCases(this)"
          class={`filter-btn text-[11px] font-semibold px-4 py-2 rounded-full transition-all duration-150 ${i === 0 ? 'bg-brand-black text-white' : 'bg-white text-brand-gray-600 border border-brand-gray-200 hover:border-brand-gray-400'}`}
        >
          {ind}
        </button>
      ))}
    </div>

    <!-- Case cards grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5" id="cases-grid">
      {cases.map((c) => (
        <article
          data-industry={c.industry.toLowerCase()}
          class="case-card group bg-white rounded-[20px] overflow-hidden scroll-fade"
          style="border:1px solid rgba(10,10,10,0.07);"
          onmouseover="this.style.boxShadow='0 12px 40px rgba(10,10,10,0.10)'"
          onmouseout="this.style.boxShadow=''"
        >
          <!-- Card header -->
          <div class="px-6 pt-6 pb-5" style="border-bottom:1px solid rgba(10,10,10,0.06);">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-[9px] uppercase tracking-[0.18em] font-bold mb-2" style="color:rgba(10,10,10,0.30);">{c.tag}</p>
                <h2 class="font-display text-lg lg:text-xl leading-snug tracking-[-0.01em] text-brand-black max-w-xs">{c.headline}</h2>
              </div>
              <!-- Big stat -->
              <div class="shrink-0 text-right">
                <p class="font-display text-3xl lg:text-4xl leading-none" style="color:#E8B4B0;">{c.stat}</p>
                <p class="text-[10px] leading-snug mt-1 max-w-[80px] text-right" style="color:rgba(10,10,10,0.38);">{c.statLabel}</p>
              </div>
            </div>
          </div>

          <!-- Before / After strip -->
          <div style="display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid rgba(10,10,10,0.06);">
            <div style="padding:10px 14px;background:rgba(220,38,38,0.03);border-right:1px solid rgba(10,10,10,0.06);">
              <p style="font-size:7.5px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:rgba(220,38,38,0.50);margin-bottom:4px;">Before</p>
              <p style="font-size:10.5px;color:rgba(10,10,10,0.55);line-height:1.45;">{c.before}</p>
            </div>
            <div style="padding:10px 14px;background:rgba(45,80,22,0.03);">
              <p style="font-size:7.5px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:rgba(45,80,22,0.55);margin-bottom:4px;">After</p>
              <p style="font-size:10.5px;color:rgba(10,10,10,0.55);line-height:1.45;">{c.detail}</p>
            </div>
          </div>

          <!-- Card body -->
          <div class="px-6 py-5">

            <!-- Client quote -->
            <blockquote style="background:#F8F6F1;border-left:2px solid #E8B4B0;border-radius:0 10px 10px 0;padding:10px 14px;margin-bottom:16px;">
              <p style="font-size:11.5px;font-style:italic;color:rgba(10,10,10,0.65);line-height:1.55;">"{c.quote}"</p>
              <p style="font-size:9.5px;color:rgba(10,10,10,0.35);margin-top:5px;font-weight:500;">— {c.quote_by}</p>
            </blockquote>

            <!-- Workflows -->
            <div class="flex flex-wrap gap-1.5 mb-5">
              {c.workflows.map((w) => (
                <span class="text-[10.5px] font-medium px-3 py-1 rounded-full" style="background:rgba(10,10,10,0.04);color:rgba(10,10,10,0.55);border:1px solid rgba(10,10,10,0.07);">{w}</span>
              ))}
            </div>

            <!-- KPI row: 4 metrics -->
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:16px;">
              {[
                { k: 'Saved/wk', v: c.hours + 'h' },
                { k: 'Annual ROI', v: c.roi.split(' ')[0] },
                { k: 'ROI multiple', v: c.roi_multiple, highlight: true },
                { k: 'Breakeven', v: c.breakeven },
              ].map(m => (
                <div style={`text-align:center;padding:8px 4px;border-radius:8px;background:${m.highlight ? 'rgba(232,180,176,0.10)' : 'rgba(10,10,10,0.03)'};border:1px solid ${m.highlight ? 'rgba(232,180,176,0.20)' : 'rgba(10,10,10,0.06)'};`}>
                  <p style={`font-family:'Fraunces',Georgia,serif;font-size:15px;font-weight:400;line-height:1;margin-bottom:3px;color:${m.highlight ? '#c4847e' : '#0A0A0A'};`}>{m.v}</p>
                  <p style="font-size:8px;font-weight:600;text-transform:uppercase;letter-spacing:0.10em;color:rgba(10,10,10,0.30);">{m.k}</p>
                </div>
              ))}
            </div>

            <!-- Stack + deploy -->
            <div class="flex items-center justify-between pt-4" style="border-top:1px solid rgba(10,10,10,0.05);">
              <div class="flex items-center gap-2">
                <p class="text-[9px] uppercase tracking-[0.14em] font-semibold shrink-0" style="color:rgba(10,10,10,0.22);">Stack</p>
                <div class="flex flex-wrap gap-1">
                  {c.tools.map((t) => (
                    <span class="text-[10px] px-2 py-0.5 rounded font-mono" style="background:rgba(10,10,10,0.03);color:rgba(10,10,10,0.40);border:1px solid rgba(10,10,10,0.06);">{t}</span>
                  ))}
                </div>
              </div>
              <div class="text-right shrink-0">
                <p class="text-[9px] uppercase tracking-[0.14em] font-semibold mb-0.5" style="color:rgba(10,10,10,0.28);">Deployed</p>
                <p class="text-sm font-display font-medium" style="color:#E8B4B0;">{c.timeline}</p>
              </div>
            </div>

          </div>
        </article>
      ))}
    </div>

    <!-- Empty state -->
