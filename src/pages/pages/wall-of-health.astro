---
import ShopLayout from '~/layouts/ShopLayout.astro';
import testimonialsData from '~/data/testimonials.json';

const { reviews, miniTestimonials } = testimonialsData;

const cases = [
  {
    id: 'dental',
    industry: 'Healthcare',
    tag: 'DENTAL GROUP · LONDON',
    headline: '60% less admin. Same staff. Better patient experience.',
    hours: '14',
    stat: '60%',
    statLabel: 'reduction in admin time',
    detail: 'Automated patient reminders, recall campaigns and insurance billing reconciliation. Front desk team refocused entirely on patient care — zero manual follow-up.',
    workflows: ['Appointment reminders', 'Insurance pre-auth', 'Recall campaigns', 'Billing reconciliation'],
    timeline: '6 days to deploy',
    roi: '£112k annual saving',
    tools: ['n8n', 'Dentally', 'SendGrid', 'Stripe'],
  },
  {
    id: 'agency',
    industry: 'Agency',
    tag: 'MARKETING AGENCY · EDINBURGH',
    headline: '45 client accounts. No additional headcount.',
    hours: '22',
    stat: '3×',
    statLabel: 'more clients per operator',
    detail: 'Client onboarding, weekly performance reporting and invoice generation fully automated. Team eliminated three manual tools and one contractor role.',
    workflows: ['Client onboarding', 'Weekly reporting', 'Invoice generation', 'Project kickoff flows'],
    timeline: '8 days to deploy',
    roi: '£89k contractor savings',
    tools: ['n8n', 'HubSpot', 'Xero', 'Slack'],
  },
  {
    id: 'realestate',
    industry: 'Real Estate',
    tag: 'PROPERTY AGENCY · MANCHESTER',
    headline: 'Portal leads followed up in 90 seconds — automatically.',
    hours: '9',
    stat: '40%',
    statLabel: 'more deals closed',
    detail: 'Portal leads captured automatically into CRM, qualified by AI, and followed up within 90 seconds. Viewing confirmations sent without any staff input.',
    workflows: ['Lead capture', 'AI qualification', 'Viewing confirmations', 'Follow-up sequences'],
    timeline: '5 days to deploy',
    roi: '£74k additional revenue',
    tools: ['n8n', 'Rightmove', 'Salesforce', 'Twilio'],
  },
  {
    id: 'ecommerce',
    industry: 'E-commerce',
    tag: 'DTC BRAND · BRISTOL',
    headline: '70% fewer support tickets. 24/7 Tier-1 support with zero staff.',
    hours: '8',
    stat: '70%',
    statLabel: 'fewer support tickets',
    detail: 'Order confirmations, abandoned cart recovery and Tier-1 support handled automatically around the clock. Customer satisfaction score up 18 points.',
    workflows: ['Order confirmations', 'Abandoned cart', 'AI support triage', 'Return processing'],
    timeline: '7 days to deploy',
    roi: '£48k support savings',
    tools: ['n8n', 'Shopify', 'Gorgias', 'Claude AI'],
  },
  {
    id: 'legal',
    industry: 'Legal',
    tag: 'LAW FIRM · BIRMINGHAM',
    headline: 'Client intake from 14 days to 3 days.',
    hours: '12',
    stat: '78%',
    statLabel: 'faster client onboarding',
    detail: 'Client intake forms, conflict checks, engagement letter generation and deadline tracking automated end-to-end. Fee earners now touch only billable work.',
    workflows: ['Client intake', 'Conflict checks', 'Document generation', 'Deadline tracking'],
    timeline: '9 days to deploy',
    roi: '£95k billable hours recovered',
    tools: ['n8n', 'Clio', 'DocuSign', 'Claude AI'],
  },
  {
    id: 'staffing',
    industry: 'Staffing',
    tag: 'RECRUITMENT FIRM · LEEDS',
    headline: '3× more placements. Same team. AI handles the pipeline.',
    hours: '10',
    stat: '3×',
    statLabel: 'more placements per consultant',
    detail: 'CV parsing, candidate follow-ups and interview scheduling handled by AI agents. Consultants only ever touch warm, pre-qualified candidates.',
    workflows: ['CV parsing', 'AI candidate scoring', 'Interview scheduling', 'Offer coordination'],
    timeline: '7 days to deploy',
    roi: '£168k additional placements',
    tools: ['n8n', 'Workable', 'Claude AI', 'Google Calendar'],
  },
];

const industries = ['All', 'Healthcare', 'Agency', 'Real Estate', 'E-commerce', 'Legal', 'Staffing'];

const aggregate = [
  { value: '312', suffix: '+', label: 'businesses automated' },
  { value: '14', suffix: 'h', label: 'average hours saved / week' },
  { value: '9.2', suffix: '×', label: 'average ROI at 90 days' },
  { value: '168', suffix: 'k', label: 'avg annual saving (£)' },
  { value: '99.97', suffix: '%', label: 'uptime across all workflows' },
  { value: '7', suffix: 'd', label: 'average deployment time' },
];
---

<ShopLayout
  title="Wall of Results — Real Client Outcomes | PURIST"
  description="312+ businesses automated. Real time savings, real ROI, real outcomes. Case studies across dental, real estate, agencies, e-commerce, legal and staffing."
>

<!-- ═══ HERO ═══════════════════════════════════════════════════════ -->
<header class="relative overflow-hidden" style="background:#0A0A0A;">
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 80% 60% at 30% 50%,rgba(232,180,176,0.07) 0%,transparent 65%);"/>

  <div class="container-x relative z-10 pt-16 lg:pt-24 pb-12 lg:pb-16">
    <div class="max-w-3xl">
      <p class="text-[9px] uppercase tracking-[0.28em] font-bold mb-5" style="color:rgba(232,180,176,0.60);">Wall of Results</p>
      <h1 class="font-display text-[2.2rem] sm:text-[3rem] lg:text-[3.8rem] leading-[1.06] tracking-[-0.025em] text-white mb-6 text-balance">
        Every number here<br/>
        <em class="font-medium" style="color:#E8B4B0;">came from a real deployment.</em>
      </h1>
      <p class="text-[15px] lg:text-base leading-relaxed max-w-xl" style="color:rgba(255,255,255,0.40);">
        Not projections. Not demos. Aggregated data from 312+ clients across dental, real estate, agencies, e-commerce, legal and staffing.
      </p>
    </div>
  </div>

  <!-- Animated counter strip -->
  <div class="relative z-10" style="border-top:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.02);">
    <div class="container-x py-8 lg:py-10">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6 lg:gap-0 lg:divide-x lg:divide-white/10">
        {aggregate.map((s) => (
          <div class="text-center lg:px-6">
            <p class="font-display text-2xl lg:text-3xl leading-none text-white mb-1.5"
               data-counter
               data-target={s.value}
               data-suffix={s.suffix}
               data-decimal={s.value.includes('.') ? 'true' : undefined}
            >0{s.suffix}</p>
            <p class="text-[10px] uppercase tracking-[0.14em] font-medium" style="color:rgba(255,255,255,0.28);">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</header>

<!-- ═══ INDUSTRY FILTER + CASES ════════════════════════════════════ -->
<section class="bg-brand-cream py-16 lg:py-24">
  <div class="container-x">

    <!-- Filter tabs -->
    <div class="flex flex-wrap gap-2 mb-12" id="filter-bar">
      {industries.map((ind, i) => (
        <button
          data-filter={ind.toLowerCase()}
          onclick="filterCases(this)"
          class={`filter-btn text-[11px] font-semibold px-4 py-2 rounded-full transition-all duration-150 ${i === 0 ? 'bg-brand-black text-white' : 'bg-white text-brand-gray-600 border border-brand-gray-200 hover:border-brand-gray-400'}`}
        >
          {ind}
        </button>
      ))}
    </div>

    <!-- Case cards grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5" id="cases-grid">
      {cases.map((c) => (
        <article
          data-industry={c.industry.toLowerCase()}
          class="case-card group bg-white rounded-[20px] overflow-hidden scroll-fade"
          style="border:1px solid rgba(10,10,10,0.07);"
          onmouseover="this.style.boxShadow='0 12px 40px rgba(10,10,10,0.10)'"
          onmouseout="this.style.boxShadow=''"
        >
          <!-- Card header -->
          <div class="px-6 pt-6 pb-5" style="border-bottom:1px solid rgba(10,10,10,0.06);">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-[9px] uppercase tracking-[0.18em] font-bold mb-2" style="color:rgba(10,10,10,0.30);">{c.tag}</p>
                <h2 class="font-display text-lg lg:text-xl leading-snug tracking-[-0.01em] text-brand-black max-w-xs">{c.headline}</h2>
              </div>
              <!-- Big stat -->
              <div class="shrink-0 text-right">
                <p class="font-display text-3xl lg:text-4xl leading-none" style="color:#E8B4B0;">{c.stat}</p>
                <p class="text-[10px] leading-snug mt-1 max-w-[80px] text-right" style="color:rgba(10,10,10,0.38);">{c.statLabel}</p>
              </div>
            </div>
          </div>

          <!-- Card body -->
          <div class="px-6 py-5">
            <p class="text-sm text-brand-gray-600 leading-relaxed mb-5">{c.detail}</p>

            <!-- Workflows -->
            <div class="flex flex-wrap gap-1.5 mb-5">
              {c.workflows.map((w) => (
                <span class="text-[10.5px] font-medium px-3 py-1 rounded-full" style="background:rgba(10,10,10,0.04);color:rgba(10,10,10,0.55);border:1px solid rgba(10,10,10,0.07);">{w}</span>
              ))}
            </div>

            <!-- Meta row -->
            <div class="flex items-center justify-between pt-4" style="border-top:1px solid rgba(10,10,10,0.05);">
              <div class="flex gap-4">
                <div>
                  <p class="text-[9px] uppercase tracking-[0.14em] font-semibold mb-0.5" style="color:rgba(10,10,10,0.28);">Time saved</p>
                  <p class="text-sm font-display font-medium text-brand-black">{c.hours}h / week</p>
                </div>
                <div>
                  <p class="text-[9px] uppercase tracking-[0.14em] font-semibold mb-0.5" style="color:rgba(10,10,10,0.28);">ROI estimate</p>
                  <p class="text-sm font-display font-medium text-brand-black">{c.roi}</p>
                </div>
              </div>
              <div class="text-right">
                <p class="text-[9px] uppercase tracking-[0.14em] font-semibold mb-0.5" style="color:rgba(10,10,10,0.28);">Deployed in</p>
                <p class="text-sm font-display font-medium" style="color:#E8B4B0;">{c.timeline}</p>
              </div>
            </div>

            <!-- Tools used -->
            <div class="mt-4 flex items-center gap-2">
              <p class="text-[9px] uppercase tracking-[0.14em] font-semibold shrink-0" style="color:rgba(10,10,10,0.22);">Stack</p>
              <div class="flex flex-wrap gap-1">
                {c.tools.map((t) => (
                  <span class="text-[10px] px-2 py-0.5 rounded font-mono" style="background:rgba(10,10,10,0.03);color:rgba(10,10,10,0.40);border:1px solid rgba(10,10,10,0.06);">{t}</span>
                ))}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Empty state -->
    <div id="no-results" class="hidden text-center py-20">
      <p class="text-brand-gray-600 text-sm">No results for this filter yet — more case studies coming soon.</p>
    </div>

  </div>
</section>

<!-- ═══ AGGREGATE KPI BANNER ═══════════════════════════════════════ -->
<section style="background:#0A0A0A;" class="py-16 lg:py-20">
  <div class="container-x">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <p class="eyebrow text-white/40 mb-4">Across all deployments</p>
      <h2 class="font-display text-3xl lg:text-4xl text-white leading-tight text-balance">
        The numbers behind <em class="font-medium" style="color:#E8B4B0;">312 deployments.</em>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {[
        { stat: '95%', body: 'of clients eliminated manual data entry within the first 30 days of deployment.', icon: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z' },
        { stat: '4 mo', body: 'median payback period — from first payment to full ROI recovery on every plan.', icon: 'M12 2v2m0 16v2M7 8h6a3 3 0 010 6H9a3 3 0 000 6h8' },
        { stat: '20h+', body: 'average hours reclaimed per team per week, across dental, agency and e-commerce verticals.', icon: 'M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z' },
      ].map((k) => (
        <div class="rounded-[18px] p-8 scroll-fade" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-5" style="background:rgba(232,180,176,0.12);border:1px solid rgba(232,180,176,0.18);">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={k.icon}/>
            </svg>
          </div>
          <p class="font-display text-4xl lg:text-5xl text-white leading-none mb-3" style="color:#E8B4B0;">{k.stat}</p>
          <p class="text-sm leading-relaxed" style="color:rgba(255,255,255,0.45);">{k.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ VERIFIED REVIEWS ════════════════════════════════════════════ -->
<section class="bg-brand-cream py-16 lg:py-24">
  <div class="container-x">
    <div class="max-w-3xl mb-12">
      <p class="eyebrow mb-4">Verified client reviews</p>
      <h2 class="font-display text-3xl lg:text-4xl leading-tight text-balance">
        What it actually feels like <em class="font-medium">six weeks in.</em>
