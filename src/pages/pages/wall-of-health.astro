    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {reviews.map((r) => (
        <article class="bg-white rounded-[16px] p-5 flex flex-col scroll-fade" style="border:1px solid rgba(10,10,10,0.07);">
          <!-- Stars -->
          <div class="flex gap-0.5 mb-3">
            {Array.from({length: 5}).map((_, i) => (
              <svg class="w-3 h-3" viewBox="0 0 12 12" fill={i < r.rating ? '#E8B4B0' : 'none'} stroke={i < r.rating ? '#E8B4B0' : '#d1d5db'} stroke-width="1" aria-hidden="true">
                <path d="M6 1l1.2 3.6H11L8.2 6.8l1.2 3.6L6 8.2l-3.4 2.2 1.2-3.6L1 4.6h3.8z"/>
              </svg>
            ))}
          </div>
          <h3 class="font-display text-[15px] mb-2 leading-snug">{r.title}</h3>
          <p class="text-[12.5px] text-brand-gray-600 leading-relaxed flex-1">{r.text}</p>
          <div class="mt-4 pt-3 flex items-center justify-between" style="border-top:1px solid rgba(10,10,10,0.05);">
            <div>
              <p class="text-[11px] font-semibold text-brand-black">{r.name}</p>
              <p class="text-[10px] text-brand-gray-400">{r.flavor}</p>
            </div>
            {r.verified && (
              <span class="text-[9px] uppercase tracking-wider font-bold" style="color:#2D5016;">✓ Verified</span>
