    var salary = parseInt(document.getElementById('calc-salary').value, 10);
    var pain   = document.getElementById('calc-pain').value;

    var hours  = (CALC_HOURS[size] || {})[pain] || 14;
    var hourlyRate = salary / 2080;
    var annualValue = Math.round(hours * hourlyRate * 52 / 1000) * 1000;
    var roiMult = CALC_ROI_MULT[size] || 9.4;
    var payback = CALC_PAYBACK[size] || '4 wks';

    document.getElementById('out-hours').textContent   = hours + 'h';
    document.getElementById('out-value').textContent   = '£' + (annualValue >= 1000 ? Math.round(annualValue / 1000) + 'K' : annualValue);
    document.getElementById('out-roi').textContent     = roiMult + '×';
    document.getElementById('out-payback').textContent = payback;

    var insight = document.getElementById('calc-insight');
    if (insight) insight.textContent = PAIN_INSIGHT[pain] || '';
  }

  calcROI();
  document.addEventListener('astro:page-load', calcROI);
</script>

</ShopLayout>
