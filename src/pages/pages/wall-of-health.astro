          { step: '03', title: 'Build & test', body: 'We build, test every edge case and run the full stack against your real data in staging.', time: 'Day 3–8' },
          { step: '04', title: 'Go live + handoff', body: '24/7 monitoring active from day one. You get full documentation and a dedicated Slack channel.', time: 'Day 9–10' },
        ].map((s, i) => (
