            <div class="shrink-0 text-right w-6">
              <span class="font-display text-[11px] font-semibold tabular-nums" style="color:rgba(10,10,10,0.20);">{s.step}</span>
            </div>
            <div class="flex-1">
              <div class="flex items-center justify-between mb-1">
                <p class="text-sm font-semibold text-brand-black">{s.title}</p>
                <span class="text-[10px] font-medium" style="color:#E8B4B0;">{s.time}</span>
              </div>
