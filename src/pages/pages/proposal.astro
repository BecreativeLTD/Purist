---
// PURIST — Client Proposal Template
// Usage: purist.online/pages/proposal?client=NomClient&industry=Restaurant&w1=Lead+CRM&w2=Email+Follow-up&w3=Invoice+Auto&hours=14&roi=9.4&price=3200&currency=EUR
// All params are optional — defaults shown below

const p = Astro.url.searchParams;

const client     = p.get('client')   || 'Your Business';
const industry   = p.get('industry') || 'Business';
const preparedBy = p.get('by')       || 'Hugo — PURIST';
const date       = p.get('date')     || new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

// 3 workflows
const w1 = p.get('w1') || 'Lead Capture → CRM Auto-entry';
const w2 = p.get('w2') || 'Follow-up Email Sequence';
const w3 = p.get('w3') || 'Invoice & Payment Automation';
const w1desc = p.get('w1desc') || 'Every new lead from your website or ads is automatically logged in your CRM, tagged, and assigned — zero manual data entry.';
const w2desc = p.get('w2desc') || 'Personalised follow-up emails sent automatically at day 1, 3, and 7 after first contact. Stops when the prospect replies.';
const w3desc = p.get('w3desc') || 'Invoices generated and sent automatically after project sign-off. Payment reminders triggered at 3, 7, and 14 days overdue.';
const w1save = p.get('w1save') || '5h/wk';
const w2save = p.get('w2save') || '4h/wk';
const w3save = p.get('w3save') || '6h/wk';

// ROI numbers
const hoursWeek  = p.get('hours')   || '15';
const roiMult    = p.get('roi')     || '9.4';
const annualSave = p.get('annual')  || '62 400';
const currency   = p.get('currency')|| 'EUR';
const currSymbol = currency === 'USD' ? '$' : currency === 'GBP' ? '£' : '€';

// Pricing
const price      = p.get('price')   || '3 200';
const plan       = p.get('plan')    || 'Growth';
const deploy     = p.get('deploy')  || '7–10';

// optional 4th/5th workflow bonus
const w4 = p.get('w4') || '';
const w5 = p.get('w5') || '';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Automation Proposal — {client} × PURIST</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black:  #0A0A0A;
      --cream:  #F8F6F1;
      --pink:   #E8B4B0;
      --gray:   #6B6B6B;
      --border: #E5E3DE;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--cream);
      color: var(--black);
      -webkit-font-smoothing: antialiased;
    }

    /* ── Cover ── */
    .cover {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 3rem;
      background: var(--black);
      color: white;
      page-break-after: always;
    }
    .cover-top { display: flex; justify-content: space-between; align-items: flex-start; }
    .logo { font-family: 'DM Serif Display', Georgia, serif; font-size: 1.5rem; letter-spacing: -0.02em; }
    .logo span { color: var(--pink); }
    .cover-badge {
      font-size: 0.625rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      background: rgba(232,180,176,0.15);
      color: var(--pink);
      padding: 0.4rem 0.9rem;
      border-radius: 99px;
      border: 1px solid rgba(232,180,176,0.25);
    }
    .cover-body { padding: 4rem 0 2rem; }
    .cover-label {
      font-size: 0.625rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      margin-bottom: 1.5rem;
    }
    .cover-h1 {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      line-height: 1.08;
      font-weight: 400;
      margin-bottom: 2rem;
    }
    .cover-h1 em { color: var(--pink); font-style: italic; }
    .cover-sub { font-size: 1rem; color: rgba(255,255,255,0.55); line-height: 1.7; max-width: 480px; }

    .cover-meta {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      border-top: 1px solid rgba(255,255,255,0.1);
      padding-top: 2rem;
    }
    .cover-meta-item { }
    .cover-meta-label { font-size: 0.625rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 0.35rem; }
    .cover-meta-value { font-size: 0.9375rem; font-weight: 500; }

    /* ── Page wrapper ── */
    .page { max-width: 860px; margin: 0 auto; padding: 4rem 2rem; }
    .section { margin-bottom: 4rem; }

    .section-label {
      font-size: 0.625rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--pink);
      margin-bottom: 0.75rem;
      font-weight: 600;
    }
    .section-title {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 400;
      line-height: 1.15;
      margin-bottom: 1rem;
    }
    .section-sub { color: var(--gray); font-size: 0.9375rem; line-height: 1.75; max-width: 580px; }

    hr.divider { border: none; border-top: 1px solid var(--border); margin: 3rem 0; }

    /* ── Workflow cards ── */
    .workflows { display: flex; flex-direction: column; gap: 1.25rem; margin-top: 2rem; }
    .wf-card {
      background: white;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 1.75rem;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 1rem;
      align-items: start;
    }
    .wf-num {
      display: inline-flex;
      width: 28px; height: 28px;
      background: var(--black);
      color: white;
      font-size: 0.6875rem;
      font-weight: 600;
      border-radius: 50%;
      align-items: center;
      justify-content: center;
      margin-bottom: 0.75rem;
    }
    .wf-title { font-family: 'DM Serif Display', Georgia, serif; font-size: 1.25rem; margin-bottom: 0.5rem; }
    .wf-desc { font-size: 0.875rem; color: var(--gray); line-height: 1.65; }
    .wf-save {
      background: #f0faf4;
      color: #1a7a45;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 0.35rem 0.85rem;
      border-radius: 99px;
      border: 1px solid #b6e8cc;
      white-space: nowrap;
    }

    /* ── ROI table ── */
    .roi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border-radius: 16px;
      overflow: hidden;
      margin-top: 2rem;
    }
    .roi-cell {
      background: white;
      padding: 2rem 1.5rem;
      text-align: center;
    }
    .roi-value {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 2.5rem;
      line-height: 1;
      margin-bottom: 0.5rem;
    }
    .roi-value.pink { color: var(--pink); }
    .roi-label { font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray); }

    .roi-disclaimer { font-size: 0.75rem; color: var(--gray); margin-top: 1rem; line-height: 1.6; }

    /* ── Timeline ── */
    .timeline { margin-top: 2rem; display: flex; flex-direction: column; gap: 0; }
    .tl-item {
      display: grid;
      grid-template-columns: 120px 1fr;
      gap: 1.5rem;
      padding: 1.5rem 0;
      border-bottom: 1px solid var(--border);
    }
    .tl-item:last-child { border-bottom: none; }
    .tl-day { font-size: 0.6875rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gray); font-weight: 500; padding-top: 0.15rem; }
    .tl-title { font-weight: 600; font-size: 0.9375rem; margin-bottom: 0.25rem; }
    .tl-desc { font-size: 0.875rem; color: var(--gray); line-height: 1.6; }

    /* ── Pricing ── */
    .price-card {
      background: var(--black);
      color: white;
      border-radius: 20px;
      padding: 2.5rem;
      margin-top: 2rem;
    }
    .price-plan { font-size: 0.6875rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 0.5rem; }
    .price-amount {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 3.5rem;
      line-height: 1;
      margin-bottom: 0.5rem;
    }
    .price-amount sup { font-size: 1.5rem; vertical-align: top; margin-top: 0.5rem; display: inline-block; font-family: 'Inter', sans-serif; font-weight: 300; }
    .price-note { font-size: 0.875rem; color: rgba(255,255,255,0.45); margin-bottom: 2rem; }
    .price-includes { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2.5rem; }
    .price-includes li { display: flex; align-items: flex-start; gap: 0.75rem; font-size: 0.9rem; }
    .price-includes li::before { content: '✓'; color: var(--pink); font-weight: 700; flex-shrink: 0; margin-top: 0.05rem; }
    .price-cta {
      display: block;
      background: var(--pink);
      color: var(--black);
      text-align: center;
      padding: 1rem 2rem;
      border-radius: 12px;
      font-weight: 600;
      font-size: 0.9375rem;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .price-cta:hover { opacity: 0.88; }

    .guarantee {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      background: white;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.5rem;
      margin-top: 1.25rem;
    }
    .guarantee-icon { font-size: 1.5rem; flex-shrink: 0; }
    .guarantee-title { font-weight: 600; font-size: 0.9375rem; margin-bottom: 0.25rem; }
    .guarantee-text { font-size: 0.875rem; color: var(--gray); line-height: 1.6; }

    /* ── Footer ── */
    .footer {
      background: var(--black);
      color: rgba(255,255,255,0.4);
      padding: 2.5rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.8125rem;
      margin-top: 4rem;
    }
    .footer strong { color: white; }

    /* ── Print ── */
    @media print {
      .cover { min-height: 100vh; }
      .no-print { display: none !important; }
    }

    @media (max-width: 640px) {
      .cover { padding: 2rem; }
      .cover-meta { grid-template-columns: 1fr 1fr; }
      .roi-grid { grid-template-columns: 1fr; }
      .tl-item { grid-template-columns: 1fr; gap: 0.25rem; }
      .wf-card { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- ══════════════════════════════════════════
     COVER PAGE
═══════════════════════════════════════════ -->
<div class="cover">
  <div class="cover-top">
    <div class="logo">PURIST<span>.</span></div>
    <div class="cover-badge">Confidential Proposal</div>
  </div>

  <div class="cover-body">
    <p class="cover-label">Automation Proposal · {industry}</p>
    <h1 class="cover-h1">
      Your roadmap to<br/>
      <em>{hoursWeek} hours saved</em><br/>
      every week.
    </h1>
    <p class="cover-sub">
      Prepared exclusively for <strong style="color:white">{client}</strong>. This plan details the 3 automations we recommend deploying first, the ROI you can expect, and exactly how we get there.
    </p>
  </div>

  <div class="cover-meta">
    <div class="cover-meta-item">
      <p class="cover-meta-label">Prepared for</p>
      <p class="cover-meta-value">{client}</p>
    </div>
    <div class="cover-meta-item">
      <p class="cover-meta-label">Prepared by</p>
      <p class="cover-meta-value">{preparedBy}</p>
    </div>
    <div class="cover-meta-item">
      <p class="cover-meta-label">Date</p>
      <p class="cover-meta-value">{date}</p>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════
     BODY
═══════════════════════════════════════════ -->
<div class="page">

  <!-- ── 1. The problem ── -->
  <div class="section">
    <p class="section-label">The situation</p>
    <h2 class="section-title">Where your time is going right now</h2>
    <p class="section-sub">
      Based on our discovery call, your team is spending an estimated <strong>{hoursWeek} hours per week</strong> on manual, repetitive tasks that can be fully automated. That's time that could be spent growing the business — not managing spreadsheets, chasing invoices, or copy-pasting data between tools.
    </p>
  </div>

  <hr class="divider" />

  <!-- ── 2. The 3 workflows ── -->
  <div class="section">
    <p class="section-label">Your automation plan</p>
    <h2 class="section-title">The 3 workflows we deploy first</h2>
    <p class="section-sub">These are ranked by ROI — the highest time-savers go live first.</p>

    <div class="workflows">
      <div class="wf-card">
        <div>
          <div class="wf-num">01</div>
          <h3 class="wf-title">{w1}</h3>
          <p class="wf-desc">{w1desc}</p>
        </div>
        <div class="wf-save">Saves {w1save}</div>
      </div>

      <div class="wf-card">
        <div>
          <div class="wf-num">02</div>
          <h3 class="wf-title">{w2}</h3>
          <p class="wf-desc">{w2desc}</p>
        </div>
        <div class="wf-save">Saves {w2save}</div>
      </div>

      <div class="wf-card">
        <div>
          <div class="wf-num">03</div>
          <h3 class="wf-title">{w3}</h3>
          <p class="wf-desc">{w3desc}</p>
        </div>
        <div class="wf-save">Saves {w3save}</div>
      </div>

      {w4 && (
        <div class="wf-card" style="border-style:dashed;opacity:0.7;">
          <div>
            <div class="wf-num" style="background:#6B6B6B;">04</div>
            <h3 class="wf-title">{w4}</h3>
            <p class="wf-desc" style="font-style:italic;">Recommended for Phase 2 — included in your Growth plan at no extra cost.</p>
          </div>
          <div class="wf-save" style="background:#f5f5f5;color:#6B6B6B;border-color:#ddd;">Phase 2</div>
        </div>
      )}

      {w5 && (
        <div class="wf-card" style="border-style:dashed;opacity:0.7;">
          <div>
            <div class="wf-num" style="background:#6B6B6B;">05</div>
            <h3 class="wf-title">{w5}</h3>
            <p class="wf-desc" style="font-style:italic;">Recommended for Phase 2 — included in your Growth plan at no extra cost.</p>
          </div>
          <div class="wf-save" style="background:#f5f5f5;color:#6B6B6B;border-color:#ddd;">Phase 2</div>
        </div>
      )}
    </div>
  </div>

  <hr class="divider" />

  <!-- ── 3. ROI ── -->
  <div class="section">
    <p class="section-label">Return on investment</p>
    <h2 class="section-title">What this means for your bottom line</h2>
    <p class="section-sub">Conservative estimates based on your team's current hourly cost and volume. Confirmed on the audit call.</p>

    <div class="roi-grid">
      <div class="roi-cell">
        <p class="roi-value">{hoursWeek}h</p>
        <p class="roi-label">Saved per week</p>
      </div>
      <div class="roi-cell">
        <p class="roi-value">{currSymbol}{annualSave}</p>
        <p class="roi-label">Annual value recovered</p>
      </div>
      <div class="roi-cell">
        <p class="roi-value pink">{roiMult}×</p>
        <p class="roi-label">ROI in year 1</p>
      </div>
    </div>

    <p class="roi-disclaimer">
      * Annual value calculated at an average fully-loaded cost of {currSymbol}80/hour for a senior operations hire. Your actual figure may be higher. ROI confirmed live during the audit call.
    </p>
  </div>

  <hr class="divider" />

  <!-- ── 4. Timeline ── -->
  <div class="section">
    <p class="section-label">Deployment timeline</p>
    <h2 class="section-title">From zero to live in {deploy} business days</h2>

    <div class="timeline">
      <div class="tl-item">
        <p class="tl-day">Day 0</p>
        <div>
          <p class="tl-title">Kickoff & stack access</p>
          <p class="tl-desc">We confirm credentials for your tools (CRM, email, billing software). You share any SOPs or process docs. We ask 5-10 targeted questions. Total time from you: ~30 minutes.</p>
        </div>
      </div>
      <div class="tl-item">
        <p class="tl-day">Days 1–3</p>
        <div>
          <p class="tl-title">Workflow #1 built & tested</p>
          <p class="tl-desc">We build the highest-ROI automation first. We run it in sandbox with real-world data before deploying. You review a short Loom walkthrough before it goes live.</p>
        </div>
      </div>
      <div class="tl-item">
        <p class="tl-day">Days 4–6</p>
        <div>
          <p class="tl-title">Workflows #2 & #3 deployed</p>
          <p class="tl-desc">Both remaining automations go live. Error handling, retry logic, and alerting configured. Your team gets a 1-page cheat sheet for each workflow.</p>
        </div>
      </div>
      <div class="tl-item">
        <p class="tl-day">Day {deploy}</p>
        <div>
          <p class="tl-title">Live review call + handover</p>
          <p class="tl-desc">We walk through the live dashboard together, confirm the numbers match the plan, and hand over the Slack channel for ongoing support. Your automations are running 24/7.</p>
        </div>
      </div>
      <div class="tl-item">
        <p class="tl-day">Month 1–3</p>
        <div>
          <p class="tl-title">Monitoring, optimisation & ROI report</p>
          <p class="tl-desc">99.97% uptime SLA. We monitor every run, fix any edge cases, and send you a 90-day ROI report confirming exactly what was saved.</p>
        </div>
      </div>
    </div>
  </div>

  <hr class="divider" />

  <!-- ── 5. Pricing ── -->
  <div class="section">
    <p class="section-label">Investment</p>
    <h2 class="section-title">One flat fee. No surprises.</h2>
    <p class="section-sub">Everything included — build, test, deploy, monitor, and support for 90 days.</p>

    <div class="price-card">
      <p class="price-plan">{plan} Plan — {client}</p>
      <p class="price-amount"><sup>{currSymbol}</sup>{price}</p>
      <p class="price-note">One-time setup fee · Includes 90 days of monitoring & support</p>

      <ul class="price-includes">
        <li>3 production-ready automations built, tested & deployed</li>
        <li>Full error handling, retry logic & alerting</li>
        <li>Live monitoring dashboard — see every run in real time</li>
        <li>Dedicated Slack channel with direct engineer access</li>
        <li>90-day ROI report confirming time and money saved</li>
        <li>30-day fix-or-refund guarantee — no questions asked</li>
      </ul>

      <a href="https://www.purist.online/pages/welcome" class="price-cta">
        Accept this proposal → Get started
      </a>
    </div>

    <div class="guarantee">
      <div class="guarantee-icon">🛡️</div>
      <div>
        <p class="guarantee-title">30-day fix-or-refund guarantee</p>
        <p class="guarantee-text">
          If any automation doesn't perform exactly as specified in this proposal, we fix it within 48 hours or issue a full refund. No questions asked. We've never had to use it — but it's there.
        </p>
      </div>
    </div>
  </div>

  <!-- ── 6. Next steps ── -->
  <div class="section">
    <p class="section-label">Next steps</p>
    <h2 class="section-title">Ready to start?</h2>
    <p class="section-sub" style="margin-bottom:1.5rem;">
      Two ways to move forward:
    </p>
    <ol style="list-style:none;display:flex;flex-direction:column;gap:1rem;">
      <li style="display:flex;gap:1rem;align-items:flex-start;">
        <span style="background:var(--black);color:white;width:28px;height:28px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;flex-shrink:0;">1</span>
        <div>
          <p style="font-weight:600;margin-bottom:0.2rem;">Reply to this email</p>
          <p style="font-size:0.875rem;color:var(--gray);">Say "let's go" and we'll send you a short onboarding form + invoice within 2 hours.</p>
        </div>
      </li>
      <li style="display:flex;gap:1rem;align-items:flex-start;">
        <span style="background:var(--black);color:white;width:28px;height:28px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;flex-shrink:0;">2</span>
        <div>
          <p style="font-weight:600;margin-bottom:0.2rem;">Click the link above</p>
          <p style="font-size:0.875rem;color:var(--gray);">Accept the proposal directly and we kick off the same day.</p>
        </div>
      </li>
    </ol>
  </div>

</div>

<!-- ══════════════════════════════════════════
     FOOTER
═══════════════════════════════════════════ -->
<div class="footer">
  <div>
    <strong>PURIST</strong> · purist.online
  </div>
  <div style="text-align:right;">
    Prepared for <strong>{client}</strong> · {date}<br/>
    This proposal is confidential and intended solely for the recipient.
  </div>
</div>

<!-- Print button (hidden on print) -->
<div class="no-print" style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:99;">
  <button
    onclick="window.print()"
    style="background:#0A0A0A;color:white;border:none;padding:0.75rem 1.5rem;border-radius:10px;font-size:0.875rem;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:0.5rem;box-shadow:0 4px 20px rgba(0,0,0,0.25);"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
    Save as PDF
  </button>
</div>

</body>
</html>
