<!-- Counter animation -->
<script is:inline>
  (function() {
    function animateCounters() {
      var els = document.querySelectorAll('[data-counter]:not([data-done])');
      if (!els.length) return;
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) return;
          var el = entry.target;
          var target = parseFloat(el.dataset.target);
          var suffix = el.dataset.suffix || '';
          var isDecimal = el.dataset.decimal === 'true';
          var start = performance.now();
          var duration = 1800;
          function tick(now) {
            var t = Math.min((now - start) / duration, 1);
            var eased = 1 - Math.pow(1 - t, 3);
            var val = target * eased;
            el.textContent = (isDecimal ? val.toFixed(1) : Math.round(val)) + suffix;
            if (t < 1) requestAnimationFrame(tick);
            else el.dataset.done = 'true';
          }
          requestAnimationFrame(tick);
          observer.unobserve(el);
        });
      }, { threshold: 0.4 });
      els.forEach(function(el) { observer.observe(el); });
    }
    animateCounters();
    document.addEventListener('astro:page-load', animateCounters);
  })();
</script>

<!-- Filter -->
<script is:inline>
  function filterCases(btn) {
    var filter = btn.dataset.filter;
    document.querySelectorAll('.filter-btn').forEach(function(b) {
      b.style.background = '#fff';
      b.style.color = 'rgba(10,10,10,0.55)';
      b.style.border = '1px solid rgba(10,10,10,0.10)';
    });
    btn.style.background = '#0A0A0A';
    btn.style.color = '#fff';
    btn.style.border = '1px solid #0A0A0A';
    var cards = document.querySelectorAll('.case-card');
    var visible = 0;
    cards.forEach(function(card) {
      var show = filter === 'all' || card.dataset.industry === filter;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    var noRes = document.getElementById('no-results');
    if (noRes) noRes.classList.toggle('hidden', visible > 0);
  }
</script>

<!-- ROI Calculator -->
<script is:inline>
  var CALC_HOURS = {
    '1-5':   { 'data-entry':6,  'client-comms':5,  'billing':4,  'crm':5,  'documents':5,  'scheduling':4,  'onboarding':4  },
    '6-15':  { 'data-entry':14, 'client-comms':10, 'billing':9,  'crm':11, 'documents':12, 'scheduling':8,  'onboarding':10 },
    '16-50': { 'data-entry':28, 'client-comms':22, 'billing':18, 'crm':24, 'documents':26, 'scheduling':16, 'onboarding':20 },
    '50+':   { 'data-entry':60, 'client-comms':48, 'billing':40, 'crm':52, 'documents':55, 'scheduling':35, 'onboarding':42 },
  };
  var CALC_ROI  = { '1-5':6.2, '6-15':9.4, '16-50':11.8, '50+':14.5 };
  var CALC_PAY  = { '1-5':'3 wks', '6-15':'4 wks', '16-50':'5 wks', '50+':'6 wks' };
  var INSIGHTS  = {
    'data-entry':   'Manual data entry is the #1 automation target — eliminated in an average of 6 business days across 312 deployments.',
    'client-comms': 'Automated follow-up sequences reduce response lag by 82% and save 6h per team member per week on average.',
    'billing':      'Invoice automation cuts billing cycles from 5 days to same-day and reduces late payments by 34%.',
    'crm':          'Automated CRM logging frees sales reps from 40% of admin time — fully recoverable as selling hours.',
    'documents':    'Document generation eliminates 90%+ of copy-paste errors and reduces contract turnaround from days to minutes.',
    'scheduling':   'Scheduling automation reduces no-shows by 35% and frees staff from 6–8h/week of coordination.',
    'onboarding':   'Automated onboarding reduces time-to-productive by 60% for new clients and staff.',
  };

  function calcROI() {
    var size   = document.getElementById('calc-size').value;
    var salary = parseInt(document.getElementById('calc-salary').value, 10);
    var pain   = document.getElementById('calc-pain').value;
    var hours  = (CALC_HOURS[size] || {})[pain] || 14;
    var annual = Math.round(hours * (salary / 2080) * 52 / 1000) * 1000;
    var roi    = CALC_ROI[size] || 9.4;
    var pay    = CALC_PAY[size] || '4 wks';
    document.getElementById('out-hours').textContent   = hours + 'h';
    document.getElementById('out-value').textContent   = '€' + (annual >= 1000 ? Math.round(annual / 1000) + 'K' : annual);
    document.getElementById('out-roi').textContent     = roi + '×';
    document.getElementById('out-payback').textContent = pay;
    var el = document.getElementById('calc-insight');
    if (el) el.textContent = INSIGHTS[pain] || '';
  }
  calcROI();
  document.addEventListener('astro:page-load', calcROI);
</script>
