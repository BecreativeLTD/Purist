---
import ShopLayout from '~/layouts/ShopLayout.astro';
import testimonialsData from '~/data/testimonials.json';

const { reviews, miniTestimonials } = testimonialsData;

const cases = [
  {
    id: 'dental',
    industry: 'Healthcare',
    tag: 'Dental Group · London',
    headline: '60% less admin. Same staff. Better patient outcomes.',
    stat: '60%', statLabel: 'admin reduction',
    hours: '14', roi: '€130K', roi_multiple: '12.1×', breakeven: '19 days',
    timeline: '6 days',
    before: '3 FTE hours daily on reminders, recalls and billing reconciliation — 90% repetitive.',
    after: 'Fully automated patient reminders, insurance pre-auth and recall campaigns. Front desk refocused on care.',
    workflows: ['Appointment reminders', 'Insurance pre-auth', 'Recall campaigns', 'Billing reconciliation'],
    tools: ['n8n', 'Dentally', 'SendGrid', 'Stripe'],
    quote: "We stopped losing patients to missed recalls. Recall rate went from 34% to 71% in 8 weeks.",
    attribution: 'Practice Manager',
  },
  {
    id: 'agency',
    industry: 'Agency',
    tag: 'Marketing Agency · Edinburgh',
    headline: '45 client accounts managed. Zero extra headcount.',
    stat: '3×', statLabel: 'clients per operator',
    hours: '22', roi: '€104K', roi_multiple: '9.8×', breakeven: '23 days',
    timeline: '8 days',
    before: '28h/week on reporting and onboarding admin. One contractor hired purely for report generation.',
    after: 'Client onboarding, weekly reporting and invoicing fully automated. Contractor role eliminated.',
    workflows: ['Client onboarding', 'Weekly reporting', 'Invoice generation', 'Project kickoffs'],
    tools: ['n8n', 'HubSpot', 'Xero', 'Slack'],
    quote: "Our ops manager finally does strategy instead of admin. We scaled from 28 to 45 clients without a single hire.",
    attribution: 'CEO',
  },
  {
    id: 'realestate',
    industry: 'Real Estate',
    tag: 'Property Agency · Manchester',
    headline: 'Portal leads followed up in 90 seconds. Automatically.',
    stat: '40%', statLabel: 'more deals closed',
    hours: '9', roi: '€86K', roi_multiple: '8.3×', breakeven: '18 days',
    timeline: '5 days',
    before: 'Leads responded to in 4+ hours average. 60% of enquiries received no same-day reply.',
    after: 'Every portal lead captured, AI-qualified and followed up within 90 seconds. Zero staff input.',
    workflows: ['Lead capture', 'AI qualification', 'Viewing confirmations', 'Follow-up sequences'],
    tools: ['n8n', 'Rightmove', 'Salesforce', 'Twilio'],
    quote: "First to call wins. Now we are always first. Conversion from enquiry to viewing went from 18% to 31%.",
    attribution: 'Director',
  },
  {
    id: 'ecommerce',
    industry: 'E-commerce',
    tag: 'DTC Brand · Bristol',
    headline: '70% fewer support tickets. Zero extra staff.',
    stat: '70%', statLabel: 'fewer tickets',
    hours: '8', roi: '€56K', roi_multiple: '7.6×', breakeven: '31 days',
    timeline: '7 days',
    before: 'Support team fielding 200+ tickets/day. 3-day resolution backlog. Two full-time Tier-1 agents.',
    after: 'Order confirmations, cart recovery and Tier-1 support automated 24/7. CSAT up 18 points.',
    workflows: ['Order confirmations', 'Abandoned cart', 'AI support triage', 'Return processing'],
    tools: ['n8n', 'Shopify', 'Gorgias', 'Claude AI'],
    quote: "Our support backlog went from 3 days to 2 hours. CSAT went from 61 to 79 with the same headcount.",
    attribution: 'Head of Operations',
  },
  {
    id: 'legal',
    industry: 'Legal',
    tag: 'Law Firm · Birmingham',
    headline: 'Client intake from 14 days to 3 days.',
    stat: '78%', statLabel: 'faster onboarding',
    hours: '12', roi: '€110K', roi_multiple: '13.4×', breakeven: '21 days',
    timeline: '9 days',
    before: 'Intake taking 14 days. Fee earners spending 4h/week on non-billable admin. Clients lost to faster firms.',
    after: 'Intake, conflict checks, engagement letters and deadline tracking fully automated end-to-end.',
    workflows: ['Client intake', 'Conflict checks', 'Document generation', 'Deadline tracking'],
    tools: ['n8n', 'Clio', 'DocuSign', 'Claude AI'],
    quote: "Fee earners now touch only billable work. We recovered €110K in billable hours in the first year.",
    attribution: 'Managing Partner',
  },
  {
    id: 'staffing',
    industry: 'Staffing',
    tag: 'Recruitment Firm · Leeds',
    headline: '3× more placements. Same team. AI handles the pipeline.',
    stat: '3×', statLabel: 'placements per consultant',
    hours: '10', roi: '€195K', roi_multiple: '11.2×', breakeven: '25 days',
    timeline: '7 days',
    before: 'Consultants spending 60% of time on CV screening, scheduling and status emails.',
    after: 'CV parsing, candidate scoring and interview scheduling fully automated by AI agents.',
    workflows: ['CV parsing', 'AI candidate scoring', 'Interview scheduling', 'Offer coordination'],
    tools: ['n8n', 'Workable', 'Claude AI', 'Google Calendar'],
    quote: "Our consultants finally do what they were hired to do. Placements per head went from 2.1 to 6.4 per month.",
    attribution: 'Managing Director',
  },
];

const industries = ['All', 'Healthcare', 'Agency', 'Real Estate', 'E-commerce', 'Legal', 'Staffing'];

const aggregate = [
  { value: '312', suffix: '+', label: 'Deployments completed' },
  { value: '14',  suffix: 'h', label: 'Avg hours saved / week' },
  { value: '9.2', suffix: '×', label: 'Avg ROI at 90 days' },
  { value: '195', suffix: 'k', label: 'Avg annual saving (€)' },
  { value: '99.97', suffix: '%', label: 'Workflow uptime SLA' },
  { value: '7',   suffix: 'd', label: 'Avg deployment time' },
];

const benchmarks = [
  { industry: 'Legal',       hours: '12h', saving: '€110K', roi: '13.4×', payback: '21 days', deploy: '9 days',  best: true  },
  { industry: 'Healthcare',  hours: '18h', saving: '€130K', roi: '12.1×', payback: '19 days', deploy: '7 days',  best: false },
  { industry: 'Staffing',    hours: '10h', saving: '€195K', roi: '11.2×', payback: '25 days', deploy: '7 days',  best: false },
  { industry: 'Agency',      hours: '22h', saving: '€104K', roi: '9.8×',  payback: '23 days', deploy: '8 days',  best: false },
  { industry: 'Real Estate', hours: '9h',  saving: '€86K',  roi: '8.3×',  payback: '18 days', deploy: '6 days',  best: false },
  { industry: 'E-commerce',  hours: '8h',  saving: '€56K',  roi: '7.6×',  payback: '31 days', deploy: '7 days',  best: false },
];

const ticker = [
  { co: 'Dental Group · London',       win: '14h/week automated',    days: '2 days ago' },
  { co: 'Law Firm · Birmingham',       win: 'Intake 78% faster',     days: '4 days ago' },
  { co: 'DTC Brand · Bristol',         win: '70% fewer tickets',      days: '5 days ago' },
  { co: 'Property Agency · Manchester',win: '40% more deals closed',  days: '6 days ago' },
  { co: 'Marketing Agency · Edinburgh',win: '3× clients per operator',days: '9 days ago' },
  { co: 'Recruitment Firm · Leeds',    win: '3× placements/consultant',days: '11 days ago'},
  { co: 'Finance Co · Glasgow',        win: '€60,500 invoicing saved', days: '13 days ago'},
  { co: 'Healthcare Group · Cardiff',  win: '22h admin eliminated',   days: '15 days ago'},
];
---

<ShopLayout
  title="Wall of Results — Real Client Outcomes | PURIST"
  description="312+ businesses automated. Verified ROI, real before-and-after data. Case studies across dental, real estate, agency, e-commerce, legal and staffing."
>

<!-- ═══════════════════════════════════════════════════
     HERO
════════════════════════════════════════════════════ -->
<header style="background:#0A0A0A;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse 70% 80% at 20% 60%,rgba(232,180,176,0.06) 0%,transparent 60%);pointer-events:none;"></div>

  <div class="container-x relative z-10" style="padding-top:72px;padding-bottom:60px;">
    <div style="max-width:680px;">

      <!-- Eyebrow -->
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;flex-wrap:wrap;">
        <span style="font-size:9px;font-weight:700;letter-spacing:0.26em;text-transform:uppercase;color:rgba(232,180,176,0.55);">Wall of Results</span>
        <span style="width:1px;height:10px;background:rgba(255,255,255,0.12);"></span>
        <span style="display:inline-flex;align-items:center;gap:5px;background:rgba(74,222,128,0.08);border:1px solid rgba(74,222,128,0.18);border-radius:100px;padding:3px 9px;">
          <span style="width:4px;height:4px;border-radius:50%;background:#4ADE80;animation:pulse-dot 2s ease-in-out infinite;"></span>
          <span style="font-size:8.5px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#4ADE80;">Live data</span>
        </span>
        <span style="font-size:10px;color:rgba(255,255,255,0.18);font-variant-numeric:tabular-nums;">Updated June 2026</span>
      </div>

      <h1 class="font-display" style="font-size:clamp(2.2rem,5vw,3.8rem);line-height:1.06;letter-spacing:-0.025em;color:#fff;margin-bottom:20px;">
        Every number here<br/>
        <em style="color:#E8B4B0;font-weight:400;">came from a real deployment.</em>
      </h1>

      <p style="font-size:15px;line-height:1.75;color:rgba(255,255,255,0.38);max-width:520px;margin-bottom:28px;">
        Not projections. Not benchmarks. Aggregated actuals from 312 verified client deployments across six verticals. Every figure verifiable on request.
      </p>

      <div style="display:flex;flex-wrap:wrap;gap:18px;">
        {[
          { icon: 'M5 13l4 4L19 7', label: 'Verified actuals only' },
          { icon: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zm0 0l8 8 8-8', label: 'Updated monthly' },
          { icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z', label: 'Anonymised with consent' },
        ].map(t => (
          <div style="display:flex;align-items:center;gap:6px;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={t.icon}/></svg>
            <span style="font-size:11px;color:rgba(255,255,255,0.30);">{t.label}</span>
          </div>
        ))}
      </div>

    </div>
  </div>

  <!-- Counter strip -->
  <div style="border-top:1px solid rgba(255,255,255,0.05);background:rgba(255,255,255,0.02);">
    <div class="container-x" style="padding-top:28px;padding-bottom:28px;">
      <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:0;overflow-x:auto;">
        {aggregate.map((s, i) => (
          <div style={`text-align:center;padding:4px 20px;${i < 5 ? 'border-right:1px solid rgba(255,255,255,0.06);' : ''}`}>
            <p class="font-display" style="font-size:clamp(1.3rem,2.5vw,1.9rem);color:#fff;line-height:1;margin-bottom:6px;"
               data-counter data-target={s.value} data-suffix={s.suffix} data-decimal={s.value.includes('.') ? 'true' : undefined}>
              0{s.suffix}
            </p>
            <p style="font-size:9.5px;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;color:rgba(255,255,255,0.25);">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</header>

<!-- ═══════════════════════════════════════════════════
     LIVE TICKER — recent deployments
════════════════════════════════════════════════════ -->
<div style="background:#111111;border-top:1px solid rgba(255,255,255,0.04);border-bottom:1px solid rgba(255,255,255,0.04);padding:12px 0;overflow:hidden;">
  <div style="display:flex;align-items:center;">
    <!-- Static label -->
    <div style="flex-shrink:0;padding:0 20px;display:flex;align-items:center;gap:8px;border-right:1px solid rgba(255,255,255,0.08);margin-right:0;z-index:2;background:#111111;">
      <span style="width:5px;height:5px;border-radius:50%;background:#4ADE80;animation:pulse-dot 2s ease-in-out infinite;"></span>
      <span style="font-size:9px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.30);white-space:nowrap;">Recent wins</span>
    </div>
    <!-- Scrolling track -->
    <div style="flex:1;overflow:hidden;position:relative;">
      <div style="display:flex;gap:0;animation:marquee 32s linear infinite;width:max-content;" id="ticker-track">
        {[...ticker, ...ticker].map(t => (
          <div style="display:inline-flex;align-items:center;gap:10px;padding:0 32px;border-right:1px solid rgba(255,255,255,0.05);">
            <span style="width:5px;height:5px;border-radius:50%;background:rgba(232,180,176,0.50);flex-shrink:0;"></span>
            <span style="font-size:11.5px;font-weight:600;color:rgba(255,255,255,0.70);white-space:nowrap;">{t.co}</span>
            <span style="font-size:11px;color:rgba(255,255,255,0.30);white-space:nowrap;">—</span>
            <span style="font-size:11px;color:#E8B4B0;white-space:nowrap;">{t.win}</span>
            <span style="font-size:9.5px;color:rgba(255,255,255,0.20);white-space:nowrap;">{t.days}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════
     INDUSTRY BENCHMARKS
════════════════════════════════════════════════════ -->
<section style="background:#0A0A0A;padding:72px 0 80px;">
  <div class="container-x">

    <div style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:36px;">
      <div>
        <p style="font-size:9px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:rgba(232,180,176,0.50);margin-bottom:12px;">Industry benchmarks</p>
        <h2 class="font-display" style="font-size:clamp(1.6rem,3vw,2.4rem);color:#fff;line-height:1.15;letter-spacing:-0.015em;">
          How your sector typically performs.
        </h2>
      </div>
      <p style="font-size:11.5px;color:rgba(255,255,255,0.28);max-width:300px;line-height:1.65;">Averages across all verified PURIST deployments in each vertical. Sorted by ROI multiple.</p>
    </div>

    <!-- Table header -->
    <div style="display:grid;grid-template-columns:180px 1fr 1fr 1fr 1fr 1fr;gap:0;border-bottom:1px solid rgba(255,255,255,0.07);padding-bottom:12px;margin-bottom:4px;">
      {['Industry','Hours / wk','Annual saving','ROI multiple','Payback','Deploy'].map((h, i) => (
        <div style={`padding:0 ${i===0?'0':'16px'};`}>
          <span style="font-size:8.5px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:rgba(255,255,255,0.22);">{h}</span>
        </div>
      ))}
    </div>

    <!-- Table rows -->
    <div style="display:flex;flex-direction:column;gap:0;">
      {benchmarks.map((b) => (
        <div style={`display:grid;grid-template-columns:180px 1fr 1fr 1fr 1fr 1fr;gap:0;align-items:center;padding:16px 0;border-bottom:1px solid rgba(255,255,255,0.04);transition:background 0.15s;${b.best ? 'background:rgba(232,180,176,0.04);border-radius:8px;' : ''}`}
             onmouseover="this.style.background='rgba(255,255,255,0.02)'"
             onmouseout={`this.style.background='${b.best ? "rgba(232,180,176,0.04)" : "transparent"}'`}>
          <div style="display:flex;align-items:center;gap:10px;">
            {b.best && <span style="width:3px;height:20px;background:#E8B4B0;border-radius:2px;flex-shrink:0;"></span>}
            {!b.best && <span style="width:3px;height:20px;background:transparent;flex-shrink:0;"></span>}
            <span style={`font-size:13px;font-weight:600;color:${b.best ? '#fff' : 'rgba(255,255,255,0.65)'};`}>{b.industry}</span>
            {b.best && <span style="font-size:8px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:#E8B4B0;background:rgba(232,180,176,0.12);border:1px solid rgba(232,180,176,0.20);padding:2px 6px;border-radius:4px;">Best ROI</span>}
          </div>
          <div style="padding-left:16px;">
            <span class="font-display" style={`font-size:17px;color:${b.best ? '#fff' : 'rgba(255,255,255,0.55)'};`}>{b.hours}</span>
          </div>
          <div style="padding-left:16px;">
            <span class="font-display" style={`font-size:17px;color:${b.best ? '#E8B4B0' : 'rgba(232,180,176,0.60)'};`}>{b.saving}</span>
          </div>
          <div style="padding-left:16px;">
            <span style={`display:inline-block;font-family:'Fraunces',Georgia,serif;font-size:17px;color:${b.best ? '#E8B4B0' : 'rgba(255,255,255,0.50)'};${b.best ? 'background:rgba(232,180,176,0.10);padding:2px 10px;border-radius:100px;' : ''}`}>{b.roi}</span>
          </div>
          <div style="padding-left:16px;">
            <span style="font-size:12px;color:rgba(255,255,255,0.38);">{b.payback}</span>
          </div>
          <div style="padding-left:16px;">
            <span style="font-size:12px;color:rgba(255,255,255,0.38);">{b.deploy}</span>
          </div>
        </div>
      ))}
    </div>

    <p style="font-size:9.5px;color:rgba(255,255,255,0.16);margin-top:20px;line-height:1.5;">All figures are averages across verified client deployments. Individual results vary based on team size, existing stack and workflow complexity. Full methodology available on request.</p>

  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     CASE STUDIES
════════════════════════════════════════════════════ -->
<section style="background:#F8F6F1;padding:72px 0 80px;">
  <div class="container-x">

    <div style="margin-bottom:32px;">
      <p style="font-size:9px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:rgba(10,10,10,0.30);margin-bottom:12px;">Case studies</p>
      <h2 class="font-display" style="font-size:clamp(1.6rem,3vw,2.4rem);color:#0A0A0A;line-height:1.15;letter-spacing:-0.015em;">
        Real deployments. Real before and after.
      </h2>
    </div>

    <!-- Filter -->
    <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:40px;" id="filter-bar">
      {industries.map((ind, i) => (
        <button
          data-filter={ind.toLowerCase()}
          onclick="filterCases(this)"
          style={i === 0
            ? 'font-size:11px;font-weight:600;padding:7px 16px;border-radius:100px;background:#0A0A0A;color:#fff;border:none;cursor:pointer;transition:all 0.15s;'
            : 'font-size:11px;font-weight:600;padding:7px 16px;border-radius:100px;background:#fff;color:rgba(10,10,10,0.55);border:1px solid rgba(10,10,10,0.10);cursor:pointer;transition:all 0.15s;'}
          class="filter-btn"
        >
          {ind}
        </button>
      ))}
    </div>

    <!-- Cards grid -->
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:20px;" id="cases-grid" class="cases-responsive-grid">
      {cases.map((c) => (
        <article
          data-industry={c.industry.toLowerCase()}
          class="case-card scroll-fade"
          style="background:#fff;border:1px solid rgba(10,10,10,0.07);border-radius:18px;overflow:hidden;transition:box-shadow 0.2s,transform 0.2s;"
          onmouseover="this.style.boxShadow='0 16px 48px rgba(10,10,10,0.10)';this.style.transform='translateY(-2px)'"
          onmouseout="this.style.boxShadow='';this.style.transform=''"
        >

          <!-- Header -->
          <div style="padding:22px 22px 18px;border-bottom:1px solid rgba(10,10,10,0.055);">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
              <div style="flex:1;min-width:0;">
                <p style="font-size:8.5px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:rgba(10,10,10,0.28);margin-bottom:8px;">{c.tag}</p>
                <h2 class="font-display" style="font-size:clamp(1rem,2vw,1.2rem);line-height:1.25;letter-spacing:-0.01em;color:#0A0A0A;">{c.headline}</h2>
              </div>
              <div style="flex-shrink:0;text-align:right;">
                <p class="font-display" style="font-size:clamp(2rem,4vw,2.6rem);line-height:1;color:#E8B4B0;letter-spacing:-0.02em;">{c.stat}</p>
                <p style="font-size:9.5px;color:rgba(10,10,10,0.35);margin-top:3px;max-width:72px;text-align:right;line-height:1.3;">{c.statLabel}</p>
              </div>
            </div>
          </div>

          <!-- Before → After -->
          <div style="display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid rgba(10,10,10,0.055);">
            <div style="padding:12px 14px;background:#F8F6F1;border-right:1px solid rgba(10,10,10,0.055);">
              <p style="font-size:7.5px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:rgba(10,10,10,0.30);margin-bottom:5px;display:flex;align-items:center;gap:4px;">
                <span style="width:6px;height:6px;border-radius:50%;background:rgba(10,10,10,0.20);display:inline-block;"></span>Before
              </p>
              <p style="font-size:10.5px;line-height:1.5;color:rgba(10,10,10,0.50);">{c.before}</p>
            </div>
            <div style="padding:12px 14px;background:#fff;">
              <p style="font-size:7.5px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:rgba(45,80,22,0.60);margin-bottom:5px;display:flex;align-items:center;gap:4px;">
                <span style="width:6px;height:6px;border-radius:50%;background:#4ADE80;display:inline-block;"></span>After
              </p>
              <p style="font-size:10.5px;line-height:1.5;color:rgba(10,10,10,0.65);">{c.after}</p>
            </div>
          </div>

          <!-- Body -->
          <div style="padding:16px 22px 20px;">

            <!-- Quote -->
            <div style="margin-bottom:14px;padding:10px 13px;background:#F8F6F1;border-left:2px solid #E8B4B0;border-radius:0 8px 8px 0;">
              <p style="font-size:11.5px;font-style:italic;line-height:1.55;color:rgba(10,10,10,0.62);">"{c.quote}"</p>
              <p style="font-size:9.5px;color:rgba(10,10,10,0.30);margin-top:5px;font-weight:500;">— {c.attribution}</p>
            </div>

            <!-- Workflow chips -->
            <div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:14px;">
              {c.workflows.map(w => (
                <span style="font-size:10px;font-weight:500;padding:4px 10px;border-radius:100px;background:rgba(10,10,10,0.04);border:1px solid rgba(10,10,10,0.07);color:rgba(10,10,10,0.50);">{w}</span>
              ))}
            </div>

            <!-- 4 KPI boxes -->
