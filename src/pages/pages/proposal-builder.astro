---
// Internal tool — noindex
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Proposal Builder — PURIST</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;background:#0f0f0f;color:white;min-height:100vh;display:flex;align-items:flex-start;justify-content:center;padding:3rem 1rem;-webkit-font-smoothing:antialiased}
    .wrap{width:100%;max-width:560px}
    .logo{font-family:'DM Serif Display',Georgia,serif;font-size:1.25rem;color:rgba(255,255,255,0.4);margin-bottom:2.5rem}
    .logo span{color:#E8B4B0}
    h1{font-family:'DM Serif Display',Georgia,serif;font-size:2rem;font-weight:400;margin-bottom:0.4rem}
    .sub{color:rgba(255,255,255,0.35);font-size:0.875rem;margin-bottom:2.5rem;line-height:1.6}
    .field{margin-bottom:1.25rem}
    label{display:block;font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-bottom:0.5rem;font-weight:500}
    input,select{width:100%;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:0.9rem 1rem;font-size:0.9375rem;color:white;font-family:'Inter',sans-serif;outline:none;transition:border-color 0.2s;-webkit-appearance:none}
    input:focus,select:focus{border-color:rgba(232,180,176,0.5);background:rgba(255,255,255,0.08)}
    input::placeholder{color:rgba(255,255,255,0.2)}
    select option{background:#1a1a1a}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .divider{border:none;border-top:1px solid rgba(255,255,255,0.08);margin:2rem 0}
    .btn{width:100%;background:#E8B4B0;color:#0A0A0A;border:none;padding:1rem;border-radius:12px;font-size:1rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.01em;transition:opacity 0.2s}
    .btn:hover{opacity:0.88}

    /* Output */
    #result{display:none;margin-top:2rem}
    .result-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:16px;overflow:hidden}
    .result-top{background:rgba(232,180,176,0.08);border-bottom:1px solid rgba(255,255,255,0.06);padding:1.25rem 1.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:gap;gap:0.75rem}
    .result-top-label{font-size:0.6875rem;letter-spacing:0.15em;text-transform:uppercase;color:#E8B4B0;font-weight:600}
    .result-top-name{font-size:0.9375rem;font-weight:600;margin-top:0.2rem}
    .btn-sm{padding:0.5rem 1.1rem;border-radius:8px;font-size:0.8125rem;font-weight:600;cursor:pointer;border:none;font-family:'Inter',sans-serif;transition:opacity 0.2s}
    .btn-sm:hover{opacity:0.8}
    .btn-copy{background:#E8B4B0;color:#0A0A0A}
    .btn-open{background:rgba(255,255,255,0.1);color:white}
    .btn-email{background:rgba(255,255,255,0.08);color:white;border:1px solid rgba(255,255,255,0.12)}

    .email-preview{padding:1.5rem;font-size:0.85rem;line-height:1.75;color:rgba(255,255,255,0.65);white-space:pre-wrap;max-height:400px;overflow-y:auto}
    .email-preview::-webkit-scrollbar{width:4px}
    .email-preview::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:2px}
    .actions-row{padding:1rem 1.5rem;border-top:1px solid rgba(255,255,255,0.06);display:flex;gap:0.75rem;flex-wrap:wrap}

    .stats-row{display:flex;gap:1rem;padding:1rem 1.5rem;border-top:1px solid rgba(255,255,255,0.06)}
    .stat{flex:1;text-align:center}
    .stat-v{font-family:'DM Serif Display',Georgia,serif;font-size:1.4rem;color:white}
    .stat-l{font-size:0.625rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-top:0.15rem}
  </style>
</head>
<body>
<div class="wrap">
  <div class="logo">PURIST<span>.</span></div>

  <h1>Proposal Builder</h1>
  <p class="sub">Fill in 4 fields → get a complete proposal link + email ready to send.</p>

  <!-- Step 1: Client -->
  <div class="field">
    <label>Client / Business name</label>
    <input id="client" type="text" placeholder="e.g. Smith Dental Clinic" />
  </div>

  <div class="field">
    <label>Client email</label>
    <input id="email" type="email" placeholder="john@business.com" />
  </div>

  <div class="field">
    <label>Industry</label>
    <select id="industry">
      <option value="">— Select industry —</option>
      <option value="Restaurant">Restaurant / Food & Beverage</option>
      <option value="Dental">Dental / Medical Clinic</option>
      <option value="Real Estate">Real Estate Agency</option>
      <option value="Law Firm">Law Firm / Legal</option>
      <option value="E-commerce">E-commerce / Retail</option>
      <option value="Marketing Agency">Marketing Agency</option>
      <option value="Accounting">Accounting / Finance</option>
      <option value="Coaching">Coaching / Consulting</option>
      <option value="SaaS">SaaS / Tech Startup</option>
      <option value="Construction">Construction / Trades</option>
    </select>
  </div>

  <div class="row">
    <div class="field">
      <label>Your price (€)</label>
      <input id="price" type="number" placeholder="3200" />
    </div>
    <div class="field">
      <label>Currency</label>
      <select id="currency">
        <option value="EUR">EUR €</option>
        <option value="USD">USD $</option>
        <option value="GBP">GBP £</option>
      </select>
    </div>
  </div>

  <button class="btn" id="generateBtn">Generate proposal →</button>

  <!-- Output -->
  <div id="result">
    <div class="result-card">
      <div class="result-top">
        <div>
          <div class="result-top-label">Proposal ready</div>
          <div class="result-top-name" id="r-name"></div>
        </div>
        <button class="btn-sm btn-open" id="openBtn">↗ Preview</button>
      </div>

      <div class="stats-row">
        <div class="stat">
          <div class="stat-v" id="r-hours"></div>
          <div class="stat-l">Hours saved / wk</div>
        </div>
        <div class="stat">
          <div class="stat-v" id="r-annual"></div>
          <div class="stat-l">Annual value</div>
        </div>
        <div class="stat">
          <div class="stat-v" id="r-roi"></div>
          <div class="stat-l">ROI year 1</div>
        </div>
        <div class="stat">
          <div class="stat-v" id="r-price"></div>
          <div class="stat-l">Your fee</div>
        </div>
      </div>

      <div style="padding:0 1.5rem 0.5rem;font-size:0.7rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.25);">Email to send</div>
      <div class="email-preview" id="r-email"></div>

      <div class="actions-row">
        <button class="btn-sm btn-copy" id="copyEmailBtn">📋 Copy email</button>
        <a class="btn-sm btn-email" id="mailtoBtn" href="#">✉️ Open in Gmail</a>
        <button class="btn-sm btn-email" id="copyLinkBtn">🔗 Copy proposal link</button>
      </div>
    </div>
  </div>
</div>

<script>
var DATA = {
  "Restaurant":{
    w1:"Online Reservation → CRM + Staff Alert",
    w1d:"Every reservation from your website, Google, or Yelp is logged automatically, the right staff notified by SMS, and a confirmation sent to the guest — zero manual steps.",
    w1s:"6h/wk",
    w2:"Review Request Automation (Google & Yelp)",
    w2d:"24 hours after each visit, a personalised review request is sent automatically. Negative feedback is flagged privately before reaching Google — protecting your rating.",
    w2s:"3h/wk",
    w3:"Supplier Order & Inventory Alert",
    w3d:"When stock drops below threshold, a reorder is sent to your supplier automatically. You get a daily inventory summary every morning before service.",
    w3s:"5h/wk",
    hours:"14", roi:"8.7", annual:"58200", price:"2800"
  },
  "Dental":{
    w1:"Appointment Booking → Patient Record Auto-update",
    w1d:"Every new booking is created in your practice management system, the patient file updated, and a reminder sequence triggered — without anyone touching a keyboard.",
    w1s:"7h/wk",
    w2:"No-show Prevention (SMS + Email Reminder Sequence)",
    w2d:"Automated reminders sent at 48h and 2h before each appointment. Patients confirm or reschedule with one tap. No-show rate drops 60–70% within the first month.",
    w2s:"4h/wk",
    w3:"Treatment Plan Follow-up & Recall Sequence",
    w3d:"Patients who haven't booked a follow-up within 30 days get a personalised recall message. Patients due for a 6-month check-up enter a re-engagement sequence automatically.",
    w3s:"5h/wk",
    hours:"16", roi:"11.2", annual:"74800", price:"3400"
  },
  "Real Estate":{
    w1:"New Lead → CRM Entry + Agent Assignment",
    w1d:"Every lead from Rightmove, Zoopla, or your website is captured, entered in your CRM, scored, and routed to the right agent — in under 60 seconds.",
    w1s:"8h/wk",
    w2:"Viewing Follow-up & Offer Nurture Sequence",
    w2d:"After every viewing, a personalised follow-up is sent at 24h, 72h, and 7 days. Non-responders enter a long-term nurture sequence until they're ready.",
    w2s:"5h/wk",
    w3:"Landlord / Vendor Monthly Report Auto-send",
    w3d:"Monthly performance reports are generated automatically with real data (views, enquiries, offers) and sent by email — no manual preparation needed.",
    w3s:"6h/wk",
    hours:"19", roi:"12.4", annual:"89600", price:"3800"
  },
  "Law Firm":{
    w1:"Client Intake Form → Matter Opening + Conflict Check",
    w1d:"New enquiries trigger an automatic intake form, conflict-of-interest check, and matter creation in your practice management system — reducing intake from 45 min to under 5.",
    w1s:"9h/wk",
    w2:"Deadline & Court Date Reminder System",
    w2d:"Critical deadlines are tracked and trigger automated reminders to the relevant fee earner at 30, 14, 7, and 1 day before — zero missed dates.",
    w2s:"4h/wk",
    w3:"Invoice Generation & Payment Chasing",
    w3d:"Invoices generated automatically at billing milestones. Payment reminders triggered at 7, 14, and 30 days overdue. Late payments escalated to the billing partner.",
    w3s:"5h/wk",
    hours:"18", roi:"13.1", annual:"94400", price:"4200"
  },
  "E-commerce":{
    w1:"Abandoned Cart Recovery Sequence",
    w1d:"Customers who abandon their cart receive a 3-step recovery sequence: email at 1h, SMS at 24h, final offer at 72h. Average recovery rate: 12–18% of abandoned carts.",
    w1s:"3h/wk",
    w2:"Post-purchase Review & Upsell Flow",
    w2d:"7 days after delivery, an automated review request is sent. Based on purchase history, a personalised upsell recommendation follows at day 14.",
    w2s:"4h/wk",
    w3:"Inventory Alert & Supplier Reorder",
    w3d:"When any SKU drops below its reorder threshold, a purchase order draft is sent to your supplier automatically. Low-stock products are flagged and removed from ads.",
    w3s:"6h/wk",
    hours:"13", roi:"9.8", annual:"67200", price:"3000"
  },
  "Marketing Agency":{
    w1:"Client Reporting — Auto-generated Monthly Reports",
    w1d:"Monthly performance reports for all clients are pulled from Google Analytics, Meta Ads, and LinkedIn automatically, formatted in your branded template, and sent by email.",
    w1s:"10h/wk",
    w2:"Lead Nurture + Proposal Follow-up Sequence",
    w2d:"Every prospect who requests a proposal enters a 5-touch follow-up sequence if they don't respond within 48h. Stops automatically when they reply or book a call.",
    w2s:"4h/wk",
    w3:"Client Onboarding Workflow Automation",
    w3d:"When a new client signs, onboarding tasks are created in your PM tool, contracts sent via DocuSign, kickoff call booked, and the client added to all channels — in minutes.",
    w3s:"5h/wk",
    hours:"19", roi:"10.3", annual:"78400", price:"3600"
  },
  "Accounting":{
    w1:"Document Collection & Client Reminder Sequence",
    w1d:"At the start of each period, document request emails are sent to every client with a personalised checklist. Reminders escalate every 5 days until all documents are received.",
    w1s:"8h/wk",
    w2:"Invoice & Payment Automation",
    w2d:"Client invoices generated automatically at billing milestones. Payment confirmations and reminders sent without manual intervention. Real-time payment status on your dashboard.",
    w2s:"5h/wk",
    w3:"Deadline Alert & Task Assignment System",
    w3d:"Filing deadlines (VAT, corporation tax, payroll) assigned automatically to the right team member with 30, 7, and 1-day reminders. Zero missed deadlines.",
    w3s:"4h/wk",
    hours:"17", roi:"11.8", annual:"82400", price:"3400"
  },
  "Coaching":{
    w1:"Discovery Call Booking → CRM + Prep Email",
    w1d:"When a prospect books a discovery call, they're added to your CRM, tagged by interest area, and sent a personalised prep questionnaire — so you walk into every call fully briefed.",
    w1s:"5h/wk",
    w2:"Client Onboarding & Welcome Sequence",
    w2d:"New clients receive a structured 7-day onboarding: welcome video, intake form, resource kit, and first session preparation — all automated and personalised by programme.",
    w2s:"4h/wk",
    w3:"Progress Check-in & Renewal Sequence",
    w3d:"Midway through each programme, an automated progress check-in is sent. 3 weeks before end, a renewal or upgrade offer is triggered with personalised messaging.",
    w3s:"4h/wk",
    hours:"13", roi:"8.9", annual:"54600", price:"2600"
  },
  "SaaS":{
    w1:"Trial Activation & Feature Adoption Sequence",
    w1d:"When a user signs up, a personalised onboarding sequence triggers based on their role. Users who don't activate key features within 48h receive targeted nudges automatically.",
    w1s:"6h/wk",
    w2:"Churn Risk Detection & Intervention",
    w2d:"Users who haven't logged in for 7 days, or whose usage dropped 50%+, are flagged and added to a re-engagement sequence. High-value accounts escalated to a CSM.",
    w2s:"5h/wk",
    w3:"Billing, Dunning & Expansion Automation",
    w3d:"Failed payments trigger an automatic dunning sequence (email + in-app). Users on limits receive upgrade prompts automatically. Churn prevented before it happens.",
    w3s:"4h/wk",
    hours:"15", roi:"14.2", annual:"96000", price:"4500"
  },
  "Construction":{
    w1:"Quote Request → Estimate + Follow-up Sequence",
    w1d:"Every quote request is logged, a templated estimate sent within 2 hours, and a follow-up triggered at day 3 and day 7 if no response — no lead goes cold.",
    w1s:"7h/wk",
    w2:"Subcontractor Scheduling & Confirmation",
    w2d:"When a job is confirmed, subcontractors are notified automatically with date, site address, and job specs. Confirmations logged. No-shows trigger an immediate alert.",
    w2s:"5h/wk",
    w3:"Invoice & Payment Collection",
    w3d:"Invoices generated and sent at project milestones automatically. Payment reminders triggered at 7, 14, and 30 days overdue.",
    w3s:"6h/wk",
    hours:"18", roi:"9.6", annual:"72000", price:"3200"
  }
};

var proposalUrl = '';
var emailText = '';

document.getElementById('generateBtn').addEventListener('click', function() {
  var client   = document.getElementById('client').value.trim();
  var email    = document.getElementById('email').value.trim();
  var industry = document.getElementById('industry').value;
  var priceVal = document.getElementById('price').value.trim();
  var currency = document.getElementById('currency').value;

  if (!client || !industry) {
    alert('Please enter a client name and select an industry.');
    return;
  }

  var d = DATA[industry];
  var sym = currency === 'USD' ? '$' : currency === 'GBP' ? '£' : '€';
  var price = priceVal || d.price;
  var annualFmt = parseInt(d.annual).toLocaleString('en-GB');

  // Build URL
  var params = new URLSearchParams({
    client: client, industry: industry, by: 'Hugo — PURIST',
    w1: d.w1, w1desc: d.w1d, w1save: d.w1s,
    w2: d.w2, w2desc: d.w2d, w2save: d.w2s,
    w3: d.w3, w3desc: d.w3d, w3save: d.w3s,
    hours: d.hours, roi: d.roi, annual: d.annual,
    price: price, currency: currency, plan: 'Growth', deploy: '7–10'
  });

  proposalUrl = 'https://www.purist.online/pages/proposal?' + params.toString();

  // Email
  emailText = 'Hi,\n\nThank you for our call — I\'ve put together your personalised automation plan for ' + client + '.\n\nHere\'s what we\'re going to build:\n\n'
    + '1. ' + d.w1 + ' → saves ' + d.w1s + '\n'
    + '2. ' + d.w2 + ' → saves ' + d.w2s + '\n'
    + '3. ' + d.w3 + ' → saves ' + d.w3s + '\n\n'
    + 'Total: ' + d.hours + ' hours saved per week — ' + sym + annualFmt + ' recovered annually, ' + d.roi + '× ROI in year 1.\n\n'
    + 'Your investment: ' + sym + price + ' (one-time setup — includes 90 days of monitoring and support, 30-day guarantee).\n\n'
    + '→ View your full proposal here:\n' + proposalUrl + '\n\n'
    + 'If this looks good, just reply "let\'s go" and I\'ll send the invoice and onboarding form within 2 hours. Your first automation goes live in 7–10 business days.\n\n'
    + 'Any questions — I\'m here.\n\nHugo\nPURIST — Workflow Automation & AI Agents\npurist.online';

  // Update UI
  document.getElementById('r-name').textContent = client + ' — ' + industry;
  document.getElementById('r-hours').textContent = d.hours + 'h';
  document.getElementById('r-annual').textContent = sym + annualFmt;
  document.getElementById('r-roi').textContent = d.roi + '×';
  document.getElementById('r-price').textContent = sym + parseInt(price).toLocaleString();
  document.getElementById('r-email').textContent = emailText;

  document.getElementById('openBtn').onclick = function() { window.open('/pages/proposal?' + params.toString(), '_blank'); };

  var subject = 'Your Automation Plan — ' + client + ' × PURIST';
  document.getElementById('mailtoBtn').href = 'mailto:' + email + '?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(emailText);

  document.getElementById('result').style.display = 'block';
  document.getElementById('result').scrollIntoView({ behavior: 'smooth', block: 'start' });
});

document.getElementById('copyEmailBtn').addEventListener('click', function() {
  var btn = this;
  navigator.clipboard.writeText(emailText).then(function() {
    btn.textContent = '✓ Copied!';
    setTimeout(function() { btn.textContent = '📋 Copy email'; }, 2000);
  });
});

document.getElementById('copyLinkBtn').addEventListener('click', function() {
  var btn = this;
  navigator.clipboard.writeText(proposalUrl).then(function() {
    btn.textContent = '✓ Link copied!';
    setTimeout(function() { btn.textContent = '🔗 Copy proposal link'; }, 2000);
  });
});
</script>
</body>
</html>
