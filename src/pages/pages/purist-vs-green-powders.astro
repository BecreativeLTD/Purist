---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';

const PINK = '#c4847e';
const PINK_BG = 'rgba(232,180,176,0.10)';

const rows = [
  { feature: 'Setup time',           purist: '< 7 days',                  other: '2–6 weeks DIY' },
  { feature: 'Custom logic',         purist: 'Unlimited',                  other: 'Limited by node library' },
  { feature: 'You own the code',     purist: '100% — no lock-in',          other: 'No — locked to platform' },
  { feature: 'Platform fees',        purist: 'None',                       other: '$20–$799/mo ongoing' },
  { feature: 'Error monitoring',     purist: '24/7 — we fix it',           other: 'You manage it yourself' },
  { feature: 'AI agents',            purist: 'Claude Opus built-in',       other: 'Basic only' },
  { feature: 'Multi-step workflows', purist: 'Unlimited steps',            other: 'Capped on lower plans' },
  { feature: 'Support',              purist: 'Dedicated Slack + engineer', other: 'Email tickets' },
  { feature: 'Self-hosted option',   purist: 'Yes — your infra',           other: 'No' },
  { feature: 'Money-back guarantee', purist: '30 days',                    other: 'None' },
];
---

<BaseLayout
  title="PURIST vs Zapier — Why Businesses Switch | PURIST Automation"
  description="Compare PURIST automation deployments against Zapier. No platform lock-in, no ongoing fees, 24/7 monitoring and custom logic that Zapier cannot match."
>
  <Header />
  <main id="main-content">

    <div class="py-16 lg:py-24" style="background:#0A0A0A">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
        <p class="text-xs uppercase tracking-widest font-bold mb-4" style={`color:${PINK}`}>Comparison</p>
        <h1 class="text-3xl lg:text-5xl font-bold text-white mb-5 leading-tight">PURIST vs Zapier</h1>
        <p class="text-base lg:text-lg text-gray-400 max-w-2xl mx-auto mb-8">
          Zapier is a great starting point. But at scale, monthly fees compound, logic hits walls, and you own nothing. Here is how PURIST compares.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/pages/welcome" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white transition" style={`background:${PINK}`}>Book free audit →</a>
          <a href="/skills" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm border border-gray-700 text-gray-300 hover:border-gray-500 transition">Browse 157 skills</a>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-14 lg:py-20">

      <div class="overflow-x-auto rounded-2xl border border-gray-200 mb-14">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 bg-gray-50">
              <th class="text-left px-5 py-4 font-semibold text-gray-700 w-1/3">Feature</th>
              <th class="text-center px-5 py-4 font-bold" style={`color:${PINK}`}>PURIST</th>
              <th class="text-center px-5 py-4 font-semibold text-gray-400">Zapier</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {rows.map(r => (
              <tr class="hover:bg-gray-50 transition">
                <td class="px-5 py-3.5 text-gray-600 font-medium">{r.feature}</td>
                <td class="px-5 py-3.5 text-center font-semibold text-gray-900">{r.purist}</td>
                <td class="px-5 py-3.5 text-center text-gray-400">{r.other}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="grid sm:grid-cols-3 gap-6 mb-14">
        {[
          { value: '£0',   label: 'Platform fees — ever',    desc: 'You pay once for deployment. No monthly Zapier bill that grows with your usage.' },
          { value: '100%', label: 'Code ownership',          desc: 'Every workflow is yours. Move it, modify it, hand it to any developer.' },
          { value: '9.2×', label: 'Average ROI at 90 days', desc: 'Clients switching from Zapier typically recoup setup cost within the first month.' },
        ].map(s => (
          <div class="rounded-xl border border-gray-200 p-6 text-center">
            <p class="text-3xl font-bold mb-1" style={`color:${PINK}`}>{s.value}</p>
            <p class="text-sm font-semibold text-gray-900 mb-2">{s.label}</p>
            <p class="text-xs text-gray-500 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>

      <div class="rounded-2xl p-8 text-center" style={`background:${PINK_BG};border:1px solid rgba(196,132,126,0.20)`}>
        <h2 class="text-xl font-bold text-gray-900 mb-3">Already on Zapier? We migrate you.</h2>
        <p class="text-sm text-gray-600 mb-6 max-w-lg mx-auto">We audit your existing Zaps, rebuild them in n8n with better logic and zero ongoing fees, and hand you full ownership.</p>
        <a href="/pages/welcome" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white transition" style={`background:${PINK}`}>Book your free migration audit →</a>
      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>
