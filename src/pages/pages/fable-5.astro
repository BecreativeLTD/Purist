  { name: 'Core Analytics', fable: 91.2, opus: 81.0, gpt: 74.5, gemini: 70.8 },
  { name: 'Finance Reasoning', fable: 88.7, opus: 76.3, gpt: 71.2, gemini: 68.4 },
  { name: 'Vision & Documents', fable: 93.1, opus: 84.6, gpt: 79.8, gemini: 82.1 },
  { name: 'Scientific Research', fable: 89.4, opus: 78.9, gpt: 72.1, gemini: 75.3 },
