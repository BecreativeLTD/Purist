const useCases = [
  {
    title: 'Autonomous coding agents',
    desc: 'Fable 5 writes, debugs, and deploys production code across entire repositories. Multi-file refactors that took hours now complete in minutes with 80.3% accuracy on SWE-Bench Pro.',
    color: '#4ADE80',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  },
  {
    title: 'Financial analysis & modelling',
    desc: 'Process earnings reports, build DCF models, and generate investment memos with 91.2% accuracy on complex analytical tasks. The strongest finance model ever benchmarked.',
    color: '#CC9560',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  },
  {
    title: 'Legal document review',
    desc: 'Analyse contracts, identify risk clauses, and compare regulatory frameworks across jurisdictions. 93.1% accuracy on document understanding with full vision capabilities.',
    color: '#60A5FA',
    icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
  },
  {
    title: 'Scientific research synthesis',
    desc: 'Review literature, critique methodologies, and generate hypotheses across domains. Cross-references papers and datasets at a level previously requiring specialist researchers.',
    color: '#F472B6',
    icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  },
  {
    title: 'Enterprise knowledge work',
    desc: 'Draft strategy decks, competitive analyses, and policy documents. The longer the task, the larger Fable 5\'s advantage — designed for complex, multi-hour knowledge work.',
    color: '#E8B4B0',
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  },
  {
    title: 'Production AI agents',
    desc: 'Orchestrate multi-step workflows with near-perfect tool use (96.1%). PURIST deploys Fable 5-powered agents for lead qualification, customer onboarding, and operations automation.',
    color: '#A78BFA',
    icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2h-2',
  },
];

const timeline = [
  { date: 'Jun 9, 2026', event: 'Fable 5 & Mythos 5 released', detail: 'Available on Pro, Max, Team, and Enterprise plans at no extra cost' },
  { date: 'Jun 22, 2026', event: 'Free access period ends', detail: 'Fable 5 moves to usage credits. API pricing: $10/$50 per million tokens' },
  { date: 'Available now', event: 'API access via Anthropic & AWS Bedrock', detail: 'Model ID: claude-fable-5 — available on Amazon Bedrock and direct API' },
];
---

<ShopLayout
  title="Claude Fable 5 & Mythos 5 — The Mythos-Class AI Model | PURIST"
  description="Claude Fable 5 is Anthropic's most powerful publicly available AI model. 80.3% SWE-Bench Pro, 1M context window, 128K output. Discover capabilities, benchmarks, pricing, and how PURIST deploys Fable 5 for business automation."
>

<!-- ═══════════════════════════════════════════
     HERO — Giant cinematic reveal
════════════════════════════════════════════ -->
<header class="relative overflow-hidden" style="background:#0A0A0A;min-height:100vh;display:flex;flex-direction:column;justify-content:center;">

  <!-- Animated gradient background -->
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 80% 60% at 50% 30%,rgba(232,180,176,0.08) 0%,transparent 50%);"></div>
  <div class="absolute inset-0 pointer-events-none fable-glow" style="background:radial-gradient(ellipse 40% 50% at 70% 60%,rgba(164,139,250,0.05) 0%,transparent 50%);"></div>

  <!-- Floating grid -->
  <div class="absolute inset-0 pointer-events-none" style="background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse 70% 70% at 50% 50%,black,transparent);"></div>

  <div class="container-x relative z-10 py-20 lg:py-0">
    <div class="max-w-5xl mx-auto text-center">

      <!-- Status pill -->
      <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full mb-8" style="background:rgba(232,180,176,0.08);border:1px solid rgba(232,180,176,0.15);">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background:#4ADE80;"></span>
          <span class="relative inline-flex rounded-full h-2 w-2" style="background:#4ADE80;"></span>
        </span>
        <span class="text-[10px] font-semibold tracking-widest uppercase" style="color:rgba(255,255,255,0.6);">Released June 9, 2026</span>
        <span class="w-px h-3" style="background:rgba(255,255,255,0.12);"></span>
        <span class="text-[10px] font-bold tracking-wider uppercase" style="color:#E8B4B0;">Mythos-class</span>
      </div>

      <!-- Giant title -->
      <h1 class="fable-title font-display leading-[0.9] tracking-[-0.04em] text-white mb-8" style="font-size:clamp(3rem,10vw,8rem);">
        <span style="color:#E8B4B0;">Fable</span> 5
      </h1>

      <p class="text-lg lg:text-xl leading-relaxed max-w-2xl mx-auto mb-6" style="color:rgba(255,255,255,0.5);">
        The most powerful AI model ever made publicly available.<br class="hidden sm:block"/>
        Built on Anthropic's <span style="color:#A78BFA;font-weight:600;">Mythos</span> architecture.
      </p>

      <p class="text-sm leading-relaxed max-w-xl mx-auto mb-10" style="color:rgba(255,255,255,0.3);">
        80.3% SWE-Bench Pro &middot; 1M context window &middot; 128K output tokens &middot; Adaptive thinking always on
      </p>

      <!-- CTA row -->
      <div class="flex flex-wrap items-center justify-center gap-4 mb-16">
        <a href="/pages/welcome"
           class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl text-sm font-bold transition-all duration-200"
           style="background:#E8B4B0;color:#0A0A0A;"
           onmouseover="this.style.background='#d9a09b';this.style.transform='translateY(-1px)'"
           onmouseout="this.style.background='#E8B4B0';this.style.transform=''">
          Deploy Fable 5 for your business
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
        <a href="#benchmarks"
           class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl text-sm font-semibold transition-all duration-200"
           style="border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.6);"
           onmouseover="this.style.borderColor='rgba(255,255,255,0.3)';this.style.color='#fff'"
           onmouseout="this.style.borderColor='rgba(255,255,255,0.12)';this.style.color='rgba(255,255,255,0.6)'">
          See benchmarks
        </a>
      </div>

      <!-- Spec pills row -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 max-w-4xl mx-auto">
        {specs.map((s) => (
          <div class="flex flex-col items-center gap-2 p-4 rounded-xl" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.6;"><path d={s.icon}/></svg>
            <span class="text-[10px] uppercase tracking-wider font-semibold" style="color:rgba(255,255,255,0.3);">{s.label}</span>
            <span class="text-[13px] font-bold text-white">{s.value}</span>
          </div>
        ))}
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
    <span class="text-[9px] uppercase tracking-[0.2em] text-white/40 font-semibold">Scroll</span>
    <div class="w-px h-8 scroll-line"></div>
  </div>
</header>


<!-- ═══════════════════════════════════════════
     FABLE vs MYTHOS — Twin models explained
════════════════════════════════════════════ -->
<section class="relative" style="background:#0D0D0D;">
  <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(90deg,transparent,rgba(232,180,176,0.15),transparent);"></div>
  <div class="container-x py-20 lg:py-28">

    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-[10px] uppercase tracking-[0.26em] font-bold mb-4 block" style="color:rgba(164,139,250,0.6);">Two models, one architecture</span>
      <h2 class="font-display text-3xl lg:text-5xl leading-tight tracking-tight text-white mb-5">
        Fable 5 <span style="color:rgba(255,255,255,0.2);">&</span> <span style="color:#A78BFA;">Mythos</span> 5
      </h2>
      <p class="text-sm lg:text-base leading-relaxed" style="color:rgba(255,255,255,0.4);">
        Same underlying weights. Same Mythos-class intelligence. Different safety profiles for different use cases. Fable 5 is the public twin — Mythos 5 is restricted to vetted cyber defence partners.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      <!-- Fable 5 card -->
      <div class="rounded-2xl p-8 lg:p-10 relative overflow-hidden" style="background:rgba(232,180,176,0.04);border:1px solid rgba(232,180,176,0.12);">
        <div class="absolute top-0 right-0 w-40 h-40 pointer-events-none" style="background:radial-gradient(circle,rgba(232,180,176,0.06) 0%,transparent 70%);"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center" style="background:linear-gradient(135deg,rgba(232,180,176,0.18),rgba(232,180,176,0.04));border:1px solid rgba(232,180,176,0.22);">
              <!-- Unfolding gem — story as craft, precision, unique -->
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 3L21 12L12 21L3 12Z" stroke="#E8B4B0" stroke-width="1.4" stroke-linejoin="round"/>
                <path d="M3 12L7.5 7.5L12 3" stroke="#E8B4B0" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" opacity="0.35"/>
                <circle cx="12" cy="12" r="2.5" fill="#E8B4B0" opacity="0.55"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">Claude Fable 5</h3>
              <span class="text-[10px] uppercase tracking-wider font-semibold" style="color:#E8B4B0;">Public release</span>
            </div>
          </div>
          <ul class="space-y-3 mb-6">
            {[
              'Available to all Pro, Max, Team & Enterprise users',
              'Safety classifiers route <5% of queries to Opus 4.8',
              'High-risk topics (cyber, bio, chem) fall back to Opus',
              'Full API access: claude-fable-5',
              'Amazon Bedrock & direct API',
              'GitHub Copilot integration',
            ].map(item => (
              <li class="flex items-start gap-2.5 text-[13px] leading-relaxed" style="color:rgba(255,255,255,0.6);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4ADE80" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5"><path d="M20 6L9 17l-5-5"/></svg>
                {item}
              </li>
            ))}
          </ul>
          <div class="flex items-baseline gap-1">
            <span class="text-2xl font-bold text-white">$10</span>
            <span class="text-[11px]" style="color:rgba(255,255,255,0.3);">/ 1M input tokens</span>
            <span class="mx-2 text-[11px]" style="color:rgba(255,255,255,0.15);">|</span>
            <span class="text-2xl font-bold text-white">$50</span>
            <span class="text-[11px]" style="color:rgba(255,255,255,0.3);">/ 1M output</span>
          </div>
        </div>
      </div>

      <!-- Mythos 5 card -->
      <div class="rounded-2xl p-8 lg:p-10 relative overflow-hidden" style="background:rgba(164,139,250,0.03);border:1px solid rgba(164,139,250,0.1);">
        <div class="absolute top-0 right-0 w-40 h-40 pointer-events-none" style="background:radial-gradient(circle,rgba(164,139,250,0.05) 0%,transparent 70%);"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center" style="background:linear-gradient(135deg,rgba(164,139,250,0.18),rgba(164,139,250,0.04));border:1px solid rgba(164,139,250,0.22);">
              <!-- Constellation mark — 4 stars + axes — myth/cosmos, unique -->
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="12" y1="6.5" x2="12" y2="17.5" stroke="#A78BFA" stroke-width="0.9" stroke-linecap="round" opacity="0.3"/>
                <line x1="6.5" y1="12" x2="17.5" y2="12" stroke="#A78BFA" stroke-width="0.9" stroke-linecap="round" opacity="0.3"/>
                <circle cx="12" cy="4.5" r="1.6" fill="#A78BFA" opacity="0.7"/>
                <circle cx="12" cy="19.5" r="1.6" fill="#A78BFA" opacity="0.7"/>
                <circle cx="4.5" cy="12" r="1.6" fill="#A78BFA" opacity="0.7"/>
                <circle cx="19.5" cy="12" r="1.6" fill="#A78BFA" opacity="0.7"/>
                <circle cx="12" cy="12" r="1.2" fill="#A78BFA" opacity="0.35"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">Claude Mythos 5</h3>
              <span class="text-[10px] uppercase tracking-wider font-semibold" style="color:#A78BFA;">Restricted access</span>
            </div>
          </div>
          <ul class="space-y-3 mb-6">
            {[
              'Restricted to vetted cyber defenders & infrastructure operators',
              'No safety classifiers — full unrestricted Mythos capabilities',
              'Deployed via Project Glasswing (US gov collaboration)',
              'Same model ID: claude-mythos-5',
              'Same pricing as Fable 5',
              'Application-only access through Anthropic',
            ].map(item => (
              <li class="flex items-start gap-2.5 text-[13px] leading-relaxed" style="color:rgba(255,255,255,0.6);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#A78BFA" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                {item}
              </li>
            ))}
