const pricing = [
  {
    model: 'Claude Fable 5',
    badge: 'Mythos-class',
    badgeColor: '#E8B4B0',
    input: '$10',
    output: '$50',
    batchInput: '$5',
    batchOutput: '$25',
    context: '1M tokens',
    maxOutput: '128K tokens',
