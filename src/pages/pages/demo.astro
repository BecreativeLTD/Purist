---
import ShopLayout from '~/layouts/ShopLayout.astro';
---

<ShopLayout title="Live Demo — See PURIST Automation in Action" description="Watch real automations execute live, trigger sandbox workflows yourself, and book a personalised demo call.">

  <!-- Hero -->
  <section class="bg-brand-black text-white pt-20 pb-14 lg:pt-28 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 50% 0%,rgba(232,180,176,0.07) 0%,transparent 60%);"></div>
    <div class="container-x relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border mb-6" style="border-color:rgba(232,180,176,0.25);background:rgba(232,180,176,0.06);">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400" style="animation:dm-pulse 2s ease-in-out infinite;"></span>
          <span class="text-[10px] uppercase tracking-[0.18em] font-semibold" style="color:rgba(232,180,176,0.80);">Live demo environment · No account needed</span>
        </div>
        <h1 class="font-display text-[2.2rem] lg:text-[3rem] leading-[1.06] tracking-[-0.025em] text-white mb-4">
          Don't take our word for it.<br/><em class="font-medium" style="color:#E8B4B0;">See it run.</em>
        </h1>
        <p class="text-[15px] leading-relaxed mb-10 max-w-xl mx-auto" style="color:rgba(255,255,255,0.45);">Three ways to experience PURIST automation — a live workflow canvas, a trigger-it-yourself sandbox, and a personalised call where we build yours live.</p>
        <div class="flex flex-wrap justify-center gap-3">
          {[{id:'workflow',label:'① Workflow canvas'},{id:'sandbox',label:'② Live sandbox'},{id:'booking',label:'③ Book a call'}].map(n=>(
            <a href={'#'+n.id} class="px-4 py-2 rounded-full text-[11px] font-semibold border transition-all"
              style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.55);border-color:rgba(255,255,255,0.10);"
              onmouseover="this.style.background='rgba(232,180,176,0.12)';this.style.color='#E8B4B0';this.style.borderColor='rgba(232,180,176,0.30)';"
              onmouseout="this.style.background='rgba(255,255,255,0.06)';this.style.color='rgba(255,255,255,0.55)';this.style.borderColor='rgba(255,255,255,0.10)';">
              {n.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════
       SECTION 1 — WORKFLOW CANVAS
  ══════════════════════════════════════════════════════════════════════ -->
  <section id="workflow" class="bg-[#0F0F0D] py-16 lg:py-24" style="scroll-margin-top:80px;">
    <div class="container-x">

      <div class="max-w-4xl mx-auto mb-10 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-5">
        <div>
          <p class="text-[9px] uppercase tracking-[0.24em] font-bold mb-3" style="color:rgba(232,180,176,0.50);">① Workflow canvas</p>
          <h2 class="font-display text-[1.9rem] text-white leading-tight mb-2">Watch an automation<br/><em class="font-medium" style="color:#E8B4B0;">execute — node by node</em></h2>
          <p class="text-[12px]" style="color:rgba(255,255,255,0.30);">Click any node to inspect its payload. Hit Run to watch it step through.</p>
        </div>
        <!-- Workflow template tabs -->
        <div class="flex gap-1 p-1 rounded-[12px] shrink-0" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);">
          {[{id:'lead',label:'Lead Nurture'},{id:'invoice',label:'Invoice Chase'},{id:'onboarding',label:'Onboarding'}].map((t,i)=>(
            <button class="wf-tab px-3.5 py-1.5 rounded-[9px] text-[11px] font-semibold transition-all" data-wf={t.id}
              style={i===0 ? 'background:#E8B4B0;color:#0A0A0A;' : 'color:rgba(255,255,255,0.40);'}>
              {t.label}
            </button>
          ))}
        </div>
      </div>

      <!-- Canvas -->
      <div class="max-w-4xl mx-auto rounded-[20px] overflow-hidden border" style="border-color:rgba(255,255,255,0.08);">

        <!-- Canvas toolbar -->
        <div class="flex items-center justify-between px-5 py-3 border-b" style="background:rgba(255,255,255,0.03);border-color:rgba(255,255,255,0.07);">
          <div class="flex items-center gap-3">
            <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,99,99,0.45);"></div>
              <div class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,189,68,0.45);"></div>
              <div class="w-2.5 h-2.5 rounded-full" style="background:rgba(45,196,68,0.45);"></div>
            </div>
            <span class="text-[10px] font-mono" style="color:rgba(255,255,255,0.25);" id="wf-tab-title">lead-nurture.workflow</span>
          </div>
          <div class="flex items-center gap-3">
            <div id="wf-exec-stats" class="hidden items-center gap-4">
              <span class="text-[10px]" style="color:rgba(255,255,255,0.35);" id="wf-stat-apis">0 API calls</span>
              <span class="text-[10px]" style="color:rgba(74,222,128,0.70);" id="wf-stat-time">0ms</span>
            </div>
            <span class="text-[10px] font-semibold" style="color:rgba(255,255,255,0.25);" id="wf-status-label">Ready</span>
            <button id="wf-run-btn" onclick="runWorkflow()"
              class="px-4 py-1.5 rounded-full text-[11px] font-bold transition-all"
              style="background:#E8B4B0;color:#0A0A0A;">
              ▶ Run
            </button>
          </div>
        </div>

        <!-- Workflow meta strip -->
        <div class="flex items-center gap-3 px-5 py-2.5 border-b flex-wrap" style="background:rgba(255,255,255,0.015);border-color:rgba(255,255,255,0.05);">
          <span class="text-[9.5px] font-mono" style="color:rgba(255,255,255,0.22);" id="wf-meta-nodes">6 nodes</span>
          <span style="color:rgba(255,255,255,0.10);">·</span>
          <span class="text-[9.5px] font-mono" style="color:rgba(255,255,255,0.22);">Manual: <strong id="wf-meta-manual" style="color:rgba(255,255,255,0.42);font-weight:600;">47 min/lead</strong></span>
          <span style="color:rgba(255,255,255,0.10);">·</span>
          <span class="text-[9.5px] font-mono" style="color:rgba(255,255,255,0.22);">Automated: <strong id="wf-meta-time" style="color:rgba(74,222,128,0.70);font-weight:600;">1.8s</strong></span>
          <span class="ml-auto text-[9.5px] font-mono" style="color:rgba(255,255,255,0.22);">Annual saving: <strong id="wf-meta-saving" style="color:rgba(232,180,176,0.80);font-weight:600;">£38,000/yr</strong></span>
        </div>

        <!-- Dot-grid canvas area -->
        <div class="relative px-5 py-8 overflow-x-auto" style="background:#0A0A09;background-image:radial-gradient(circle,rgba(255,255,255,0.06) 1px,transparent 1px);background-size:22px 22px;min-height:200px;">

          <!-- Nodes row -->
          <div class="flex items-stretch gap-0 min-w-[680px] relative" id="wf-nodes-row">
            <!-- nodes injected by JS -->
          </div>

          <!-- SVG connector layer (rendered behind nodes by JS) -->
          <svg id="wf-svg" class="absolute inset-0 pointer-events-none" style="z-index:0;"></svg>

        </div>

        <!-- Split bottom: log + payload -->
        <div class="grid grid-cols-1 lg:grid-cols-2 border-t" style="border-color:rgba(255,255,255,0.07);">

          <!-- Execution log -->
          <div class="px-5 py-4 border-r" style="border-color:rgba(255,255,255,0.07);min-height:160px;">
            <p class="text-[9px] uppercase tracking-[0.18em] font-bold mb-3" style="color:rgba(255,255,255,0.20);">Execution log</p>
            <div id="wf-log" class="space-y-1.5 font-mono text-[10.5px]">
              <p style="color:rgba(255,255,255,0.18);">› Waiting for trigger…</p>
            </div>
          </div>

          <!-- Payload inspector -->
          <div class="px-5 py-4" style="min-height:160px;">
            <div class="flex items-center justify-between mb-3">
              <p class="text-[9px] uppercase tracking-[0.18em] font-bold" style="color:rgba(255,255,255,0.20);">Payload inspector</p>
              <p class="text-[9px] font-mono" style="color:rgba(255,255,255,0.12);">click a node</p>
            </div>
            <div id="wf-payload" class="font-mono text-[10px] leading-relaxed" style="color:rgba(255,255,255,0.25);">
              <p>// Select a node to inspect its output</p>
            </div>
          </div>

        </div>

        <!-- Result bar -->
        <div id="wf-result-bar" class="hidden px-5 py-4 border-t flex flex-wrap items-center gap-6" style="border-color:rgba(255,255,255,0.07);background:rgba(45,80,22,0.12);">
          <div class="flex items-center gap-2">
            <span class="w-5 h-5 rounded-full flex items-center justify-center" style="background:rgba(74,222,128,0.20);">
              <svg class="w-3 h-3" style="color:#4ade80;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <span class="text-[12px] font-bold text-white" id="rb-title">Completed</span>
          </div>
          <div class="flex flex-wrap gap-5 text-[11px]" style="color:rgba(255,255,255,0.45);">
            <span><strong class="text-white" id="rb-time">—</strong> execution time</span>
            <span><strong class="text-white" id="rb-apis">—</strong> API calls</span>
            <span>Manual equivalent: <strong style="color:#E8B4B0;" id="rb-manual">—</strong></span>
            <span>Annual saving: <strong style="color:#4ade80;" id="rb-saving">—</strong></span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════
       SECTION 2 — LIVE SANDBOX
  ══════════════════════════════════════════════════════════════════════ -->
  <section id="sandbox" class="bg-brand-beige py-16 lg:py-24 border-t border-brand-gray-100" style="scroll-margin-top:80px;">
    <div class="container-x">
      <div class="max-w-4xl mx-auto mb-12">
        <p class="eyebrow mb-3">② Live sandbox</p>
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
          <div>
            <h2 class="font-display text-h2 mb-2">Trigger it yourself</h2>
            <p class="text-sm text-brand-gray-600 max-w-lg">Three real scenarios. Enter your data, hit trigger — watch the automation execute with live API feedback.</p>
          </div>
          <div class="flex items-center gap-3 lg:flex-col lg:items-end shrink-0">
            <div class="flex items-baseline gap-1.5">
              <p class="font-display text-2xl text-brand-black leading-none" id="sb-exec-count">0</p>
              <p class="text-[10px] uppercase tracking-wider text-brand-gray-500">executions</p>
            </div>
            <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full" style="background:rgba(45,80,22,0.07);">
              <span class="w-1.5 h-1.5 rounded-full bg-green-400" style="animation:dm-pulse 2s ease-in-out infinite;"></span>
              <span class="text-[9px] font-bold uppercase tracking-wider" style="color:#2D5016;">Live environment</span>
            </div>
          </div>
        </div>
      </div>

      <div class="max-w-4xl mx-auto space-y-6">

        <!-- ─ Sandbox 1: Lead capture ─────────────────────────────────── -->
        <div class="bg-white rounded-card border border-brand-gray-100 overflow-hidden">
          <div class="h-[2px]" style="background:linear-gradient(90deg,#E8B4B0 0%,rgba(232,180,176,0.15) 55%,transparent 100%);"></div>
          <div class="grid grid-cols-1 lg:grid-cols-2">

            <!-- Input side -->
            <div class="p-6 border-b lg:border-b-0 lg:border-r border-brand-gray-100">
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-[12px] flex items-center justify-center shrink-0" style="background:rgba(232,180,176,0.12);">
                  <!-- Custom: person with signal waves -->
                  <svg class="w-5 h-5" style="color:#c4847e;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                    <path d="M16.5 3.5a6 6 0 010 7M19.5 1a10 10 0 010 11"/>
                  </svg>
                </div>
                <div>
                  <p class="text-[10px] uppercase tracking-wider font-bold text-brand-gray-400">Lead capture</p>
                  <h3 class="font-display text-base text-brand-black">CRM sync + personalised email</h3>
                </div>
                <div class="ml-auto flex items-center gap-1.5 px-2.5 py-1 rounded-full" style="background:rgba(45,80,22,0.08);">
                  <svg class="w-3 h-3" style="color:#2D5016;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                  <span class="text-[10px] font-bold" style="color:#2D5016;">Live</span>
                </div>
              </div>

              <div class="space-y-2.5 mb-5">
                <div>
                  <label class="block text-[10px] uppercase tracking-wider font-semibold text-brand-gray-400 mb-1.5">Lead name</label>
                  <input id="sb1-name" type="text" placeholder="e.g. Alex Chen" class="w-full text-sm border border-brand-gray-200 rounded-[10px] px-3.5 py-2.5 outline-none focus:border-brand-black transition"/>
                </div>
                <div>
                  <label class="block text-[10px] uppercase tracking-wider font-semibold text-brand-gray-400 mb-1.5">Email address</label>
                  <input id="sb1-email" type="email" placeholder="alex@company.com" class="w-full text-sm border border-brand-gray-200 rounded-[10px] px-3.5 py-2.5 outline-none focus:border-brand-black transition"/>
                </div>
                <div>
                  <label class="block text-[10px] uppercase tracking-wider font-semibold text-brand-gray-400 mb-1.5">Company</label>
                  <input id="sb1-company" type="text" placeholder="Acme Corp" class="w-full text-sm border border-brand-gray-200 rounded-[10px] px-3.5 py-2.5 outline-none focus:border-brand-black transition"/>
                </div>
              </div>

              <!-- API call chain preview -->
              <div class="rounded-[10px] p-3.5 mb-4" style="background:#F7F7F5;border:1px solid #EBEBEB;">
                <div class="flex items-center justify-between mb-2.5">
                  <p class="text-[9px] uppercase tracking-wider font-bold text-brand-gray-400">Will execute</p>
                  <span class="text-[9px] font-mono text-brand-gray-400">4 API calls</span>
                </div>
                <div class="space-y-1.5">
                  {[
                    ['POST','HubSpot /contacts','Create contact','#7B68EE'],
                    ['POST','Gmail /send','Intro email','#c4847e'],
                    ['POST','Slack /chat.postMessage','Sales alert','#C89840'],
                    ['POST','n8n /scheduler','Queue follow-up','#2D5016']
                  ].map(([method,endpoint,desc,col])=>(
                    <div class="flex items-center gap-2">
                      <span class="text-[9px] font-bold px-1.5 py-0.5 rounded font-mono" style={`background:${col}18;color:${col};`}>{method}</span>
                      <span class="text-[10px] font-mono text-brand-gray-500 truncate flex-1">{endpoint}</span>
                      <span class="text-[9.5px] text-brand-gray-400 shrink-0">{desc}</span>
                    </div>
                  ))}
                </div>
              </div>

              <button onclick="runSandbox(1)" id="sb1-btn"
                class="w-full py-2.5 rounded-[10px] text-[12px] font-bold text-white transition-all flex items-center justify-center gap-2"
                style="background:#0A0A0A;">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                Trigger automation
              </button>
            </div>

            <!-- Output side -->
            <div class="p-6 flex flex-col" style="background:#FAFAF8;">
              <div class="flex items-center justify-between mb-4">
                <p class="text-[10px] uppercase tracking-wider font-bold text-brand-gray-400">Output preview</p>
                <span class="text-[9px] font-semibold px-2 py-0.5 rounded-full" style="background:rgba(232,180,176,0.12);color:#c4847e;">CRM + Email + Slack</span>
              </div>
              <div id="sb1-idle" class="flex-1 flex items-center justify-center">
                <div class="text-center">
                  <div class="w-10 h-10 rounded-full border-2 border-dashed border-brand-gray-200 flex items-center justify-center mx-auto mb-3">
                    <svg class="w-4 h-4 text-brand-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                  </div>
                  <p class="text-[11px] text-brand-gray-400">Trigger the automation to see live output</p>
                </div>
              </div>
              <div id="sb1-output" class="hidden flex-1 flex flex-col gap-3">
                <!-- Progress steps -->
                <div id="sb1-steps" class="space-y-2"></div>
                <!-- Email preview card -->
                <div id="sb1-email-card" class="hidden rounded-[12px] border border-brand-gray-200 overflow-hidden mt-2" style="animation:slideUp 0.4s ease-out;">
                  <div class="px-4 py-3 border-b border-brand-gray-100 bg-white">
                    <p class="text-[9px] uppercase tracking-wider font-bold text-brand-gray-400 mb-2">Email delivered</p>
                    <div class="space-y-1">
                      <div class="flex gap-2 text-[11px]"><span class="text-brand-gray-400 w-10">From</span><span class="font-medium text-brand-black">hello@purist.co</span></div>
                      <div class="flex gap-2 text-[11px]"><span class="text-brand-gray-400 w-10">To</span><span class="font-medium text-brand-black" id="sb1-to-field">—</span></div>
                      <div class="flex gap-2 text-[11px]"><span class="text-brand-gray-400 w-10">Re</span><span class="font-medium text-brand-black" id="sb1-subject-field">—</span></div>
                    </div>
                  </div>
                  <div class="px-4 py-3 bg-white">
                    <p class="text-[11px] text-brand-gray-700 leading-relaxed" id="sb1-body-field"></p>
                  </div>
                  <div class="px-4 py-2 border-t border-brand-gray-100 flex items-center gap-2" style="background:#F7F7F5;">
                    <div class="w-1.5 h-1.5 rounded-full bg-green-400"></div>
                    <p class="text-[10px] text-brand-gray-500">Delivered · Open tracked · 5-touch sequence queued</p>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- ─ Sandbox 2: AI Triage ────────────────────────────────────── -->
        <div class="bg-white rounded-card border border-brand-gray-100 overflow-hidden">
          <div class="h-[2px]" style="background:linear-gradient(90deg,#7B68EE 0%,rgba(123,104,238,0.15) 55%,transparent 100%);"></div>
          <div class="grid grid-cols-1 lg:grid-cols-2">

            <div class="p-6 border-b lg:border-b-0 lg:border-r border-brand-gray-100">
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-[12px] flex items-center justify-center shrink-0" style="background:rgba(123,104,238,0.10);">
                  <!-- Custom: brain/circuit icon -->
                  <svg class="w-5 h-5" style="color:#7B68EE;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/>
                  </svg>
                </div>
                <div>
                  <p class="text-[10px] uppercase tracking-wider font-bold text-brand-gray-400">Claude AI</p>
                  <h3 class="font-display text-base text-brand-black">Support ticket triage</h3>
                </div>
                <div class="ml-auto flex items-center gap-1.5 px-2.5 py-1 rounded-full" style="background:rgba(123,104,238,0.10);">
                  <span class="text-[10px] font-bold" style="color:#7B68EE;">AI-powered</span>
                </div>
              </div>

              <div class="mb-4">
                <label class="block text-[10px] uppercase tracking-wider font-semibold text-brand-gray-400 mb-1.5">Paste any support message</label>
                <textarea id="sb2-text" rows="5" placeholder="e.g. My payment failed and I can't access my account. I have a client demo in 2 hours — this is urgent."
                  class="w-full text-sm border border-brand-gray-200 rounded-[10px] px-3.5 py-2.5 outline-none focus:border-brand-black transition resize-none"></textarea>
              </div>

              <!-- Quick presets -->
              <p class="text-[10px] text-brand-gray-400 mb-2">Try a preset:</p>
              <div class="flex flex-wrap gap-1.5 mb-5">
                {[
                  ['Billing issue','My invoice is wrong, been charged twice this month.'],
                  ['Urgent access','System down, team of 12 can\'t log in. Launch in 1 hour.'],
                  ['General query','Can I change my plan? I need more seats.']
                ].map(([label,val])=>(
                  <button onclick={`document.getElementById('sb2-text').value='${val}';`}
                    class="text-[10px] font-medium px-2.5 py-1 rounded-full border border-brand-gray-200 hover:border-brand-black transition text-brand-gray-600">
                    {label}
                  </button>
                ))}
              </div>

              <button onclick="runSandbox(2)" id="sb2-btn"
                class="w-full py-2.5 rounded-[10px] text-[12px] font-bold text-white transition-all flex items-center justify-center gap-2"
                style="background:#0A0A0A;">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                Classify with Claude AI
              </button>
            </div>

            <div class="p-6 flex flex-col" style="background:#FAFAF8;">
              <div class="flex items-center justify-between mb-4">
                <p class="text-[10px] uppercase tracking-wider font-bold text-brand-gray-400">Classification result</p>
                <span class="text-[9px] font-semibold px-2 py-0.5 rounded-full" style="background:rgba(123,104,238,0.10);color:#7B68EE;">Claude AI · &lt;800ms</span>
              </div>
              <div id="sb2-idle" class="flex-1 flex items-center justify-center">
                <div class="text-center">
                  <div class="w-10 h-10 rounded-full border-2 border-dashed border-brand-gray-200 flex items-center justify-center mx-auto mb-3">
                    <svg class="w-4 h-4 text-brand-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  </div>
                  <p class="text-[11px] text-brand-gray-400">Classification will appear here</p>
                </div>
              </div>
              <div id="sb2-output" class="hidden flex-1 flex flex-col gap-3" style="animation:slideUp 0.4s ease-out;">
                <!-- Urgency + confidence -->
                <div class="flex items-center gap-3">
                  <div id="sb2-urgency-badge" class="flex-1 rounded-[10px] px-4 py-3 flex items-center gap-3">
                    <div id="sb2-urgency-dot" class="w-3 h-3 rounded-full shrink-0"></div>
                    <div>
                      <p class="text-[9px] uppercase tracking-wider font-bold opacity-60 mb-0.5">Urgency</p>
                      <p class="text-[14px] font-bold" id="sb2-urgency-text">—</p>
                    </div>
                  </div>
                  <div class="flex-1 rounded-[10px] px-4 py-3" style="background:#F3F3F0;">
                    <p class="text-[9px] uppercase tracking-wider font-bold text-brand-gray-400 mb-0.5">Confidence</p>
                    <p class="text-[14px] font-bold text-brand-black" id="sb2-confidence">—</p>
                  </div>
                </div>
                <!-- Details grid -->
                <div class="grid grid-cols-2 gap-2">
                  <div class="rounded-[10px] px-3 py-2.5" style="background:#F3F3F0;">
                    <p class="text-[9px] uppercase tracking-wider font-bold text-brand-gray-400 mb-0.5">Category</p>
                    <p class="text-[12px] font-semibold text-brand-black" id="sb2-category">—</p>
                  </div>
                  <div class="rounded-[10px] px-3 py-2.5" style="background:#F3F3F0;">
                    <p class="text-[9px] uppercase tracking-wider font-bold text-brand-gray-400 mb-0.5">Assigned to</p>
                    <p class="text-[12px] font-semibold text-brand-black" id="sb2-owner">—</p>
                  </div>
                  <div class="rounded-[10px] px-3 py-2.5" style="background:#F3F3F0;">
                    <p class="text-[9px] uppercase tracking-wider font-bold text-brand-gray-400 mb-0.5">SLA target</p>
                    <p class="text-[12px] font-semibold text-brand-black" id="sb2-sla">—</p>
                  </div>
                  <div class="rounded-[10px] px-3 py-2.5" style="background:#F3F3F0;">
                    <p class="text-[9px] uppercase tracking-wider font-bold text-brand-gray-400 mb-0.5">Sentiment</p>
                    <p class="text-[12px] font-semibold text-brand-black" id="sb2-sentiment">—</p>
                  </div>
                </div>
                <!-- Key phrases -->
                <div>
                  <p class="text-[9px] uppercase tracking-wider font-bold text-brand-gray-400 mb-1.5">Key phrases extracted</p>
                  <div id="sb2-phrases" class="flex flex-wrap gap-1.5"></div>
                </div>
                <!-- Ticket created -->
                <div class="rounded-[10px] border border-brand-gray-200 px-3 py-2.5 flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <div class="w-1.5 h-1.5 rounded-full bg-green-400"></div>
                    <span class="text-[11px] text-brand-gray-600">Zendesk ticket <strong class="text-brand-black" id="sb2-ticket">#—</strong> created</span>
                  </div>
                  <span class="text-[10px] text-brand-gray-400" id="sb2-elapsed">0ms</span>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- ─ Sandbox 3: Invoice ──────────────────────────────────────── -->
        <div class="bg-white rounded-card border border-brand-gray-100 overflow-hidden">
          <div class="h-[2px]" style="background:linear-gradient(90deg,#C89840 0%,rgba(200,152,64,0.15) 55%,transparent 100%);"></div>
          <div class="grid grid-cols-1 lg:grid-cols-2">

            <div class="p-6 border-b lg:border-b-0 lg:border-r border-brand-gray-100">
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-[12px] flex items-center justify-center shrink-0" style="background:rgba(200,152,64,0.12);">
                  <svg class="w-5 h-5" style="color:#C89840;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="12" y1="18" x2="12" y2="12"/>
                    <line x1="9" y1="15" x2="15" y2="15"/>
                  </svg>
                </div>
                <div>
                  <p class="text-[10px] uppercase tracking-wider font-bold text-brand-gray-400">Finance</p>
