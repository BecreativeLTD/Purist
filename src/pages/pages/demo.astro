                </div>
              </div>

              <div class="space-y-2.5 mb-5">
                <div class="grid grid-cols-2 gap-2.5">
                  <div>
                    <label class="block text-[10px] uppercase tracking-wider font-semibold text-brand-gray-400 mb-1.5">Client name</label>
                    <input id="sb3-client" type="text" placeholder="Acme Corp" class="w-full text-sm border border-brand-gray-200 rounded-[10px] px-3.5 py-2.5 outline-none focus:border-brand-black transition"/>
                  </div>
                  <div>
                    <label class="block text-[10px] uppercase tracking-wider font-semibold text-brand-gray-400 mb-1.5">Amount</label>
                    <div class="relative">
                      <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm text-brand-gray-400">£</span>
                      <input id="sb3-amount" type="number" placeholder="2400" class="w-full text-sm border border-brand-gray-200 rounded-[10px] pl-7 pr-3 py-2.5 outline-none focus:border-brand-black transition"/>
                    </div>
                  </div>
                </div>
                <div>
                  <label class="block text-[10px] uppercase tracking-wider font-semibold text-brand-gray-400 mb-1.5">Service description</label>
                  <input id="sb3-desc" type="text" placeholder="Automation build — Phase 1" class="w-full text-sm border border-brand-gray-200 rounded-[10px] px-3.5 py-2.5 outline-none focus:border-brand-black transition"/>
                </div>
                <div>
                  <label class="block text-[10px] uppercase tracking-wider font-semibold text-brand-gray-400 mb-1.5">Payment terms</label>
                  <select id="sb3-terms" class="w-full text-sm border border-brand-gray-200 rounded-[10px] px-3.5 py-2.5 outline-none focus:border-brand-black transition bg-white">
                    <option>Net 14</option><option>Net 30</option><option>Due on receipt</option>
                  </select>
                </div>
              </div>

              <button onclick="runSandbox(3)" id="sb3-btn"
                class="w-full py-2.5 rounded-[10px] text-[12px] font-bold text-white transition-all flex items-center justify-center gap-2"
                style="background:#0A0A0A;">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Generate invoice + sequence
              </button>
            </div>

            <div class="p-6 flex flex-col" style="background:#FAFAF8;">
              <div class="flex items-center justify-between mb-4">
                <p class="text-[10px] uppercase tracking-wider font-bold text-brand-gray-400">Invoice preview</p>
                <span class="text-[9px] font-semibold px-2 py-0.5 rounded-full" style="background:rgba(200,152,64,0.10);color:#C89840;">Xero · PDF · Chase</span>
              </div>
              <div id="sb3-idle" class="flex-1 flex items-center justify-center">
                <div class="text-center">
                  <div class="w-10 h-10 rounded-full border-2 border-dashed border-brand-gray-200 flex items-center justify-center mx-auto mb-3">
                    <svg class="w-4 h-4 text-brand-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  </div>
                  <p class="text-[11px] text-brand-gray-400">Invoice preview will render here</p>
                </div>
              </div>
              <div id="sb3-output" class="hidden flex-1 flex flex-col gap-3" style="animation:slideUp 0.4s ease-out;">
                <!-- Mini invoice -->
                <div class="rounded-[12px] border border-brand-gray-200 overflow-hidden bg-white">
                  <div class="px-4 py-3 flex items-center justify-between border-b border-brand-gray-100">
                    <div>
                      <p class="font-display text-base font-medium text-brand-black">PURIST</p>
                      <p class="text-[10px] text-brand-gray-400">purist.co · hello@purist.co</p>
                    </div>
                    <div class="text-right">
                      <p class="text-[9px] uppercase tracking-wider font-bold text-brand-gray-400">Invoice</p>
                      <p class="text-[13px] font-bold text-brand-black" id="inv-number">#INV-—</p>
                    </div>
                  </div>
                  <div class="px-4 py-3 border-b border-brand-gray-100">
                    <div class="grid grid-cols-2 gap-3">
                      <div>
                        <p class="text-[9px] uppercase tracking-wider font-bold text-brand-gray-400 mb-1">Bill to</p>
                        <p class="text-[12px] font-semibold text-brand-black" id="inv-client">—</p>
                      </div>
                      <div class="text-right">
                        <p class="text-[9px] uppercase tracking-wider font-bold text-brand-gray-400 mb-1">Due date</p>
                        <p class="text-[12px] font-semibold text-brand-black" id="inv-due">—</p>
                      </div>
                    </div>
                  </div>
                  <div class="px-4 py-3 border-b border-brand-gray-100">
                    <div class="flex items-center justify-between text-[11px]">
                      <span class="text-brand-gray-600" id="inv-desc">—</span>
                      <span class="font-bold text-brand-black" id="inv-amount">£—</span>
                    </div>
                  </div>
                  <div class="px-4 py-3 flex items-center justify-between">
                    <span class="text-[11px] font-bold text-brand-black">Total</span>
                    <span class="font-display text-lg text-brand-black" id="inv-total">£—</span>
                  </div>
                </div>
                <!-- Chase sequence -->
                <div>
                  <p class="text-[9px] uppercase tracking-wider font-bold text-brand-gray-400 mb-2">Chase sequence queued</p>
                  <div class="space-y-1.5">
                    {[['Day 0','Invoice sent','Delivered'],['Day 7','Polite reminder','Scheduled'],['Day 14','Escalation email','Scheduled'],['Day 30','Final notice','Scheduled']].map(([day,action,status])=>(
                      <div class="flex items-center gap-2 text-[10px]">
                        <span class="w-10 font-bold text-brand-gray-400 shrink-0">{day}</span>
                        <span class="flex-1 text-brand-gray-700">{action}</span>
                        <span class="px-1.5 py-0.5 rounded-full font-bold" style={status==='Delivered'?'background:rgba(45,80,22,0.10);color:#2D5016;':'background:rgba(200,152,64,0.10);color:#C89840;'}>{status}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════
       SECTION 3 — BOOK A CALL
  ══════════════════════════════════════════════════════════════════════ -->
  <section id="booking" class="bg-white py-16 lg:py-24 border-t border-brand-gray-100" style="scroll-margin-top:80px;">
    <div class="container-x">
      <div class="max-w-4xl mx-auto">

        <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">

          <!-- Left: form -->
          <div class="flex-1">
            <p class="eyebrow mb-3">③ Book a call</p>
            <h2 class="font-display text-h2 mb-3">We build yours live — on screen</h2>
            <p class="text-sm text-brand-gray-600 mb-10">3 questions. We arrive with your first automation already mapped. No slides, no sales pitch — just building.</p>

            <!-- Step indicators -->
            <div class="flex items-start gap-0 mb-10">
              {[{n:1,l:'Industry'},{n:2,l:'Bottleneck'},{n:3,l:'Team'},{n:4,l:'Book'}].map(({n,l},i)=>(
                <div class="flex items-start flex-1">
                  <div class="flex flex-col items-center shrink-0">
                    <div class="bk-dot w-7 h-7 rounded-full flex items-center justify-center text-[11px] font-bold transition-all duration-300 z-10" data-step={n}
                      style={n===1?'background:#0A0A0A;color:#fff;':'background:#F3F3F0;color:#9CA3AF;'}>
                      {n}
                    </div>
                    <p class="text-[8.5px] font-semibold mt-1.5 text-center leading-none tracking-wide" style="color:#C0BAB0;width:56px;">{l}</p>
                  </div>
                  {i < 3 && <div class="bk-line flex-1 h-0.5 transition-all duration-500 mt-3.5" data-after={n} style="background:#F3F3F0;"></div>}
                </div>
              ))}
            </div>

            <!-- Step 1 -->
            <div id="bk-1" class="bk-step">
              <h3 class="font-display text-lg mb-1">What's your industry?</h3>
              <p class="text-[12px] text-brand-gray-500 mb-5">We'll arrive with workflows built for your sector.</p>
              <div class="grid grid-cols-2 gap-2">

                <button class="bk-opt text-left px-4 py-3.5 rounded-[12px] border border-brand-gray-200 hover:border-brand-black transition flex items-center gap-3" data-step="1" data-val="Dental / Medical">
                  <span class="w-7 h-7 rounded-[8px] flex items-center justify-center shrink-0" style="background:#F3F3F0;">
                    <svg class="w-3.5 h-3.5 text-brand-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8 2 5 5 5 8c0 2.5 1 4.5 2 6l1 8h4v-5h2v5h4l1-8c1-1.5 2-3.5 2-6 0-3-3-6-7-6z"/></svg>
                  </span>
                  <span class="text-[12px] font-medium text-brand-black">Dental / Medical</span>
                </button>

                <button class="bk-opt text-left px-4 py-3.5 rounded-[12px] border border-brand-gray-200 hover:border-brand-black transition flex items-center gap-3" data-step="1" data-val="Real Estate">
                  <span class="w-7 h-7 rounded-[8px] flex items-center justify-center shrink-0" style="background:#F3F3F0;">
                    <svg class="w-3.5 h-3.5 text-brand-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                  </span>
                  <span class="text-[12px] font-medium text-brand-black">Real Estate</span>
                </button>

                <button class="bk-opt text-left px-4 py-3.5 rounded-[12px] border border-brand-gray-200 hover:border-brand-black transition flex items-center gap-3" data-step="1" data-val="Agency / Creative">
                  <span class="w-7 h-7 rounded-[8px] flex items-center justify-center shrink-0" style="background:#F3F3F0;">
                    <svg class="w-3.5 h-3.5 text-brand-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 011.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>
                  </span>
                  <span class="text-[12px] font-medium text-brand-black">Agency / Creative</span>
                </button>

                <button class="bk-opt text-left px-4 py-3.5 rounded-[12px] border border-brand-gray-200 hover:border-brand-black transition flex items-center gap-3" data-step="1" data-val="E-commerce">
                  <span class="w-7 h-7 rounded-[8px] flex items-center justify-center shrink-0" style="background:#F3F3F0;">
                    <svg class="w-3.5 h-3.5 text-brand-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                  </span>
                  <span class="text-[12px] font-medium text-brand-black">E-commerce</span>
                </button>

                <button class="bk-opt text-left px-4 py-3.5 rounded-[12px] border border-brand-gray-200 hover:border-brand-black transition flex items-center gap-3" data-step="1" data-val="SaaS / Tech">
                  <span class="w-7 h-7 rounded-[8px] flex items-center justify-center shrink-0" style="background:#F3F3F0;">
                    <svg class="w-3.5 h-3.5 text-brand-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                  </span>
                  <span class="text-[12px] font-medium text-brand-black">SaaS / Tech</span>
                </button>

                <button class="bk-opt text-left px-4 py-3.5 rounded-[12px] border border-brand-gray-200 hover:border-brand-black transition flex items-center gap-3" data-step="1" data-val="Finance">
                  <span class="w-7 h-7 rounded-[8px] flex items-center justify-center shrink-0" style="background:#F3F3F0;">
                    <svg class="w-3.5 h-3.5 text-brand-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                  </span>
                  <span class="text-[12px] font-medium text-brand-black">Finance</span>
                </button>

                <button class="bk-opt text-left px-4 py-3.5 rounded-[12px] border border-brand-gray-200 hover:border-brand-black transition flex items-center gap-3" data-step="1" data-val="Law Firm">
                  <span class="w-7 h-7 rounded-[8px] flex items-center justify-center shrink-0" style="background:#F3F3F0;">
                    <svg class="w-3.5 h-3.5 text-brand-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V2M4 6l4 8M20 6l-4 8M4 14h8M12 14h8"/><line x1="4" y1="6" x2="20" y2="6"/></svg>
                  </span>
                  <span class="text-[12px] font-medium text-brand-black">Law Firm</span>
                </button>

                <button class="bk-opt text-left px-4 py-3.5 rounded-[12px] border border-brand-gray-200 hover:border-brand-black transition flex items-center gap-3" data-step="1" data-val="Other">
                  <span class="w-7 h-7 rounded-[8px] flex items-center justify-center shrink-0" style="background:#F3F3F0;">
                    <svg class="w-3.5 h-3.5 text-brand-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  </span>
                  <span class="text-[12px] font-medium text-brand-black">Other</span>
                </button>

              </div>
            </div>

            <!-- Step 2 -->
            <div id="bk-2" class="bk-step hidden">
              <h3 class="font-display text-lg mb-1">Biggest bottleneck?</h3>
              <p class="text-[12px] text-brand-gray-500 mb-5">We'll solve this live on the call.</p>
              <div class="grid grid-cols-1 gap-2">
                {[
                  ['Following up with leads takes too long',  'M13 10V3L4 14h7v7l9-11h-7z', 'lead follow-up + CRM sync'],
                  ['Invoicing and cash collection is manual', 'M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8', 'invoice + 3-touch chase'],
                  ['Onboarding new clients is chaotic',       'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 7a4 4 0 100 8 4 4 0 000-8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75', '14-step onboarding sequence'],
                  ['Reporting eats half my Monday',           'M18 20V10M12 20V4M6 20v-6', 'weekly KPI auto-digest'],
                  ['Support volume is overwhelming us',       'M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z', 'AI ticket triage + routing'],
                ].map(([label, iconPath, hint]) => (
                  <button class="bk-opt text-left px-4 py-3.5 rounded-[12px] border border-brand-gray-200 hover:border-brand-black transition flex items-center gap-3 group" data-step="2" data-val={label}>
                    <span class="w-7 h-7 rounded-[8px] flex items-center justify-center shrink-0" style="background:#F3F3F0;">
                      <svg class="w-3.5 h-3.5 text-brand-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d={iconPath}/></svg>
                    </span>
                    <div>
                      <p class="text-[12px] font-medium text-brand-black leading-snug">{label}</p>
                      <p class="text-[10px] text-brand-gray-400 mt-0.5 group-hover:text-brand-gray-600 transition">→ We'll build: {hint}</p>
                    </div>
                  </button>
                ))}
              </div>
            </div>

            <!-- Step 3 -->
            <div id="bk-3" class="bk-step hidden">
              <h3 class="font-display text-lg mb-1">Team size and urgency?</h3>
              <p class="text-[12px] text-brand-gray-500 mb-5">Shapes the scope and starting point.</p>
              <div class="grid grid-cols-2 gap-2 mb-5">
                {[['1–5','Solo / micro'],['6–15','Small team'],['16–30','Growing'],['30+','Scale-up']].map(([n,sub])=>(
                  <button class="bk-opt text-left px-4 py-3.5 rounded-[12px] border border-brand-gray-200 hover:border-brand-black transition" data-step="3a" data-val={n+' people'}>
                    <p class="text-[13px] font-bold text-brand-black leading-none mb-0.5">{n}</p>
                    <p class="text-[10px] text-brand-gray-400">{sub}</p>
                  </button>
