    // Icon — bare, no background box
    html += '<div class="wf-node-icon">';
    html += '<svg viewBox="0 0 24 24" fill="none" stroke="' + node.textColor + '" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">' + paths + '</svg>';
    html += '</div>';
    // Type
    html += '<p class="wf-node-type" style="color:' + node.textColor + ';opacity:0.45;">' + node.type + '</p>';
    // Label
    html += '<p class="wf-node-label">' + node.label + '</p>';
    // Status
    html += '<div class="wf-node-status"><div class="node-dot"></div><span class="node-status-text">Idle</span></div>';
    html += '</div>';
    // Connector
    if (!isLast) {
      html += '<div class="wf-connector" id="conn-' + i + '"></div>';
    }
    html += '</div>';
    row.innerHTML += html;
  });
}

function inspectNode(idx) {
  var wf = WORKFLOWS[currentWf];
  var node = wf.nodes[idx];
  var el = document.getElementById('wf-payload');
  el.innerHTML = '<span style="color:#E8B4B0;">// ' + node.type + ': ' + node.label.replace('\n',' ') + ' output</span>\n' +
    JSON.stringify(JSON.parse(node.data), null, 2)
      .replace(/("[\w_]+"):/g, '<span style="color:#7B68EE;">$1</span>:')
      .replace(/:\s*(".*?")/g, ': <span style="color:#E8B4B0;">$1</span>')
      .replace(/:\s*(\d+\.?\d*)/g, ': <span style="color:#C89840;">$1</span>')
      .replace(/:\s*(true|false|null)/g, ': <span style="color:#4ade80;">$1</span>');
  el.style.whiteSpace = 'pre';
  el.style.color = 'rgba(255,255,255,0.55)';
}

// ── Run workflow ───────────────────────────────────────────────────────────

function runWorkflow() {
  if (wfRunning) return;
  wfRunning = true;

  var wf = WORKFLOWS[currentWf];
  var btn = document.getElementById('wf-run-btn');
  btn.textContent = '● Running';
  btn.style.background = 'rgba(232,180,176,0.20)';
  btn.style.color = '#E8B4B0';
  btn.disabled = true;

  document.getElementById('wf-status-label').textContent = 'Executing…';
  document.getElementById('wf-result-bar').classList.add('hidden');
  document.getElementById('wf-exec-stats').classList.add('hidden');
  document.getElementById('wf-log').innerHTML = '';
  document.getElementById('wf-payload').innerHTML = '<p style="color:rgba(255,255,255,0.18);">// Executing…</p>';

  // Reset nodes
  document.querySelectorAll('.wf-node-card').forEach(function(c) {
    c.classList.remove('running','done');
    var dot = c.querySelector('.node-dot');
    var lbl = c.querySelector('.node-status span');
    if (dot) dot.style.background = 'rgba(255,255,255,0.15)';
    if (lbl) { lbl.textContent = 'Idle'; lbl.style.color = 'rgba(255,255,255,0.25)'; }
  });
  document.querySelectorAll('.wf-connector').forEach(function(c) { c.classList.remove('done','running'); c.innerHTML = ''; });

  var delay = 0;
  var stepMs = 620;

  wf.nodes.forEach(function(node, i) {
    var startAt = delay + i * stepMs;

    // Activate node
    setTimeout(function() {
      var cards = document.querySelectorAll('.wf-node-card');
      var card = cards[i];
      if (!card) return;
      card.classList.add('running');
      var lbl = card.querySelector('.node-status-text');
      if (lbl) lbl.textContent = node.run;
      if (i > 0) {
        var conn = document.getElementById('conn-' + (i-1));
        if (conn) { conn.classList.add('running'); conn.classList.remove('done'); }
      }
    }, startAt);

    // Complete node
    setTimeout(function() {
      var cards = document.querySelectorAll('.wf-node-card');
      var card = cards[i];
      if (!card) return;
      card.classList.remove('running');
      card.classList.add('done');
      var lbl = card.querySelector('.node-status-text');
      if (lbl) lbl.textContent = node.done;

      if (i > 0) {
        var conn = document.getElementById('conn-' + (i-1));
        if (conn) { conn.classList.add('done'); conn.classList.remove('running'); }
      }

      // Log
      if (wf.logs[i]) {
        var p = document.createElement('p');
        p.style.color = wf.logs[i].color;
        p.style.animation = 'fadeLog 0.25s ease-out';
        p.textContent = wf.logs[i].text;
        document.getElementById('wf-log').appendChild(p);
      }

      // Auto-inspect last node
      if (i === wf.nodes.length - 1) {
        inspectNode(i);
      }
    }, startAt + 420);
  });

  // Final
  var totalDur = wf.nodes.length * stepMs + 450;
  setTimeout(function() {
    var apis = wf.apis;
    var statEl = document.getElementById('wf-exec-stats');
    statEl.classList.remove('hidden');
    statEl.style.display = 'flex';
    document.getElementById('wf-stat-apis').textContent = apis + ' API calls';
    document.getElementById('wf-stat-time').textContent = wf.time;

    document.getElementById('wf-status-label').textContent = 'Complete';
    var rb = document.getElementById('wf-result-bar');
    rb.classList.remove('hidden');
    rb.style.display = 'flex';
    document.getElementById('rb-time').textContent = wf.time;
    document.getElementById('rb-apis').textContent = apis + ' calls';
    document.getElementById('rb-manual').textContent = wf.manual;
    document.getElementById('rb-saving').textContent = wf.saving;

    btn.textContent = '↺ Run again';
    btn.style.background = '#E8B4B0';
    btn.style.color = '#0A0A0A';
    btn.disabled = false;
    btn.onclick = function() { wfRunning = false; runWorkflow(); };
    wfRunning = false;
  }, totalDur);
}

