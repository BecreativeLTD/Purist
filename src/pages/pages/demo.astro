// BOOKING — ROI + multi-step
// ══════════════════════════════════════════════════════════════════════════

var bkData = {};
var PAIN_LABEL = {
  'Following up with leads takes too long': 'Live build: lead follow-up + CRM sync sequence',
  'Invoicing and cash collection is manual': 'Live build: invoice generation + 3-touch chase',
  'Onboarding new clients is chaotic': 'Live build: 14-step client onboarding automation',
  'Reporting eats half my Monday': 'Live build: auto-generated weekly KPI digest',
  'Support volume is overwhelming us': 'Live build: Claude AI ticket triage + routing',
};
var IND_HRS = { 'Dental / Medical':18,'Real Estate':12,'Agency / Creative':14,'E-commerce':16,'SaaS / Tech':11,'Finance':10,'Law Firm':12,'Other':14 };

function updateROI() {
  var ind  = bkData['1'] || null;
  var size = bkData['3a'] || null;
  var pain = bkData['2'] || null;

  if (!ind && !size && !pain) return;

  var hrs = IND_HRS[ind] || 14;
  var sizeMap = { '1–5 people':0.5,'6–15 people':1,'16–30 people':2,'30+ people':3.5 };
  var mult = sizeMap[size] || 1;
  var weekHrs = Math.round(hrs * mult);
  var annualCost = weekHrs * 35 * 52;
  var saving = Math.round(annualCost * 0.70);
  var roi = (saving / 2400).toFixed(1);

  document.getElementById('roi-cost').textContent = '£' + (annualCost/1000).toFixed(0) + 'k/yr';
  document.getElementById('roi-saving').textContent = '£' + (saving/1000).toFixed(0) + 'k/yr';
  document.getElementById('roi-hours').textContent = weekHrs + 'h/wk';
  document.getElementById('roi-mult').textContent = roi + '×';
  // Progress bars — normalise relative to max plausible values
  var maxCost = 180000; var maxSave = 130000; var maxHrs = 120;
  document.getElementById('roi-bar-cost').style.width = Math.min(100, Math.round(annualCost/maxCost*100)) + '%';
  document.getElementById('roi-bar-saving').style.width = Math.min(100, Math.round(saving/maxSave*100)) + '%';
  document.getElementById('roi-bar-hours').style.width = Math.min(100, Math.round(weekHrs/maxHrs*100)) + '%';
}

document.querySelectorAll('.bk-opt').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var step = this.dataset.step;
    document.querySelectorAll('.bk-opt[data-step="' + step + '"]').forEach(function(b){ b.classList.remove('selected'); });
    this.classList.add('selected');
    bkData[step] = this.dataset.val;
    updateROI();

    var advance = { '1':2, '2':3, '3b':4 };
    if (advance[step]) {
      setTimeout(function() {
        var next = advance[step];
        document.querySelectorAll('.bk-step').forEach(function(s){ s.classList.add('hidden'); });
        document.getElementById('bk-' + next).classList.remove('hidden');

        document.querySelectorAll('.bk-dot').forEach(function(dot){
          var s = parseInt(dot.dataset.step);
          if (s < next) { dot.style.background='#2D5016'; dot.style.color='#fff'; dot.textContent='✓'; }
          else if (s === next) { dot.style.background='#0A0A0A'; dot.style.color='#fff'; dot.textContent=s; }
          else { dot.style.background='#F3F3F0'; dot.style.color='#9CA3AF'; dot.textContent=s; }
        });
        document.querySelectorAll('.bk-line').forEach(function(line){
          line.style.background = parseInt(line.dataset.after) < next ? '#2D5016' : '#F3F3F0';
        });

        if (next === 4 && bkData['2']) {
          var live = PAIN_LABEL[bkData['2']] || 'Live build: your #1 pain point automated on screen';
          document.getElementById('bk-agenda-live').textContent = live;
        }
      }, 200);
    }
  });
});
</script>
