  @keyframes topbar-pulse { 0%,100%{opacity:0.55} 50%{opacity:1} }

  .wf-node-card.running {
    border-color: rgba(232,180,176,0.22);
    box-shadow: 0 0 28px rgba(232,180,176,0.08);
  }
  .wf-node-card.done {
    border-color: rgba(45,80,22,0.28);
    background: rgba(45,80,22,0.03);
  }

  /* Icon — bare SVG, no bg box */
  .wf-node-icon {
    width: 20px; height: 20px;
    margin-bottom: 14px;
    transition: transform 0.3s;
  }
  .wf-node-icon svg { width: 100%; height: 100%; display: block; }
  .wf-node-card.running .wf-node-icon { animation: iconFloat 1.4s ease-in-out infinite; }
  @keyframes iconFloat { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-2px)} }

  /* Type label */
  .wf-node-type {
    font-size: 8.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 5px;
    transition: color 0.3s;
  }
  /* Name */
  .wf-node-label {
    font-size: 11.5px;
    font-weight: 600;
    color: rgba(255,255,255,0.82);
    line-height: 1.35;
    margin-bottom: 12px;
  }
  /* Status row */
  .wf-node-status {
    display: flex; align-items: center; gap: 5px;
    padding-top: 10px;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .node-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: rgba(255,255,255,0.12);
    flex-shrink: 0;
    transition: background 0.3s;
  }
  .node-status-text {
    font-size: 9px;
    color: rgba(255,255,255,0.22);
    transition: color 0.3s;
    font-weight: 500;
  }
  .wf-node-card.running .node-dot { background:#E8B4B0; animation:dot-pulse 1s ease-in-out infinite; }
  .wf-node-card.running .node-status-text { color:#E8B4B0; }
  .wf-node-card.done .node-dot { background:#4ade80; }
  .wf-node-card.done .node-status-text { color:rgba(74,222,128,0.75); }
  @keyframes dot-pulse { 0%,100%{opacity:0.5} 50%{opacity:1} }

  /* Connectors */
  .wf-connector {
    flex:1; height:5px; border-radius:99px;
    background:rgba(255,255,255,0.07);
    position:relative; margin-top:26px;
    min-width:14px; overflow:hidden;
    transition:background 0.4s;
  }
  .wf-connector::after {
    content:''; position:absolute; inset:0;
    background:linear-gradient(90deg,transparent 0%,rgba(255,255,255,0.10) 50%,transparent 100%);
    background-size:200% 100%;
    animation:conn-shimmer 2.5s ease-in-out infinite;
  }
  @keyframes conn-shimmer {
    0%   { background-position:200% 0; }
    100% { background-position:-200% 0; }
  }
  .wf-connector.running {
    background:rgba(232,180,176,0.18);
  }
  .wf-connector.running::after {
    background:linear-gradient(90deg,transparent 0%,#E8B4B0 50%,transparent 100%);
    background-size:200% 100%;
    animation:conn-flow 0.65s linear infinite;
    box-shadow:0 0 8px rgba(232,180,176,0.6);
  }
  @keyframes conn-flow {
    0%   { background-position:-200% 0; }
    100% { background-position: 200% 0; }
  }
  /* Done: solid green, subtle right-to-right fill */
  .wf-connector.done {
    background:rgba(45,80,22,0.45);
  }
  .wf-connector.done::after {
    background:linear-gradient(90deg,transparent 0%,rgba(74,222,128,0.25) 50%,transparent 100%);
    background-size:300% 100%;
    animation:conn-shimmer 3s ease-in-out infinite;
  }
</style>

