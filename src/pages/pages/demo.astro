function sbStep(text, color) {
  color = color || '#2D5016';
  var div = document.createElement('div');
  div.style.cssText = 'display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:8px;background:rgba(45,80,22,0.06);border:1px solid rgba(45,80,22,0.12);font-size:11px;color:#374151;animation:slideUp 0.3s ease-out;';
  div.innerHTML = '<div style="width:6px;height:6px;border-radius:50%;background:' + color + ';flex-shrink:0;"></div><span>' + text + '</span>';
  return div;
}

function setBtnLoading(btn) {
  btn.disabled = true;
  btn.style.opacity = '0.6';
  btn.innerHTML = '<svg class="w-3.5 h-3.5 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6-8.5"/></svg> Running…';
}

function setBtnDone(btn, label) {
  btn.disabled = false;
  btn.style.opacity = '1';
  btn.innerHTML = '✓ ' + label;
  sbCount++;
  document.getElementById('sb-exec-count').textContent = sbCount;
}

function runSandbox(id) {
  var btn = document.getElementById('sb' + id + '-btn');
  setBtnLoading(btn);

  if (id === 1) {
    var name    = document.getElementById('sb1-name').value.trim()    || 'Alex Chen';
    var email   = document.getElementById('sb1-email').value.trim()   || 'alex@example.com';
    var company = document.getElementById('sb1-company').value.trim() || 'Acme Corp';

    document.getElementById('sb1-idle').classList.add('hidden');
    document.getElementById('sb1-output').classList.remove('hidden');
    document.getElementById('sb1-email-card').classList.add('hidden');
    var steps = document.getElementById('sb1-steps');
    steps.innerHTML = '';

    var seq = [
      [380,  '✓ HubSpot: Contact "' + name + '" created (id: ' + (78000+Math.floor(Math.random()*999)) + ')', '#7B68EE'],
      [850,  '✓ Gmail: Intro email dispatched → ' + email, '#E8B4B0'],
      [1300, '✓ Slack: Sales team notified — @lead-owner assigned', '#C89840'],
      [1700, '✓ Scheduler: 5-touch follow-up sequence queued (T+1, 3, 7, 14, 30 days)', '#2D5016'],
    ];
    seq.forEach(function(s) {
      setTimeout(function() { steps.appendChild(sbStep(s[1], s[2])); }, s[0]);
    });
    setTimeout(function() {
      var card = document.getElementById('sb1-email-card');
      document.getElementById('sb1-to-field').textContent = email;
      document.getElementById('sb1-subject-field').textContent = 'Welcome to PURIST, ' + name.split(' ')[0] + ' — your onboarding starts here';
      document.getElementById('sb1-body-field').textContent = 'Hi ' + name.split(' ')[0] + ',\n\nWe\'ve just set up your profile in our system. I\'m Jamie, your account lead — I\'ll be reaching out in the next 24 hours to map your first automation.\n\nIn the meantime, here\'s a link to our onboarding pack.\n\nBest,\nJamie @ PURIST';
      card.classList.remove('hidden');
      setBtnDone(btn, 'Run again');
    }, 2100);
  }

  if (id === 2) {
    var text = document.getElementById('sb2-text').value.trim();
    if (!text || text.length < 8) {
      text = "My payment failed and I can't access my account. I have a client demo in 2 hours — this is urgent.";
      document.getElementById('sb2-text').value = text;
    }
    document.getElementById('sb2-idle').classList.add('hidden');
    document.getElementById('sb2-output').classList.add('hidden');

    var urgency, urgColor, bgColor, category, owner, sla, sentiment, confidence;
    if (/urgent|asap|now|deadline|critical|immediately|hour|minutes/i.test(text)) {
      urgency='Urgent'; urgColor='#dc2626'; bgColor='rgba(220,38,38,0.08)'; confidence = Math.floor(Math.random()*6)+91+'%'; sla='2 hours';
    } else if (/problem|issue|broken|fail|wrong|not working/i.test(text)) {
      urgency='Medium'; urgColor='#C89840'; bgColor='rgba(200,152,64,0.08)'; confidence = Math.floor(Math.random()*8)+84+'%'; sla='8 hours';
    } else {
      urgency='Low'; urgColor='#2D5016'; bgColor='rgba(45,80,22,0.08)'; confidence = Math.floor(Math.random()*6)+88+'%'; sla='24 hours';
    }
    if (/payment|invoice|billing|charge|refund|money/i.test(text)) { category='Billing'; owner='Finance Support'; }
    else if (/account|access|login|password|locked/i.test(text)) { category='Account Access'; owner='Identity Team'; }
    else if (/bug|crash|error|down|broken|not working/i.test(text)) { category='Technical'; owner='Engineering'; }
    else if (/plan|upgrade|downgrade|seat|pricing/i.test(text)) { category='Sales'; owner='Account Manager'; }
    else { category='General'; owner='Support Queue'; }
    sentiment = /angry|furious|disappointed|terrible|awful|worst/i.test(text) ? 'Negative 😠' : /urgent|critical|deadline/i.test(text) ? 'Frustrated 😰' : 'Neutral 😐';

    // Extract phrases
    var words = text.match(/\b[a-zA-Z]{4,}\b/g) || [];
    var stop = ['that','this','with','have','from','they','will','your','just','been','more','also','were','what','when'];
    var phrases = words.filter(function(w){ return stop.indexOf(w.toLowerCase()) === -1; }).slice(0, 5);

    var t = Math.floor(Math.random()*200)+280;

    setTimeout(function() {
      var out = document.getElementById('sb2-output');
      out.classList.remove('hidden');
      document.getElementById('sb2-urgency-badge').style.background = bgColor;
      document.getElementById('sb2-urgency-dot').style.background = urgColor;
      document.getElementById('sb2-urgency-text').textContent = urgency;
      document.getElementById('sb2-urgency-text').style.color = urgColor;
      document.getElementById('sb2-confidence').textContent = confidence;
      document.getElementById('sb2-category').textContent = category;
      document.getElementById('sb2-owner').textContent = owner;
      document.getElementById('sb2-sla').textContent = sla;
      document.getElementById('sb2-sentiment').textContent = sentiment;
      document.getElementById('sb2-ticket').textContent = '#' + (4000+Math.floor(Math.random()*999));
      document.getElementById('sb2-elapsed').textContent = t + 'ms';
      var phEl = document.getElementById('sb2-phrases');
      phEl.innerHTML = '';
      phrases.forEach(function(p) {
        phEl.innerHTML += '<span style="display:inline-block;padding:2px 8px;border-radius:99px;font-size:10px;font-weight:600;background:rgba(123,104,238,0.10);color:#7B68EE;margin:2px;">' + p + '</span>';
      });
      setBtnDone(btn, 'Classify again');
    }, 800);
  }

  if (id === 3) {
    var client  = document.getElementById('sb3-client').value.trim()  || 'Acme Corp';
    var amount  = document.getElementById('sb3-amount').value.trim()  || '2400';
    var desc    = document.getElementById('sb3-desc').value.trim()    || 'Automation build — Phase 1';
    var terms   = document.getElementById('sb3-terms').value;
    var invNum  = 'INV-' + (2000+Math.floor(Math.random()*999));
    var today   = new Date();
    var daysAdd = terms === 'Net 14' ? 14 : terms === 'Net 30' ? 30 : 0;
    var due     = new Date(today.getTime() + daysAdd*86400000);
    var dueStr  = due.toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'});

    document.getElementById('sb3-idle').classList.add('hidden');
    document.getElementById('sb3-output').classList.remove('hidden');
    document.getElementById('inv-number').textContent = invNum;
    document.getElementById('inv-client').textContent = client;
    document.getElementById('inv-due').textContent = dueStr;
    document.getElementById('inv-desc').textContent = desc;
    document.getElementById('inv-amount').textContent = '£' + parseFloat(amount).toLocaleString('en-GB');
    document.getElementById('inv-total').textContent = '£' + parseFloat(amount).toLocaleString('en-GB');

    setTimeout(function() { setBtnDone(btn, 'Generate another'); }, 1200);
  }
}

