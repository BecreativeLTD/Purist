  .wf-node-card {
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.025);
    padding: 18px 16px 14px;
    min-width: 118px;
    cursor: pointer;
    transition: border-color 0.35s ease, box-shadow 0.35s ease, background 0.35s ease;
    position: relative;
    overflow: hidden;
  }
  .wf-node-card:hover {
    border-color: rgba(255,255,255,0.14);
    background: rgba(255,255,255,0.04);
  }
  /* Top accent bar */
  .wf-node-topbar {
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    border-radius: 18px 18px 0 0;
    transition: opacity 0.3s;
    opacity: 0;
  }
  .wf-node-card.running .wf-node-topbar {
    opacity: 1;
    background: linear-gradient(90deg, #E8B4B0, #c4847e);
    animation: topbar-pulse 1.2s ease-in-out infinite;
  }
  .wf-node-card.done .wf-node-topbar {
    opacity: 1;
    background: linear-gradient(90deg, #2D5016, #4ade80);
