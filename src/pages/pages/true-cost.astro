---
import ShopLayout from '~/layouts/ShopLayout.astro';
---

<ShopLayout
  title="The True Cost of Manual Work — Live Counter | PURIST"
  description="Watch in real time how much money UK businesses are losing right now to manual processes. The most expensive thing you're not tracking."
  canonical="https://purist.online/pages/true-cost"
>

<!-- Hero -->
<section class="bg-brand-black text-white pt-20 pb-10 lg:pt-28 relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 50% 0%,rgba(239,68,68,0.07) 0%,transparent 60%);"></div>
  <div class="container-x relative z-10 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border mb-6" style="border-color:rgba(239,68,68,0.25);background:rgba(239,68,68,0.06);">
      <span class="w-1.5 h-1.5 rounded-full bg-red-400" style="animation:tc-pulse 1s ease-in-out infinite;"></span>
      <span class="text-[10px] uppercase tracking-[0.18em] font-semibold text-red-400">Live · Updating every second</span>
    </div>
    <h1 class="font-display text-[2.2rem] lg:text-[3.2rem] leading-[1.06] tracking-[-0.025em] text-white mb-4 max-w-3xl mx-auto">
      Every second you wait,<br/><em class="font-medium text-red-400">your business loses money.</em>
    </h1>
    <p class="text-[15px] max-w-xl mx-auto leading-relaxed mb-4" style="color:rgba(255,255,255,0.40);">
      The counter below shows what UK businesses collectively lose to manual work right now. Then pick your industry and see your personal number.
    </p>
  </div>
</section>

<!-- Big live counter -->
<section class="bg-brand-black pb-0 relative">
  <div class="container-x">
    <div class="max-w-3xl mx-auto">

      <!-- Global counter -->
      <div class="rounded-[24px] border overflow-hidden mb-6" style="background:rgba(239,68,68,0.04);border-color:rgba(239,68,68,0.15);">
        <div class="h-0.5" style="background:linear-gradient(90deg,#ef4444,rgba(239,68,68,0.20),transparent);"></div>
        <div class="px-6 pt-6 pb-4 text-center">
          <p class="text-[10px] uppercase tracking-[0.22em] font-bold mb-2 text-red-400 opacity-70">UK businesses losing to manual work — right now</p>
          <p class="font-display leading-none mb-1" style="font-size:clamp(2.4rem,8vw,4.5rem);color:#ef4444;" id="tc-global">£0</p>
          <p class="text-[11px]" style="color:rgba(255,255,255,0.20);">since you opened this page · <span id="tc-seconds">0</span>s ago</p>
        </div>
        <div class="grid grid-cols-3 border-t" style="border-color:rgba(239,68,68,0.10);">
          {[
            {id:'tc-per-sec',  label:'per second'},
            {id:'tc-per-min',  label:'per minute'},
            {id:'tc-per-hour', label:'per hour'},
          ].map(({id,label},i)=>(
            <div class={`px-4 py-3 text-center${i<2?' border-r':''}`} style="border-color:rgba(239,68,68,0.10);">
              <p class="font-display text-lg leading-none text-white mb-0.5" id={id}>£0</p>
              <p class="text-[9px] uppercase tracking-wider" style="color:rgba(255,255,255,0.20);">{label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Industry selector -->
      <div class="rounded-[20px] border p-5 mb-6" style="background:rgba(255,255,255,0.025);border-color:rgba(255,255,255,0.07);">
        <p class="text-[9px] uppercase tracking-[0.2em] font-bold mb-4 text-center" style="color:rgba(255,255,255,0.25);">Now calculate YOUR industry's cost</p>
        <div class="grid grid-cols-3 gap-2">
          {[
            ['dental',     'Dental',      '£4,800/mo'],
            ['agency',     'Agency',      '£5,200/mo'],
            ['ecom',       'E-commerce',  '£6,800/mo'],
            ['realestate', 'Real Estate', '£4,200/mo'],
            ['saas',       'SaaS',        '£3,800/mo'],
            ['finance',    'Finance',     '£5,600/mo'],
          ].map(([id, label, avg], i)=>(
            <button class="tc-ind px-3 py-3 rounded-[12px] border text-center transition-all" data-tcid={id}
              style={i===0?'background:rgba(239,68,68,0.15);border-color:rgba(239,68,68,0.40);':'background:rgba(255,255,255,0.03);border-color:rgba(255,255,255,0.07);'}>
              <p class="text-[11px] font-semibold mb-0.5" style={i===0?'color:#fff;':'color:rgba(255,255,255,0.55);'}>{label}</p>
              <p class="text-[9px]" style={i===0?'color:rgba(255,255,255,0.45);':'color:rgba(255,255,255,0.20);'}>{avg} avg</p>
            </button>
          ))}
        </div>
      </div>

      <!-- Personal counter -->
      <div class="rounded-[24px] border overflow-hidden mb-10" style="background:rgba(255,255,255,0.02);border-color:rgba(255,255,255,0.07);">
        <div class="h-0.5" style="background:linear-gradient(90deg,#E8B4B0,rgba(232,180,176,0.20),transparent);"></div>
        <div class="px-6 pt-6 pb-4 text-center">
          <p class="text-[10px] uppercase tracking-[0.22em] font-bold mb-2" style="color:rgba(232,180,176,0.55);" id="tc-ind-label">Dental practice cost — since you opened this page</p>
          <p class="font-display leading-none mb-1" style="font-size:clamp(2rem,6vw,3.5rem);color:#E8B4B0;" id="tc-personal">£0</p>
          <div class="flex items-center justify-center gap-4 text-[10px] mt-2" style="color:rgba(255,255,255,0.25);">
            <span>Yearly: <strong class="text-white" id="tc-personal-yr">£0</strong></span>
            <span>Monthly: <strong class="text-white" id="tc-personal-mo">£0</strong></span>
          </div>
        </div>
        <!-- What this could be -->
        <div class="px-6 pb-5 border-t pt-4" style="border-color:rgba(255,255,255,0.05);">
          <p class="text-[9px] uppercase tracking-wider font-bold mb-3 text-center" style="color:rgba(255,255,255,0.18);">What that cost could fund instead</p>
          <div class="grid grid-cols-3 gap-3" id="tc-alternatives"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- What is manual work actually costing? -->
<section class="bg-[#0C0C0A] py-14 lg:py-20 border-t" style="border-color:rgba(255,255,255,0.06);">
  <div class="container-x">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12 scroll-fade">
        <p class="text-[9px] uppercase tracking-[0.2em] font-bold mb-3" style="color:rgba(232,180,176,0.50);">The real breakdown</p>
        <h2 class="font-display text-[1.8rem] text-white mb-3">Where the time actually goes</h2>
        <p class="text-[14px] max-w-xl mx-auto" style="color:rgba(255,255,255,0.40);">We've tracked 312+ automation deployments. These are the real numbers.</p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        {[
          { task:'Email triage & response drafting', pct:22, hrs:'8.8h/wk', col:'#E8B4B0' },
          { task:'CRM data entry & contact updates', pct:18, hrs:'7.2h/wk', col:'#7B68EE' },
          { task:'Invoice creation, chasing, reconciling', pct:15, hrs:'6.0h/wk', col:'#C89840' },
          { task:'Reporting: pulling data, building decks', pct:20, hrs:'8.0h/wk', col:'#4ade80' },
          { task:'Client onboarding & setup',            pct:12, hrs:'4.8h/wk', col:'#E8B4B0' },
          { task:'Scheduling & appointment management',  pct:13, hrs:'5.2h/wk', col:'#7B68EE' },
        ].map(({task,pct,hrs,col})=>(
          <div class="rounded-[16px] border p-5 scroll-fade" style="background:rgba(255,255,255,0.02);border-color:rgba(255,255,255,0.06);">
            <div class="flex items-start justify-between gap-3 mb-3">
              <p class="text-[12px] font-medium leading-snug" style="color:rgba(255,255,255,0.70);">{task}</p>
              <span class="shrink-0 text-[11px] font-bold" style={`color:${col};`}>{pct}%</span>
            </div>
            <div class="h-1 rounded-full overflow-hidden mb-2" style="background:rgba(255,255,255,0.06);">
              <div class="h-full rounded-full" style={`width:${pct}%;background:${col};`}></div>
            </div>
            <p class="text-[10px]" style="color:rgba(255,255,255,0.25);">{hrs} average per 40hr business</p>
          </div>
        ))}
      </div>
      <div class="mt-6 p-5 rounded-[16px] border text-center scroll-fade" style="background:rgba(232,180,176,0.04);border-color:rgba(232,180,176,0.12);">
        <p class="text-white text-[14px] font-medium">Total: <strong style="color:#E8B4B0;">40 hours per week</strong> — that's an entire full-time employee doing nothing but admin.</p>
        <p class="text-[11px] mt-1" style="color:rgba(255,255,255,0.30);">At £35/hr blended rate = £72,800/yr. Minimum.</p>
      </div>
    </div>
  </div>
</section>

<!-- The compound effect -->
<section class="bg-white py-16 lg:py-20 border-t border-brand-gray-100">
  <div class="container-x">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12 scroll-fade">
        <p class="eyebrow mb-3">The compound effect</p>
        <h2 class="font-display text-h2 mb-3">Every year you wait, it gets worse</h2>
        <p class="text-sm text-brand-gray-600 max-w-lg mx-auto">Manual work doesn't stay flat. As your business grows, admin grows faster — unless you automate.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-4 scroll-fade">
        {[
          { yr:'Year 1', team:5,  hrs:20, cost:'£36k',  col:'rgba(239,68,68,0.30)' },
          { yr:'Year 2', team:10, hrs:40, cost:'£73k',  col:'rgba(239,68,68,0.50)' },
          { yr:'Year 3', team:20, hrs:80, cost:'£145k', col:'rgba(239,68,68,0.75)' },
          { yr:'Year 4', team:35, hrs:140,cost:'£254k', col:'#ef4444' },
        ].map(({yr,team,hrs,cost,col})=>(
          <div class="rounded-[16px] border border-brand-gray-100 p-5 text-center">
            <p class="text-[10px] uppercase tracking-wider font-bold text-brand-gray-400 mb-3">{yr}</p>
            <div class="mx-auto mb-3 rounded-lg flex items-end justify-center" style={`height:80px;background:${col};width:100%;border-radius:8px;`}></div>
            <p class="font-display text-xl text-brand-black leading-none mb-1">{cost}</p>
            <p class="text-[10px] text-brand-gray-500">{team} people · {hrs}h/wk</p>
          </div>
        ))}
      </div>

      <div class="mt-6 grid grid-cols-1 lg:grid-cols-2 gap-6 scroll-fade">
        <div class="rounded-[16px] border border-red-100 p-6" style="background:rgba(239,68,68,0.03);">
          <p class="text-[10px] uppercase tracking-wider font-bold mb-3" style="color:rgba(239,68,68,0.60);">Without automation — 4 years</p>
          <p class="font-display text-3xl text-brand-black mb-1">£508,000</p>
          <p class="text-[11px] text-brand-gray-500">total manual work cost · still growing</p>
        </div>
        <div class="rounded-[16px] border p-6" style="border-color:rgba(74,222,128,0.20);background:rgba(74,222,128,0.03);">
          <p class="text-[10px] uppercase tracking-wider font-bold mb-3" style="color:rgba(74,222,128,0.60);">With PURIST — 4 years</p>
          <p class="font-display text-3xl text-brand-black mb-1">£57,600</p>
          <p class="text-[11px] text-brand-gray-500">total plan cost · saving compounds annually</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="bg-brand-black py-16 border-t" style="border-color:rgba(255,255,255,0.06);">
  <div class="container-x">
    <div class="max-w-xl mx-auto text-center scroll-fade">
      <h2 class="font-display text-[1.8rem] text-white mb-3">Stop watching the counter go up.</h2>
      <p class="text-[14px] mb-8" style="color:rgba(255,255,255,0.40);">In 45 minutes, we'll map every manual process in your business and show you exactly what to automate first.</p>
      <a href="/pages/welcome"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-button text-[14px] font-bold transition"
        style="background:#E8B4B0;color:#0A0A0A;">
        Stop the leak — book my free audit
        <svg class="w-4 h-4" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M2 7h10M8 3l4 4-4 4"/></svg>
      </a>
      <p class="text-[10px] mt-3" style="color:rgba(255,255,255,0.18);">Free · 45 minutes · No commitment required</p>
    </div>
  </div>
</section>

</ShopLayout>

<style is:global>
  @keyframes tc-pulse { 0%,100%{opacity:0.5;transform:scale(1)} 50%{opacity:1;transform:scale(1.5)} }
</style>

<script is:inline>
(function(){
  // UK estimate: ~3.5M businesses, avg 40h/wk manual work, £35/hr
  // Total annual = 3.5M * 40 * 35 * 52 ≈ £254B/yr
  // Per second = £254B / (52 * 5 * 8 * 3600) ≈ £33,900/sec
  var GLOBAL_PER_SEC = 33900;

  var IND_DATA = {
    dental:     { label:'Dental practices',     perSec:0.0058, mo:4800,  yr:57600 },
    agency:     { label:'Agencies',             perSec:0.0069, mo:5200,  yr:62400 },
    ecom:       { label:'E-commerce brands',    perSec:0.0089, mo:6800,  yr:81600 },
    realestate: { label:'Real estate agencies', perSec:0.0048, mo:4200,  yr:50400 },
    saas:       { label:'SaaS companies',       perSec:0.0042, mo:3800,  yr:45600 },
    finance:    { label:'Finance firms',        perSec:0.0073, mo:5600,  yr:67200 },
  };

  var ALTERNATIVES = {
    dental:     [['1 extra nurse',    '£28k/yr'],['360 new patients',  '(£135 avg)'],['36 staff days',  '(bank holidays)']],
    agency:     [['1 account exec',  '£32k/yr'],['310 billable days',  '(£200/day)'],['2 new offices',   '']],
    ecom:       [['1 full-time VA',  '£24k/yr'],['2,300 orders',       '(£35 avg)' ],['Paid ads — 8mo', '']],
    realestate: [['1 extra agent',   '£25k/yr'],['210 viewings',       '(£200 each)'],['5 new listings', '']],
    saas:       [['1 junior dev',    '£32k/yr'],['480 new seats',      '(£80/mo)'  ],['12 feature sprints', '']],
    finance:    [['1 analyst',       '£38k/yr'],['1,400 client hours', '(£40/hr)'  ],['3 new client wins', '']],
  };

  var startTime = Date.now();
  var currentInd = 'dental';

  function fmt(n) {
    if (n >= 1000000) return '£' + (n/1000000).toFixed(2) + 'M';
    if (n >= 1000)    return '£' + (n/1000).toFixed(1) + 'k';
    return '£' + n.toFixed(2);
  }
  function fmtInt(n) {
    if (n >= 1000000) return '£' + Math.round(n/1000) + 'k';
    return '£' + Math.round(n).toLocaleString('en-GB');
  }

  function tick() {
    var elapsed = (Date.now() - startTime) / 1000;
    var globalTotal = GLOBAL_PER_SEC * elapsed;
    var ind = IND_DATA[currentInd];
    var personalTotal = ind.perSec * elapsed;

    document.getElementById('tc-global').textContent = fmtInt(globalTotal);
    document.getElementById('tc-seconds').textContent = Math.floor(elapsed);
    document.getElementById('tc-per-sec').textContent = '£' + GLOBAL_PER_SEC.toLocaleString('en-GB');
    document.getElementById('tc-per-min').textContent = '£' + (GLOBAL_PER_SEC * 60).toLocaleString('en-GB');
    document.getElementById('tc-per-hour').textContent = '£' + (GLOBAL_PER_SEC * 3600).toLocaleString('en-GB');

    document.getElementById('tc-personal').textContent = '£' + personalTotal.toFixed(2);
    document.getElementById('tc-personal-yr').textContent = '£' + ind.yr.toLocaleString('en-GB');
    document.getElementById('tc-personal-mo').textContent = '£' + ind.mo.toLocaleString('en-GB');
    document.getElementById('tc-ind-label').textContent = ind.label.replace('s','') + ' cost — since you opened this page';
  }

  function renderAlternatives(id) {
    var alts = ALTERNATIVES[id];
    var el = document.getElementById('tc-alternatives');
    if (!el || !alts) return;
    el.innerHTML = alts.map(function(a) {
      return '<div class="text-center">' +
        '<p class="text-[12px] font-semibold text-white leading-snug">' + a[0] + '</p>' +
        '<p class="text-[9px] mt-0.5" style="color:rgba(255,255,255,0.25);">' + a[1] + '</p>' +
      '</div>';
    }).join('');
  }

  document.querySelectorAll('.tc-ind').forEach(function(btn) {
    btn.addEventListener('click', function() {
      currentInd = this.dataset.tcid;
      document.querySelectorAll('.tc-ind').forEach(function(b) {
        b.style.background = 'rgba(255,255,255,0.03)';
        b.style.borderColor = 'rgba(255,255,255,0.07)';
        b.querySelectorAll('p').forEach(function(p) { p.style.color = ''; });
      });
      this.style.background = 'rgba(239,68,68,0.15)';
      this.style.borderColor = 'rgba(239,68,68,0.40)';
      var ps = this.querySelectorAll('p');
      if (ps[0]) ps[0].style.color = '#fff';
      if (ps[1]) ps[1].style.color = 'rgba(255,255,255,0.45)';
      renderAlternatives(currentInd);
    });
  });

  renderAlternatives('dental');
  setInterval(tick, 100);
  tick();
})();
</script>
