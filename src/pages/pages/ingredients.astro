    tag: 'Healthcare',
    pain: 'Manual patient intake, missed recall reminders, billing by hand',
    workflows: ['Appointment reminders', 'Recall campaigns', 'Billing & insurance', 'Patient intake forms', 'Review requests'],
    stats: [
