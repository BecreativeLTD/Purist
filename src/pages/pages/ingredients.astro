    name: 'Real Estate',
    tag: 'Property',
    pain: 'Slow lead response, manual CRM updates, listing distribution by hand',
    workflows: ['Lead capture & routing', 'CRM auto-sync', 'Listing alerts', 'Follow-up sequences', 'Contract reminders'],
    stats: [
      { v: '8h', l: 'saved / week' },
      { v: '3×', l: 'faster response' },
      { v: '100%', l: 'lead capture' },
    ],
  },
  {
    icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
    name: 'Law Firms',
    tag: 'Legal',
    pain: 'Email-based matter intake, manual time logging, slow invoice generation',
    workflows: ['Matter intake forms', 'Time auto-tracking', 'Invoice generation', 'Deadline reminders', 'Document routing'],
    stats: [
      { v: '15h', l: 'saved / week' },
      { v: '100%', l: 'billable capture' },
      { v: '4 days', l: 'faster payment' },
    ],
  },
  {
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
    name: 'Staffing Agencies',
    tag: 'HR & Talent',
    pain: 'CV screening by hand, manual interview scheduling, placement tracking in spreadsheets',
    workflows: ['AI CV screening', 'Interview scheduling', 'Placement tracking', 'Candidate nurture', 'Client reporting'],
    stats: [
      { v: '22h', l: 'saved / week' },
      { v: '2×', l: 'placement velocity' },
      { v: '40%', l: 'less admin time' },
    ],
  },
  {
    icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z',
    name: 'E-commerce',
    tag: 'Retail',
    pain: 'Manual order updates, slow return processing, no post-purchase review flow',
    workflows: ['Order status comms', 'Return processing', 'Review campaigns', 'Inventory alerts', 'Abandoned cart'],
    stats: [
      { v: '18h', l: 'saved / week' },
      { v: '0', l: 'manual order updates' },
      { v: '+28%', l: 'review rate' },
    ],
  },
  {
    icon: 'M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z',
    name: 'Marketing Agencies',
    tag: 'Agency',
    pain: 'Manual report compilation, briefing chaos, client update emails written by hand',
    workflows: ['Client reporting', 'Campaign briefs', 'Slack delivery alerts', 'Budget tracking', 'Asset delivery'],
    stats: [
      { v: '11h', l: 'saved / week' },
      { v: 'Live', l: 'client dashboards' },
      { v: '100%', l: 'on-time delivery' },
