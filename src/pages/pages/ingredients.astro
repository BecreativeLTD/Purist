const integrations = [
  { name: 'HubSpot',     cat: 'CRM' },
  { name: 'Salesforce',  cat: 'CRM' },
  { name: 'Pipedrive',   cat: 'CRM' },
  { name: 'ActiveCampaign', cat: 'CRM' },
  { name: 'Gmail',       cat: 'Email' },
  { name: 'Outlook',     cat: 'Email' },
  { name: 'Mailchimp',   cat: 'Email' },
  { name: 'ConvertKit',  cat: 'Email' },
  { name: 'Stripe',      cat: 'Finance' },
  { name: 'QuickBooks',  cat: 'Finance' },
  { name: 'Xero',        cat: 'Finance' },
  { name: 'FreshBooks',  cat: 'Finance' },
  { name: 'Asana',       cat: 'PM' },
  { name: 'ClickUp',     cat: 'PM' },
  { name: 'Monday.com',  cat: 'PM' },
  { name: 'Notion',      cat: 'PM' },
  { name: 'Slack',       cat: 'Comms' },
  { name: 'Teams',       cat: 'Comms' },
  { name: 'WhatsApp',    cat: 'Comms' },
  { name: 'Intercom',    cat: 'Comms' },
  { name: 'n8n',         cat: 'Automation' },
  { name: 'Make',        cat: 'Automation' },
  { name: 'Zapier',      cat: 'Automation' },
  { name: 'Airtable',    cat: 'Automation' },
  { name: 'Claude AI',   cat: 'AI' },
  { name: 'GPT-4',       cat: 'AI' },
  { name: 'GitHub',      cat: 'DevOps' },
  { name: 'AWS',         cat: 'DevOps' },
];

const catColors: Record<string, string> = {
  CRM:        'bg-emerald-500/15 text-emerald-300',
  Email:      'bg-rose-400/15 text-rose-300',
  Finance:    'bg-amber-400/15 text-amber-300',
  PM:         'bg-violet-400/15 text-violet-300',
  Comms:      'bg-teal-400/15 text-teal-300',
  Automation: 'bg-blue-400/15 text-blue-300',
  AI:         'bg-pink-400/15 text-pink-300',
  DevOps:     'bg-orange-400/15 text-orange-300',
};
---

<ShopLayout
  title="Industries & integrations – PURIST"
  description="Six industries. Nine core processes. 28+ integrations. One deployment that automates your entire operation in 5–10 days."
>

  <!-- ── Hero ─────────────────────────────────────────────────────────────── -->
  <header class="bg-brand-black text-white">
    <div class="container-x py-20 lg:py-28">
      <div class="max-w-3xl">
        <p class="eyebrow text-white/50 mb-4">Industries & integrations</p>
        <h1 class="font-display text-4xl lg:text-5xl xl:text-6xl leading-tight tracking-tight mb-6 text-balance">
          6 industries. 9 processes. <em class="font-medium text-brand-pink">One deployment.</em>
        </h1>
        <p class="text-base lg:text-lg text-white/60 text-pretty max-w-xl">
          Every workflow is built against real operational data from your sector — not generic
          templates. If an integration does not deliver measurable ROI, it does not ship.
        </p>
      </div>

      <!-- KPI strip -->
      <div class="mt-12 grid grid-cols-2 lg:grid-cols-4 gap-px bg-white/10 rounded-card overflow-hidden">
        {[
          { v: '329', l: 'Claude AI skills' },
          { v: '5–10d', l: 'Deployment window' },
          { v: '$168K', l: 'Avg. savings / yr' },
          { v: '9.4×', l: 'Return on investment' },
        ].map(m => (
          <div class="bg-brand-black px-6 py-5">
            <p class="font-display text-2xl lg:text-3xl text-white leading-none mb-1">{m.v}</p>
            <p class="text-[10px] uppercase tracking-[0.18em] text-white/45 font-medium">{m.l}</p>
          </div>
        ))}
      </div>
    </div>
  </header>

  <!-- ── Industries Grid ───────────────────────────────────────────────────── -->
  <section class="bg-brand-cream py-20 lg:py-28">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="eyebrow mb-4">Vertical expertise</p>
        <h2 class="font-display text-3xl lg:text-4xl xl:text-5xl leading-tight text-balance">
          Built for your industry. <em class="font-medium">Deployed for your stack.</em>
        </h2>
        <p class="text-base text-brand-gray-600 mt-4 text-pretty">
          Each vertical has its own workflow library, integration set, and ROI benchmarks.
          You're not getting a generic setup — you're getting a deployment refined across dozens of clients in your sector.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {industries.map((ind) => (
          <article class="group bg-white rounded-card border border-brand-gray-100 hover:border-brand-gray-300 hover:shadow-md transition-all duration-300 overflow-hidden flex flex-col">

            <!-- Card header -->
            <div class="px-6 pt-6 pb-5 border-b border-brand-gray-100">
              <div class="flex items-start justify-between gap-3 mb-4">
                <div class="w-11 h-11 rounded-lg bg-brand-cream flex items-center justify-center shrink-0 group-hover:bg-brand-black/5 transition-colors">
                  <svg class="w-5 h-5 text-brand-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d={ind.icon}/>
                  </svg>
                </div>
                <span class="text-[10px] uppercase tracking-[0.15em] font-medium px-2.5 py-1 rounded-full bg-brand-black/6 text-brand-gray-600">
                  {ind.tag}
                </span>
              </div>
              <h3 class="font-display text-xl mb-1.5">{ind.name}</h3>
              <p class="text-sm text-brand-gray-600 leading-relaxed">{ind.pain}</p>
            </div>

            <!-- Workflows -->
            <div class="px-6 py-4 flex-1">
              <p class="text-[10px] uppercase tracking-[0.15em] font-medium text-brand-gray-600 mb-3">Automated workflows</p>
              <ul class="space-y-1.5">
                {ind.workflows.map(w => (
                  <li class="flex items-center gap-2 text-sm">
                    <svg class="w-3.5 h-3.5 text-brand-green shrink-0" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                      <circle cx="8" cy="8" r="8" opacity="0.15"/>
                      <path d="M4.5 8l2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class="text-brand-gray-600">{w}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Stats footer -->
            <div class="px-6 pb-6">
              <div class="grid grid-cols-3 gap-2 pt-4 border-t border-brand-gray-100">
                {ind.stats.map(s => (
                  <div class="text-center">
                    <p class="font-display text-lg leading-none text-brand-black mb-0.5">{s.v}</p>
                    <p class="text-[9px] uppercase tracking-[0.12em] text-brand-gray-500 font-medium leading-tight">{s.l}</p>
                  </div>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>

      <p class="mt-10 text-center text-sm text-brand-gray-500">
        Don't see your industry? <a href="/pages/contact-us" class="underline underline-offset-2 hover:text-brand-black transition">Let us know</a> — we deploy across any B2B sector.
      </p>
    </div>
  </section>

  <!-- ── Nine core processes ───────────────────────────────────────────────── -->
  <NineOrganSystems />

  <!-- ── Integration Ecosystem ─────────────────────────────────────────────── -->
  <section class="bg-brand-black text-white py-20 lg:py-28">
    <div class="container-x">
      <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-start">

        <!-- Left: copy -->
        <div class="lg:sticky lg:top-24">
          <p class="eyebrow text-white/50 mb-4">Integration ecosystem</p>
          <h2 class="font-display text-3xl lg:text-4xl xl:text-5xl leading-tight text-balance mb-6">
            28+ tools. <em class="font-medium text-brand-pink">Zero new logins.</em>
          </h2>
          <p class="text-base text-white/60 leading-relaxed mb-8">
            We connect to the tools you already use — your CRM, email, finance platform, PM
            tool, and communications stack. No rip-and-replace. No new software to learn.
          </p>

          <!-- Integration stats grid -->
          <div class="grid grid-cols-2 gap-3 mb-8">
            {[
              { v: '28+', l: 'Native integrations', sub: 'pre-tested & monitored' },
              { v: '100%', l: 'Bidirectional sync', sub: 'with conflict resolution' },
              { v: '<200ms', l: 'API response time', sub: 'avg. across all connectors' },
              { v: '0', l: 'Data dropped', sub: 'on burst traffic via Redis' },
            ].map(s => (
              <div class="bg-white/5 border border-white/8 rounded-xl px-4 py-3.5">
                <div class="font-display text-xl text-white mb-0.5">{s.v}</div>
                <div class="text-[11px] text-white/60 font-medium leading-tight">{s.l}</div>
                <div class="text-[10px] text-white/30 mt-0.5">{s.sub}</div>
              </div>
            ))}
          </div>

          <!-- Feature list -->
          <ul class="space-y-2.5 mb-10">
            {[
              'OAuth 2.0 + refresh-token rotation on all auth flows',
              'API change detection with automated alerts',
              'Rate-limit management via shared token bucket',
              'Custom webhooks & REST APIs for proprietary systems',
            ].map(f => (
              <li class="flex items-start gap-2.5 text-sm text-white/55">
                <svg class="w-3.5 h-3.5 text-brand-pink mt-0.5 shrink-0" viewBox="0 0 16 16" fill="currentColor">
                  <circle cx="8" cy="8" r="8" opacity="0.15"/>
                  <path d="M4.5 8l2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>

          <Button href="/pages/contact-us">Discuss your stack →</Button>
        </div>

        <!-- Right: integration grid -->
        <div>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-2.5">
            {integrations.map(tool => (
              <div class="group rounded-card border border-white/10 bg-white/5 hover:bg-white/8 hover:border-white/20 transition-all duration-200 px-4 py-3.5">
                <p class="font-medium text-sm text-white mb-1">{tool.name}</p>
                <span class={`text-[9px] uppercase tracking-wider font-medium px-2 py-0.5 rounded-full ${catColors[tool.cat] ?? 'bg-white/10 text-white/50'}`}>
                  {tool.cat}
                </span>
              </div>
            ))}
          </div>
          <p class="text-[11px] text-white/35 mt-4 text-center tracking-wide">
            + custom webhooks, REST APIs, and proprietary systems on request
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Automation comparison table ───────────────────────────────────────── -->
  <IngredientComparison />

  <!-- ── CTA ────────────────────────────────────────────────────────────────── -->
  <section class="bg-brand-black text-white py-16 lg:py-20">
    <div class="container-x">
      <div class="grid lg:grid-cols-2 gap-10 items-center max-w-5xl mx-auto">
        <div>
          <p class="eyebrow text-white/50 mb-4">Next step</p>
          <h2 class="font-display text-3xl lg:text-4xl leading-tight text-balance mb-4">
            See full workflow specs for <em class="font-medium text-brand-pink">your industry.</em>
          </h2>
          <p class="text-base text-white/60 leading-relaxed">
            Book a free 60-minute audit. We map your current operations, identify bottleneck processes,
            and give you a full ROI projection — no obligation.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row lg:flex-col xl:flex-row gap-4 lg:justify-end">
          <Button href="/pages/contact-us" size="lg">Book free audit →</Button>
          <Button href="/pages/science" variant="secondary" size="lg">How it works →</Button>
        </div>
      </div>
    </div>
  </section>

</ShopLayout>
