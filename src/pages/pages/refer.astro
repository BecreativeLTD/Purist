<script is:inline>
function copyDemo() {
 var code = document.getElementById('demo-code');
 if (!code) return;
 try {
   navigator.clipboard.writeText(code.textContent.trim()).then(function() {
     var btn = event.target;
     var orig = btn.textContent;
     btn.textContent = 'Copied!';
     btn.style.color = '#2D5016';
     setTimeout(function() { btn.textContent = orig; btn.style.color = ''; }, 1800);
   });
 } catch(e) {}
}

// FAQ accordion
document.addEventListener('DOMContentLoaded', function() {
 var triggers = document.querySelectorAll('.faq-trigger');
 triggers.forEach(function(btn) {
   btn.addEventListener('click', function() {
     var item = btn.closest('.faq-item');
     var body = item.querySelector('.faq-body');
     var chevron = btn.querySelector('.faq-chevron');
     var isOpen = btn.getAttribute('aria-expanded') === 'true';

     // Close all
     triggers.forEach(function(other) {
       var otherItem = other.closest('.faq-item');
       otherItem.querySelector('.faq-body').classList.add('hidden');
       other.querySelector('.faq-chevron').style.transform = '';
       other.setAttribute('aria-expanded', 'false');
       other.style.background = 'rgba(255,255,255,0.04)';
     });

     if (!isOpen) {
       body.classList.remove('hidden');
       chevron.style.transform = 'rotate(180deg)';
       btn.setAttribute('aria-expanded', 'true');
       btn.style.background = 'rgba(232,180,176,0.06)';
     }
   });
 });
});
</script>
