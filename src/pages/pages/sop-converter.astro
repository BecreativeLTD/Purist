---
import ShopLayout from '~/layouts/ShopLayout.astro';
---

<ShopLayout
  title="SOP to Automation Converter — Turn Any Process into an n8n Workflow | PURIST"
  description="Paste your Standard Operating Procedure and get a complete automation blueprint: triggers, tools, logic map, n8n nodes, and implementation priority score."
  canonical="https://purist.online/pages/sop-converter"
>

<!-- Hero -->
<section class="bg-brand-black text-white pt-20 pb-12 lg:pt-28 relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 50% 0%,rgba(232,180,176,0.07) 0%,transparent 60%);"></div>
  <div class="container-x relative z-10">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border mb-6" style="border-color:rgba(232,180,176,0.25);background:rgba(232,180,176,0.06);">
        <span class="text-[10px] uppercase tracking-[0.18em] font-semibold" style="color:rgba(232,180,176,0.80);">Free tool · Based on 312+ live automations</span>
      </div>
      <h1 class="font-display text-[2.2rem] lg:text-[3rem] leading-[1.06] tracking-[-0.025em] text-white mb-4">
        Paste your SOP.<br/><em class="font-medium" style="color:#E8B4B0;">Get your automation blueprint.</em>
      </h1>
      <p class="text-[15px] leading-relaxed mb-8 max-w-xl mx-auto" style="color:rgba(255,255,255,0.45);">
        Describe any business process in plain language. The converter identifies triggers, actions, decisions and tools — then maps it to a ready-to-build n8n workflow.
      </p>
      <!-- Stats row -->
      <div class="flex flex-wrap justify-center gap-6">
        {[
          ['312+', 'workflows deployed'],
          ['< 30s', 'to analyse your SOP'],
          ['91%', 'automatable on average'],
        ].map(([val, lbl]) => (
          <div class="text-center">
            <div class="font-display text-[1.6rem] leading-none" style="color:#E8B4B0;">{val}</div>
            <div class="text-[11px] uppercase tracking-widest mt-1" style="color:rgba(255,255,255,0.35);">{lbl}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Main converter -->
<section class="bg-brand-black text-white pb-20">
  <div class="container-x">
    <div class="max-w-5xl mx-auto">

      <!-- Step progress bar -->
      <div class="flex items-center justify-center gap-0 mb-12" id="step-bar">
        {[
          ['1', 'Paste SOP'],
          ['2', 'Classify'],
          ['3', 'Blueprint'],
        ].map(([n, lbl], i) => (
          <>
            <div class="flex flex-col items-center" id={`step-dot-${n}`}>
              <div class={`w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold border-2 transition-all duration-300 ${i === 0 ? 'step-active' : 'step-inactive'}`}
                   style={i === 0 ? 'background:#E8B4B0;border-color:#E8B4B0;color:#0a0a0a;' : 'border-color:rgba(255,255,255,0.15);color:rgba(255,255,255,0.3);'}>
                {n}
              </div>
              <span class="text-[8px] sm:text-[10px] uppercase tracking-widest mt-1.5 hidden sm:block" style={i === 0 ? 'color:#E8B4B0;' : 'color:rgba(255,255,255,0.25);'}>{lbl}</span>
            </div>
            {i < 2 && <div class="w-16 h-px mx-2 mt-[-14px]" style="background:rgba(255,255,255,0.1);" id={`step-line-${i}`}></div>}
          </>
        ))}
      </div>

      <!-- Step 1: Input -->
      <div id="step1" class="sop-step">
        <div class="grid lg:grid-cols-5 gap-6">
          <!-- Input panel -->
          <div class="lg:col-span-3">
            <div class="rounded-2xl border overflow-hidden" style="border-color:rgba(255,255,255,0.08);background:rgba(255,255,255,0.03);">
              <div class="flex items-center justify-between px-5 py-3.5 border-b" style="border-color:rgba(255,255,255,0.06);">
                <span class="text-[11px] uppercase tracking-widest font-semibold" style="color:rgba(232,180,176,0.7);">Your SOP / process description</span>
                <div class="flex gap-2">
                  <button id="btn-example" class="text-[11px] px-3 py-1 rounded-full border transition-colors" style="border-color:rgba(255,255,255,0.15);color:rgba(255,255,255,0.5);" onmouseenter="this.style.borderColor='rgba(232,180,176,0.5)';this.style.color='#E8B4B0';" onmouseleave="this.style.borderColor='rgba(255,255,255,0.15)';this.style.color='rgba(255,255,255,0.5)';">Load example</button>
                  <button id="btn-clear" class="text-[11px] px-3 py-1 rounded-full border transition-colors" style="border-color:rgba(255,255,255,0.15);color:rgba(255,255,255,0.5);" onmouseenter="this.style.borderColor='rgba(232,180,176,0.5)';this.style.color='#E8B4B0';" onmouseleave="this.style.borderColor='rgba(255,255,255,0.15)';this.style.color='rgba(255,255,255,0.5)';">Clear</button>
                </div>
              </div>
              <textarea id="sop-input" rows="14" placeholder="Describe your process in plain language. For example:

When a new lead fills our contact form on the website, our team manually checks if they're already in HubSpot. If yes, we update their record and notify the account manager by email. If no, we create a new contact, assign them to the relevant rep based on industry, send a welcome email, create a deal in the pipeline at 'New' stage, and schedule a follow-up task for 48 hours later. We also add them to a Slack channel notification so the whole team sees it." class="w-full bg-transparent resize-none px-5 py-4 text-[13px] leading-relaxed outline-none" style="color:rgba(255,255,255,0.75);min-height:260px;"></textarea>
              <div class="px-5 py-3 border-t flex items-center justify-between" style="border-color:rgba(255,255,255,0.06);">
                <div class="flex items-center gap-2">
                  <span id="char-count" class="text-[11px]" style="color:rgba(255,255,255,0.25);">0 words · 0 chars</span>
                  <span id="quality-indicator" class="text-[11px] hidden"></span>
                </div>
                <button id="btn-analyse" disabled class="px-6 py-2.5 rounded-lg text-[13px] font-semibold transition-all duration-200 opacity-40 cursor-not-allowed" style="background:#E8B4B0;color:#0a0a0a;">
                  Analyse Process →
                </button>
              </div>
            </div>
          </div>

          <!-- Tips panel -->
          <div class="lg:col-span-2 flex flex-col gap-4">
            <div class="rounded-2xl border p-5" style="border-color:rgba(255,255,255,0.08);background:rgba(255,255,255,0.02);">
              <h3 class="text-[11px] uppercase tracking-widest font-semibold mb-4" style="color:rgba(232,180,176,0.7);">What makes a good SOP</h3>
              <div class="space-y-3">
                {[
                  ['Triggers', 'What starts the process? (new form, email, schedule, manual action)'],
                  ['Steps', 'Each action in order, including manual checks and decisions'],
                  ['Tools', 'Name the apps involved (HubSpot, Slack, Gmail, Notion…)'],
                  ['People', 'Who does each step — names optional, roles preferred'],
                  ['Branches', 'If/then logic ("if customer is VIP…", "if deal > £5k…")'],
                ].map(([title, desc]) => (
                  <div class="flex gap-3">
                    <div class="w-1.5 h-1.5 rounded-full mt-1.5 shrink-0" style="background:#E8B4B0;"></div>
                    <div>
                      <span class="text-[12px] font-semibold text-white">{title}: </span>
                      <span class="text-[12px]" style="color:rgba(255,255,255,0.45);">{desc}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div class="rounded-2xl border p-5" style="border-color:rgba(255,255,255,0.08);background:rgba(255,255,255,0.02);">
              <h3 class="text-[11px] uppercase tracking-widest font-semibold mb-3" style="color:rgba(255,255,255,0.35);">Works best for</h3>
              <div class="flex flex-wrap gap-2">
                {['Lead management', 'Client onboarding', 'Invoice processing', 'Reporting', 'Support tickets', 'Scheduling', 'Data sync', 'Notifications', 'Approvals', 'Follow-ups'].map(t => (
                  <span class="text-[11px] px-2.5 py-1 rounded-full border" style="border-color:rgba(255,255,255,0.1);color:rgba(255,255,255,0.4);">{t}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 2: Classifying (loading) -->
      <div id="step2" class="sop-step hidden">
        <div class="max-w-xl mx-auto text-center py-16">
          <div id="analyse-log" class="space-y-2 text-left mb-8 font-mono text-[12px]" style="color:rgba(255,255,255,0.5);"></div>
          <div class="text-[13px]" style="color:rgba(255,255,255,0.35);">Mapping your workflow…</div>
        </div>
      </div>

      <!-- Step 3: Blueprint output -->
      <div id="step3" class="sop-step hidden">
        <!-- Top metrics -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8" id="result-metrics"></div>

        <!-- Main blueprint grid -->
        <div class="grid lg:grid-cols-3 gap-6 mb-8">
          <!-- Workflow map -->
          <div class="lg:col-span-2">
            <div class="rounded-2xl border overflow-hidden" style="border-color:rgba(255,255,255,0.08);background:rgba(255,255,255,0.02);">
              <div class="px-5 py-3.5 border-b flex items-center justify-between" style="border-color:rgba(255,255,255,0.06);">
                <span class="text-[11px] uppercase tracking-widest font-semibold" style="color:rgba(232,180,176,0.7);">Workflow map</span>
                <span class="text-[11px]" style="color:rgba(255,255,255,0.3);">trigger → actions → output</span>
              </div>
              <div id="workflow-map" class="p-5 space-y-3"></div>
            </div>
          </div>

          <!-- Side panel: tools + complexity -->
          <div class="space-y-4">
            <div class="rounded-2xl border p-5" style="border-color:rgba(255,255,255,0.08);background:rgba(255,255,255,0.02);">
              <h3 class="text-[11px] uppercase tracking-widest font-semibold mb-4" style="color:rgba(255,255,255,0.35);">Tools detected</h3>
              <div id="tools-detected" class="space-y-2"></div>
            </div>
            <div class="rounded-2xl border p-5" style="border-color:rgba(255,255,255,0.08);background:rgba(255,255,255,0.02);">
              <h3 class="text-[11px] uppercase tracking-widest font-semibold mb-4" style="color:rgba(255,255,255,0.35);">Automation score</h3>
              <div id="auto-score-display"></div>
            </div>
          </div>
        </div>

        <!-- n8n nodes -->
        <div class="rounded-2xl border overflow-hidden mb-6" style="border-color:rgba(255,255,255,0.08);background:rgba(255,255,255,0.02);">
          <div class="px-5 py-3.5 border-b flex items-center justify-between" style="border-color:rgba(255,255,255,0.06);">
            <span class="text-[11px] uppercase tracking-widest font-semibold" style="color:rgba(232,180,176,0.7);">n8n node blueprint</span>
            <button id="btn-copy-blueprint" class="text-[10px] px-2.5 py-1 rounded-full border transition-all cursor-pointer" style="border-color:rgba(232,180,176,0.25);color:rgba(232,180,176,0.6);">Copy blueprint</button>
          </div>
          <div id="n8n-nodes" class="p-5"></div>
        </div>

        <!-- Next steps -->
        <div class="rounded-2xl border overflow-hidden mb-8" style="border-color:rgba(255,255,255,0.08);background:rgba(255,255,255,0.02);">
          <div class="px-5 py-3.5 border-b" style="border-color:rgba(255,255,255,0.06);">
            <span class="text-[11px] uppercase tracking-widest font-semibold" style="color:rgba(255,255,255,0.35);">Recommended next steps</span>
          </div>
          <div id="next-steps" class="p-5 grid sm:grid-cols-3 gap-4"></div>
        </div>

        <!-- CTA + restart -->
        <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
          <a href="/pages/demo" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl text-[14px] font-semibold transition-all duration-200 hover:opacity-90" style="background:#E8B4B0;color:#0a0a0a;">
            See PURIST build this for you
          </a>
          <button id="btn-restart" class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl text-[13px] font-medium border transition-all duration-200" style="border-color:rgba(255,255,255,0.15);color:rgba(255,255,255,0.6);" onmouseenter="this.style.borderColor='rgba(232,180,176,0.4)';this.style.color='#E8B4B0';" onmouseleave="this.style.borderColor='rgba(255,255,255,0.15)';this.style.color='rgba(255,255,255,0.6)';">
            ← Convert another SOP
          </button>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- How it works -->
<section class="bg-brand-black text-white pb-20 border-t" style="border-color:rgba(255,255,255,0.05);">
  <div class="container-x">
    <div class="max-w-4xl mx-auto pt-16">
      <div class="text-center mb-12">
        <h2 class="font-display text-[1.7rem] lg:text-[2.2rem] leading-tight tracking-[-0.02em] text-white mb-3">How the analysis works</h2>
        <p class="text-[14px]" style="color:rgba(255,255,255,0.4);">Pattern recognition built from 312 real automation deployments</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8 relative">
        <!-- Dashed connector row 1 (desktop) -->
        <div class="hidden md:block absolute top-5 left-[calc(33.33%+1rem)] right-[calc(33.33%+1rem)] h-px" style="border-top:1px dashed rgba(232,180,176,0.18);pointer-events:none;"></div>
        <!-- Dashed connector row 2 (desktop) — positioned after first row, roughly at step 4-5-6 -->
        {[
          {
            n: '01',
            title: 'Trigger detection',
            desc: 'Identifies what starts the process — form submission, email received, schedule, webhook, manual action or data change.'
          },
          {
            n: '02',
            title: 'Action mapping',
            desc: 'Extracts every discrete step, labels it as data-read, data-write, API call, notification, conditional branch or human task.'
          },
          {
            n: '03',
            title: 'Tool matching',
            desc: 'Cross-references mentioned apps against 180+ n8n-supported integrations to identify which nodes to use for each action.'
          },
          {
            n: '04',
            title: 'Complexity scoring',
            desc: 'Scores each step for automation feasibility: 1-click (native n8n node), medium (some config) or complex (custom code needed).'
          },
          {
            n: '05',
            title: 'Priority ordering',
            desc: 'Ranks which steps to automate first based on time saved × frequency × risk level from our deployment database.'
          },
          {
            n: '06',
            title: 'ROI estimate',
            desc: 'Benchmarks the workflow against similar deployments to produce a time-saved and cost-saved estimate based on real data.'
          },
        ].map(({ n, title, desc }) => (
          <div class="relative flex flex-col gap-2 rounded-[16px] border p-5" style="background:rgba(255,255,255,0.02);border-color:rgba(232,180,176,0.10);">
            <h3 class="text-[14px] font-semibold tracking-[-0.01em] text-white">{title}</h3>
            <p class="text-[12px] leading-relaxed flex-1" style="color:rgba(255,255,255,0.40);">{desc}</p>
            <div class="font-display leading-none mt-3 select-none" style="font-size:3.5rem;color:#E8B4B0;opacity:0.55;">{n}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Example SOPs for inspiration -->
<section class="bg-brand-black text-white pb-24 border-t" style="border-color:rgba(255,255,255,0.05);">
  <div class="container-x">
    <div class="max-w-5xl mx-auto pt-16">
      <div class="text-center mb-10">
        <h2 class="font-display text-[1.7rem] lg:text-[2.2rem] leading-tight tracking-[-0.02em] text-white mb-3">Common SOPs we've automated</h2>
        <p class="text-[14px]" style="color:rgba(255,255,255,0.4);">Click any to load it into the converter</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4" id="example-cards"></div>
    </div>
  </div>
</section>

<style is:global>
  .sop-step { transition: opacity 0.3s ease, transform 0.3s ease; }
  .sop-step.hidden { display: none; }

  @keyframes sop-fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .sop-anim { animation: sop-fade-in 0.4s ease-out both; }

  @keyframes node-in {
    from { opacity: 0; transform: translateX(-8px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .node-row { animation: node-in 0.35s ease-out both; }

  @keyframes log-line {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .log-line { animation: log-line 0.2s ease-out both; }

  #sop-input::placeholder { color: rgba(255,255,255,0.18); }
  #sop-input { caret-color: #E8B4B0; }
  #sop-input:focus { outline: none; }
</style>

<script is:inline>
(function(){

  /* ─── Example SOPs ─── */
  var EXAMPLES = [
    {
      label: 'Lead intake → CRM',
      industry: 'Agency',
      industryColor: '#E8B4B0',
      icon: '🎯',
      tools: ['HubSpot', 'Slack', 'Gmail'],
      text: `When a prospect submits the contact form on our website, we manually check HubSpot to see if they already exist as a contact. If they do, we update their record with the new inquiry details and send an internal Slack message to their assigned rep. If they don't exist, we create a new contact in HubSpot, assign them to a sales rep based on their selected service (SEO, Paid Ads, or Web Design), add them to the correct pipeline at "New Lead" stage, send a personalised welcome email from the rep's address, create a follow-up task for 24 hours later, and post a notification to our #new-leads Slack channel.`
    },
    {
      label: 'Invoice processing',
      industry: 'Finance',
      industryColor: '#4ADE80',
      icon: '💳',
      tools: ['Xero', 'Notion', 'Gmail'],
      text: `When an invoice email arrives in our accounts@company.com inbox, we download the PDF attachment and enter the data manually into our spreadsheet: supplier name, invoice number, amount, due date, and category. We then check if the supplier is on our approved list in Notion. If approved and under £2,000, we mark it for auto-payment in Xero. If over £2,000, we send an approval request to the Finance Director via email. Once approved, we schedule payment in Xero, update the spreadsheet, and archive the email with a label "processed".`
    },
    {
      label: 'New client onboarding',
      industry: 'Consulting',
      industryColor: '#7B68EE',
      icon: '🤝',
      tools: ['DocuSign', 'ClickUp', 'Slack'],
      text: `When a contract is signed in DocuSign, we manually create a new project folder in Google Drive using our template structure. We then create a project in ClickUp with all standard tasks assigned to the relevant team members. We send the client a welcome email with their portal login details, add them to our client Slack workspace, schedule the kickoff call in Calendly and send the invite, create their profile in our billing system, add them to our monthly reporting spreadsheet, and notify the account manager in our internal #onboarding Slack channel.`
    },
    {
      label: 'E-comm post-purchase',
      industry: 'E-commerce',
      industryColor: '#96BF48',
      icon: '📦',
      tools: ['Shopify', 'Klaviyo', 'Stripe'],
      text: `After an order is placed on our Shopify store, we check if it's the customer's first order or a repeat purchase. For first-time buyers, we send a welcome email sequence (3 emails over 7 days), add them to our loyalty programme in Klaviyo, and create a customer card in our CRM. For repeat buyers, we check their total spend. If over £500 lifetime, we tag them as VIP and add them to our VIP segment. All orders trigger a confirmation email. When the order ships, we send tracking info. 14 days after delivery, we send an automated review request.`
    },
    {
      label: 'Support ticket routing',
      industry: 'SaaS',
      industryColor: '#00A2FF',
      icon: '🎧',
      tools: ['Freshdesk', 'Linear', 'Slack'],
      text: `When a support ticket arrives in Freshdesk, a team member reads it and manually assigns it to either Technical, Billing, or General Support. For technical issues, they check the customer's plan in our database and assign to senior support if they're on Enterprise plan. They create a bug report in Linear if it's a platform issue. For billing issues, they check Stripe for the customer's subscription status. They update the ticket priority based on plan type and respond within SLA targets. At end of day, they compile a summary report of all tickets by category in a spreadsheet.`
    },
    {
      label: 'Real estate lead follow-up',
      industry: 'Real Estate',
      industryColor: '#F59E0B',
      icon: '🏠',
      tools: ['Gmail', 'Calendly', 'Sheets'],
      text: `When someone books a valuation through our website form, we manually enter their details into our CRM (Address, contact info, property type, estimated value range). We assign them to the nearest agent based on postcode, send a confirmation email with appointment details, create a calendar event for the agent, prepare a comparables report by pulling 5 recent sales from Rightmove, and add the lead to a weekly pipeline review spreadsheet. If the appointment is not confirmed within 24 hours, we send a reminder. After the valuation, we log the outcome and move them to the relevant pipeline stage.`
    },
  ];

  /* ─── Pattern library (keyword → node mapping) ─── */
  var TRIGGERS = [
    { kw: ['form', 'submits', 'submitted', 'fills'], label: 'Form submission', node: 'Webhook / Form Trigger', icon: '⚡' },
    { kw: ['email arrives', 'email received', 'inbox', 'email comes in'], label: 'Email received', node: 'Gmail / IMAP Trigger', icon: '📧' },
    { kw: ['order placed', 'purchase', 'checkout', 'shopify'], label: 'New order', node: 'Shopify Trigger', icon: '🛒' },
    { kw: ['contract signed', 'docusign', 'signed'], label: 'Contract signed', node: 'DocuSign Trigger', icon: '✍️' },
    { kw: ['ticket', 'freshdesk', 'zendesk', 'support request'], label: 'Support ticket created', node: 'Freshdesk / Webhook', icon: '🎟️' },
    { kw: ['scheduled', 'daily', 'weekly', 'monthly', 'every morning'], label: 'Schedule trigger', node: 'Schedule Trigger', icon: '🕐' },
    { kw: ['booked', 'booking', 'appointment', 'calendly'], label: 'Booking made', node: 'Calendly / Webhook', icon: '📅' },
    { kw: ['deal', 'pipeline', 'stage changes', 'moved to'], label: 'CRM stage change', node: 'HubSpot / Pipedrive Trigger', icon: '🔄' },
  ];

  var TOOL_MAP = {
    'hubspot': { name: 'HubSpot', node: 'HubSpot', category: 'CRM', color: '#FF7A59' },
    'salesforce': { name: 'Salesforce', node: 'Salesforce', category: 'CRM', color: '#00A1E0' },
    'pipedrive': { name: 'Pipedrive', node: 'Pipedrive', category: 'CRM', color: '#2C3E6B' },
    'slack': { name: 'Slack', node: 'Slack', category: 'Messaging', color: '#4A154B' },
    'gmail': { name: 'Gmail', node: 'Gmail', category: 'Email', color: '#EA4335' },
    'sheets': { name: 'Google Sheets', node: 'Google Sheets', category: 'Spreadsheet', color: '#0F9D58' },
    'spreadsheet': { name: 'Google Sheets', node: 'Google Sheets', category: 'Spreadsheet', color: '#0F9D58' },
    'notion': { name: 'Notion', node: 'Notion', category: 'Database', color: '#ffffff' },
    'clickup': { name: 'ClickUp', node: 'ClickUp', category: 'Project Mgmt', color: '#7B68EE' },
    'xero': { name: 'Xero', node: 'Xero / HTTP Request', category: 'Finance', color: '#13B5EA' },
    'stripe': { name: 'Stripe', node: 'Stripe', category: 'Payments', color: '#635BFF' },
    'shopify': { name: 'Shopify', node: 'Shopify', category: 'E-commerce', color: '#96BF48' },
