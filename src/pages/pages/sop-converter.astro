        '<div class="text-[13px] font-semibold text-white mb-1.5">' + ex.label + '</div>' +
        '<div class="text-[11px] leading-relaxed mb-3" style="color:rgba(255,255,255,0.35);">' + ex.text.substring(0, 90) + '…</div>' +
        (toolTags ? '<div class="flex flex-wrap gap-1.5 mb-3">' + toolTags + '</div>' : '') +
        '<div class="text-[11px] font-medium" style="color:#E8B4B0;">Load & analyse →</div>' +
      '</button>';
    }).join('');
  }

  /* ─── Step transitions ─── */
  function goToStep(n) {
    [1,2,3].forEach(function(s) {
      var el = document.getElementById('step' + s);
      if (el) { el.classList.toggle('hidden', s !== n); }
      var dot = document.getElementById('step-dot-' + s);
      if (dot) {
        var circle = dot.querySelector('div');
        var label = dot.querySelector('span');
        if (s < n) {
          if (circle) { circle.style.cssText = 'background:#E8B4B0;border-color:#E8B4B0;color:#0a0a0a;border-width:2px;'; }
          if (label) label.style.color = 'rgba(232,180,176,0.7)';
        } else if (s === n) {
          if (circle) { circle.style.cssText = 'background:#E8B4B0;border-color:#E8B4B0;color:#0a0a0a;border-width:2px;'; }
          if (label) label.style.color = '#E8B4B0';
        } else {
          if (circle) { circle.style.cssText = 'border-color:rgba(255,255,255,0.15);color:rgba(255,255,255,0.3);border-width:2px;'; }
          if (label) label.style.color = 'rgba(255,255,255,0.25)';
        }
      }
    });
  }

  /* ─── Loading simulation ─── */
  var LOG_MESSAGES = [
    'Parsing process description…',
    'Detecting trigger type…',
    'Mapping action sequence…',
    'Identifying tool integrations…',
    'Scoring automation feasibility…',
    'Generating n8n node blueprint…',
    'Calculating ROI estimates…',
    'Blueprint ready.',
  ];

  function runAnalysis(text, cb) {
    goToStep(2);
    var logEl = document.getElementById('analyse-log');
    if (logEl) logEl.innerHTML = '';
    var i = 0;
    function nextLog() {
      if (!logEl) { if (i >= LOG_MESSAGES.length - 1) { cb(); } return; }
      var line = document.createElement('div');
      line.className = 'log-line flex items-center gap-2';
      var isLast = i === LOG_MESSAGES.length - 1;
      line.innerHTML =
        '<span style="color:' + (isLast ? '#4ADE80' : 'rgba(232,180,176,0.5)') + ';">' + (isLast ? '✓' : '›') + '</span>' +
        '<span>' + LOG_MESSAGES[i] + '</span>';
      logEl.appendChild(line);
      i++;
      if (i < LOG_MESSAGES.length) {
        setTimeout(nextLog, 260 + Math.random() * 180);
      } else {
        setTimeout(cb, 400);
      }
    }
    nextLog();
  }

  /* ─── Init ─── */
  function init() {
    var input = document.getElementById('sop-input');
    var btnAnalyse = document.getElementById('btn-analyse');
    var btnExample = document.getElementById('btn-example');
    var btnClear = document.getElementById('btn-clear');
    var btnRestart = document.getElementById('btn-restart');
    var charCount = document.getElementById('char-count');

    if (!input) return;

    renderExampleCards();

    // Char counter + word count + quality indicator + enable button
    input.addEventListener('input', function() {
      var text = input.value.trim();
      var len = text.length;
      var words = text.split(/\s+/).filter(Boolean).length;
      if (charCount) charCount.textContent = words + ' words · ' + len + ' chars';
      var qualEl = document.getElementById('quality-indicator');
      if (qualEl) {
        if (len === 0) {
          qualEl.classList.add('hidden');
        } else if (len < 50) {
          qualEl.classList.remove('hidden');
          qualEl.innerHTML = '<span style="color:#F59E0B;">● Add more detail</span>';
        } else if (len < 200) {
          qualEl.classList.remove('hidden');
          qualEl.innerHTML = '<span style="color:#FACC15;">● Good — add tools &amp; steps</span>';
        } else {
          qualEl.classList.remove('hidden');
          qualEl.innerHTML = '<span style="color:#4ADE80;">● Great detail</span>';
        }
      }
      if (btnAnalyse) {
        var enabled = len >= 30;
        btnAnalyse.disabled = !enabled;
        btnAnalyse.style.opacity = enabled ? '1' : '0.4';
        btnAnalyse.style.cursor = enabled ? 'pointer' : 'not-allowed';
      }
    });

    // Example
    if (btnExample) {
      btnExample.addEventListener('click', function() {
        var ex = EXAMPLES[Math.floor(Math.random() * EXAMPLES.length)];
        input.value = ex.text;
        input.dispatchEvent(new Event('input'));
      });
    }

    // Clear
    if (btnClear) {
      btnClear.addEventListener('click', function() {
        input.value = '';
        input.dispatchEvent(new Event('input'));
      });
    }

    // Analyse
    if (btnAnalyse) {
      btnAnalyse.addEventListener('click', function() {
        var text = input.value.trim();
        if (text.length < 30) return;
        var result = analyseSOP(text);
        runAnalysis(text, function() {
          goToStep(3);
          renderMetrics(result);
          renderWorkflowMap(result);
          renderTools(result);
          renderScore(result);
          renderNodes(result);
          renderNextSteps(result);
        });
      });
    }

    // Restart
    if (btnRestart) {
      btnRestart.addEventListener('click', function() {
        goToStep(1);
        input.value = '';
        if (charCount) charCount.textContent = '0 words · 0 chars';
        var qualEl = document.getElementById('quality-indicator');
        if (qualEl) qualEl.classList.add('hidden');
        if (btnAnalyse) { btnAnalyse.disabled = true; btnAnalyse.style.opacity = '0.4'; }
      });
    }

    // Example cards
    document.addEventListener('click', function(e) {
      var card = e.target.closest('.example-card');
      if (!card) return;
      var idx = parseInt(card.getAttribute('data-idx'), 10);
      if (isNaN(idx) || !EXAMPLES[idx]) return;
      input.value = EXAMPLES[idx].text;
      input.dispatchEvent(new Event('input'));
      input.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
})();
</script>

</ShopLayout>
