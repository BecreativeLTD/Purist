  /* ─── Analyse SOP ─── */
  function analyseSOP(text) {
    var lower = text.toLowerCase();

    // Detect trigger
    var trigger = { label: 'Manual trigger', node: 'Manual Trigger', icon: '👆' };
    for (var t = 0; t < TRIGGERS.length; t++) {
      for (var k = 0; k < TRIGGERS[t].kw.length; k++) {
        if (lower.indexOf(TRIGGERS[t].kw[k]) !== -1) {
          trigger = TRIGGERS[t];
          break;
        }
      }
      if (trigger.label !== 'Manual trigger') break;
    }

    // Detect tools
    var toolsFound = {};
    Object.keys(TOOL_MAP).forEach(function(key) {
      if (lower.indexOf(key) !== -1) {
        toolsFound[TOOL_MAP[key].name] = TOOL_MAP[key];
      }
    });

    // Detect actions
    var actions = [];
    var seen = {};
    ACTION_PATTERNS.forEach(function(ap) {
      for (var i = 0; i < ap.kw.length; i++) {
        var kw = ap.kw[i];
        var match = kw.indexOf('.*') !== -1
          ? new RegExp(kw).test(lower)
          : lower.indexOf(kw) !== -1;
        if (match && !seen[ap.label]) {
          seen[ap.label] = true;
          actions.push({ label: ap.label, type: ap.type, node: ap.node });
          break;
        }
      }
    });

    // If no actions detected, add generic ones
    if (actions.length === 0) {
      actions = [
        { label: 'Read input data', type: 'read', node: 'HTTP Request / Webhook' },
        { label: 'Process & transform', type: 'logic', node: 'Function node' },
        { label: 'Write to destination', type: 'write', node: 'HTTP Request → API' },
        { label: 'Send confirmation', type: 'notify', node: 'Gmail → Send Email' },
      ];
    }

    // Automation score
    var totalSteps = actions.length + 1;
    var automatable = actions.filter(function(a) {
      return ['read', 'write', 'notify', 'output'].indexOf(a.type) !== -1;
    }).length + 1;
    var score = Math.round((automatable / totalSteps) * 100);
    score = Math.min(96, Math.max(62, score));

    // Time saved estimate
    var timeSaved = Math.min(32, Math.max(3, Math.round(actions.length * 1.8)));
    var hoursPerMonth = timeSaved * 20;

    // Complexity
    var complexity = actions.length <= 4 ? 'Low' : actions.length <= 8 ? 'Medium' : 'High';
    var buildDays = actions.length <= 4 ? '1–2 days' : actions.length <= 8 ? '3–5 days' : '5–7 days';

    return { trigger, actions, toolsFound, score, timeSaved, hoursPerMonth, complexity, buildDays };
  }

