---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';

const PINK = '#c4847e';
const PINK_BG = 'rgba(232,180,176,0.10)';

const rows = [
  { feature: 'Time to first result',  purist: '< 7 days',              other: '3–6 months onboarding' },
  { feature: 'Monthly cost',          purist: 'From £799/mo',           other: '£4,000–£8,000/mo salary' },
  { feature: 'Workflows delivered',   purist: '12+ in month one',       other: '1–2 depending on scope' },
  { feature: 'Availability',          purist: '24/7 automated',         other: '40h/week, holidays, sick days' },
  { feature: 'Knowledge retained',    purist: '100% — code you own',    other: 'Leaves with the employee' },
  { feature: 'Scales instantly',      purist: 'Yes — unlimited',        other: 'Hire again' },
  { feature: 'AI capabilities',       purist: 'Claude Opus built-in',   other: 'Depends on individual' },
  { feature: 'Error monitoring',      purist: '24/7 — 90s alert',       other: 'Only when at desk' },
  { feature: 'Guarantee',             purist: '30-day money back',      other: 'Probation period only' },
  { feature: 'Risk if it fails',      purist: 'Full refund',            other: 'Redundancy cost + time lost' },
];
---

<BaseLayout
  title="PURIST vs Hiring In-House — The Real Cost Comparison | PURIST Automation"
  description="Compare hiring an automation developer vs deploying PURIST. Lower cost, faster results, 24/7 availability and no knowledge risk when someone leaves."
>
  <Header />
  <main id="main-content">

    <div class="py-16 lg:py-24" style="background:#0A0A0A">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
        <p class="text-xs uppercase tracking-widest font-bold mb-4" style={`color:${PINK}`}>Comparison</p>
        <h1 class="text-3xl lg:text-5xl font-bold text-white mb-5 leading-tight">PURIST vs Hiring In-House</h1>
        <p class="text-base lg:text-lg text-gray-400 max-w-2xl mx-auto mb-8">
          An automation developer costs £50–90k/year and delivers 1–2 workflows per month after a long onboarding. PURIST delivers 12+ workflows in under a week, at a fraction of the cost.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/pages/welcome" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white transition" style={`background:${PINK}`}>Book free audit →</a>
          <a href="/collections/all" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm border border-gray-700 text-gray-300 hover:border-gray-500 transition">View plans</a>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-14 lg:py-20">

      <div class="overflow-x-auto rounded-2xl border border-gray-200 mb-14">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 bg-gray-50">
              <th class="text-left px-5 py-4 font-semibold text-gray-700 w-1/3">Feature</th>
              <th class="text-center px-5 py-4 font-bold" style={`color:${PINK}`}>PURIST</th>
              <th class="text-center px-5 py-4 font-semibold text-gray-400">In-house hire</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {rows.map(r => (
              <tr class="hover:bg-gray-50 transition">
                <td class="px-5 py-3.5 text-gray-600 font-medium">{r.feature}</td>
                <td class="px-5 py-3.5 text-center font-semibold text-gray-900">{r.purist}</td>
                <td class="px-5 py-3.5 text-center text-gray-400">{r.other}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="grid sm:grid-cols-3 gap-6 mb-14">
        {[
          { value: '6×',    label: 'Cheaper than a hire',   desc: 'PURIST Full Stack at £1,499/mo vs a mid-level automation dev at £72k/year.' },
          { value: '12+',   label: 'Workflows in month one', desc: 'A new hire spends months onboarding. PURIST is live in under 7 days.' },
          { value: '100%',  label: 'Knowledge retained',    desc: 'Every workflow lives in your infrastructure. No knowledge walks out the door.' },
        ].map(s => (
          <div class="rounded-xl border border-gray-200 p-6 text-center">
            <p class="text-3xl font-bold mb-1" style={`color:${PINK}`}>{s.value}</p>
            <p class="text-sm font-semibold text-gray-900 mb-2">{s.label}</p>
            <p class="text-xs text-gray-500 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>

      <div class="rounded-2xl p-8 text-center" style={`background:${PINK_BG};border:1px solid rgba(196,132,126,0.20)`}>
        <h2 class="text-xl font-bold text-gray-900 mb-3">Get a free ROI comparison for your business.</h2>
        <p class="text-sm text-gray-600 mb-6 max-w-lg mx-auto">In 60 minutes we calculate the exact cost of hiring vs deploying PURIST for your specific processes — and show you which automations to start with.</p>
        <a href="/pages/welcome" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white transition" style={`background:${PINK}`}>Book your free audit →</a>
      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>
