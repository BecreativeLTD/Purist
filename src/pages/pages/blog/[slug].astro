<script type="application/ld+json" is:inline set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'Article',
 '@id': `${pageUrl}#article`,
 headline: article.title,
 description: article.metaDescription ?? article.excerpt,
 url: pageUrl,
 datePublished: schemaDate,
 dateModified: schemaDate,
 wordCount: wordCount,
 inLanguage: 'en-GB',
 image: {
   '@type': 'ImageObject',
   url: `https://purist.online${article.image}`,
   width: 1200,
   height: 630,
 },
 thumbnailUrl: `https://purist.online${article.image}`,
 author: {
   '@type': 'Organization',
   '@id': 'https://purist.online/#organization',
   name: 'PURIST',
   url: 'https://purist.online',
 },
 publisher: {
   '@type': 'Organization',
   '@id': 'https://purist.online/#organization',
   name: 'PURIST',
   url: 'https://purist.online',
   logo: {
     '@type': 'ImageObject',
     url: 'https://purist.online/favicon.svg',
     width: 512,
     height: 512,
   },
 },
 mainEntityOfPage: {
   '@type': 'WebPage',
   '@id': pageUrl,
 },
 isPartOf: {
   '@type': 'WebSite',
   '@id': 'https://purist.online/#website',
   name: 'PURIST',
   url: 'https://purist.online',
 },
 breadcrumb: {
   '@type': 'BreadcrumbList',
   itemListElement: [
     { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://purist.online' },
     { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://purist.online/pages/blog' },
     { '@type': 'ListItem', position: 3, name: article.title, item: pageUrl },
   ],
 },
 speakable: {
   '@type': 'SpeakableSpecification',
   cssSelector: ['h1', '.article-excerpt', 'blockquote p'],
 },
 about: (article.tags ?? []).slice(0, 5).map((tag: string) => ({
   '@type': 'Thing',
   name: tag,
 })),
 keywords: (article.tags ?? []).join(', '),
 articleSection: category?.name ?? article.category,
 articleBody: article.excerpt,
})}/>

{faqItems.length > 0 && (
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    '@id': `${pageUrl}#faqpage`,
    url: pageUrl,
    mainEntity: faqItems.map(item => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  })}/>
)}

{isHowTo && howToSteps.length > 0 && (
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    '@id': `${pageUrl}#howto`,
    name: article.title,
    description: article.excerpt,
    url: pageUrl,
    totalTime: `PT${parseInt(article.readingTime) * 2 || 30}M`,
    step: howToSteps.map((step, i) => ({
      '@type': 'HowToStep',
      position: i + 1,
      name: step.name,
      text: step.text,
      url: `${pageUrl}#step-${i + 1}`,
    })),
  })}/>
)}

<script is:inline>
 // Progress bar
 var bar = document.getElementById('progress-bar');
 if (bar) {
   window.addEventListener('scroll', function() {
     var doc = document.documentElement;
     var scrolled = doc.scrollTop / (doc.scrollHeight - doc.clientHeight);
     bar.style.width = Math.min(scrolled * 100, 100) + '%';
   }, { passive: true });
 }

 // Show ToC aside on desktop
 var aside = document.getElementById('toc-aside');
 if (aside && window.innerWidth >= 1024) {
   aside.style.display = 'block';
 }
 window.addEventListener('resize', function() {
   if (aside) aside.style.display = window.innerWidth >= 1024 ? 'block' : 'none';
 });

 // Active ToC link on scroll
 var tocLinks = document.querySelectorAll('.toc-link');
 if (tocLinks.length) {
   var headings = Array.from(document.querySelectorAll('h2[id]'));
   var obs = new IntersectionObserver(function(entries) {
     entries.forEach(function(e) {
       if (e.isIntersecting) {
         tocLinks.forEach(function(l) {
           l.classList.remove('active');
           l.style.color = 'rgba(10,10,10,0.45)';
           l.style.borderLeftColor = 'rgba(10,10,10,0.08)';
         });
         var active = document.querySelector('.toc-link[data-id="' + e.target.id + '"]');
         if (active) {
           active.classList.add('active');
           active.style.color = '#0A0A0A';
           active.style.borderLeftColor = '#E8B4B0';
           active.style.fontWeight = '600';
         }
       }
     });
   }, { rootMargin: '-20% 0px -70% 0px' });
   headings.forEach(function(h) { obs.observe(h); });
 }
</script>

