---
import ShopLayout from '~/layouts/ShopLayout.astro';
import blogData from '~/data/blog.json';

export function getStaticPaths() {
  return blogData.articles.map((a) => ({
    params: { slug: a.slug },
    props: { article: a },
  }));
}

const { article } = Astro.props;
const { categories, articles } = blogData;
const category = categories.find((c) => c.id === article.category);
const sameCat = articles.filter((a) => a.id !== article.id && a.category === article.category);
const others  = articles.filter((a) => a.id !== article.id && a.category !== article.category);
const moreArticles = [...sameCat, ...others].slice(0, 3);

// ── Parse body into structured blocks ──────────────────────────
type Block =
  | { type: 'h2'; text: string; id: string }
  | { type: 'h3'; text: string }
  | { type: 'blockquote'; text: string }
  | { type: 'callout'; text: string }
  | { type: 'list'; items: string[] }
  | { type: 'paragraph'; text: string; first: boolean };

const slugify = (t: string) => t.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

const blocks: Block[] = [];
let firstPara = true;
let listBuffer: string[] = [];

const flushList = () => {
  if (listBuffer.length) { blocks.push({ type: 'list', items: [...listBuffer] }); listBuffer = []; }
};

for (const raw of article.body.split('\n\n')) {
  const line = raw.trim();
  if (!line) continue;

  if (line.startsWith('## ')) {
    flushList();
    const text = line.slice(3);
    blocks.push({ type: 'h2', text, id: slugify(text) });
  } else if (line.startsWith('### ')) {
    flushList();
    blocks.push({ type: 'h3', text: line.slice(4) });
  } else if (line.startsWith('> ')) {
    flushList();
    blocks.push({ type: 'blockquote', text: line.slice(2) });
  } else if (line.startsWith('!! ')) {
    flushList();
    blocks.push({ type: 'callout', text: line.slice(3) });
  } else if (line.startsWith('- ')) {
    const items = line.split('\n').filter(l => l.startsWith('- ')).map(l => l.slice(2));
    blocks.push({ type: 'list', items });
  } else {
    flushList();
    blocks.push({ type: 'paragraph', text: line, first: firstPara });
    firstPara = false;
  }
}
flushList();

// ── ToC from H2 blocks ─────────────────────────────────────────
const toc = blocks.filter((b): b is Extract<Block, { type: 'h2' }> => b.type === 'h2');

// ── Word count & reading time ──────────────────────────────────
const wordCount = article.body.split(/\s+/).length;
const pageUrl = `${(Astro.site?.toString() ?? 'https://purist.online').replace(/\/$/, '')}/pages/blog/${article.slug}`;
const schemaDate = (() => {
  const months: Record<string,string> = { January:'01',February:'02',March:'03',April:'04',May:'05',June:'06',July:'07',August:'08',September:'09',October:'10',November:'11',December:'12' };
  const [m, y] = article.date.split(' ');
  return `${y}-${months[m] ?? '01'}-01`;
})();
---

<ShopLayout
  title={article.metaTitle ?? `${article.title} – PURIST`}
  description={article.metaDescription ?? article.excerpt}
>

<!-- ── PROGRESS BAR ───────────────────────────────────── -->
<div id="progress-bar" style="position:fixed;top:0;left:0;height:2px;background:#E8B4B0;width:0%;z-index:200;transition:width 0.1s linear;" aria-hidden="true"></div>

<!-- ── HERO ──────────────────────────────────────────────────── -->
<header style="background:#0A0A0A;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 70% 50%,rgba(232,180,176,0.07) 0%,transparent 70%);pointer-events:none;"></div>

  <div class="container-x" style="position:relative;z-index:10;padding-top:2.5rem;padding-bottom:0;">

    <!-- Breadcrumb -->
    <nav aria-label="Fil d'Ariane" style="margin-bottom:2rem;">
      <ol itemscope itemtype="https://schema.org/BreadcrumbList" style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;list-style:none;">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a itemprop="item" href="/" style="font-size:10px;font-weight:500;color:rgba(255,255,255,0.3);text-decoration:none;" onmouseover="this.style.color='rgba(255,255,255,0.65)'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">
            <span itemprop="name">Home</span>
          </a>
          <meta itemprop="position" content="1"/>
        </li>
        <li aria-hidden="true" style="color:rgba(255,255,255,0.18);font-size:10px;">/</li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a itemprop="item" href="/pages/blog" style="font-size:10px;font-weight:500;color:rgba(255,255,255,0.3);text-decoration:none;" onmouseover="this.style.color='rgba(255,255,255,0.65)'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">
            <span itemprop="name">Blog</span>
          </a>
          <meta itemprop="position" content="2"/>
        </li>
        <li aria-hidden="true" style="color:rgba(255,255,255,0.18);font-size:10px;">/</li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" style="font-size:10px;color:rgba(255,255,255,0.4);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:260px;">
          <span itemprop="name">{article.title}</span>
          <meta itemprop="position" content="3"/>
        </li>
      </ol>
    </nav>

    <div style="max-width:700px;margin-bottom:2.5rem;">
      <!-- Category + reading time -->
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:1.25rem;flex-wrap:wrap;">
        <a href={`/pages/blog?cat=${article.category}`}
           style="font-size:9px;text-transform:uppercase;letter-spacing:0.2em;font-weight:700;padding:5px 12px;border-radius:100px;background:rgba(232,180,176,0.12);color:#E8B4B0;border:1px solid rgba(232,180,176,0.22);text-decoration:none;">
          {category?.name ?? article.category}
        </a>
        <span style="font-size:10px;color:rgba(255,255,255,0.25);">{article.readingTime}</span>
        <span style="font-size:10px;color:rgba(255,255,255,0.18);">·</span>
        <span style="font-size:10px;color:rgba(255,255,255,0.25);">{wordCount.toLocaleString()} words</span>
      </div>

      <h1 style="font-family:'Fraunces',Georgia,serif;font-size:clamp(1.75rem,4vw,2.75rem);font-weight:400;letter-spacing:-0.025em;line-height:1.1;color:#fff;margin-bottom:1.25rem;">
        {article.title}
      </h1>
      <p style="font-size:15px;line-height:1.75;color:rgba(255,255,255,0.42);margin-bottom:2rem;max-width:580px;">
        {article.excerpt}
      </p>

      <!-- Author + date + share -->
      <div style="display:flex;align-items:center;gap:12px;padding-bottom:2.5rem;flex-wrap:wrap;">
        <div style="width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;background:rgba(232,180,176,0.15);border:1px solid rgba(232,180,176,0.25);color:#E8B4B0;flex-shrink:0;">
          {article.author.split(' ').map((w: string) => w[0]).join('').slice(0,2).toUpperCase()}
        </div>
        <div>
          <p style="font-size:11.5px;font-weight:600;color:rgba(255,255,255,0.75);">{article.author}</p>
          <p style="font-size:9.5px;color:rgba(255,255,255,0.28);">{article.date}</p>
        </div>
        <div style="margin-left:auto;display:flex;align-items:center;gap:16px;">
          <a href={`https://x.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener" style="font-size:10px;color:rgba(255,255,255,0.3);text-decoration:none;display:flex;align-items:center;gap:5px;" onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>
          <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener" style="font-size:10px;color:rgba(255,255,255,0.3);text-decoration:none;display:flex;align-items:center;gap:5px;" onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            LinkedIn
          </a>
          <a href={`mailto:?subject=${encodeURIComponent(article.title)}&body=${encodeURIComponent(pageUrl)}`} style="font-size:10px;color:rgba(255,255,255,0.3);text-decoration:none;display:flex;align-items:center;gap:5px;" onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>
            Email
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Hero image -->
  <div style="position:relative;overflow:hidden;aspect-ratio:21/8;min-height:240px;">
    <img src={article.image} alt={article.title} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" loading="eager"/>
    <div style="position:absolute;inset:0;background:linear-gradient(0deg,#0A0A0A 0%,transparent 45%);"></div>
  </div>
</header>

<!-- ── ARTICLE BODY ───────────────────────────────────────────── -->
<article style="background:#fff;padding:5rem 0;" itemscope itemtype="https://schema.org/Article">
  <meta itemprop="headline" content={article.title}/>
  <meta itemprop="description" content={article.excerpt}/>
  <meta itemprop="datePublished" content={schemaDate}/>
  <meta itemprop="wordCount" content={String(wordCount)}/>

  <div class="container-x">
    <div style="display:grid;grid-template-columns:1fr minmax(0,660px) minmax(0,220px) 1fr;gap:0 3rem;align-items:start;" id="article-grid">

      <!-- Left spacer -->
      <div></div>

      <!-- Main content -->
      <div style="min-width:0;" itemprop="articleBody">
        {blocks.map((block) => {
          if (block.type === 'h2') return (
            <h2 id={block.id} style="font-family:'Fraunces',Georgia,serif;font-size:clamp(1.4rem,3vw,1.9rem);font-weight:400;letter-spacing:-0.02em;line-height:1.2;color:#0A0A0A;margin:3rem 0 1.25rem;scroll-margin-top:80px;">
              {block.text}
            </h2>
          );
          if (block.type === 'h3') return (
            <h3 style="font-family:'Fraunces',Georgia,serif;font-size:1.2rem;font-weight:400;letter-spacing:-0.01em;line-height:1.3;color:#0A0A0A;margin:2rem 0 0.75rem;">
              {block.text}
            </h3>
          );
          if (block.type === 'blockquote') return (
            <blockquote style="border-left:3px solid #E8B4B0;padding:1.25rem 1.5rem;margin:2rem 0;background:#FDF9F8;border-radius:0 12px 12px 0;">
              <p style="font-family:'Fraunces',Georgia,serif;font-size:1.1rem;font-style:italic;font-weight:400;color:#0A0A0A;line-height:1.6;margin:0;">{block.text}</p>
            </blockquote>
          );
          if (block.type === 'callout') return (
            <div style="background:#0A0A0A;border-radius:14px;padding:1.5rem 1.75rem;margin:2rem 0;display:flex;align-items:flex-start;gap:12px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
              <p style="font-size:13.5px;color:rgba(255,255,255,0.85);line-height:1.6;margin:0;font-weight:500;">{block.text}</p>
            </div>
          );
          if (block.type === 'list') return (
            <ul style="margin:1.25rem 0;padding-left:0;list-style:none;display:flex;flex-direction:column;gap:10px;">
              {block.items.map((item: string) => (
                <li style="display:flex;align-items:flex-start;gap:10px;font-size:15px;line-height:1.7;color:rgba(10,10,10,0.78);">
                  <span style="width:5px;height:5px;border-radius:50%;background:#E8B4B0;flex-shrink:0;margin-top:9px;"></span>
                  {item}
                </li>
              ))}
            </ul>
          );
          if (block.type === 'paragraph' && block.first) return (
            <p style="font-size:17px;line-height:1.8;color:#0A0A0A;margin-bottom:1.5rem;font-feature-settings:'kern' 1,'liga' 1;">
              <span style="float:left;font-family:'Fraunces',Georgia,serif;font-size:4.5rem;line-height:0.82;margin-right:8px;margin-top:8px;color:#0A0A0A;">{block.text[0]}</span>{block.text.slice(1)}
            </p>
          );
          return (
            <p style="font-size:16px;line-height:1.85;color:rgba(10,10,10,0.78);margin-bottom:1.5rem;">{(block as any).text}</p>
          );
        })}

        <!-- Tags -->
        {article.tags && article.tags.length > 0 && (
          <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(10,10,10,0.07);">
            <p style="font-size:9.5px;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:rgba(10,10,10,0.3);margin-bottom:10px;">Tags</p>
            <div style="display:flex;flex-wrap:wrap;gap:6px;">
              {article.tags.map((tag: string) => (
                <span style="font-size:10px;padding:4px 10px;border-radius:100px;background:#F4EFE6;color:#6B6B6B;font-weight:500;">{tag}</span>
              ))}
            </div>
          </div>
        )}

        <!-- Author box -->
        <div style="margin-top:3rem;padding:1.5rem;border-radius:16px;background:#F8F6F1;border:1px solid rgba(10,10,10,0.07);display:flex;gap:1rem;align-items:flex-start;">
          <div style="width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;background:#0A0A0A;color:#E8B4B0;flex-shrink:0;">
            {article.author.split(' ').map((w: string) => w[0]).join('').slice(0,2).toUpperCase()}
          </div>
          <div>
            <p style="font-size:12px;font-weight:700;color:#0A0A0A;margin-bottom:2px;" itemprop="author" itemscope itemtype="https://schema.org/Person"><span itemprop="name">{article.author}</span></p>
            <p style="font-size:11px;color:#6B6B6B;line-height:1.5;">The PURIST editorial team covers automation, AI agents, and operations strategy for businesses scaling with n8n, Make, and Claude AI.</p>
          </div>
        </div>

        <!-- Share bottom -->
        <div style="margin-top:2.5rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
          <span style="font-size:10.5px;font-weight:600;text-transform:uppercase;letter-spacing:0.14em;color:rgba(10,10,10,0.3);">Share</span>
          <a href={`https://x.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:600;padding:7px 14px;border-radius:8px;background:#0A0A0A;color:#fff;text-decoration:none;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Share on X
          </a>
          <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:600;padding:7px 14px;border-radius:8px;border:1.5px solid #E5E5E5;color:#0A0A0A;text-decoration:none;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            LinkedIn
          </a>
        </div>
      </div>

      <!-- Sticky ToC (desktop) -->
      <aside style="display:none;" id="toc-aside">
        <div style="position:sticky;top:90px;">
          <p style="font-size:9px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:rgba(10,10,10,0.3);margin-bottom:12px;">In this article</p>
          <nav>
            <ol style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:2px;">
              {toc.map((h, i) => (
                <li>
                  <a href={`#${h.id}`}
                     class="toc-link"
                     data-id={h.id}
                     style="display:block;font-size:11px;line-height:1.45;padding:5px 10px 5px 12px;border-left:2px solid rgba(10,10,10,0.08);color:rgba(10,10,10,0.45);text-decoration:none;transition:all 0.15s;border-radius:0 4px 4px 0;"
                     onmouseover="this.style.color='#0A0A0A';this.style.borderLeftColor='#0A0A0A'"
                     onmouseout="if(!this.classList.contains('active')){this.style.color='rgba(10,10,10,0.45)';this.style.borderLeftColor='rgba(10,10,10,0.08)'}"
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>

          <!-- CTA inline -->
          <div style="margin-top:2rem;padding:1.25rem;border-radius:14px;background:#0A0A0A;">
            <p style="font-size:11px;font-weight:600;color:#fff;margin-bottom:6px;line-height:1.4;">Ready to automate your business?</p>
            <p style="font-size:10px;color:rgba(255,255,255,0.4);margin-bottom:12px;line-height:1.5;">Free audit within 48h.</p>
            <a href="/pages/welcome" style="display:block;text-align:center;font-size:11px;font-weight:600;padding:9px;border-radius:8px;background:#E8B4B0;color:#0A0A0A;text-decoration:none;">
              Book your free audit →
            </a>
          </div>
        </div>
      </aside>

      <!-- Right spacer -->
      <div></div>
    </div>
  </div>
</article>

<!-- ── RELATED ARTICLES ───────────────────────────────────────── -->
{moreArticles.length > 0 && (
  <section style="background:#F8F6F1;border-top:1px solid rgba(10,10,10,0.07);padding:5rem 0;">
    <div class="container-x">
      <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2.5rem;flex-wrap:wrap;gap:1rem;">
        <div>
          <p style="font-size:9px;text-transform:uppercase;letter-spacing:0.26em;font-weight:700;color:rgba(10,10,10,0.35);margin-bottom:6px;">Keep reading</p>
          <h2 style="font-family:'Fraunces',Georgia,serif;font-size:clamp(1.5rem,3vw,2rem);font-weight:400;letter-spacing:-0.02em;">More from the blog.</h2>
        </div>
        <a href="/pages/blog" style="font-size:11px;font-weight:600;color:rgba(10,10,10,0.4);text-decoration:none;display:flex;align-items:center;gap:6px;" onmouseover="this.style.color='#0A0A0A'" onmouseout="this.style.color='rgba(10,10,10,0.4)'">
          All articles
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7h10M8 3l4 4-4 4"/></svg>
        </a>
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;">
        {moreArticles.map((a) => (
          <article style="background:#fff;border:1px solid rgba(10,10,10,0.07);border-radius:18px;overflow:hidden;transition:box-shadow 0.2s,transform 0.2s;display:flex;flex-direction:column;"
                   onmouseover="this.style.boxShadow='0 8px 28px rgba(10,10,10,0.09)';this.style.transform='translateY(-2px)'"
                   onmouseout="this.style.boxShadow='';this.style.transform=''">
            <a href={`/pages/blog/${a.slug}`} style="display:block;aspect-ratio:16/9;position:relative;overflow:hidden;">
              <img src={a.image} alt={a.title} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform 0.7s;" loading="lazy"
                   onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform=''"/>
              <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(10,10,10,0.3) 100%);"></div>
              <span style="position:absolute;bottom:12px;left:12px;font-size:8.5px;text-transform:uppercase;letter-spacing:0.15em;font-weight:700;padding:4px 10px;border-radius:100px;background:rgba(10,10,10,0.55);color:rgba(255,255,255,0.85);backdrop-filter:blur(6px);">
                {categories.find((c) => c.id === a.category)?.name ?? a.category}
              </span>
            </a>
            <div style="padding:1.25rem;display:flex;flex-direction:column;flex:1;">
              <h3 style="font-family:'Fraunces',Georgia,serif;font-size:17px;line-height:1.3;letter-spacing:-0.01em;margin-bottom:8px;color:#0A0A0A;">
                <a href={`/pages/blog/${a.slug}`} style="text-decoration:none;color:inherit;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">{a.title}</a>
              </h3>
              <p style="font-size:12px;line-height:1.6;color:rgba(10,10,10,0.48);flex:1;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{a.excerpt}</p>
              <div style="display:flex;align-items:center;gap:6px;margin-top:1rem;padding-top:1rem;border-top:1px solid rgba(10,10,10,0.06);font-size:10px;color:rgba(10,10,10,0.35);">
                <span>{a.date}</span>
                <span>·</span>
                <span>{a.readingTime}</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
)}

<!-- ── CTA STRIP ──────────────────────────────────────────────── -->
<section style="background:#0A0A0A;padding:5rem 0;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse 50% 70% at 75% 50%,rgba(232,180,176,0.06) 0%,transparent 70%);pointer-events:none;"></div>
  <div class="container-x" style="position:relative;z-index:10;text-align:center;max-width:600px;margin-left:auto;margin-right:auto;">
    <p style="font-size:9px;text-transform:uppercase;letter-spacing:0.26em;font-weight:700;color:rgba(232,180,176,0.5);margin-bottom:1rem;">From audit to deployment</p>
    <h2 style="font-family:'Fraunces',Georgia,serif;font-size:clamp(1.75rem,4vw,2.75rem);font-weight:400;color:#fff;line-height:1.15;letter-spacing:-0.02em;margin-bottom:2rem;">
      Experience the automation<br/><em style="color:#E8B4B0;font-style:italic;">these articles are about.</em>
    </h2>
    <a href="/pages/welcome"
       style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:12px;font-size:13.5px;font-weight:600;background:#E8B4B0;color:#0A0A0A;text-decoration:none;"
       onmouseover="this.style.background='#d9a09b'" onmouseout="this.style.background='#E8B4B0'">
