---
import ShopLayout from '~/layouts/ShopLayout.astro';
import blogData from '~/data/blog.json';
import { terms as _glossaryTerms } from '~/data/glossary';

export function getStaticPaths() {
 return blogData.articles.map((a) => ({
   params: { slug: a.slug },
   props: { article: a },
 }));
}

const { article } = Astro.props;
const { categories, articles } = blogData;
const category = categories.find((c) => c.id === article.category);
const sameCat = articles.filter((a) => a.id !== article.id && a.category === article.category);
const others = articles.filter((a) => a.id !== article.id && a.category !== article.category);
const moreArticles = [...sameCat, ...others].slice(0, 3);

// ── Silo navigation ───────────────────────────────────────────
const hasSilo = !!(article as any).silo;
const siloName: string = (article as any).siloName ?? '';
const isPillar: boolean = (article as any).isPillar ?? false;
const pillarSlug: string = (article as any).pillarSlug ?? '';
const siloClusterArticles = hasSilo
 ? articles.filter((a) => (a as any).silo === (article as any).silo && a.slug !== article.slug)
 : [];
const pillarArticle = hasSilo && !isPillar
 ? articles.find((a) => a.slug === pillarSlug)
 : null;

// ── Parse body into structured blocks ──────────────────────────
type Block =
 | { type: 'h2'; text: string; id: string }
 | { type: 'h3'; text: string }
 | { type: 'blockquote'; text: string }
 | { type: 'callout'; text: string }
 | { type: 'list'; items: string[] }
 | { type: 'paragraph'; text: string; first: boolean };

const slugify = (t: string) => t.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

const blocks: Block[] = [];
let firstPara = true;
let listBuffer: string[] = [];

const flushList = () => {
 if (listBuffer.length) { blocks.push({ type: 'list', items: [...listBuffer] }); listBuffer = []; }
};

for (const raw of article.body.split('\n\n')) {
 const line = raw.trim();
 if (!line) continue;

 if (line.startsWith('## ')) {
   flushList();
   const text = line.slice(3);
   blocks.push({ type: 'h2', text, id: slugify(text) });
 } else if (line.startsWith('### ')) {
   flushList();
   blocks.push({ type: 'h3', text: line.slice(4) });
 } else if (line.startsWith('> ')) {
   flushList();
   blocks.push({ type: 'blockquote', text: line.slice(2) });
 } else if (line.startsWith('!! ')) {
   flushList();
   blocks.push({ type: 'callout', text: line.slice(3) });
 } else if (line.startsWith('- ')) {
   const items = line.split('\n').filter(l => l.startsWith('- ')).map(l => l.slice(2));
   blocks.push({ type: 'list', items });
 } else {
   flushList();
   blocks.push({ type: 'paragraph', text: line, first: firstPara });
   firstPara = false;
 }
}
flushList();

// ── ToC from H2 blocks ─────────────────────────────────────────
const toc = blocks.filter((b): b is Extract<Block, { type: 'h2' }> => b.type === 'h2');

// ── Word count & reading time ──────────────────────────────────
const wordCount = article.body.split(/\s+/).length;
const pageUrl = `${(Astro.site?.toString() ?? 'https://purist.online').replace(/\/$/, '')}/pages/blog/${article.slug}`;

// ── Markdown link parser ───────────────────────────────────────
function parseMdLinks(text: string): string {
 return text.replace(
   /\[([^\]]+)\]\(([^)]+)\)/g,
   '<a href="$2" style="color:#0A0A0A;font-weight:600;text-decoration:underline;text-decoration-color:rgba(232,180,176,0.8);text-underline-offset:3px;transition:text-decoration-color 0.15s;">$1</a>'
 );
}

// ── Glossary auto-linker (first occurrence per term, max 10 per article) ──
const _sortedGlossary = [..._glossaryTerms].sort((a, b) => b.term.length - a.term.length);
const _linkedSlugs = new Set<string>();

function linkifyGlossary(text: string): string {
 if (_linkedSlugs.size >= 10) return text;
 let out = text;
 for (const gt of _sortedGlossary) {
   if (_linkedSlugs.has(gt.slug)) continue;
   const esc = gt.term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
   const re = new RegExp(`(?<![\\w/.-])(${esc})(?![\\w/.-])`, 'i');
   if (re.test(out)) {
     out = out.replace(re, (match) => {
       _linkedSlugs.add(gt.slug);
       return `<a href="/pages/glossary/${gt.slug}" style="color:inherit;font-weight:600;text-decoration:underline;text-decoration-color:rgba(232,180,176,0.7);text-underline-offset:3px;" title="${gt.term} see glossary">${match}</a>`;
     });
     if (_linkedSlugs.size >= 10) break;
   }
 }
 return out;
}
const schemaDate = (() => {
 const months: Record<string,string> = { January:'01',February:'02',March:'03',April:'04',May:'05',June:'06',July:'07',August:'08',September:'09',October:'10',November:'11',December:'12' };
 const [m, y] = article.date.split(' ');
 return `${y}-${months[m] ?? '01'}-01`;
})();

// ── FAQ Schema extraction ──────────────────────────────────
// Finds ## Frequently Asked Questions section and extracts Q&A pairs
const faqItems: { question: string; answer: string }[] = (() => {
  const body = article.body;
  const faqStart = body.search(/## Frequently Asked Questions/i);
  if (faqStart === -1) return [];
  const faqSection = body.slice(faqStart);
  const items: { question: string; answer: string }[] = [];
  const qaRegex = /### ([^\n]+)\n\n([\s\S]+?)(?=\n\n###|\n\n##|$)/g;
  let match;
  while ((match = qaRegex.exec(faqSection)) !== null) {
    const question = match[1].trim();
    const answer = match[2].trim().replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').slice(0, 500);
    if (question && answer) items.push({ question, answer });
  }
  return items.slice(0, 10);
})();

// ── HowTo Schema extraction ────────────────────────────────
// For tutorial/guide articles with numbered step sections
const isHowTo = ['guides', 'automation'].includes(article.category) && article.body.includes('### Step ');
const howToSteps: { name: string; text: string }[] = (() => {
  if (!isHowTo) return [];
  const stepRegex = /### Step \d+[:\s–-]+([^\n]+)\n\n([\s\S]+?)(?=\n\n###|\n\n##|$)/g;
  const steps: { name: string; text: string }[] = [];
  let match;
  while ((match = stepRegex.exec(article.body)) !== null) {
    steps.push({ name: match[1].trim(), text: match[2].trim().replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').slice(0, 300) });
  }
  return steps.slice(0, 10);
})();
---

<ShopLayout
 title={article.metaTitle ?? `${article.title} | PURIST`}
 description={article.metaDescription ?? article.excerpt}
 image={article.image}
 canonical={pageUrl}
 type="article"
>

<Fragment slot="head">
 {article.tags && article.tags.length > 0 && (
   <meta name="keywords" content={article.tags.join(', ')} />
 )}
 <meta property="article:published_time" content={schemaDate} />
 <meta property="article:author" content={article.author} />
 <meta property="article:section" content={category?.name ?? article.category} />
 {article.tags?.map((tag: string) => (
   <meta property="article:tag" content={tag} />
 ))}
</Fragment>

<style>
 /* ── Article grid: single column on mobile ── */
 #article-grid {
   display: grid;
   grid-template-columns: 1fr minmax(0,660px) minmax(0,220px) 1fr;
   gap: 0 3rem;
   align-items: start; /* keep article + spacers at top */
 }
 /* aside must fill grid cell height so sticky works */
 #article-grid aside {
   align-self: stretch;
 }
 @media (max-width: 1023px) {
   #article-grid {
     grid-template-columns: 1fr !important;
   }
   #article-grid > div:first-child,
   #article-grid > div:last-child {
     display: none;
   }
 }
 /* ── Article body font sizes on mobile ── */
 @media (max-width: 639px) {
   #article-grid p { font-size: 15px !important; line-height: 1.75 !important; }
   #article-grid h2 { font-size: 1.35rem !important; }
   #article-grid h3 { font-size: 1.1rem !important; }
   #article-grid li { font-size: 14px !important; }
 }
 /* ── Hero title + excerpt sizes ── */
 .article-title { font-size: clamp(1.55rem, 5vw, 2.75rem); }
 .article-excerpt { font-size: 14px; }
 @media (min-width: 640px) { .article-excerpt { font-size: 15px; } }
 /* ── Hero content padding on small screens ── */
 @media (max-width: 479px) {
   .article-hero-content { padding-top: 6rem !important; padding-bottom: 2rem !important; }
   .article-title { font-size: 1.45rem !important; }
 }
 /* ── Related articles grid ── */
 .related-grid {
   display: grid;
   grid-template-columns: repeat(3, 1fr);
   gap: 1.25rem;
 }
 @media (max-width: 767px) {
   .related-grid { grid-template-columns: 1fr !important; }
 }
 @media (min-width: 768px) and (max-width: 1023px) {
   .related-grid { grid-template-columns: repeat(2, 1fr) !important; }
 }
 /* ── Share buttons on mobile ── */
 @media (max-width: 480px) {
   .share-row { flex-direction: column; align-items: flex-start !important; }
 }
</style>

<!-- ── PROGRESS BAR ───────────────────────────────────── -->
<div id="progress-bar" style="position:fixed;top:0;left:0;height:2px;background:#E8B4B0;width:0%;z-index:200;transition:width 0.1s linear;" aria-hidden="true"></div>

<!-- ── HERO ──────────────────────────────────────────────────── -->
<header style="background:#0A0A0A;position:relative;overflow:hidden;min-height:480px;display:flex;flex-direction:column;justify-content:flex-end;">

 <!-- Full-bleed image as background -->
 <div style="position:absolute;inset:0;">
   <img src={article.image} alt={article.title} width="1200" height="630" style="width:100%;height:100%;object-fit:cover;opacity:0.32;" loading="eager"/>
   <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(10,10,10,0.15) 0%,rgba(10,10,10,0.55) 40%,#0A0A0A 85%);"></div>
 </div>

 <!-- Content on top of image -->
 <div class="container-x article-hero-content" style="position:relative;z-index:10;padding-top:5rem;padding-bottom:2.5rem;">

   <!-- Breadcrumb -->
   <nav aria-label="Breadcrumb" style="margin-bottom:1.5rem;">
     <ol itemscope itemtype="https://schema.org/BreadcrumbList" style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;list-style:none;padding:0;margin:0;">
       <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
         <a itemprop="item" href="/" style="font-size:10px;font-weight:500;color:rgba(255,255,255,0.35);text-decoration:none;" onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.35)'">
           <span itemprop="name">Home</span>
         </a>
         <meta itemprop="position" content="1"/>
       </li>
       <li aria-hidden="true" style="color:rgba(255,255,255,0.18);font-size:10px;">/</li>
       <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
         <a itemprop="item" href="/pages/blog" style="font-size:10px;font-weight:500;color:rgba(255,255,255,0.35);text-decoration:none;" onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.35)'">
           <span itemprop="name">Blog</span>
         </a>
         <meta itemprop="position" content="2"/>
       </li>
       <li aria-hidden="true" style="color:rgba(255,255,255,0.18);font-size:10px;">/</li>
       <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" style="font-size:10px;color:rgba(255,255,255,0.4);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:200px;">
         <span itemprop="name">{article.title}</span>
         <meta itemprop="position" content="3"/>
       </li>
     </ol>
   </nav>

   <div style="max-width:680px;">
     <!-- Category + reading time -->
     <div style="display:flex;align-items:center;gap:10px;margin-bottom:1rem;flex-wrap:wrap;">
       <a href={`/pages/blog?cat=${article.category}`}
          style="font-size:9px;text-transform:uppercase;letter-spacing:0.18em;font-weight:700;padding:4px 11px;border-radius:100px;background:rgba(232,180,176,0.14);color:#E8B4B0;border:1px solid rgba(232,180,176,0.25);text-decoration:none;">
         {category?.name ?? article.category}
       </a>
       <span style="font-size:10px;color:rgba(255,255,255,0.3);">{article.readingTime}</span>
       <span style="font-size:10px;color:rgba(255,255,255,0.16);">·</span>
       <span style="font-size:10px;color:rgba(255,255,255,0.3);">{wordCount.toLocaleString()} words</span>
     </div>

     <h1 class="article-title" style="font-family:'Fraunces',Georgia,serif;font-weight:400;letter-spacing:-0.025em;line-height:1.12;color:#fff;margin-bottom:1rem;">
       {article.title}
     </h1>
     <p class="article-excerpt" style="line-height:1.75;color:rgba(255,255,255,0.45);margin-bottom:1.75rem;max-width:560px;">
       {article.excerpt}
     </p>

     <!-- Author + share -->
     <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
       <div style="width:32px;height:32px;border-radius:50%;background:rgba(232,180,176,0.15);border:1px solid rgba(232,180,176,0.3);flex-shrink:0;display:flex;align-items:center;justify-content:center;">
         <span style="font-family:'Fraunces',Georgia,serif;font-size:13px;font-weight:600;color:#E8B4B0;letter-spacing:-0.02em;line-height:1;">P</span>
       </div>
       <div>
         <p style="font-size:11px;font-weight:600;color:rgba(255,255,255,0.75);margin:0;">{article.author}</p>
         <p style="font-size:9px;color:rgba(255,255,255,0.28);margin:0;">{article.date}</p>
       </div>
       <div style="margin-left:auto;display:flex;align-items:center;gap:14px;">
         <a href={`https://x.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener" style="font-size:10px;color:rgba(255,255,255,0.3);text-decoration:none;display:flex;align-items:center;gap:4px;" onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">
           <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
           X
         </a>
         <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener" style="font-size:10px;color:rgba(255,255,255,0.3);text-decoration:none;display:flex;align-items:center;gap:4px;" onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">
           <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
           LinkedIn
         </a>
       </div>
     </div>
   </div>
 </div>
</header>

<!-- ── ARTICLE BODY ───────────────────────────────────────────── -->
<article style="background:#fff;padding:5rem 0;" itemscope itemtype="https://schema.org/Article">
 <meta itemprop="headline" content={article.title}/>
 <meta itemprop="description" content={article.excerpt}/>
 <meta itemprop="datePublished" content={schemaDate}/>
 <meta itemprop="wordCount" content={String(wordCount)}/>

 <div class="container-x">
   <div id="article-grid">

     <!-- Left spacer -->
     <div></div>

     <!-- Main content -->
     <div style="min-width:0;" itemprop="articleBody">
       {blocks.map((block) => {
         if (block.type === 'h2') return (
           <h2 id={block.id} style="font-family:'Fraunces',Georgia,serif;font-size:clamp(1.4rem,3vw,1.9rem);font-weight:400;letter-spacing:-0.02em;line-height:1.2;color:#0A0A0A;margin:3rem 0 1.25rem;scroll-margin-top:80px;">
             {block.text}
           </h2>
         );
         if (block.type === 'h3') return (
           <h3 style="font-family:'Fraunces',Georgia,serif;font-size:1.2rem;font-weight:400;letter-spacing:-0.01em;line-height:1.3;color:#0A0A0A;margin:2rem 0 0.75rem;">
             {block.text}
           </h3>
         );
         if (block.type === 'blockquote') return (
           <blockquote style="border-left:3px solid #E8B4B0;padding:1.25rem 1.5rem;margin:2rem 0;background:#FDF9F8;border-radius:0 12px 12px 0;">
             <p style="font-family:'Fraunces',Georgia,serif;font-size:1.1rem;font-style:italic;font-weight:400;color:#0A0A0A;line-height:1.6;margin:0;">{block.text}</p>
           </blockquote>
         );
         if (block.type === 'callout') return (
           <div style="background:#0A0A0A;border-radius:14px;padding:1.5rem 1.75rem;margin:2rem 0;display:flex;align-items:flex-start;gap:12px;">
             <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
             <p style="font-size:13.5px;color:rgba(255,255,255,0.85);line-height:1.6;margin:0;font-weight:500;">{block.text}</p>
           </div>
         );
         if (block.type === 'list') return (
           <ul style="margin:1.25rem 0;padding-left:0;list-style:none;display:flex;flex-direction:column;gap:10px;">
             {block.items.map((item: string) => (
               <li style="display:flex;align-items:flex-start;gap:10px;font-size:15px;line-height:1.7;color:rgba(10,10,10,0.78);">
                 <span style="width:5px;height:5px;border-radius:50%;background:#E8B4B0;flex-shrink:0;margin-top:9px;"></span>
                 <Fragment set:html={parseMdLinks(linkifyGlossary(item))}/>
               </li>
             ))}
           </ul>
         );
         if (block.type === 'paragraph' && block.first) return (
           <p style="font-size:17px;line-height:1.8;color:#0A0A0A;margin-bottom:1.5rem;font-feature-settings:'kern' 1,'liga' 1;">
             <span style="float:left;font-family:'Fraunces',Georgia,serif;font-size:4.5rem;line-height:0.82;margin-right:8px;margin-top:8px;color:#0A0A0A;">{block.text[0]}</span><Fragment set:html={parseMdLinks(linkifyGlossary(block.text.slice(1)))}/>
           </p>
         );
         return (
           <p style="font-size:16px;line-height:1.85;color:rgba(10,10,10,0.78);margin-bottom:1.5rem;" set:html={parseMdLinks(linkifyGlossary((block as any).text))}/>
         );
       })}

       <!-- Tags -->
       {article.tags && article.tags.length > 0 && (
         <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(10,10,10,0.07);">
           <p style="font-size:9.5px;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:rgba(10,10,10,0.3);margin-bottom:10px;">Tags</p>
           <div style="display:flex;flex-wrap:wrap;gap:6px;">
             {article.tags.map((tag: string) => (
               <span style="font-size:10px;padding:4px 10px;border-radius:100px;background:#F4EFE6;color:#6B6B6B;font-weight:500;">{tag}</span>
             ))}
           </div>
         </div>
       )}

       <!-- Author box -->
       <div style="margin-top:3rem;padding:1.5rem;border-radius:16px;background:#F8F6F1;border:1px solid rgba(10,10,10,0.07);display:flex;gap:1rem;align-items:flex-start;">
         <div style="width:44px;height:44px;border-radius:50%;background:#0A0A0A;border:1.5px solid rgba(10,10,10,0.12);flex-shrink:0;display:flex;align-items:center;justify-content:center;">
           <span style="font-family:'Fraunces',Georgia,serif;font-size:18px;font-weight:600;color:#E8B4B0;letter-spacing:-0.02em;line-height:1;">P</span>
         </div>
         <div>
           <p style="font-size:12px;font-weight:700;color:#0A0A0A;margin-bottom:2px;" itemprop="author" itemscope itemtype="https://schema.org/Person"><span itemprop="name">{article.author}</span></p>
           <p style="font-size:11px;color:#6B6B6B;line-height:1.5;">The PURIST editorial team covers automation, AI agents, and operations strategy for businesses scaling with n8n, Make, and Claude AI.</p>
         </div>
       </div>

       <!-- Share bottom -->
       <div style="margin-top:2.5rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
         <span style="font-size:10.5px;font-weight:600;text-transform:uppercase;letter-spacing:0.14em;color:rgba(10,10,10,0.3);">Share</span>
         <a href={`https://x.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:600;padding:7px 14px;border-radius:8px;background:#0A0A0A;color:#fff;text-decoration:none;">
           <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
           Share on X
         </a>
         <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:600;padding:7px 14px;border-radius:8px;border:1.5px solid #E5E5E5;color:#0A0A0A;text-decoration:none;">
           <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
           LinkedIn
         </a>
       </div>
     </div>

     <!-- Sticky ToC (desktop) -->
     <aside style="display:none;" id="toc-aside">
