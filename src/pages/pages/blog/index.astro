---
import ShopLayout from '~/layouts/ShopLayout.astro';
import blogData from '~/data/blog.json';
const { categories, articles } = blogData;
const featured = articles.find((a) => a.featured) ?? articles[0];
const rest = articles; // show ALL articles in the grid
---

<ShopLayout
  title="The Automation Blog – PURIST"
  description="Workflow templates, automation case studies, AI agent insights, and the plumber paradox — from our engineering team."
>

<!-- ═══════════════════════════════════════════════
     HERO — editorial dark
════════════════════════════════════════════════ -->
<header class="relative overflow-hidden" style="background:#0A0A0A;">
  <!-- Subtle radial glow -->
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 70% 60% at 60% 50%,rgba(232,180,176,0.07) 0%,transparent 70%);"/>

  <div class="container-x relative z-10 py-12 lg:py-24">
    <div class="max-w-2xl">
      <p class="text-[9px] uppercase tracking-[0.28em] font-bold mb-4" style="color:rgba(232,180,176,0.6);">The Automation Blog</p>
      <h1 class="font-display text-[1.9rem] sm:text-[2.4rem] lg:text-[3.4rem] leading-[1.08] tracking-[-0.02em] text-white mb-4 text-balance">
        Stories about<br/><em class="font-medium" style="color:#E8B4B0;">working smarter,</em><br/>not harder.
      </h1>
      <p class="text-[13px] lg:text-base leading-relaxed max-w-lg" style="color:rgba(255,255,255,0.42);">
        Workflow templates, case studies, AI agent insights, and industry guides — from our engineering team.
      </p>
    </div>
  </div>

  <!-- Category tab bar -->
  <div class="relative z-10 border-t" style="border-color:rgba(255,255,255,0.07);">
    <div class="container-x">
      <div class="flex overflow-x-auto gap-px" style="scrollbar-width:none;" id="cat-bar">
        {categories.map((c, i) => (
          <a
            href={c.id === 'all' ? '/pages/blog' : `/pages/blog?cat=${c.id}`}
            data-cat={c.id}
            class="cat-btn group shrink-0 flex items-center gap-2 px-4 lg:px-5 py-4 text-left transition-all duration-150 border-b-2 whitespace-nowrap"
            style={i === 0
              ? 'border-color:#E8B4B0;color:rgba(255,255,255,0.9);'
              : 'border-color:transparent;color:rgba(255,255,255,0.35);'}
          >
            <svg class="w-3.5 h-3.5 shrink-0 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={c.icon}/>
            </svg>
            <span class="text-[11px] font-semibold tracking-[0.06em] uppercase leading-none">{c.name}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<!-- ═══════════════════════════════════════════════
     FEATURED ARTICLE
════════════════════════════════════════════════ -->
<section class="bg-brand-cream py-14 lg:py-20">
  <div class="container-x">
    <p class="text-[9px] uppercase tracking-[0.26em] font-bold mb-8" style="color:rgba(10,10,10,0.35);">Featured</p>
    <article class="grid md:grid-cols-[1fr_400px] lg:grid-cols-[1fr_480px] gap-0 rounded-[16px] overflow-hidden" style="background:#0A0A0A;border:1px solid rgba(255,255,255,0.06);">
      <!-- Image -->
      <a href={`/pages/blog/${featured.slug}`} class="block relative overflow-hidden" style="aspect-ratio:16/9;min-height:220px;">
        <img src={featured.image} alt={featured.title}
             width="1200" height="675"
             class="w-full h-full object-cover transition-transform duration-700 hover:scale-[1.03]"
             style="display:block;max-width:100%;"
             loading="eager"/>
        <div class="absolute inset-0 pointer-events-none" style="background:linear-gradient(135deg,rgba(10,10,10,0.3) 0%,transparent 60%);"/>
        <span class="absolute top-4 left-4 text-[9px] uppercase tracking-[0.18em] font-bold px-2.5 py-1 rounded-full" style="background:rgba(10,10,10,0.6);color:#E8B4B0;border:1px solid rgba(232,180,176,0.25);backdrop-filter:blur(8px);">
          {categories.find((c) => c.id === featured.category)?.name ?? featured.category}
        </span>
      </a>
      <!-- Content -->
      <div class="p-6 md:p-8 lg:p-10 flex flex-col justify-between" style="background:#0A0A0A;">
        <div>
          <div class="flex items-center gap-2 mb-4">
            <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background:#E8B4B0;"/>
            <span class="text-[9px] uppercase tracking-[0.2em] font-semibold" style="color:rgba(255,255,255,0.3);">Editor's pick</span>
          </div>
          <h2 class="font-display text-xl md:text-2xl lg:text-[1.75rem] leading-tight tracking-[-0.02em] text-white mb-3 text-balance">
            <a href={`/pages/blog/${featured.slug}`} class="hover:opacity-75 transition">{featured.title}</a>
          </h2>
          <p class="text-[13px] leading-relaxed mb-6 line-clamp-3" style="color:rgba(255,255,255,0.45);">{featured.excerpt}</p>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-5 text-[10px]" style="color:rgba(255,255,255,0.3);">
            <span class="font-semibold" style="color:rgba(255,255,255,0.55);">{featured.author}</span>
            <span aria-hidden="true">·</span>
            <span>{featured.date}</span>
            <span aria-hidden="true">·</span>
            <span>{featured.readingTime}</span>
          </div>
          <a href={`/pages/blog/${featured.slug}`}
             class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-[11px] font-semibold transition-all duration-150"
             style="background:rgba(232,180,176,0.12);color:#E8B4B0;border:1px solid rgba(232,180,176,0.22);"
             onmouseover="this.style.background='rgba(232,180,176,0.2)'"
             onmouseout="this.style.background='rgba(232,180,176,0.12)'"
          >
            Read article
            <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 7h10M8 3l4 4-4 4"/>
            </svg>
          </a>
        </div>
      </div>
    </article>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     ARTICLE GRID
════════════════════════════════════════════════ -->
<section class="bg-brand-cream pb-20 lg:pb-28" data-article-grid>
  <div class="container-x">
    <div class="flex items-center justify-between mb-8">
      <p class="text-[9px] uppercase tracking-[0.26em] font-bold" style="color:rgba(10,10,10,0.35);">All articles</p>
      <span class="text-[10.5px]" style="color:rgba(10,10,10,0.3);" id="article-count">{articles.length} articles</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
      {rest.map((a) => (
        <article
          data-article-card
          data-cat={a.category}
          class="group/card flex flex-col rounded-[16px] overflow-hidden transition-all duration-200"
          style="background:#fff;border:1px solid rgba(10,10,10,0.07);"
          onmouseover="this.style.boxShadow='0 8px 32px rgba(10,10,10,0.1)';this.style.transform='translateY(-2px)'"
          onmouseout="this.style.boxShadow='';this.style.transform=''"
        >
          <!-- Image thumbnail -->
          <a href={`/pages/blog/${a.slug}`} class="block relative overflow-hidden shrink-0" style="aspect-ratio:16/9;background:#0A0A0A;">
            <img src={a.image} alt={a.title}
                 width="480" height="270"
                 class="w-full h-full object-cover transition-transform duration-700 group-hover/card:scale-[1.025]"
                 style="display:block;max-width:100%;"
                 loading="lazy"/>
            <span class="absolute top-3 left-3 text-[8px] uppercase tracking-[0.14em] font-bold px-2 py-1 rounded-full" style="background:rgba(10,10,10,0.6);color:rgba(255,255,255,0.85);backdrop-filter:blur(6px);">
              {categories.find((c) => c.id === a.category)?.name ?? a.category}
            </span>
            {a.featured && (
              <span class="absolute top-3 right-3 text-[8px] uppercase tracking-[0.14em] font-bold px-2 py-1 rounded-full" style="background:#E8B4B0;color:#0A0A0A;">
                Featured
              </span>
            )}
          </a>
          <!-- Body -->
          <div class="p-4 lg:p-5 flex flex-col flex-1">
            <h3 class="font-display text-[15px] lg:text-[17px] leading-snug tracking-[-0.01em] mb-2 text-brand-black">
              <a href={`/pages/blog/${a.slug}`} class="hover:opacity-70 transition">{a.title}</a>
            </h3>
            <p class="text-[11.5px] leading-relaxed flex-1 line-clamp-2 mb-3" style="color:rgba(10,10,10,0.5);">{a.excerpt}</p>
            <!-- Footer meta -->
            <div class="flex items-center justify-between pt-3" style="border-top:1px solid rgba(10,10,10,0.06);">
              <div class="flex items-center gap-1.5 text-[10px]" style="color:rgba(10,10,10,0.38);">
                <span class="font-medium" style="color:rgba(10,10,10,0.55);">{a.date}</span>
                <span aria-hidden="true">·</span>
                <span>{a.readingTime}</span>
              </div>
              <svg class="w-3 h-3 transition-transform duration-150 group-hover/card:translate-x-0.5 shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:rgba(10,10,10,0.28);">
                <path d="M3 8h10M9 4l4 4-4 4"/>
              </svg>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     CTA STRIP
════════════════════════════════════════════════ -->
<section class="relative overflow-hidden py-16 lg:py-20" style="background:#0A0A0A;">
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 50% 70% at 75% 50%,rgba(232,180,176,0.06) 0%,transparent 70%);"/>
  <div class="container-x relative z-10 text-center max-w-2xl mx-auto">
    <p class="text-[9px] uppercase tracking-[0.26em] font-bold mb-4" style="color:rgba(232,180,176,0.5);">From the audit to the deployment</p>
    <h2 class="font-display text-3xl lg:text-4xl text-white leading-tight tracking-[-0.02em] mb-8 text-balance">
      Try the automation<br/><em class="font-medium" style="color:#E8B4B0;">these articles are about.</em>
    </h2>
    <a href="/pages/welcome"
       class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl text-[13px] font-semibold transition-all duration-150"
       style="background:#E8B4B0;color:#0A0A0A;"
       onmouseover="this.style.background='#d9a09b'"
       onmouseout="this.style.background='#E8B4B0'"
    >
      Book your free audit
      <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 8h10M9 4l4 4-4 4"/>
      </svg>
    </a>
  </div>
</section>

<style>
  /* ── Category tab active state ──────────────────────────────────── */
  .cat-btn.is-active {
    border-bottom-color: #E8B4B0 !important;
    color: rgba(255,255,255,0.9) !important;
  }
  .cat-btn:not(.is-active):hover {
    color: rgba(255,255,255,0.62) !important;
    border-bottom-color: rgba(255,255,255,0.15) !important;
  }
  #cat-bar { scrollbar-width: none; }
  #cat-bar::-webkit-scrollbar { display: none; }
</style>

<script is:inline>
  function applyFilter() {
    const params = new URLSearchParams(location.search);
    const cat = params.get('cat');
    const cards = document.querySelectorAll('[data-article-card]');
    let visible = 0;
    cards.forEach((el) => {
      const show = !cat || cat === 'all' || el.dataset.cat === cat;
      el.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    const countEl = document.getElementById('article-count');
    if (countEl) countEl.textContent = visible + ' article' + (visible !== 1 ? 's' : '');
    document.querySelectorAll('.cat-btn[data-cat]').forEach((el) => {
      el.classList.remove('is-active');
      if (el.dataset.cat === (cat || 'all')) el.classList.add('is-active');
    });
  }
  applyFilter();
  document.addEventListener('astro:page-load', applyFilter);
</script>

<script type="application/ld+json" is:inline set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://purist.online/pages/blog#webpage',
  name: 'The Automation Blog — PURIST',
  description: 'Workflow automation guides, AI agent insights, case studies, and operations strategy from the PURIST engineering team.',
  url: 'https://purist.online/pages/blog',
  inLanguage: 'en-GB',
  isPartOf: { '@type': 'WebSite', '@id': 'https://purist.online/#website' },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://purist.online' },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://purist.online/pages/blog' },
    ],
  },
  mainEntity: {
    '@type': 'ItemList',
    name: 'PURIST Automation Blog Articles',
    numberOfItems: articles.length,
    itemListElement: articles.map((a, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://purist.online/pages/blog/${a.slug}`,
      name: a.title,
      description: a.excerpt,
    })),
  },
})}/>

</ShopLayout>
