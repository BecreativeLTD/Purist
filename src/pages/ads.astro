---

<ShopLayout
  title="Creative Ads — Built by AI, Powered by Purist"
  description="Every ad you see was produced entirely by the Purist automation stack. n8n workflows + Claude AI Skills. Brief in. Campaign out."
  noindex={false}
>
  <div class="ads-page bg-brand-black min-h-screen">

    <!-- Hero -->
    <section class="pt-24 pb-16 px-6 lg:px-12 max-w-7xl mx-auto">
      <div class="hero-line">
        <span class="inline-block bg-white/8 border border-white/10 rounded-full text-[10px] tracking-[0.2em] uppercase font-medium px-4 py-1.5 mb-8 text-white/40">
          Creative Showcase · Purist.online
        </span>
      </div>

      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-10 mb-4">
        <div>
          <h1 class="hero-title font-display text-5xl lg:text-7xl xl:text-8xl text-white leading-[0.95] tracking-tight">
            Made by AI.<br />
            <em class="text-white/40 font-medium">For Purist.</em>
          </h1>
        </div>
        <div class="hero-desc max-w-sm">
          <p class="text-[15px] text-white/50 leading-relaxed mb-5">
            Every visual on this page was generated entirely by our automation stack —
            no agency, no retainer, no designer on payroll.
            Just a brief, an n8n workflow, and Claude AI Skills.
          </p>
          <div class="flex flex-wrap gap-2">
            {['n8n', 'Claude Skills', 'GPT Image-2', '< 4 min/creative'].map(t => (
              <span class="text-[10px] tracking-widest uppercase text-white/30 border border-white/10 rounded-full px-3 py-1">{t}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="hero-stats flex flex-wrap gap-px mt-12 border border-white/8 rounded-2xl overflow-hidden">
        {[
          { n: `${ads.length}`, label: 'Ads on this page' },
          { n: '< 4 min', label: 'Per creative' },
          { n: '£0', label: 'Agency fees' },
          { n: '100%', label: 'AI-produced' },
        ].map(s => (
          <div class="flex-1 min-w-[120px] bg-white/[0.03] px-6 py-5">
            <div class="text-2xl font-display text-white mb-0.5">{s.n}</div>
            <div class="text-[11px] text-white/30 uppercase tracking-widest">{s.label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Divider -->
    <div class="w-full h-px bg-white/6 mb-2"></div>

    <!-- Masonry grid -->
    <section class="px-4 lg:px-8 py-12 max-w-[1600px] mx-auto" id="gallery">
      <div class="masonry-grid">
        {ads.map((ad, i) => (
          <div
            class="masonry-item"
            style={`animation-delay: ${(i % 6) * 80}ms`}
            data-index={i}
          >
            <div class="masonry-inner">
              <img
                src={ad.src}
                alt={ad.alt}
                loading={i < 6 ? 'eager' : 'lazy'}
                decoding="async"
                class="w-full h-full object-cover"
              />
              <div class="masonry-overlay">
                <p class="text-white text-[13px] font-medium leading-snug px-4 py-3">{ad.alt}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="px-6 py-20 max-w-4xl mx-auto text-center">
      <div class="border border-white/10 rounded-3xl p-10 lg:p-16 bg-white/[0.02]">
