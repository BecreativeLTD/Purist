</ShopLayout>

<style>
  /* Hero animations */
  .hero-line,
  .hero-title,
  .hero-desc,
  .hero-stats {
    opacity: 0;
    transform: translateY(24px);
    animation: fade-up 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .hero-line   { animation-delay: 0ms; }
  .hero-title  { animation-delay: 80ms; }
  .hero-desc   { animation-delay: 160ms; }
  .hero-stats  { animation-delay: 240ms; }

  @keyframes fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Masonry */
  .masonry-grid {
    columns: 2;
    column-gap: 12px;
  }
  @media (min-width: 640px)  { .masonry-grid { columns: 3; } }
  @media (min-width: 1024px) { .masonry-grid { columns: 4; } }
  @media (min-width: 1280px) { .masonry-grid { columns: 5; } }

  .masonry-item {
    break-inside: avoid;
    margin-bottom: 12px;
    opacity: 0;
    transform: translateY(32px);
    animation: item-rise 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes item-rise {
    to { opacity: 1; transform: translateY(0); }
  }

  .masonry-inner {
    position: relative;
    overflow: hidden;
    border-radius: 14px;
    background: #111;
    cursor: zoom-in;
  }

  .masonry-inner img {
    display: block;
    width: 100%;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .masonry-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .masonry-inner:hover img {
    transform: scale(1.04);
  }

  .masonry-inner:hover .masonry-overlay {
    opacity: 1;
    transform: translateY(0);
  }

  /* Lightbox */
  .lb-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
    backdrop-filter: blur(8px);
  }
  .lb-backdrop.open {
    opacity: 1;
    pointer-events: all;
  }
  .lb-img {
    max-height: 90vh;
    max-width: 90vw;
    border-radius: 16px;
    object-fit: contain;
    transform: scale(0.92);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .lb-backdrop.open .lb-img {
    transform: scale(1);
  }
  .lb-close {
    position: absolute;
    top: 24px;
    right: 28px;
    color: rgba(255,255,255,0.5);
    font-size: 28px;
    cursor: pointer;
    background: none;
    border: none;
    line-height: 1;
    transition: color 0.2s;
  }
  .lb-close:hover { color: #fff; }
  .lb-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.08);
    border: none;
    color: #fff;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .lb-nav:hover { background: rgba(255,255,255,0.16); }
  .lb-prev { left: 20px; }
  .lb-next { right: 20px; }
</style>

<div class="lb-backdrop" id="lb">
  <button class="lb-close" id="lb-close" aria-label="Close">×</button>
  <button class="lb-nav lb-prev" id="lb-prev" aria-label="Previous">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12 4l-6 6 6 6" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
  <img src="" alt="" class="lb-img" id="lb-img" />
  <button class="lb-nav lb-next" id="lb-next" aria-label="Next">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M8 4l6 6-6 6" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
</div>

<script>
  const ads = Array.from(document.querySelectorAll<HTMLElement>('.masonry-item'));
  const lb = document.getElementById('lb')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  let current = 0;

  function open(i: number) {
    current = i;
    const img = ads[i].querySelector('img')!;
    lbImg.src = img.src;
    lbImg.alt = img.alt;
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function close() {
    lb.classList.remove('open');
    document.body.style.overflow = '';
  }
  function nav(dir: number) {
    open((current + dir + ads.length) % ads.length);
  }

  ads.forEach((el, i) => el.addEventListener('click', () => open(i)));
  document.getElementById('lb-close')!.addEventListener('click', close);
  document.getElementById('lb-prev')!.addEventListener('click', () => nav(-1));
  document.getElementById('lb-next')!.addEventListener('click', () => nav(1));
  lb.addEventListener('click', e => { if (e.target === lb) close(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') nav(-1);
    if (e.key === 'ArrowRight') nav(1);
  });

  // Intersection Observer for scroll-triggered reveal
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.animationPlayState = 'running';
        observer.unobserve(e.target);
      }
    }),
    { threshold: 0.05 }
  );
  ads.forEach((el, i) => {
    if (i >= 6) {
      el.style.animationPlayState = 'paused';
      observer.observe(el);
    }
  });
</script>
