<ShopLayout
  title="AI Ad Creative Gallery by Industry — Workflow Automation Ads by Purist"
  description="65 production-ready ad creatives generated entirely by the Purist automation stack. Browse by industry. n8n workflows, Claude AI Skills, GPT Image-2. Brief in. Campaign out."
  noindex={false}
>
  <div class="ads-page bg-brand-black min-h-screen">

    <!-- Hero -->
    <section class="pt-24 sm:pt-28 pb-12 sm:pb-16 px-4 sm:px-6 lg:px-16 max-w-7xl mx-auto">
      <div class="hero-line mb-10">
        <span class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full text-[10px] tracking-[0.2em] uppercase font-medium px-4 py-1.5 text-white/40">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-pink inline-block"></span>
          Creative Showcase · Purist.online
        </span>
      </div>

      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-12 mb-14">
        <div class="max-w-2xl">
          <h1 class="hero-title font-display text-[2.8rem] sm:text-5xl md:text-6xl lg:text-8xl text-white leading-[0.9] tracking-tight">
            Made by AI.<br />
            <em class="text-white/35 font-medium">For every industry.</em>
          </h1>
        </div>
        <div class="hero-desc lg:max-w-xs">
          <p class="text-[14px] text-white/45 leading-relaxed mb-6">
            Every visual was generated entirely by our automation stack.
            No agency. No retainer. No designer on payroll.
            Just a brief, an n8n workflow, and Claude AI Skills.
          </p>
          <div class="flex flex-wrap gap-2">
            {['n8n', 'Claude Skills', 'GPT Image-2', 'Under 4 min'].map(t => (
              <span class="text-[10px] tracking-widest uppercase text-white/30 border border-white/10 rounded-full px-3 py-1">{t}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="hero-stats grid grid-cols-2 sm:grid-cols-4 gap-px border border-white/8 rounded-xl sm:rounded-2xl overflow-hidden">
        {[
          { n: `${ads.length}`, label: 'Creatives' },
          { n: '< 4 min', label: 'Per creative' },
          { n: '£0', label: 'Agency fees' },
          { n: '50+', label: 'Industries' },
        ].map(s => (
          <div class="bg-white/[0.03] px-4 sm:px-6 py-4 sm:py-6">
            <div class="text-2xl sm:text-3xl font-display text-white mb-1 tracking-tight">{s.n}</div>
            <div class="text-[9px] sm:text-[10px] text-white/25 uppercase tracking-[0.15em]">{s.label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Filter bar -->
    <div class="sticky top-0 z-50 bg-brand-black/95 backdrop-blur-md border-b border-white/6 px-4 sm:px-6 lg:px-16 py-3 sm:py-4">
      <div class="max-w-7xl mx-auto flex items-center justify-between gap-4 sm:gap-6">
        <div class="flex items-center gap-3">
          <span class="text-[10px] uppercase tracking-[0.2em] text-white/30 hidden sm:block">Filter by industry</span>
          <div class="relative">
            <select
              id="industry-filter"
              class="appearance-none bg-white/5 border border-white/12 text-white/70 text-[12px] tracking-wide rounded-full pl-4 pr-10 py-2.5 cursor-pointer focus:outline-none focus:border-white/30 transition-colors"
            >
              {industries.map(ind => (
                <option value={ind.id} class="bg-[#0a0a0a] text-white">{ind.label}</option>
              ))}
            </select>
            <svg class="pointer-events-none absolute right-3.5 top-1/2 -translate-y-1/2 text-white/40" width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
        <span id="filter-count" class="text-[11px] text-white/30 shrink-0">{ads.length} creatives</span>
      </div>
    </div>

    <!-- Masonry grid -->
    <section class="px-4 lg:px-8 py-10 max-w-[1800px] mx-auto" id="gallery">
      <div class="masonry-grid" id="masonry-grid">
        {ads.map((ad, i) => (
          <div
            class="masonry-item"
            data-category={ad.category}
            data-index={i}
            style={`animation-delay: ${(i % 8) * 60}ms`}
          >
            <div class="masonry-inner">
              <img
                src={ad.src}
                alt={ad.alt}
                loading={i < 10 ? 'eager' : 'lazy'}
                decoding="async"
                class="w-full h-full object-cover"
              />
              <div class="masonry-overlay">
                <p>{ad.alt}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden py-32 text-center">
        <p class="text-white/20 text-[13px] tracking-wide mb-2">No creatives yet for this industry.</p>
        <p class="text-white/12 text-[11px] tracking-widest uppercase">Coming soon · Share your brief with us</p>
        <a href="/#products" class="inline-flex items-center gap-2 mt-8 border border-white/15 text-white/40 hover:text-white text-[11px] tracking-[0.1em] uppercase px-5 py-2.5 rounded-full transition-all duration-200">
          Request custom ads
        </a>
      </div>
    </section>

    <!-- Pipeline section -->
    <section class="px-4 sm:px-6 lg:px-16 py-20 lg:py-28 max-w-7xl mx-auto">

      <div class="mb-12 lg:mb-16">
        <span class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full text-[10px] tracking-[0.2em] uppercase font-medium px-4 py-1.5 text-white/40 mb-6 sm:mb-8 block w-fit">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-pink inline-block"></span>
          Backend Infrastructure · n8n + Claude AI
        </span>
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 lg:gap-8">
          <h2 class="font-display text-4xl sm:text-5xl lg:text-7xl text-white leading-[0.92] tracking-tight max-w-lg">
            The pipelines<br />
            <em class="text-white/30">behind every ad.</em>
          </h2>
          <p class="text-[13px] sm:text-[14px] text-white/40 leading-relaxed max-w-sm">
            Every format runs on a dedicated n8n workflow, triggered by a single brief.
            Claude AI orchestrates the creative logic. GPT Image-2 renders the visuals.
            Production-ready assets delivered straight to your drive.
          </p>
        </div>
      </div>

      <!-- Pipeline cards grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3 sm:gap-4">

        <!-- Static Image Pipeline -->
        <div class="pipeline-card border border-white/8 rounded-2xl p-5 sm:p-7 bg-white/[0.02] hover:bg-white/[0.04] transition-colors duration-300">
          <div class="flex items-start justify-between mb-5 sm:mb-6">
            <div>
              <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-xl bg-brand-pink/10 border border-brand-pink/20 flex items-center justify-center mb-3 sm:mb-4">
                <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><rect x="2" y="2" width="16" height="16" rx="3" stroke="#FF6B9D" stroke-width="1.4"/><path d="M6 10l3 3 5-5" stroke="#FF6B9D" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="font-display text-lg sm:text-xl text-white mb-0.5">Static Image Ads</h3>
              <p class="text-[10px] text-brand-pink/70 uppercase tracking-[0.15em]">Active · 65 creatives live</p>
            </div>
            <span class="text-[9px] sm:text-[10px] text-white/20 border border-white/10 rounded-full px-2.5 py-1 tracking-widest uppercase shrink-0">Live</span>
          </div>
          <p class="text-[12px] sm:text-[13px] text-white/40 leading-relaxed mb-5 sm:mb-6">
            Single-image ads in 9:16, 4:5, and 1:1 for Meta, TikTok, Google Display, and LinkedIn.
            One brief triggers the full creative cycle without human intervention.
          </p>
          <div class="border-t border-white/6 pt-4 sm:pt-5 space-y-2.5 sm:space-y-3">
            <div class="pipeline-step">
              <span class="pipeline-node">Webhook</span>
              <span class="pipeline-arrow">→</span>
              <span class="pipeline-label">Brief received from form or Airtable trigger</span>
            </div>
            <div class="pipeline-step">
              <span class="pipeline-node">Claude Skill</span>
              <span class="pipeline-arrow">→</span>
              <span class="pipeline-label">Generates 3 creative concepts + copy variants</span>
            </div>
            <div class="pipeline-step">
              <span class="pipeline-node">HTTP node</span>
              <span class="pipeline-arrow">→</span>
              <span class="pipeline-label">Calls GPT Image-2 API with structured prompt</span>
            </div>
            <div class="pipeline-step">
              <span class="pipeline-node">Google Drive</span>
              <span class="pipeline-arrow">→</span>
              <span class="pipeline-label">Assets organized by ratio in client folder</span>
            </div>
          </div>
          <div class="flex items-center justify-between mt-4 sm:mt-5 pt-3 sm:pt-4 border-t border-white/5">
            <span class="text-[9px] sm:text-[10px] text-white/20 uppercase tracking-widest">Time to deliver</span>
            <span class="text-[12px] sm:text-[13px] text-white/60 font-medium">under 4 min</span>
          </div>
        </div>

        <!-- Video Ads Pipeline -->
        <div class="pipeline-card border border-white/8 rounded-2xl p-5 sm:p-7 bg-white/[0.02] hover:bg-white/[0.04] transition-colors duration-300">
          <div class="flex items-start justify-between mb-5 sm:mb-6">
