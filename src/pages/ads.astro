<script>
  const items = Array.from(document.querySelectorAll<HTMLElement>('.masonry-item'));
  const lb        = document.getElementById('lb')!;
  const lbImg     = document.getElementById('lb-img') as HTMLImageElement;
  const lbDesc    = document.getElementById('lb-desc')!;
  const lbCounter = document.getElementById('lb-counter')!;
  let current = 0;
  let visibleItems: HTMLElement[] = [];

  function getVisible() {
    return items.filter(el => !el.classList.contains('hidden'));
  }

  function updateLb(i: number) {
    const img = visibleItems[i].querySelector('img')!;
    // Smooth image swap
    lbImg.style.opacity = '0';
    lbImg.style.transform = 'scale(0.97)';
    setTimeout(() => {
      lbImg.src = img.src;
      lbImg.alt = img.alt;
      lbDesc.textContent = img.alt;
      lbCounter.textContent = `${i + 1} / ${visibleItems.length}`;
      lbImg.style.transition = 'none';
      lbImg.style.opacity = '0';
      lbImg.style.transform = 'scale(0.97)';
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          lbImg.style.transition = 'transform 0.32s cubic-bezier(0.22,1,0.36,1), opacity 0.28s ease';
          lbImg.style.opacity = '1';
          lbImg.style.transform = 'scale(1)';
        });
      });
    }, 80);
  }

  function openLb(i: number) {
    visibleItems = getVisible();
    current = i;
    const img = visibleItems[i].querySelector('img')!;
    lbImg.src = img.src;
    lbImg.alt = img.alt;
    lbDesc.textContent = img.alt;
    lbCounter.textContent = `${i + 1} / ${visibleItems.length}`;
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeLb() {
    lb.classList.remove('open');
    document.body.style.overflow = '';
  }
  function navLb(dir: number) {
    visibleItems = getVisible();
    current = (current + dir + visibleItems.length) % visibleItems.length;
    updateLb(current);
  }

  items.forEach(el => {
    el.addEventListener('click', () => {
      visibleItems = getVisible();
      const vi = visibleItems.indexOf(el);
      if (vi !== -1) openLb(vi);
    });
  });
  document.getElementById('lb-close')!.addEventListener('click', closeLb);
  document.getElementById('lb-prev')!.addEventListener('click', () => navLb(-1));
  document.getElementById('lb-next')!.addEventListener('click', () => navLb(1));
  lb.addEventListener('click', e => { if (e.target === lb) closeLb(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') closeLb();
    if (e.key === 'ArrowLeft') navLb(-1);
    if (e.key === 'ArrowRight') navLb(1);
  });

  // Industry filter
  const select = document.getElementById('industry-filter') as HTMLSelectElement;
  const countEl = document.getElementById('filter-count')!;
  const emptyState = document.getElementById('empty-state')!;

  function applyFilter(value: string) {
    let count = 0;
    items.forEach(el => {
      const cat = el.dataset.category || '';
      const show = value === 'all' || cat === value;
      el.classList.toggle('hidden', !show);
      if (show) count++;
    });
    countEl.textContent = `${count} creative${count !== 1 ? 's' : ''}`;
    emptyState.classList.toggle('hidden', count > 0);
  }

  select.addEventListener('change', () => applyFilter(select.value));

  // Intersection Observer for scroll reveal
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.animationPlayState = 'running';
        observer.unobserve(e.target);
      }
    }),
    { threshold: 0.04 }
  );
  items.forEach((el, i) => {
    if (i >= 10) {
      el.style.animationPlayState = 'paused';
      observer.observe(el);
    }
  });
</script>
