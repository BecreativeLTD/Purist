---
import ShopLayout from '~/layouts/ShopLayout.astro';
import Button from '~/components/ui/Button.astro';
---

<ShopLayout
  title="Add-ons & resources – PURIST"
  description="Automation playbooks, priority support, and custom integration packages — launching soon."
>
  <header class="bg-brand-cream">
    <div class="container-x py-16 lg:py-20 max-w-3xl mx-auto text-center">
      <p class="eyebrow mb-4">Add-ons & resources</p>
      <h1 class="font-display text-4xl lg:text-5xl xl:text-6xl leading-tight tracking-tight mb-6 text-balance">
        The playbook, the support, the extras.<br/>
        <em class="font-medium">Launching soon.</em>
      </h1>
      <p class="text-base lg:text-lg text-brand-gray-600 text-pretty">
        A curated set of resources and add-ons to get even more from your automations.
        Sign up below and you will be first in line when they launch.
      </p>
    </div>
  </header>

  <section class="bg-white py-20 lg:py-28">
    <div class="container-x grid grid-cols-1 md:grid-cols-3 gap-4 max-w-4xl mx-auto">
      {[
        { name: 'Automation Playbook', sub: 'Industry-specific workflow templates · step-by-step guides · ROI calculators' },
        { name: 'Priority Support Add-on', sub: '15-minute response SLA · dedicated Slack channel · weekly strategy calls' },
        { name: 'Custom Integration Package', sub: 'Bespoke API integrations · legacy system connectors · data migration' },
      ].map((item) => (
        <article class="bg-brand-cream rounded-card p-6 flex flex-col items-center text-center scroll-fade">
          <div class="w-full aspect-square rounded-image bg-brand-sand mb-5 flex items-center justify-center">
            <svg class="w-16 h-16 text-brand-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <path d="M8 4h8l-1 4h-6L8 4z" stroke-linejoin="round"/>
              <path d="M7 8h10v12a2 2 0 01-2 2H9a2 2 0 01-2-2V8z" stroke-linejoin="round"/>
            </svg>
          </div>
          <h2 class="font-display text-lg mb-2 leading-tight">{item.name}</h2>
          <p class="text-xs text-brand-gray-600 leading-relaxed">{item.sub}</p>
          <p class="text-[10px] uppercase tracking-wider text-brand-rust mt-3">Coming soon</p>
        </article>
      ))}
    </div>
  </section>

  <section class="bg-brand-beige py-16 lg:py-20">
    <div class="container-x max-w-md mx-auto text-center">
      <p class="eyebrow mb-3">Early access</p>
      <h2 class="font-display text-2xl lg:text-3xl mb-6 leading-tight text-balance">
        Be first in line.
      </h2>
      <form class="flex gap-2" onsubmit="event.preventDefault(); this.querySelector('button').textContent='✓ You are on the list';">
        <input type="email" required placeholder="Your email" class="flex-1 bg-white border border-brand-gray-200 rounded-button px-4 py-3 text-sm focus:border-brand-black focus:outline-none transition" />
        <button type="submit" class="bg-brand-black text-white px-5 py-3 rounded-button text-sm font-medium hover:bg-brand-gray-900 transition shrink-0">
          Notify me
        </button>
      </form>
      <p class="text-[11px] text-brand-gray-600 mt-3">
        No spam. Unsubscribe with one click.
      </p>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-20 text-center">
    <div class="container-x max-w-2xl">
      <h2 class="font-display text-2xl lg:text-3xl mb-6 leading-tight text-balance">
        In the meantime —
      </h2>
      <Button href="/collections/all" size="lg">View all services →</Button>
    </div>
  </section>
</ShopLayout>
