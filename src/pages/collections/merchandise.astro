---
import ShopLayout from '~/layouts/ShopLayout.astro';
import Button from '~/components/ui/Button.astro';

const addons = [
 {
   name: 'Automation Playbook',
   sub: 'Industry-specific workflow templates, step-by-step guides, and ROI calculators for your sector.',
   price: 'Coming soon',
   icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12">
     <rect x="8" y="6" width="32" height="36" rx="3"/>
     <path d="M15 16h18M15 22h18M15 28h12"/>
     <circle cx="34" cy="34" r="7" fill="#0A0A0A" stroke="none"/>
     <path d="M31 34l2 2 4-4" stroke="white" stroke-width="1.8" fill="none"/>
   </svg>`,
   highlights: ['12 industry templates', 'ROI calculator included', 'Video walkthroughs'],
 },
 {
   name: 'Priority Support',
   sub: '15-minute response SLA, dedicated Slack channel, and weekly strategy calls with your CSM.',
   price: 'Coming soon',
   icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12">
     <path d="M24 6C14 6 7 13 7 22c0 5.5 2.7 10.3 7 13.4V42l7-4.5c1.3.3 2.6.5 3 .5 10 0 17-7 17-16S34 6 24 6z"/>
     <circle cx="24" cy="22" r="2" fill="currentColor" stroke="none"/>
     <circle cx="17" cy="22" r="2" fill="currentColor" stroke="none"/>
     <circle cx="31" cy="22" r="2" fill="currentColor" stroke="none"/>
   </svg>`,
   highlights: ['15-min response SLA', 'Dedicated Slack channel', 'Weekly strategy calls'],
 },
 {
   name: 'Custom Integration',
   sub: 'Bespoke API integrations, legacy system connectors, and full data migration managed by our engineers.',
   price: 'Coming soon',
   icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12">
     <rect x="6" y="18" width="12" height="12" rx="2"/>
     <rect x="30" y="18" width="12" height="12" rx="2"/>
     <path d="M18 24h12"/>
     <path d="M24 6v8M24 34v8"/>
     <circle cx="24" cy="24" r="3" fill="currentColor" stroke="none" opacity="0.3"/>
   </svg>`,
   highlights: ['Any API connected', 'Legacy system support', 'Full data migration'],
 },
];
---

<ShopLayout
 title="Add-ons & Resources – PURIST"
 description="Automation playbooks, priority support, and custom integration packages launching soon."
>
 <header class="bg-brand-cream border-b border-brand-gray-100">
   <div class="container-x py-14 lg:py-20 max-w-2xl mx-auto text-center">
     <p class="eyebrow mb-4">Add-ons & Resources</p>
     <h1 class="font-display text-4xl lg:text-5xl leading-tight tracking-tight mb-5 text-balance">
       Go further.<br/><em class="font-medium">Launching soon.</em>
     </h1>
     <p class="text-base text-brand-gray-600 text-pretty">
       A curated set of add-ons to get even more from your automation stack.
       Be first in line when they drop.
     </p>
   </div>
 </header>

 <!-- Add-on cards -->
 <section class="bg-white py-16 lg:py-24">
   <div class="container-x">
     <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
       {addons.map((item) => (
         <article class="bg-brand-cream rounded-card p-7 flex flex-col">
           <!-- Icon -->
           <div class="w-16 h-16 rounded-2xl bg-white border border-brand-gray-100 flex items-center justify-center mb-5 text-brand-gray-600 shadow-sm">
             <Fragment set:html={item.icon} />
           </div>

           <h2 class="font-display text-xl mb-2 leading-tight">{item.name}</h2>
           <p class="text-sm text-brand-gray-600 leading-relaxed mb-5 flex-1">{item.sub}</p>

           <!-- Feature bullets -->
           <ul class="space-y-1.5 mb-5">
             {item.highlights.map(h => (
               <li class="flex items-center gap-2 text-xs text-brand-gray-600">
                 <span class="w-1.5 h-1.5 rounded-full bg-brand-black shrink-0 opacity-40"/>
                 {h}
               </li>
             ))}
           </ul>

           <div class="pt-4 border-t border-brand-gray-200">
             <p class="text-[10px] uppercase tracking-widest text-brand-rust font-medium">{item.price}</p>
           </div>
         </article>
       ))}
     </div>
   </div>
 </section>

 <!-- Email signup -->
 <section class="bg-brand-cream py-16 lg:py-20 border-t border-brand-gray-100">
   <div class="container-x max-w-md mx-auto text-center">
     <p class="eyebrow mb-3">Early access</p>
     <h2 class="font-display text-2xl lg:text-3xl mb-3 leading-tight">
       Be first in line.
     </h2>
     <p class="text-sm text-brand-gray-600 mb-6">We'll notify you the moment add-ons go live.</p>
     <form class="flex gap-2" onsubmit="event.preventDefault(); this.querySelector('button').textContent='✓ On the list';">
       <input type="email" required placeholder="Your work email"
         class="flex-1 bg-white border border-brand-gray-200 rounded-button px-4 py-3 text-sm focus:border-brand-black focus:outline-none transition min-w-0" />
       <button type="submit"
         class="bg-brand-black text-white px-5 py-3 rounded-button text-sm font-medium hover:bg-brand-gray-900 transition shrink-0 whitespace-nowrap">
         Notify me
       </button>
     </form>
     <p class="text-[11px] text-brand-gray-600 mt-3">No spam. Unsubscribe anytime.</p>
   </div>
 </section>

 <!-- CTA -->
 <section class="bg-white py-14 lg:py-20 text-center border-t border-brand-gray-100">
   <div class="container-x max-w-2xl">
     <p class="text-sm text-brand-gray-600 mb-4">Ready to start now?</p>
     <Button href="/collections/all" size="lg">View all services →</Button>
   </div>
 </section>
</ShopLayout>
