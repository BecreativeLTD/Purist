---
import ShopLayout from '~/layouts/ShopLayout.astro';
import Hero from '~/components/sections/Hero.astro';
import AsFeaturedIn from '~/components/sections/AsFeaturedIn.astro';
import ProductsGrid from '~/components/sections/ProductsGrid.astro';
import ClaudeSkills from '~/components/sections/ClaudeSkills.astro';
import N8nIntegrations from '~/components/sections/N8nIntegrations.astro';
import ROICalculator from '~/components/sections/ROICalculator.astro';
import HowItWorksSection from '~/components/sections/HowItWorksSection.astro';
import AddonsSection from '~/components/sections/AddonsSection.astro';
import TrustedTestimonials from '~/components/sections/TrustedTestimonials.astro';
import FounderNote from '~/components/sections/FounderNote.astro';
import MoneyBackGuarantee from '~/components/sections/MoneyBackGuarantee.astro';
import ReferralSection from '~/components/sections/ReferralSection.astro';
import FAQSection from '~/components/sections/FAQSection.astro';
---

<ShopLayout
  title="PURIST · Workflow Automation and AI Agents for Business"
  description="500+ production deployments across dental, real estate, agencies, e-commerce and legal. n8n workflows and Claude AI agents. Deployed in days, 99.97% uptime."
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/images/hero/hero-bg.svg" fetchpriority="high" />
  </Fragment>
  <Hero />
  <AsFeaturedIn />
  <ProductsGrid />
  <ClaudeSkills />
  <N8nIntegrations />
  <ROICalculator />
  <HowItWorksSection />
  <AddonsSection />
  <TrustedTestimonials />
  <FounderNote />
  <MoneyBackGuarantee />
  <ReferralSection />
  <FAQSection />
</ShopLayout>
