---
import ShopLayout from '~/layouts/ShopLayout.astro';
import skillsData from '~/data/skills.json';

const { skills } = skillsData;

const cats = [
 { id: 'all', label: 'All workflows', icon: 'M4 6h16M4 12h16M4 18h16' },
 { id: 'crm', label: 'CRM & Sales', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0' },
 { id: 'finance', label: 'Finance', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
 { id: 'ops', label: 'Operations', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
 { id: 'support', label: 'Support & CS', icon: 'M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z' },
 { id: 'marketing', label: 'Marketing', icon: 'M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z' },
 { id: 'reporting', label: 'Reporting & BI', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
 { id: 'hr', label: 'HR & People', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
 { id: 'ai', label: 'AI Workflows', icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2h-2' },
 { id: 'integration', label: 'Integrations', icon: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
 { id: 'security', label: 'Security', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
];

const industries = [
 { id: 'all', label: 'All industries' },
 { id: 'agency', label: 'Agencies' },
 { id: 'ecommerce', label: 'E-commerce' },
 { id: 'realestate', label: 'Real Estate' },
 { id: 'saas', label: 'SaaS' },
 { id: 'legal', label: 'Law Firms' },
 { id: 'accounting', label: 'Accounting' },
 { id: 'financial', label: 'Financial Advisory' },
 { id: 'construction', label: 'Construction' },
 { id: 'staffing', label: 'Staffing & HR' },
 { id: 'hotel', label: 'Hotels' },
 { id: 'restaurant', label: 'Restaurants' },
 { id: 'healthcare', label: 'Healthcare' },
 { id: 'media', label: 'Media & Publishing' },
 { id: 'callcenter', label: 'Call Centres' },
 { id: 'nonprofit', label: 'Non-Profits' },
 { id: 'education', label: 'Education' },
 { id: 'logistics', label: 'Logistics' },
 { id: 'insurance', label: 'Insurance' },
 { id: 'property_management', label: 'Property Mgmt' },
 { id: 'gym', label: 'Gyms & Fitness' },
];

// Noindex filtered/search views — only the clean /skills URL should be indexed
const hasParams = Object.keys(Astro.url.searchParams).length > 0;

const stats = [
 { n: `${skills.length}+`, l: 'Production workflows' },
 { n: '20+', l: 'Industries covered' },
 { n: '14h', l: 'Avg. saved per week' },
 { n: '< 7d', l: 'Time to live' },
];

const complexityColor: Record<string, string> = {
 Starter: 'text-green-700 bg-green-50',
 Intermediate: 'text-amber-700 bg-amber-50',
 Advanced: 'text-purple-700 bg-purple-50',
};
---

<ShopLayout
 title="Automation Skills Marketplace PURIST | n8n Workflows & AI Agents"
 description={`Browse ${skills.length}+ production-ready n8n workflow automations and AI agent skills. Filter by industry or function. Each deployed in under 7 days with 24/7 monitoring.`}
 noindex={hasParams}
 canonical="https://purist.online/skills"
>

 <!-- Breadcrumb -->
 <nav aria-label="Breadcrumb" class="container-x py-4 text-xs text-brand-gray-600">
   <ol class="flex items-center gap-1.5 flex-wrap">
     <li><a href="/" class="hover:text-brand-black transition">Home</a></li>
     <li aria-hidden="true">/</li>
     <li class="text-brand-black">Skills Library</li>
   </ol>
 </nav>

   <!-- Hero -->
   <section class="bg-brand-black text-white py-16 lg:py-20">
     <div class="container-x">
       <div class="max-w-3xl">
         <p class="eyebrow text-brand-pink/70 mb-4">Automation Skills Marketplace</p>
         <h1 class="font-display text-[clamp(2.2rem,5vw,3.8rem)] leading-[1.05] mb-5 text-balance">
           Every workflow your business needs.<br/>
           <em class="font-medium text-brand-pink">Ready to deploy.</em>
         </h1>
         <p class="text-white/60 text-lg mb-8 max-w-xl leading-relaxed">
           {skills.length}+ production-grade automations built on n8n and Claude AI. Browse, filter by industry or function, and deploy any workflow in under 7 days.
         </p>
         <!-- Stats row -->
         <div class="flex flex-wrap gap-x-8 gap-y-3">
           {stats.map(s => (
             <div>
               <p class="font-display text-2xl leading-none text-white">{s.n}</p>
               <p class="text-[10px] uppercase tracking-widest text-white/40 mt-1">{s.l}</p>
             </div>
           ))}
         </div>
       </div>
     </div>
   </section>

   <!-- Filters + Grid -->
   <section class="bg-white">
     <div class="container-x py-10 lg:py-14">

       <!-- Search + filters bar -->
       <div class="flex flex-col gap-4 mb-8 sticky top-16 z-20 bg-white/95 backdrop-blur-sm py-4 -mx-4 px-4 border-b border-brand-gray-100">
         <!-- Search -->
         <div class="relative max-w-lg">
           <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-brand-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
           <input
             id="skill-search"
             type="search"
             placeholder="Search workflows..."
             class="w-full pl-10 pr-4 py-2.5 text-sm border border-brand-gray-200 rounded-button outline-none focus:border-brand-black transition bg-brand-gray-50"
           />
         </div>

         <!-- Category tabs -->
         <div class="flex items-center gap-2 overflow-x-auto pb-1 scrollbar-none">
           {cats.map(c => (
             <button
               type="button"
               class="cat-btn shrink-0 flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-wider px-3 py-1.5 rounded-full border transition whitespace-nowrap"
               data-cat={c.id}
               data-active={c.id === 'all' ? 'true' : 'false'}
               style={c.id === 'all' ? 'background:#0A0A0A;color:#fff;border-color:#0A0A0A;' : 'background:white;color:#6B7280;border-color:#E5E7EB;'}
             >
               <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                 <path d={c.icon}/>
               </svg>
               {c.label}
             </button>
           ))}
         </div>

         <!-- Industry pills -->
         <div class="flex items-center gap-1.5 overflow-x-auto pb-1 scrollbar-none">
           {industries.map(i => (
             <button
               type="button"
               class="ind-btn shrink-0 text-[10px] font-medium px-2.5 py-1 rounded-full border transition whitespace-nowrap"
               data-ind={i.id}
               data-active={i.id === 'all' ? 'true' : 'false'}
               style={i.id === 'all' ? 'background:#0A0A0A;color:#fff;border-color:#0A0A0A;' : 'background:white;color:#6B7280;border-color:#E5E7EB;'}
             >
               {i.label}
             </button>
           ))}
         </div>

         <!-- Results count -->
         <p id="results-count" class="text-xs text-brand-gray-400">{skills.length} skills</p>
       </div>

       <!-- Grid -->
       <div id="skills-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
         {skills.map(s => (
           <a
             href={`/skills/${s.slug}`}
             class="skill-card group flex flex-col bg-white border border-brand-gray-100 hover:border-brand-gray-300 hover:shadow-md rounded-card p-5 transition-all duration-200"
             data-cat={s.cat}
             data-industries={s.industries.join(',')}
             data-title={s.title.toLowerCase()}
             data-tags={((s as any).tags ?? []).join(',')}
             data-badge={s.badge ?? ''}
           >
             <!-- Top row -->
             <div class="flex items-start justify-between gap-2 mb-3">
               <span class={`text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full ${complexityColor[s.complexity]}`}>
                 {s.complexity}
               </span>
               {s.badge && (
                 <span class="text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full shrink-0"
                   style={s.badge === 'AI-powered' ? 'background:rgba(123,104,238,0.12);color:#7B68EE;' : 'background:rgba(232,180,176,0.15);color:#c4847e;'}>
                   {s.badge}
                 </span>
               )}
             </div>

             <!-- Title + benefit -->
             <p class="text-sm font-semibold text-brand-black mb-1.5 leading-snug group-hover:text-brand-black flex-1">{s.title}</p>
             <p class="text-[11px] text-brand-gray-500 leading-relaxed mb-4 line-clamp-2">{s.benefit}</p>

             <!-- Tools -->
             <div class="flex flex-wrap gap-1 mb-4">
               {s.tools.map(t => (
                 <span class="text-[9px] font-medium bg-brand-gray-50 text-brand-gray-500 border border-brand-gray-100 px-1.5 py-0.5 rounded">{t}</span>
               ))}
             </div>

             <!-- Footer -->
             <div class="flex items-center justify-between pt-3 border-t border-brand-gray-100 mt-auto">
               <span class="text-[10px] font-semibold text-brand-green">{s.time} saved</span>
               <span class="text-[10px] font-semibold text-brand-gray-400">
                 {(s as any).price ? <span class="text-brand-gray-500">From £{(s as any).price}</span> : <span class="flex items-center gap-1 group-hover:text-brand-black transition">Deploy <svg class="w-3 h-3" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 7h10M8 3l4 4-4 4"/></svg></span>}
               </span>
             </div>
           </a>
         ))}
       </div>

       <!-- Empty state -->
       <div id="empty-state" class="hidden text-center py-20">
         <p class="font-display text-2xl text-brand-gray-400 mb-2">No workflows found</p>
         <p class="text-sm text-brand-gray-400">Try a different search or filter combination</p>
         <button type="button" id="reset-btn" class="mt-4 text-sm text-brand-black underline underline-offset-4">Reset filters</button>
       </div>

       <!-- Load more -->
       <div id="load-more-wrap" class="text-center mt-10">
         <button type="button" id="load-more-btn"
           class="inline-flex items-center gap-2 px-7 py-3.5 rounded-button border border-brand-gray-200 text-sm font-semibold text-brand-black hover:border-brand-gray-400 hover:bg-brand-gray-50 transition">
           Load more workflows
           <span id="load-more-count" class="text-brand-gray-400 font-normal text-xs"></span>
           <svg class="w-4 h-4 text-brand-gray-400" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7 2v10M3 8l4 4 4-4"/></svg>
         </button>
       </div>
     </div>
   </section>

   <!-- ═══════════════════════════════════════════════
        MARKETING PSYCHOLOGY 60 Mental Models (SEO)
   ════════════════════════════════════════════════ -->
   <section class="bg-brand-cream border-t border-brand-gray-100 py-16 lg:py-24">
     <div class="container-x">

       <div class="max-w-2xl mb-12">
         <p class="eyebrow mb-3">Marketing Psychology & Behavioral Science</p>
         <h2 class="font-display text-h2 mb-4 text-balance">60 Mental Models That Drive Conversion</h2>
         <p class="text-brand-gray-600 leading-relaxed">
           PURIST automation workflows are built around how buyers actually think and decide.
           These 60 psychological principles from cognitive biases to behavioral economics underpin every funnel, email sequence, and CRM workflow we deploy.
         </p>
       </div>

       <!-- Category 1: Foundational Strategy -->
       <div class="mb-12">
         <h3 class="font-display text-xl mb-6" style="color:#0A0A0A;">Foundational Strategy Models</h3>
         <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
           {[
             { name: 'First Principles', desc: 'Break assumptions to find root truths. Rebuild strategy from evidence, not habit.', tag: 'Strategy' },
             { name: 'Jobs to Be Done', desc: 'Buyers hire products to accomplish outcomes. Frame offers around the job, not features.', tag: 'Strategy' },
             { name: 'Circle of Competence', desc: 'Double down where you have genuine edge. Do not chase every channel.', tag: 'Strategy' },
             { name: 'Inversion', desc: 'Ask what guarantees failure. Eliminate those things before optimising for success.', tag: 'Strategy' },
             { name: 'Occam\'s Razor', desc: 'The simplest explanation is usually correct. Check the obvious before complex attribution.', tag: 'Strategy' },
             { name: 'Pareto Principle (80/20)', desc: '80% of results come from 20% of effort. Identify the vital few and cut the rest.', tag: 'Strategy' },
             { name: 'Local vs Global Optima', desc: 'Don\'t optimise a tactic when the whole channel is wrong. Zoom out first.', tag: 'Strategy' },
             { name: 'Theory of Constraints', desc: 'Every funnel has one bottleneck. Fix the constraint before optimising anything else.', tag: 'Strategy' },
             { name: 'Opportunity Cost', desc: 'Every choice forecloses alternatives. Compare ROI across channels, not in isolation.', tag: 'Strategy' },
             { name: 'Law of Diminishing Returns', desc: 'Know when additional investment yields smaller gains. Diversify before you plateau.', tag: 'Strategy' },
             { name: 'Second-Order Thinking', desc: 'Discounts increase revenue today but train buyers to wait for sales tomorrow.', tag: 'Strategy' },
             { name: 'Map ≠ Territory', desc: 'Dashboards are models of reality. Talk to real customers regularly.', tag: 'Strategy' },
             { name: 'Probabilistic Thinking', desc: 'Think in likelihoods, not certainties. Spread risk across multiple campaigns.', tag: 'Strategy' },
             { name: 'Barbell Strategy', desc: '80% into proven channels, 20% into high-risk experiments. Avoid the mediocre middle.', tag: 'Strategy' },
           ].map(m => (
             <div class="bg-white border border-brand-gray-100 rounded-card p-4">
               <div class="flex items-start justify-between gap-2 mb-2">
                 <p class="text-sm font-semibold text-brand-black leading-snug">{m.name}</p>
                 <span class="shrink-0 text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full bg-brand-cream text-brand-gray-500">{m.tag}</span>
               </div>
               <p class="text-[11.5px] text-brand-gray-500 leading-relaxed">{m.desc}</p>
             </div>
           ))}
         </div>
       </div>

       <!-- Category 2: Buyer Psychology -->
       <div class="mb-12">
         <h3 class="font-display text-xl mb-6" style="color:#0A0A0A;">Buyer Psychology & Behavioural Science</h3>
         <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
           {[
             { name: 'Fundamental Attribution Error', desc: 'Low conversion? Blame the checkout flow, not the buyer. Examine your process first.', tag: 'Psychology' },
             { name: 'Mere Exposure Effect', desc: 'Familiarity breeds liking. Consistent brand presence compounds into trust over time.', tag: 'Psychology' },
             { name: 'Availability Heuristic', desc: 'Case studies make success feel achievable. Make positive outcomes easy to imagine.', tag: 'Psychology' },
             { name: 'Confirmation Bias', desc: 'Buyers seek information that confirms their beliefs. Align messaging to existing worldviews.', tag: 'Psychology' },
             { name: 'Lindy Effect', desc: 'Proven principles outlast trendy tactics. Don\'t abandon social proof for the latest fad.', tag: 'Psychology' },
             { name: 'Mimetic Desire', desc: 'People want what desirable others want. Waitlists and community signal demand.', tag: 'Psychology' },
             { name: 'Sunk Cost Fallacy', desc: 'Past spend should not justify future spend. Kill underperforming campaigns quickly.', tag: 'Psychology' },
             { name: 'Endowment Effect', desc: 'Free trials create ownership feelings. Buyers become reluctant to give up what they \'own\'.', tag: 'Psychology' },
             { name: 'IKEA Effect', desc: 'Effort increases perceived value. Let prospects configure or customise their own solution.', tag: 'Psychology' },
             { name: 'Zero-Price Effect', desc: '"Free" is psychologically distinct from £0. The gap from £1 to free is disproportionate.', tag: 'Psychology' },
             { name: 'Hyperbolic Discounting', desc: 'Immediate benefits outperform future ones. Lead with "Start saving time today."', tag: 'Psychology' },
             { name: 'Status-Quo Bias', desc: 'Change feels risky. Reduce friction. "Import your data in one click" removes hesitation.', tag: 'Psychology' },
             { name: 'Default Effect', desc: 'Pre-selected options get chosen. Set your preferred plan as the default.', tag: 'Psychology' },
             { name: 'Paradox of Choice', desc: 'Too many options cause paralysis. Three pricing tiers outperform seven.', tag: 'Psychology' },
             { name: 'Goal-Gradient Effect', desc: 'Progress accelerates as goals near. "80% complete" pull people to finish.', tag: 'Psychology' },
             { name: 'Peak-End Rule', desc: 'Experiences are judged by their peak and end, not the average. Design both deliberately.', tag: 'Psychology' },
             { name: 'Zeigarnik Effect', desc: 'Unfinished tasks occupy the mind. Open loops in onboarding drive re-engagement.', tag: 'Psychology' },
             { name: 'Pratfall Effect', desc: 'Admitting a flaw increases likeability. "We\'re not the cheapest" signals honesty.', tag: 'Psychology' },
             { name: 'Curse of Knowledge', desc: 'Experts cannot imagine not knowing. Test copy with people outside your industry.', tag: 'Psychology' },
             { name: 'Mental Accounting', desc: '£16/day feels different than £497/month. Frame costs in favourable mental categories.', tag: 'Psychology' },
             { name: 'Regret Aversion', desc: 'Fear of regret blocks action. Money-back guarantees and free trials remove that fear.', tag: 'Psychology' },
             { name: 'Social Proof / Bandwagon', desc: '"500+ businesses automated" signals safety and quality. Numbers create confidence.', tag: 'Psychology' },
           ].map(m => (
             <div class="bg-white border border-brand-gray-100 rounded-card p-4">
               <div class="flex items-start justify-between gap-2 mb-2">
                 <p class="text-sm font-semibold text-brand-black leading-snug">{m.name}</p>
                 <span class="shrink-0 text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:rgba(232,180,176,0.12);color:#c4847e;">{m.tag}</span>
               </div>
               <p class="text-[11.5px] text-brand-gray-500 leading-relaxed">{m.desc}</p>
             </div>
           ))}
         </div>
       </div>

       <!-- Category 3: Persuasion & Influence -->
       <div class="mb-12">
         <h3 class="font-display text-xl mb-6" style="color:#0A0A0A;">Persuasion & Ethical Influence</h3>
         <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
           {[
             { name: 'Reciprocity Principle', desc: 'Give first free audits, free content, free tools. Generous giving creates obligation to return.', tag: 'Persuasion' },
             { name: 'Commitment & Consistency', desc: 'Small commitments lead to larger ones. Audit → call → proposal → signature.', tag: 'Persuasion' },
             { name: 'Authority Bias', desc: 'Expert endorsements, uptime metrics, and certifications build instant trust signals.', tag: 'Persuasion' },
             { name: 'Liking / Similarity Bias', desc: '"Built by ops people, for ops people" signals we understand your world.', tag: 'Persuasion' },
             { name: 'Unity Principle', desc: 'Shared identity drives influence. Position your brand inside the buyer\'s tribe.', tag: 'Persuasion' },
             { name: 'Scarcity / Urgency', desc: 'Limited availability increases perceived value. Only use genuine scarcity.', tag: 'Persuasion' },
             { name: 'Foot-in-the-Door', desc: 'Start small. Each step makes the next easier: audit → Starter → Pro → Enterprise.', tag: 'Persuasion' },
             { name: 'Door-in-the-Face', desc: 'Show the largest option first. Everything else feels reasonable by contrast.', tag: 'Persuasion' },
             { name: 'Loss Aversion / Prospect Theory', desc: 'Losses feel 2× more painful than equivalent gains. Frame around what they\'ll lose by waiting.', tag: 'Persuasion' },
             { name: 'Anchoring Effect', desc: 'The first number seen shapes all subsequent judgements. Anchor high.', tag: 'Persuasion' },
             { name: 'Decoy Effect', desc: 'A third, inferior option makes the preferred tier look like the obvious choice.', tag: 'Persuasion' },
             { name: 'Framing Effect', desc: '"9.4× ROI" and "saves 14h/week" describe the same outcome differently. Frame wins.', tag: 'Persuasion' },
             { name: 'Contrast Effect', desc: 'Show the "before" state clearly. The gap with "after" makes the value vivid.', tag: 'Persuasion' },
           ].map(m => (
             <div class="bg-white border border-brand-gray-100 rounded-card p-4">
               <div class="flex items-start justify-between gap-2 mb-2">
                 <p class="text-sm font-semibold text-brand-black leading-snug">{m.name}</p>
                 <span class="shrink-0 text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:rgba(45,80,22,0.10);color:#2D5016;">{m.tag}</span>
               </div>
               <p class="text-[11.5px] text-brand-gray-500 leading-relaxed">{m.desc}</p>
             </div>
           ))}
         </div>
       </div>

       <!-- Categories 4 & 5: Pricing + Design in 2-col -->
       <div class="grid lg:grid-cols-2 gap-10 mb-12">

         <!-- Pricing Psychology -->
         <div>
           <h3 class="font-display text-xl mb-6" style="color:#0A0A0A;">Pricing Psychology</h3>
           <div class="grid gap-4">
             {[
               { name: 'Charm Pricing / Left-Digit Effect', desc: '£497 feels materially cheaper than £500. The left digit dominates price perception.' },
               { name: 'Rounded-Price (Fluency) Effect', desc: 'Round numbers signal premium quality. Use £1,200 for high-end, £997 for value.' },
               { name: 'Rule of 100', desc: 'Under £100: show percentage off. Over £100: show pounds saved. Whichever feels bigger.' },
