<script is:inline>
(function () {
 var PAGE_SIZE = 24;
 var page = 1;
 var matching = [];

 var cards  = Array.from(document.querySelectorAll('.skill-card'));
 var catBtns = Array.from(document.querySelectorAll('.cat-btn'));
 var indBtns = Array.from(document.querySelectorAll('.ind-btn'));
 var searchEl = document.getElementById('skill-search');
 var grid   = document.getElementById('skills-grid');
 var empty  = document.getElementById('empty-state');
 var countEl = document.getElementById('results-count');
 var resetBtn = document.getElementById('reset-btn');
 var loadWrap = document.getElementById('load-more-wrap');
 var loadBtn = document.getElementById('load-more-btn');
 var loadCnt = document.getElementById('load-more-count');

 var activeCat = 'all';
 var activeInd = 'all';
 var query   = '';

 function styleBtn(btn, active) {
   btn.style.cssText = active
     ? 'background:#0A0A0A;color:#fff;border-color:#0A0A0A;'
     : 'background:white;color:#6B7280;border-color:#E5E7EB;';
 }

 function setActive(btns, activeId, key) {
   btns.forEach(function(b) { styleBtn(b, b.dataset[key] === activeId); });
 }

 function buildMatching() {
   matching = cards.filter(function(card) {
     var catOk = activeCat === 'all' || card.dataset.cat === activeCat;
     var indOk = activeInd === 'all' || (card.dataset.industries || '').split(',').indexOf(activeInd) !== -1;
     var qOk = !query || (card.dataset.title || '').indexOf(query) !== -1 || (card.dataset.tags || '').indexOf(query) !== -1;
     return catOk && indOk && qOk;
   });
 }

 function render() {
   var toShow = matching.slice(0, page * PAGE_SIZE);
   cards.forEach(function(card) {
     card.style.display = toShow.indexOf(card) !== -1 ? '' : 'none';
   });

   var total = matching.length;
   if (countEl) countEl.textContent = total + ' skill' + (total !== 1 ? 's' : '');

   var hasMore = total > page * PAGE_SIZE;
   if (loadWrap) loadWrap.style.display = hasMore ? '' : 'none';
   if (loadCnt) loadCnt.textContent = hasMore ? '(' + Math.min(PAGE_SIZE, total - page * PAGE_SIZE) + ' more)' : '';

   var noResults = total === 0;
   if (empty) empty.classList.toggle('hidden', !noResults);
   if (grid) grid.classList.toggle('hidden', noResults);
 }

 function filter() {
   page = 1;
   buildMatching();
   render();
 }

 catBtns.forEach(function(b) {
   b.addEventListener('click', function() {
     activeCat = b.dataset.cat || 'all';
     setActive(catBtns, activeCat, 'cat');
     filter();
   });
 });

 indBtns.forEach(function(b) {
   b.addEventListener('click', function() {
     activeInd = b.dataset.ind || 'all';
     setActive(indBtns, activeInd, 'ind');
     filter();
   });
 });

 if (searchEl) {
   searchEl.addEventListener('input', function() {
     query = searchEl.value.toLowerCase().trim();
     filter();
   });
 }

 if (resetBtn) {
   resetBtn.addEventListener('click', function() {
     activeCat = 'all'; activeInd = 'all'; query = '';
     if (searchEl) searchEl.value = '';
     setActive(catBtns, 'all', 'cat');
     setActive(indBtns, 'all', 'ind');
     filter();
   });
 }

 if (loadBtn) {
   loadBtn.addEventListener('click', function() {
     page++;
     render();
   });
 }

 // Handle URL params (/skills?cat=crm&industry=legal&q=SMS)
 var params = new URLSearchParams(window.location.search);
 var urlCat = params.get('cat');
 var urlInd = params.get('industry');
 var urlQ  = params.get('q');
 if (urlCat) { activeCat = urlCat; setActive(catBtns, urlCat, 'cat'); }
 if (urlInd) { activeInd = urlInd; setActive(indBtns, urlInd, 'ind'); }
 if (urlQ) { query = urlQ.toLowerCase(); if (searchEl) searchEl.value = urlQ; }

 // Initial render always paginated
 buildMatching();
 render();
})();
</script>
