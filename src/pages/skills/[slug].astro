---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import skillsData from '~/data/skills.json';

export function getStaticPaths() {
  return skillsData.skills.map((s) => ({
    params: { slug: s.slug },
    props: { skill: s },
  }));
}

const { skill } = Astro.props;

// ── Labels ────────────────────────────────────────────────────────────
const catLabels: Record<string, string> = {
  crm: 'CRM & Sales', finance: 'Finance', ops: 'Operations',
  support: 'Support & CS', marketing: 'Marketing', reporting: 'Reporting & BI',
  hr: 'HR & People', ai: 'AI Workflows', integration: 'Integrations',
  security: 'Security & Compliance',
};
const industryLabels: Record<string, string> = {
  agency: 'Agencies', ecommerce: 'E-commerce', realestate: 'Real Estate',
  legal: 'Law Firms', staffing: 'Staffing & HR', hotel: 'Hotels',
  construction: 'Construction', accounting: 'Accounting', financial: 'Financial Advisory',
  media: 'Media & Publishing', saas: 'SaaS', callcenter: 'Call Centres',
  restaurant: 'Restaurants', healthcare: 'Healthcare', nonprofit: 'Non-Profits',
  education: 'Education', logistics: 'Logistics', insurance: 'Insurance',
  property_management: 'Property Management', gym: 'Gyms & Fitness',
};

// ── PURIST brand pink ─────────────────────────────────────────────────
const PINK = '#c4847e';
const PINK_BG = 'rgba(232,180,176,0.12)';
const PINK_BORDER = 'rgba(196,132,126,0.25)';

// ── Category icon ─────────────────────────────────────────────────────
const catStyle: Record<string, { icon: string }> = {
  crm:         { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
  finance:     { icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
  ops:         { icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  support:     { icon: 'M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z' },
  marketing:   { icon: 'M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z' },
  reporting:   { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
  hr:          { icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
  ai:          { icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
  integration: { icon: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
  security:    { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
};
const cs = catStyle[skill.cat] ?? catStyle.ops;

// ── Derived content ───────────────────────────────────────────────────
const basePrice: number = (skill as any).price ?? (skill.complexity === 'Starter' ? 299 : skill.complexity === 'Intermediate' ? 499 : 799);
const tags: string[] = (skill as any).tags ?? [skill.cat, skill.complexity.toLowerCase(), ...skill.tools.slice(0, 2)];
const displayTools = skill.tools.filter(t => t.toLowerCase() !== 'n8n');

// Hero bullet points — from description sentences with fallbacks
const rawSentences = skill.desc
  .split(/(?<=\.)\s+/)
  .map(s => s.replace(/\.$/, '').trim())
  .filter(s => s.length > 20);

const fallbackBullets = [
  `Automates ${catLabels[skill.cat].toLowerCase()} so your team focuses on higher-value work`,
  `Connects ${displayTools.slice(0, 2).join(' and ')} without manual intervention`,
  `Saves ${skill.time} every week — runs 24/7 with zero maintenance required`,
];
const descSentences = [...rawSentences.slice(0, 3), ...fallbackBullets].slice(0, 3);

// Distinct Trigger / Process / Output content (not recycled from hero bullets)
const triggerTool = displayTools[0] ?? catLabels[skill.cat];
const outputTool  = displayTools.length > 1 ? displayTools[displayTools.length - 1] : displayTools[0] ?? 'your tools';
const howItWorks = [
  {
    label: 'Trigger',
    text: `A new event in ${triggerTool} starts the automation — a form submission, status change, or a scheduled interval. No manual kickoff, no waiting.`,
  },
  {
    label: 'Process',
    text: `${displayTools.slice(0, 3).join(', ')} connect automatically. Data is validated, transformed, and routed exactly as configured — edge cases handled without human review.`,
  },
  {
    label: 'Output',
    text: `The result lands in ${outputTool} — no copy-paste, no delay, no errors. Your team sees the outcome without touching the process. ${skill.time} reclaimed every week.`,
  },
];

// Sample scenario — industry-specific micro story
const firstIndustry = skill.industries[0] ?? 'business';
const industryName = industryLabels[firstIndustry] ?? firstIndustry;
const sampleScenario = `A ${industryName.toLowerCase().replace(/s$/, '')} team was spending ${skill.time} every week on ${catLabels[skill.cat].toLowerCase()} tasks across ${displayTools.slice(0,2).join(' and ')}. After deploying this skill, the entire process runs automatically from trigger to output — the team now spends that time on client work instead.`;

// Use cases from industries
const useCaseBullets = skill.industries.slice(0, 5).map(i =>
  `${industryLabels[i] ?? i} automating ${catLabels[skill.cat].toLowerCase()}`
);

// Included in deployment checklist
const included = [
  `Custom ${catLabels[skill.cat]} automation built for your stack`,
  `Connected to ${displayTools.slice(0, 2).join(' and ')}`,
  '24/7 monitoring with error alerts',
  'You own 100% of the code — no lock-in',
  '30-day free modification guarantee',
];

// Related skills
const related = skillsData.skills
  .filter(s => s.slug !== skill.slug && (s.cat === skill.cat || s.industries.some(i => skill.industries.includes(i))))
  .slice(0, 4);

// Schema
const schemaLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: skill.title,
  description: skill.benefit + ' ' + skill.desc,
  estimatedCost: { '@type': 'MonetaryAmount', currency: 'GBP', value: String(basePrice) },
  tool: skill.tools.map(t => ({ '@type': 'HowToTool', name: t })),
  step: [
    { '@type': 'HowToStep', name: 'Book a free audit', text: 'We map your current process and confirm exact ROI on a 60-minute call.' },
    { '@type': 'HowToStep', name: 'PURIST builds and tests', text: `We configure the automation with ${skill.tools.join(', ')}, test against real data, and get your approval.` },
    { '@type': 'HowToStep', name: 'Live in 7 days', text: `Start saving ${skill.time} from week one. 24/7 monitoring included.` },
  ],
  mainEntity: [
    { '@type': 'Question', name: `How long to deploy ${skill.title}?`, acceptedAnswer: { '@type': 'Answer', text: 'Most clients are live within 7 business days after the initial audit call.' } },
    { '@type': 'Question', name: 'Do I need technical knowledge?', acceptedAnswer: { '@type': 'Answer', text: 'No. PURIST handles all setup, testing, and deployment. You approve before anything goes live.' } },
    { '@type': 'Question', name: 'Do I own the automation?', acceptedAnswer: { '@type': 'Answer', text: 'Yes, 100%. Full source code, credentials, and access. No platform fees.' } },
  ],
};
---

<BaseLayout
  title={`${skill.title} — PURIST Automation Skill`}
  description={`${skill.benefit} ${skill.desc} Deployed in 7 days with 24/7 monitoring. From £${basePrice}.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLd)} slot="head" />
  <Header />

  <main id="main-content" class="bg-white min-h-screen">

    <!-- Breadcrumb -->
    <div class="border-b border-gray-100">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3">
        <nav class="text-sm text-gray-400 flex items-center gap-1.5 flex-wrap">
          <a href="/" class="hover:text-gray-700 transition">Home</a>
          <span>/</span>
          <a href="/skills" class="hover:text-gray-700 transition">Skills</a>
          <span>/</span>
          <a href={`/skills?cat=${skill.cat}`} class="hover:text-gray-700 transition">{catLabels[skill.cat]}</a>
          <span>/</span>
          <span class="text-gray-700 font-medium">{skill.title}</span>
        </nav>
      </div>
    </div>

    <!-- Hero section -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 lg:py-12">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16">

        <!-- Left: main content -->
        <div class="lg:col-span-8">

          <!-- Icon + title -->
          <div class="flex items-start gap-4 mb-5">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center shrink-0" style={`background:${PINK_BG}`}>
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke={PINK} stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d={cs.icon}/>
              </svg>
            </div>
            <div>
              <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 leading-tight">{skill.title}</h1>
              <p class="text-sm text-gray-400 mt-1">by <span class="text-gray-600 font-medium">PURIST</span> · {catLabels[skill.cat]}</p>
            </div>
          </div>

          <!-- One-line benefit -->
          <p class="text-base text-gray-600 mb-4 leading-relaxed max-w-2xl">{skill.benefit}</p>

          <!-- Updated + time saved -->
          <div class="flex items-center gap-4 text-xs text-gray-400 mb-5">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
              Updated June 2026
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              Saves {skill.time}
            </span>
          </div>

          <!-- 3 key capability bullets -->
          <ul class="space-y-2.5 mb-6">
            {descSentences.map(s => (
              <li class="flex items-start gap-2.5 text-sm text-gray-700">
                <svg class="w-4 h-4 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke={PINK} stroke-width="2.5" stroke-linecap="round"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                {s}
              </li>
            ))}
          </ul>

          <!-- Tool pills -->
          <div class="flex flex-wrap gap-2 mb-6">
            {displayTools.map(t => (
              <span class="text-xs font-medium px-3 py-1.5 rounded-full border border-gray-200 text-gray-600 bg-gray-50">{t}</span>
            ))}
          </div>

          <!-- Trust signals row -->
          <div class="flex flex-wrap items-center gap-4 text-xs text-gray-400 border-t border-gray-100 pt-4 mb-8">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke={PINK} stroke-width="2.5" stroke-linecap="round"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              Verified deployment
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 shrink-0" style={`color:${PINK}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              Live in 7 days
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              30-day money-back guarantee
            </span>
            {skill.complexity === 'Starter' && (
              <span class="flex items-center gap-1.5 font-medium" style={`color:${PINK}`}>
                <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 13l4 4L19 7"/></svg>
                Beginner-friendly
              </span>
            )}
          </div>

          <!-- ROI snapshot -->
          <div class="grid grid-cols-2 gap-3 mb-6">
            {[
              { label: 'Time saved', value: skill.time, sub: 'per week, every week' },
              { label: 'Go live', value: '7 days', sub: 'from audit to deployment' },
              { label: 'Monitoring', value: '24/7', sub: 'error alerts to our team' },
              { label: 'Guarantee', value: '30 days', sub: 'full refund if not satisfied' },
            ].map(m => (
              <div class="rounded-xl border border-gray-100 bg-gray-50 p-4">
                <p class="text-xl font-bold leading-none mb-1" style={`color:${PINK}`}>{m.value}</p>
                <p class="text-xs font-semibold text-gray-700 mb-0.5">{m.label}</p>
                <p class="text-[11px] text-gray-400 leading-snug">{m.sub}</p>
              </div>
            ))}
          </div>

          <!-- Best fit for -->
          <div class="rounded-xl border border-gray-100 p-4">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Best fit for</p>
            <ul class="space-y-1.5">
              {skill.industries.slice(0, 4).map(i => (
                <li class="flex items-center gap-2 text-sm text-gray-600">
                  <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background:${PINK}`}></span>
                  {industryLabels[i] ?? i}
                </li>
              ))}
              <li class="flex items-center gap-2 text-sm text-gray-600">
                <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background:${PINK}`}></span>
                Any team doing {catLabels[skill.cat].toLowerCase()} manually
              </li>
            </ul>
          </div>
        </div>

        <!-- Right: price card -->
        <div class="lg:col-span-4">
          <div class="border border-gray-200 rounded-2xl p-6 sticky top-24">
            <div class="mb-4">
              <span class="text-4xl font-bold text-gray-900">£{basePrice}</span>
              <span class="text-sm text-gray-400 ml-2">one-time · 30-day refund</span>
            </div>

            <a href="/pages/welcome"
               class="flex items-center justify-center gap-2 w-full text-white font-semibold text-sm py-3.5 rounded-xl transition mb-3"
               style={`background:${PINK}`}
               onmouseover={`this.style.background='#b5726c'`}
               onmouseout={`this.style.background='${PINK}'`}>
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              Book free audit →
            </a>
            <a href="/collections/all"
               class="flex items-center justify-center w-full border border-gray-200 text-gray-600 font-medium text-sm py-3 rounded-xl hover:bg-gray-50 transition mb-5">
              View plans
            </a>

            <div class="flex items-center justify-center gap-1.5 text-xs text-gray-400 mb-5">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              Secure · No subscription · You own everything
            </div>

            <div class="border-t border-gray-100 pt-4">
              <p class="text-xs font-semibold text-gray-700 mb-3">Included in deployment</p>
              <ul class="space-y-2">
                {included.map(item => (
                  <li class="flex items-start gap-2 text-xs text-gray-500">
                    <svg class="w-3.5 h-3.5 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke={PINK} stroke-width="2.5" stroke-linecap="round"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            <div class="border-t border-gray-100 mt-4 pt-4 flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-brand-black flex items-center justify-center shrink-0 overflow-hidden">
                <svg viewBox="0 0 32 32" class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
                  <rect width="32" height="32" fill="#0A0A0A"/>
                  <text x="16" y="22" font-family="Georgia, serif" font-size="15" font-weight="500" fill="#F8F6F1" text-anchor="middle">P</text>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold text-gray-800">PURIST</p>
                <p class="text-[10px] text-gray-400">Automation studio · London</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Social proof strip -->
    <div class="border-t border-b border-gray-100">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4">
        <div class="flex flex-wrap items-center justify-center gap-6 sm:gap-10 text-center">
          {[
            { value: '500+', label: 'automations deployed' },
            { value: '99.97%', label: 'uptime across all workflows' },
            { value: '£2.4M', label: 'in client time saved' },
            { value: '4.9 / 5', label: 'average client rating' },
          ].map(stat => (
            <div>
              <p class="text-lg font-bold text-gray-900">{stat.value}</p>
              <p class="text-xs text-gray-400">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Content + sidebar -->
    <div>
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 lg:py-12 grid lg:grid-cols-12 gap-10 lg:gap-16">

        <!-- Main content -->
        <div class="lg:col-span-8 space-y-10">

          <!-- About -->
          <div>
            <h2 class="text-xl font-bold text-gray-900 mb-4">About this skill</h2>
            <p class="text-gray-600 leading-relaxed mb-5">{skill.desc}</p>
            <p class="text-gray-600 leading-relaxed">
              PURIST builds this automation end-to-end — connecting {displayTools.join(', ')} — so you never touch the technical setup.
              Every deployment is tested against real data before handover, with 24/7 monitoring from day one.
            </p>
          </div>

          <!-- How it works: Trigger / Process / Output -->
          <div>
            <h2 class="text-xl font-bold text-gray-900 mb-2">How it works</h2>
            <p class="text-sm text-gray-400 mb-5">Three stages — trigger, process, output. Fully automated.</p>
            <ul class="space-y-0 divide-y divide-gray-100 rounded-xl border border-gray-100 overflow-hidden">
              {howItWorks.map(step => (
                <li class="flex items-start gap-4 p-5 bg-white">
                  <span class="text-xs font-bold uppercase tracking-widest shrink-0 mt-0.5 w-16" style={`color:${PINK}`}>{step.label}</span>
                  <span class="text-sm text-gray-600 leading-relaxed">{step.text}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Sample scenario -->
          <div class="rounded-xl p-5" style={`background:${PINK_BG};border:1px solid ${PINK_BORDER}`}>
            <p class="text-xs font-semibold uppercase tracking-wider mb-2" style={`color:${PINK}`}>Real-world scenario</p>
            <p class="text-sm text-gray-700 leading-relaxed">{sampleScenario}</p>
          </div>

          <!-- Why use this skill -->
          <div>
            <h2 class="text-xl font-bold text-gray-900 mb-4">Why use this skill</h2>
            <p class="text-gray-600 leading-relaxed mb-4">
              Most teams handle {catLabels[skill.cat].toLowerCase()} manually — copying data between tools, chasing updates, writing the same emails. That costs your team
              <strong> {skill.time} every week</strong>, creates inconsistency, and scales badly.
            </p>
            <p class="text-gray-600 leading-relaxed">
              This automation runs in the background, exactly as configured, every time — no errors, no forgotten steps, no context switching. You get the output; PURIST handles the execution and the monitoring.
            </p>
          </div>

          <!-- Use cases -->
          <div>
            <h2 class="text-xl font-bold text-gray-900 mb-4">Use cases</h2>
            <ul class="grid sm:grid-cols-2 gap-2">
              {useCaseBullets.map(uc => (
                <li class="flex items-center gap-2.5 text-sm text-gray-600 rounded-lg border border-gray-100 px-3.5 py-2.5 bg-gray-50">
                  <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background:${PINK}`}></span>
                  {uc}
                </li>
              ))}
              <li class="flex items-center gap-2.5 text-sm text-gray-600 rounded-lg border border-gray-100 px-3.5 py-2.5 bg-gray-50">
                <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background:${PINK}`}></span>
