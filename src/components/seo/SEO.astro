---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article' | 'product';
  noindex?: boolean;
}

const {
  title = 'Production-grade business automation',
  description = 'PURIST builds reliable workflow automations and AI agents for dental practices, real estate, agencies and e-commerce. Deployed in days, not months. 99.5% uptime SLA.',
  image,
  canonical,
  type = 'website',
  noindex = false,
} = Astro.props;

const fullTitle = title.includes('PURIST') ? title : `${title} – PURIST`;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const siteBase = (Astro.site?.toString() ?? 'https://purist.online').replace(/\/$/, '');

// Dynamic OG image — use static image if provided (e.g. blog article hero),
// otherwise generate via /api/og with the current page title + description
const ogImage = image
  ? new URL(image, Astro.site).toString()
  : `${siteBase}/api/og?title=${encodeURIComponent(fullTitle)}&description=${encodeURIComponent(description)}&type=${type}`;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content="PURIST" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

