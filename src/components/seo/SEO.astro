---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article' | 'product';
  noindex?: boolean;
}

const {
  title = 'Production-grade business automation',
  description = 'PURIST builds reliable workflow automations and AI agents for dental practices, real estate, agencies and e-commerce. Deployed in days, not months. 99.5% uptime SLA.',
  image = '/images/og-default.jpg',
  canonical,
  type = 'website',
  noindex = false,
} = Astro.props;

const fullTitle = title.includes('PURIST') ? title : `${title} – PURIST`;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content="PURIST" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<script type="application/ld+json" is:inline set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://purist.online/#organization',
      name: 'PURIST',
      url: 'https://purist.online',
      logo: {
        '@type': 'ImageObject',
        url: 'https://purist.online/favicon.svg',
        width: 512,
        height: 512,
      },
      foundingDate: '2024',
      description: 'Production-grade business automation and AI agent deployment for dental practices, real estate, agencies and e-commerce.',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'London',
        addressCountry: 'GB',
      },
      contactPoint: [
        {
          '@type': 'ContactPoint',
          email: 'hello@purist.online',
          contactType: 'customer support',
          availableLanguage: ['English', 'French'],
        },
        {
          '@type': 'ContactPoint',
          email: 'press@purist.online',
          contactType: 'press',
        },
      ],
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Automation Services',
        itemListElement: [
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Automation Pro',
              url: 'https://purist.online/products/foundation-pro',
              description: 'Production-grade workflow automation deployed in days.',
            },
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'The Full Stack',
              url: 'https://purist.online/products/founder-stack',
              description: 'End-to-end operations automation for scaling teams.',
            },
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'AI Agent Deploy',
              url: 'https://purist.online/products/longevity-protocol',
              description: 'Conversational AI agents handling scheduling, intake, and follow-ups.',
            },
          },
        ],
      },
      sameAs: [
        'https://www.linkedin.com/company/purist-automation',
        'https://twitter.com/purist_hq',
        'https://github.com/purist-hq',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://purist.online/#website',
      url: 'https://purist.online',
      name: 'PURIST',
      description: 'Production-grade business automation and AI agents.',
      publisher: { '@id': 'https://purist.online/#organization' },
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
