---
export interface Props {
 title?: string;
 description?: string;
 image?: string;
 canonical?: string;
 type?: 'website' | 'article' | 'product';
 noindex?: boolean;
}

const {
 title = 'Workflow Automation and AI Agents for Business',
 description = '500+ production deployments across dental, real estate, agencies, e-commerce, legal and staffing. n8n workflows and Claude AI agents. Deployed in days, 99.97% uptime.',
 image,
 canonical,
 type = 'website',
 noindex = false,
} = Astro.props;

const fullTitle = title.includes('PURIST') ? title : `${title} · PURIST`;
// canonicalURL uses the actual request origin (works on any deployment)
const CANONICAL_BASE = 'https://www.purist.online';
const canonicalURL = canonical || `${CANONICAL_BASE}${Astro.url.pathname}`;
// ogImage always uses the canonical site domain so social crawlers get a stable URL
const ogBase = (Astro.site?.toString() ?? Astro.url.origin).replace(/\/$/, '');
const ogImage = image
 ? `${ogBase}${image.startsWith('/') ? image : `/${image}`}`
 : `${ogBase}/og-default.png`;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content="PURIST" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@Puristonline" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta property="og:locale" content="en_GB" />

