---
// ReferralSection.astro — Partner / referral programme
---

<section id="referral" class="relative overflow-hidden py-12 lg:py-20" style="background:#0A0A0A;">

  <!-- Warm brand tint — subtle, not garish -->
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 80% 55% at 50% 0%,rgba(232,180,176,0.05) 0%,transparent 60%);"/>
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 50% 40% at 0% 100%,rgba(232,180,176,0.03) 0%,transparent 55%);"/>
  <!-- Very subtle warm top rule -->
  <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(90deg,transparent,rgba(232,180,176,0.18),transparent);"/>

  <div class="container-x relative z-10">

    <!-- ── HEADER ── -->
    <div class="max-w-2xl mb-10 lg:mb-14">
      <p class="text-[9px] uppercase tracking-[0.28em] font-bold mb-3" style="color:rgba(232,180,176,0.55);">Partner Programme</p>
      <h2 class="font-display text-[1.8rem] lg:text-[2.4rem] leading-[1.08] tracking-[-0.025em] text-white mb-3 text-balance">
        Refer a client. Earn 15% of the setup fee —
        <em class="font-medium" style="color:#E8B4B0;">forever.</em>
      </h2>
      <p class="text-[13px] leading-relaxed max-w-xl" style="color:rgba(255,255,255,0.36);">
        A straightforward programme for professionals who work with businesses that need operational leverage. No quotas, no complexity. Refer once, earn on signing.
      </p>
    </div>

    <!-- ── PARTNER TYPES STRIP ── -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 lg:gap-4 mb-10 lg:mb-14">

      <!-- Type 1: Accountants & Bookkeepers -->
      <div class="partner-card rounded-[16px] p-5 flex gap-4 items-start"
           style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);">
        <div class="w-9 h-9 rounded-[10px] flex items-center justify-center shrink-0 mt-0.5"
             style="background:rgba(232,180,176,0.08);border:1px solid rgba(232,180,176,0.14);">
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="#E8B4B0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="12" height="12" rx="2"/>
            <path d="M5 8h6M5 5.5h3M5 10.5h4"/>
          </svg>
        </div>
        <div>
          <p class="text-[12px] font-semibold text-white mb-1.5 leading-snug">Accountants &amp; Bookkeepers</p>
          <p class="text-[11px] leading-relaxed" style="color:rgba(255,255,255,0.40);">
            You see exactly which clients are drowning in manual work. Refer them to PURIST.
          </p>
        </div>
      </div>

      <!-- Type 2: n8n / Make Consultants -->
      <div class="partner-card rounded-[16px] p-5 flex gap-4 items-start"
           style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);">
        <div class="w-9 h-9 rounded-[10px] flex items-center justify-center shrink-0 mt-0.5"
             style="background:rgba(232,180,176,0.08);border:1px solid rgba(232,180,176,0.14);">
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="#E8B4B0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="8" cy="8" r="2"/>
            <circle cx="2.5" cy="4" r="1.5"/>
            <circle cx="13.5" cy="4" r="1.5"/>
            <circle cx="2.5" cy="12" r="1.5"/>
            <circle cx="13.5" cy="12" r="1.5"/>
            <path d="M4 4.5L6.5 7M9.5 7l2.5-2.5M4 11.5l2.5-2.5M9.5 9l2.5 2.5"/>
          </svg>
        </div>
        <div>
          <p class="text-[12px] font-semibold text-white mb-1.5 leading-snug">n8n / Make Consultants</p>
          <p class="text-[11px] leading-relaxed" style="color:rgba(255,255,255,0.40);">
            Have more project requests than capacity? Send overflow work our way.
          </p>
        </div>
      </div>

      <!-- Type 3: Business Coaches & Advisors -->
      <div class="partner-card rounded-[16px] p-5 flex gap-4 items-start"
           style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);">
        <div class="w-9 h-9 rounded-[10px] flex items-center justify-center shrink-0 mt-0.5"
             style="background:rgba(232,180,176,0.08);border:1px solid rgba(232,180,176,0.14);">
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="#E8B4B0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 11.5C2 9.5 4.5 8 8 8s6 1.5 6 3.5"/>
            <path d="M5.5 5a2.5 2.5 0 1 0 5 0 2.5 2.5 0 0 0-5 0z"/>
            <path d="M10.5 10.5l1.5 1.5-1.5 1.5"/>
          </svg>
        </div>
        <div>
          <p class="text-[12px] font-semibold text-white mb-1.5 leading-snug">Business Coaches &amp; Advisors</p>
          <p class="text-[11px] leading-relaxed" style="color:rgba(255,255,255,0.40);">
            Your clients need operational leverage. We deliver it.
          </p>
        </div>
      </div>

    </div>

    <!-- ── HOW IT WORKS + STATS ── -->
    <div class="grid lg:grid-cols-2 gap-4 lg:gap-6 mb-8 lg:mb-10">

      <!-- Left: How it works -->
      <div class="rounded-[18px] p-6 lg:p-7"
           style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);">
        <p class="text-[9px] uppercase tracking-[0.22em] font-bold mb-5" style="color:rgba(255,255,255,0.26);">How it works</p>

        <ol class="space-y-5">
          <li class="flex gap-4">
            <span class="w-6 h-6 rounded-full flex items-center justify-center text-[9px] font-bold shrink-0 mt-0.5"
                  style="background:rgba(232,180,176,0.12);color:#E8B4B0;border:1px solid rgba(232,180,176,0.22);">1</span>
            <div>
              <p class="text-[12px] font-semibold text-white mb-1">Share your referral link</p>
              <p class="text-[11px] leading-relaxed" style="color:rgba(255,255,255,0.38);">
                We send you a unique link. Share it by email, message, or mention — however you naturally communicate.
              </p>
            </div>
          </li>
          <li class="flex gap-4" style="padding-top:1rem;border-top:1px solid rgba(255,255,255,0.06);">
            <span class="w-6 h-6 rounded-full flex items-center justify-center text-[9px] font-bold shrink-0 mt-0.5"
                  style="background:rgba(232,180,176,0.12);color:#E8B4B0;border:1px solid rgba(232,180,176,0.22);">2</span>
            <div>
              <p class="text-[12px] font-semibold text-white mb-1">Your contact books an audit call</p>
              <p class="text-[11px] leading-relaxed" style="color:rgba(255,255,255,0.38);">
                No pressure on them. It's a free 45-minute automation audit — genuinely useful, no obligation.
              </p>
            </div>
          </li>
          <li class="flex gap-4" style="padding-top:1rem;border-top:1px solid rgba(255,255,255,0.06);">
            <span class="w-6 h-6 rounded-full flex items-center justify-center text-[9px] font-bold shrink-0 mt-0.5"
                  style="background:rgba(232,180,176,0.12);color:#E8B4B0;border:1px solid rgba(232,180,176,0.22);">3</span>
            <div>
              <p class="text-[12px] font-semibold text-white mb-1">Earn 15% of setup fee on signing</p>
              <p class="text-[11px] leading-relaxed" style="color:rgba(255,255,255,0.38);">
                Typically <span style="color:rgba(255,255,255,0.60);font-weight:600;">£200–750 per referral</span>, paid within 48h of the client's setup fee clearing.
              </p>
            </div>
          </li>
        </ol>
      </div>

      <!-- Right: Stats box -->
      <div class="rounded-[18px] p-6 lg:p-7 flex flex-col justify-between"
           style="background:rgba(232,180,176,0.05);border:1px solid rgba(232,180,176,0.14);">

        <p class="text-[9px] uppercase tracking-[0.22em] font-bold mb-6" style="color:rgba(232,180,176,0.55);">Programme at a glance</p>

        <div class="space-y-5">

          <div class="flex items-start justify-between gap-4" style="padding-bottom:1.1rem;border-bottom:1px solid rgba(255,255,255,0.06);">
            <p class="text-[11.5px] leading-snug" style="color:rgba(255,255,255,0.44);">Clients referred by partners</p>
            <p class="font-display text-[1.5rem] leading-none font-medium tabular-nums shrink-0" style="color:#E8B4B0;">312</p>
          </div>

          <div class="flex items-start justify-between gap-4" style="padding-bottom:1.1rem;border-bottom:1px solid rgba(255,255,255,0.06);">
            <p class="text-[11.5px] leading-snug" style="color:rgba(255,255,255,0.44);">Average referral earning</p>
            <p class="font-display text-[1.5rem] leading-none font-medium tabular-nums shrink-0 text-white" data-price="340">£340</p>
          </div>

          <div class="flex items-start justify-between gap-4">
            <p class="text-[11.5px] leading-snug" style="color:rgba(255,255,255,0.44);">Payment timeline</p>
            <p class="font-display text-[1.5rem] leading-none font-medium shrink-0 text-white">48h</p>
          </div>
        </div>

        <div class="mt-6 pt-5" style="border-top:1px solid rgba(255,255,255,0.07);">
          <p class="text-[10.5px] leading-relaxed" style="color:rgba(255,255,255,0.30);">
            No minimum referrals. No expiry on your link. Paid per signed client, not per lead.
          </p>
        </div>
      </div>

    </div>

    <!-- ── CTA ── -->
    <div class="flex flex-col sm:flex-row sm:items-center gap-4">
      <a href="/pages/welcome"
         class="inline-flex items-center gap-2.5 px-5 py-3.5 rounded-[14px] text-[13px] font-semibold transition-all duration-150 self-start"
         style="background:#E8B4B0;color:#0A0A0A;"
         onmouseover="this.style.background='#d9a09b'"
         onmouseout="this.style.background='#E8B4B0'">
        Become a partner
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 8h10M9 4l4 4-4 4"/>
        </svg>
      </a>
      <p class="text-[11px]" style="color:rgba(255,255,255,0.28);">Takes 2 minutes to set up. We handle the rest.</p>
    </div>

  </div>
</section>

<style>
  .partner-card { transition: border-color 0.15s, background 0.15s; }
  .partner-card:hover { border-color: rgba(232,180,176,0.20) !important; background: rgba(255,255,255,0.06) !important; }
</style>
