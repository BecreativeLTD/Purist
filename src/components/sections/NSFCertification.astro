---
import Button from '~/components/ui/Button.astro';
---

<section class="bg-white py-20 lg:py-28">
 <div class="container-x grid lg:grid-cols-12 gap-12 items-center">

   <!-- Left: animated radar SVG in a circle frame -->
   <div class="lg:col-span-5 flex justify-center">
     <div class="flex flex-col items-center gap-4">
     <div class="relative w-64 h-64 lg:w-80 lg:h-80">

       <!-- Soft atmospheric glow -->
       <div class="absolute inset-0 rounded-full"
         style="background:radial-gradient(ellipse,rgba(160,82,45,0.10) 0%,transparent 68%);filter:blur(28px);"></div>

       <svg viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg"
         class="w-full h-full" aria-hidden="true" role="presentation">

         <style>
           /* Rotations */
           @keyframes nc-cw { to { transform:rotate(360deg); } }
           @keyframes nc-ccw { to { transform:rotate(-360deg); } }

           /* Focal pulse */
           @keyframes nc-fp { 0%,100%{opacity:.55} 50%{opacity:1} }

           /* Node blink */
           @keyframes nc-nb { 0%,100%{opacity:.25} 50%{opacity:.80} }

           /* Radar sweep */
           @keyframes nc-sw { to{transform:rotate(360deg)} }

           /* Data stream */
           @keyframes nc-ds { from{stroke-dashoffset:0} to{stroke-dashoffset:-24} }

           /* Pulse ring expand */
           @keyframes nc-pr { 0%{transform:scale(.04);opacity:.5} 100%{transform:scale(1);opacity:0} }

           /* Text fade cycle */
           @keyframes nc-tx { 0%,15%,85%,100%{opacity:0} 35%,65%{opacity:.70} }

           /* Ring classes */
           .nc-r1{transform-origin:160px 160px;animation:nc-cw 28s linear infinite}
           .nc-r2{transform-origin:160px 160px;animation:nc-ccw 18s linear infinite}
           .nc-r3{transform-origin:160px 160px;animation:nc-cw 40s linear infinite}
           .nc-r4{transform-origin:160px 160px;animation:nc-ccw 12s linear infinite}

           /* Sweep */
           .nc-sw{transform-origin:160px 160px;animation:nc-sw 6s linear infinite}
           .nc-sw2{transform-origin:160px 160px;animation:nc-sw 10s linear infinite 2s}

           /* Nodes */
           .nc-n1{animation:nc-nb 4s ease-in-out infinite}
           .nc-n2{animation:nc-nb 6s ease-in-out infinite 1.2s}
           .nc-n3{animation:nc-nb 5s ease-in-out infinite 2.8s}
           .nc-n4{animation:nc-nb 7s ease-in-out infinite .6s}

           /* Focal */
           .nc-fp{animation:nc-fp 3s ease-in-out infinite}

           /* Data streams */
           .nc-ds1{animation:nc-ds 1.4s linear infinite}
           .nc-ds2{animation:nc-ds 1.8s linear infinite .5s}
           .nc-ds3{animation:nc-ds 2.2s linear infinite 1s}

           /* Pulse rings */
           .nc-pr1{transform-origin:160px 160px;animation:nc-pr 3.4s ease-out infinite}
           .nc-pr2{transform-origin:160px 160px;animation:nc-pr 3.4s ease-out infinite 1.13s}
           .nc-pr3{transform-origin:160px 160px;animation:nc-pr 3.4s ease-out infinite 2.26s}

           /* Text */
           .nc-t1{animation:nc-tx 12s ease-in-out infinite}
           .nc-t2{animation:nc-tx 12s ease-in-out infinite 4s}
           .nc-t3{animation:nc-tx 12s ease-in-out infinite 8s}
         </style>

         <!-- Blueprint grid -->
         <g stroke="#0A0A0A" stroke-width=".18" opacity=".04">
           <line x1="53" y1="0" x2="53" y2="320"/>
           <line x1="107" y1="0" x2="107" y2="320"/>
           <line x1="160" y1="0" x2="160" y2="320"/>
           <line x1="213" y1="0" x2="213" y2="320"/>
           <line x1="267" y1="0" x2="267" y2="320"/>
           <line x1="0" y1="53" x2="320" y2="53"/>
           <line x1="0" y1="107" x2="320" y2="107"/>
           <line x1="0" y1="160" x2="320" y2="160"/>
           <line x1="0" y1="213" x2="320" y2="213"/>
           <line x1="0" y1="267" x2="320" y2="267"/>
         </g>

         <!-- Focal radial glow -->
         <defs>
           <radialGradient id="ncfg" cx="50%" cy="50%" r="50%">
             <stop offset="0%" stop-color="#A0522D" stop-opacity=".20"/>
             <stop offset="100%" stop-color="#A0522D" stop-opacity="0"/>
           </radialGradient>
           <clipPath id="ncc"><circle cx="160" cy="160" r="148"/></clipPath>
         </defs>
         <circle cx="160" cy="160" r="120" fill="url(#ncfg)"/>

         <!-- Outer circle frame -->
         <circle cx="160" cy="160" r="148" fill="none" stroke="#0A0A0A" stroke-width=".5" opacity=".10"/>

         <!-- Static reference rings -->
         <circle cx="160" cy="160" r="138" fill="none" stroke="#0A0A0A" stroke-width=".28" opacity=".06"/>
         <circle cx="160" cy="160" r="95" fill="none" stroke="#0A0A0A" stroke-width=".24" opacity=".07"/>
         <circle cx="160" cy="160" r="30" fill="none" stroke="#0A0A0A" stroke-width=".50" opacity=".14"/>

         <!-- Animated rings -->
         <!-- r=130 CW rust -->
         <circle class="nc-r1" cx="160" cy="160" r="130"
           fill="none" stroke="#A0522D" stroke-width="1.0" opacity=".28" stroke-dasharray="20 10"/>
         <!-- r=100 CCW black -->
         <circle class="nc-r2" cx="160" cy="160" r="100"
           fill="none" stroke="#0A0A0A" stroke-width=".70" opacity=".20" stroke-dasharray="12 8"/>
         <!-- r=70 CW green -->
         <circle class="nc-r3" cx="160" cy="160" r="70"
           fill="none" stroke="#2D5016" stroke-width=".80" opacity=".24" stroke-dasharray="8 10"/>
         <!-- r=44 CCW rust fast -->
         <circle class="nc-r4" cx="160" cy="160" r="44"
           fill="none" stroke="#A0522D" stroke-width=".90" opacity=".30" stroke-dasharray="5 7"/>

         <!-- Outer hexagon (r=130, pointy-top) -->
         <!-- Top:160,30 NE:273,95 SE:273,225 Bot:160,290 SW:47,225 NW:47,95 -->
         <polygon points="160,30 273,95 273,225 160,290 47,225 47,95"
           fill="none" stroke="#0A0A0A" stroke-width=".42" opacity=".09"/>

         <!-- Mid hexagon (r=87) -->
         <!-- 160,73 235,116 235,204 160,247 85,204 85,116 -->
         <polygon points="160,73 235,116 235,204 160,247 85,204 85,116"
           fill="none" stroke="#A0522D" stroke-width=".44" opacity=".11"/>

         <!-- Diamond at N/E/S/W of r=95 -->
         <polygon points="160,65 255,160 160,255 65,160"
           fill="none" stroke="#0A0A0A" stroke-width=".36" opacity=".10"/>

         <!-- Spokes (6-fold symmetry) -->
         <g stroke="#0A0A0A" stroke-width=".30" opacity=".09">
           <line x1="160" y1="160" x2="160" y2="30"/>
           <line x1="160" y1="160" x2="273" y2="95"/>
           <line x1="160" y1="160" x2="273" y2="225"/>
           <line x1="160" y1="160" x2="160" y2="290"/>
           <line x1="160" y1="160" x2="47" y2="225"/>
           <line x1="160" y1="160" x2="47" y2="95"/>
         </g>
         <!-- Accent spokes -->
         <line x1="160" y1="160" x2="273" y2="95" stroke="#A0522D" stroke-width=".44" opacity=".18"/>
         <line x1="160" y1="160" x2="47" y2="225" stroke="#2D5016" stroke-width=".44" opacity=".18"/>

         <!-- Radar sweeps -->
         <g class="nc-sw">
           <line x1="160" y1="160" x2="160" y2="32"
             stroke="#A0522D" stroke-width=".90" opacity=".22" stroke-linecap="round"/>
           <circle cx="160" cy="40" r="2.5" fill="#A0522D" opacity=".40"/>
         </g>
         <g class="nc-sw2">
           <line x1="160" y1="160" x2="160" y2="32"
             stroke="#2D5016" stroke-width=".60" opacity=".16" stroke-linecap="round"/>
         </g>

         <!-- Data streams on accent spokes -->
         <line class="nc-ds1" x1="160" y1="160" x2="273" y2="95"
           stroke="#A0522D" stroke-width=".85" stroke-dasharray="4 8" opacity=".26"/>
         <line class="nc-ds2" x1="160" y1="160" x2="47" y2="225"
           stroke="#2D5016" stroke-width=".85" stroke-dasharray="4 8" opacity=".26"/>
         <line class="nc-ds3" x1="160" y1="160" x2="160" y2="30"
           stroke="#0A0A0A" stroke-width=".65" stroke-dasharray="3 8" opacity=".18"/>

         <!-- Pulse rings -->
         <circle class="nc-pr1" cx="160" cy="160" r="63" fill="none" stroke="#A0522D" stroke-width=".85"/>
         <circle class="nc-pr2" cx="160" cy="160" r="63" fill="none" stroke="#A0522D" stroke-width=".85"/>
         <circle class="nc-pr3" cx="160" cy="160" r="63" fill="none" stroke="#A0522D" stroke-width=".85"/>

         <!-- Outer hex nodes -->
         <circle cx="160" cy="30" r="4.0" fill="#0A0A0A" opacity=".40"/>
         <circle class="nc-n1" cx="273" cy="95" r="3.6" fill="#A0522D" opacity=".58"/>
         <circle class="nc-n2" cx="273" cy="225" r="3.6" fill="#2D5016" opacity=".54"/>
         <circle cx="160" cy="290" r="4.0" fill="#0A0A0A" opacity=".40"/>
         <circle class="nc-n3" cx="47" cy="225" r="3.6" fill="#A0522D" opacity=".54"/>
         <circle class="nc-n4" cx="47" cy="95" r="3.6" fill="#2D5016" opacity=".58"/>

         <!-- Mid hex nodes -->
         <circle class="nc-n2" cx="160" cy="73" r="2.8" fill="#A0522D" opacity=".50"/>
         <circle cx="235" cy="116"           r="2.4" fill="#0A0A0A" opacity=".40"/>
         <circle class="nc-n4" cx="235" cy="204" r="2.8" fill="#2D5016" opacity=".48"/>
         <circle cx="160" cy="247"           r="2.8" fill="#0A0A0A" opacity=".40"/>
         <circle class="nc-n1" cx="85" cy="204" r="2.8" fill="#A0522D" opacity=".48"/>
         <circle cx="85" cy="116"           r="2.4" fill="#0A0A0A" opacity=".40"/>

         <!-- Diamond N/E/S/W nodes -->
         <circle class="nc-n3" cx="160" cy="65" r="2.6" fill="#A0522D" opacity=".48"/>
         <circle class="nc-n1" cx="255" cy="160" r="2.6" fill="#2D5016" opacity=".46"/>
         <circle class="nc-n4" cx="160" cy="255" r="2.6" fill="#A0522D" opacity=".48"/>
         <circle class="nc-n2" cx="65" cy="160" r="2.6" fill="#2D5016" opacity=".46"/>

         <!-- Precision tick marks at 30° on r=63 -->
         <g stroke="#0A0A0A" stroke-width=".60" opacity=".26" stroke-linecap="round">
           <line x1="223" y1="160" x2="228" y2="160"/>
           <line x1="214" y1="128" x2="219" y2="125"/>
           <line x1="191" y1="105" x2="195" y2="99"/>
           <line x1="160" y1="97" x2="160" y2="91"/>
           <line x1="129" y1="105" x2="125" y2="99"/>
           <line x1="106" y1="128" x2="101" y2="125"/>
           <line x1="97" y1="160" x2="92" y2="160"/>
           <line x1="106" y1="192" x2="101" y2="195"/>
           <line x1="129" y1="215" x2="125" y2="221"/>
           <line x1="160" y1="223" x2="160" y2="229"/>
           <line x1="191" y1="215" x2="195" y2="221"/>
           <line x1="214" y1="192" x2="219" y2="195"/>
         </g>

         <!-- Crosshair at center -->
         <g stroke="#0A0A0A" stroke-width=".44" opacity=".20" stroke-linecap="round">
           <line x1="148" y1="160" x2="155" y2="160"/>
           <line x1="165" y1="160" x2="172" y2="160"/>
           <line x1="160" y1="148" x2="160" y2="155"/>
           <line x1="160" y1="165" x2="160" y2="172"/>
         </g>

         <!-- Focal dot -->
         <circle cx="160" cy="160" r="11" fill="none" stroke="#A0522D" stroke-width=".65" opacity=".20"/>
         <circle cx="160" cy="160" r="7" fill="none" stroke="#A0522D" stroke-width=".50" opacity=".16"/>
         <circle class="nc-fp" cx="160" cy="160" r="4.5" fill="#A0522D" opacity=".65"/>
         <circle cx="160" cy="160" r="1.8" fill="#0A0A0A" opacity=".85"/>

         <!-- Floating data labels (3 staggered groups) -->
         <g class="nc-t1" font-family="ui-monospace,monospace">
           <text x="160" y="20" font-size="6.5" fill="#0A0A0A" text-anchor="middle" letter-spacing="2">ACTIVE</text>
           <text x="273" y="86" font-size="6.5" fill="#A0522D" text-anchor="middle" letter-spacing="2">SYNC</text>
           <text x="230" y="156" font-size="5.5" fill="#0A0A0A" text-anchor="start" letter-spacing=".8" opacity=".55">99.97%</text>
           <text x="230" y="166" font-size="4.2" fill="#6B6B6B" text-anchor="start" letter-spacing=".6" opacity=".45">uptime SLA</text>
         </g>
         <g class="nc-t2" font-family="ui-monospace,monospace">
           <text x="47" y="86" font-size="6.5" fill="#2D5016" text-anchor="middle" letter-spacing="2">MONITOR</text>
           <text x="273" y="234" font-size="6.5" fill="#0A0A0A" text-anchor="middle" letter-spacing="2">n8n CLOUD</text>
           <text x="160" y="118" font-size="5.5" fill="#0A0A0A" text-anchor="middle" letter-spacing=".8" opacity=".55">142,847</text>
           <text x="160" y="128" font-size="4.2" fill="#6B6B6B" text-anchor="middle" letter-spacing=".6" opacity=".45">exec / month</text>
         </g>
         <g class="nc-t3" font-family="ui-monospace,monospace">
           <text x="47" y="234" font-size="6.5" fill="#A0522D" text-anchor="middle" letter-spacing="2">24/7 LIVE</text>
           <text x="160" y="282" font-size="6.5" fill="#0A0A0A" text-anchor="middle" letter-spacing="2">DEPLOY</text>
           <text x="90" y="156" font-size="5.5" fill="#2D5016" text-anchor="end" letter-spacing=".8" opacity=".55">9.4× ROI</text>
           <text x="90" y="166" font-size="4.2" fill="#6B6B6B" text-anchor="end" letter-spacing=".6" opacity=".45">per $ invested</text>
         </g>

         <!-- Crop marks -->
         <g stroke="#0A0A0A" stroke-width=".28" opacity=".10">
           <line x1="5" y1="5" x2="26" y2="5"/> <line x1="5" y1="5" x2="5" y2="26"/>
           <line x1="315" y1="5" x2="294" y2="5"/> <line x1="315" y1="5" x2="315" y2="26"/>
           <line x1="5" y1="315" x2="26" y2="315"/> <line x1="5" y1="315" x2="5" y2="294"/>
           <line x1="315" y1="315" x2="294" y2="315"/> <line x1="315" y1="315" x2="315" y2="294"/>
         </g>

       </svg>

       <!-- Badge -->
       <span class="absolute -top-2 -right-2 bg-brand-black text-white text-[10px] tracking-wider uppercase px-3 py-1 rounded-full font-medium">
         Production-tested
       </span>
     </div>

     <!-- Stat block below the circle -->
     <div class="text-center">
       <p class="font-display text-4xl lg:text-5xl leading-none">99.97%</p>
       <p class="text-[11px] tracking-[0.22em] uppercase text-brand-gray-600 mt-2 font-medium">Uptime SLA</p>
     </div>
     </div>
   </div>

   <div class="lg:col-span-7 max-w-xl">
     <p class="eyebrow mb-4">Production-grade reliability</p>
     <h2 class="font-display text-h1 mb-5 text-balance">
       Battle-tested workflows.<br />
       Continuously <em class="font-medium">monitored.</em>
     </h2>
     <p class="text-base text-brand-gray-600 mb-4 leading-relaxed">
       Every workflow in Automation Pro and AI Agent Deploy is tested in staging,
       deployed with full error handling, and monitored 24/7 with real-time alerts
       for failures, latency spikes and API changes.
     </p>
     <p class="text-base text-brand-gray-600 mb-8 leading-relaxed">
       99.97% uptime SLA is our minimum standard 
       the same reliability level expected by regulated industries, scaling startups and
       multi-location businesses.
     </p>
     <Button href="/pages/dashboard" variant="secondary">View monitoring dashboard →</Button>
   </div>
 </div>
</section>
