 .roi-range--green::-webkit-slider-thumb { background:#2D5016; box-shadow:0 0 0 3px rgba(45,80,22,0.22); }
 .roi-range--green::-moz-range-thumb    { background:#2D5016; }
 .roi-range--amber::-webkit-slider-thumb { background:#C89840; box-shadow:0 0 0 3px rgba(200,152,64,0.22); }
 .roi-range--amber::-moz-range-thumb    { background:#C89840; }

 .roi-lbl   { font-size:11px; font-weight:600; color:rgba(255,255,255,0.55); display:block; }
 .roi-lbl-sub { font-size:9.5px; font-weight:400; color:rgba(255,255,255,0.55); }
 .roi-val   { font-size:11.5px; font-weight:700; color:rgba(255,255,255,0.75); font-family:ui-monospace,monospace; white-space:nowrap; }
 .roi-ticks { display:flex; justify-content:space-between; font-size:9px; color:rgba(255,255,255,0.22); margin-top:4px; letter-spacing:0.04em; }

 .ind-tab:not([style*="background:#E8B4B0"]):hover {
   background: rgba(255,255,255,0.10) !important;
   color: rgba(255,255,255,0.72) !important;
 }
