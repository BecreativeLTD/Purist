---
// ROICalculator.astro Interactive ROI Calculator
---

<section id="roi-calc" class="relative overflow-hidden py-12 lg:py-16" style="background:#0A0A0A;">

 <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 70% 50% at 50% 0%,rgba(232,180,176,0.05) 0%,transparent 55%);"/>
 <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 40% 40% at 10% 80%,rgba(45,80,22,0.04) 0%,transparent 60%);"/>

 <div class="container-x relative z-10">

   <!-- ── HEADER ── -->
   <div class="max-w-3xl mb-7 lg:mb-9">
     <p class="text-[9px] uppercase tracking-[0.28em] font-bold mb-3" style="color:rgba(232,180,176,0.55);">ROI Calculator</p>
     <h2 class="font-display text-[1.8rem] lg:text-[2.4rem] leading-[1.08] tracking-[-0.025em] text-white mb-3 text-balance">
       Your automation ROI,<br/><em class="font-medium" style="color:#E8B4B0;">calculated to the penny.</em>
     </h2>
     <p class="text-[13px] leading-relaxed max-w-2xl" style="color:rgba(255,255,255,0.60);">
       Every figure uses verified benchmarks from 500+ automation deployments task coverage rates, error frequencies, and hourly costs by UK industry.
     </p>
   </div>

   <!-- ── INDUSTRY TABS ── -->
   <div class="flex flex-wrap gap-1.5 mb-6" id="ind-tabs">
     {[
       { id: 'dental',  label: 'Dental / Medical' },
       { id: 'legal',   label: 'Law Firm'        },
       { id: 'agency',  label: 'Agency'          },
       { id: 'ecommerce', label: 'E-commerce'      },
       { id: 'saas',    label: 'SaaS / Tech'     },
       { id: 'realestate',label: 'Real Estate'     },
       { id: 'finance', label: 'Finance / Accounting'},
     ].map((ind, i) => (
       <button
         class="ind-tab text-[11px] font-semibold px-3.5 py-1.5 rounded-full transition-all duration-150"
         data-ind={ind.id}
         aria-label={`Calculate ROI for ${ind.label}`}
         style={i === 0
           ? 'background:#E8B4B0;color:#0A0A0A;'
           : 'background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.46);border:1px solid rgba(255,255,255,0.09);'}
       >{ind.label}</button>
     ))}
   </div>

   <!-- ── MAIN GRID ── -->
   <div class="grid lg:grid-cols-[390px_1fr] xl:grid-cols-[420px_1fr] gap-4 lg:gap-5 mb-6">

     <!-- ═══ LEFT: INPUTS ═══ -->
     <div class="rounded-[18px] p-5" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);">

       <p class="text-[9px] uppercase tracking-[0.22em] font-bold mb-4" style="color:rgba(255,255,255,0.55);">Adjust your numbers</p>

       <!-- Team size -->
       <div class="roi-slider-group mb-4">
         <div class="flex items-center justify-between mb-1.5">
           <label class="roi-lbl" for="sl-team">Team size</label>
           <span class="roi-val"><span id="val-team">8</span> people</span>
         </div>
         <input id="sl-team" type="range" min="1" max="100" value="8" step="1" class="roi-range"/>
         <div class="roi-ticks"><span>1</span><span>50</span><span>100</span></div>
       </div>

       <!-- Hourly cost -->
       <div class="roi-slider-group mb-4">
         <div class="flex items-center justify-between mb-1.5">
           <label class="roi-lbl" for="sl-hourly">Avg. hourly cost</label>
           <span class="roi-val">€<span id="val-hourly">26</span>/hr</span>
         </div>
         <input id="sl-hourly" type="range" min="15" max="150" value="26" step="1" class="roi-range"/>
         <div class="roi-ticks"><span>€15</span><span>€80</span><span>€150</span></div>
       </div>

       <!-- Manual hours/week -->
       <div class="roi-slider-group mb-4">
         <div class="flex items-center justify-between mb-1.5">
           <label class="roi-lbl" for="sl-manual">Manual hours / week <span class="roi-lbl-sub">per person</span></label>
           <span class="roi-val"><span id="val-manual">16</span>h/wk</span>
         </div>
         <input id="sl-manual" type="range" min="1" max="30" value="16" step="0.5" class="roi-range"/>
         <div class="roi-ticks"><span>1h</span><span>15h</span><span>30h</span></div>
       </div>

       <!-- Advanced -->
       <div class="mb-4" style="border-top:1px solid rgba(255,255,255,0.06);padding-top:1rem;">
         <button id="adv-toggle" aria-expanded="false" aria-controls="adv-panel" class="flex items-center gap-2 transition-all" style="color:rgba(255,255,255,0.32);">
           <svg id="adv-arrow" class="w-3 h-3 transition-transform duration-200" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
             <path d="M3 5l4 4 4-4"/>
           </svg>
           <span class="text-[10.5px] font-semibold uppercase tracking-[0.14em]">Advanced inputs</span>
         </button>
         <div id="adv-panel" class="hidden mt-4 space-y-4">
           <div class="roi-slider-group">
             <div class="flex items-center justify-between mb-1.5">
               <label class="roi-lbl" for="sl-tools">Monthly SaaS stack <span class="roi-lbl-sub">subscriptions</span></label>
               <span class="roi-val">€<span id="val-tools">750</span>/mo</span>
             </div>
             <input id="sl-tools" type="range" min="0" max="5000" value="750" step="50" class="roi-range roi-range--purple"/>
             <div class="roi-ticks"><span>€0</span><span>€2.5K</span><span>€5K</span></div>
           </div>
           <div class="roi-slider-group">
             <div class="flex items-center justify-between mb-1.5">
               <label class="roi-lbl" for="sl-error">Error rate in manual tasks</label>
               <span class="roi-val"><span id="val-error">12</span>%</span>
             </div>
             <input id="sl-error" type="range" min="1" max="30" value="12" step="1" class="roi-range roi-range--green"/>
             <div class="roi-ticks"><span>1%</span><span>15%</span><span>30%</span></div>
           </div>
           <div class="roi-slider-group">
             <div class="flex items-center justify-between mb-1.5">
               <label class="roi-lbl" for="sl-turnover">Staff turnover / year <span class="roi-lbl-sub">replacement cost €5–9K each</span></label>
               <span class="roi-val"><span id="val-turnover">2</span> people</span>
             </div>
             <input id="sl-turnover" type="range" min="0" max="20" value="2" step="1" class="roi-range roi-range--amber"/>
             <div class="roi-ticks"><span>0</span><span>10</span><span>20</span></div>
           </div>
         </div>
       </div>

       <!-- Scenario -->
       <div class="mb-4" style="border-top:1px solid rgba(255,255,255,0.06);padding-top:1rem;">
         <p class="text-[9px] uppercase tracking-[0.18em] font-bold mb-2.5" style="color:rgba(255,255,255,0.26);">Scenario</p>
         <div class="flex gap-1.5" id="tier-btns">
           <button class="tier-btn text-[10.5px] font-semibold px-3 py-1.5 rounded-full transition-all duration-100"
             data-tier="0" aria-label="Conservative ROI scenario" style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.44);border:1px solid rgba(255,255,255,0.08);">Conservative</button>
           <button class="tier-btn text-[10.5px] font-semibold px-3 py-1.5 rounded-full transition-all duration-100"
             data-tier="1" aria-label="Realistic ROI scenario" style="background:#E8B4B0;color:#0A0A0A;">Realistic</button>
           <button class="tier-btn text-[10.5px] font-semibold px-3 py-1.5 rounded-full transition-all duration-100"
             data-tier="2" aria-label="Optimistic ROI scenario" style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.44);border:1px solid rgba(255,255,255,0.08);">Optimistic</button>
         </div>
       </div>

       <!-- Processes -->
       <div style="border-top:1px solid rgba(255,255,255,0.06);padding-top:1rem;">
         <p class="text-[9px] uppercase tracking-[0.18em] font-bold mb-2.5" style="color:rgba(255,255,255,0.26);">Automatable processes detected</p>
         <ul id="process-list" class="space-y-1.5"></ul>
         <p class="text-[9.5px] mt-2.5" style="color:rgba(255,255,255,0.22);">Based on <span id="proc-ind-label">dental practice</span> workflow patterns</p>
       </div>

       <!-- PURIST cost indicator -->
       <div class="mt-4 pt-4 flex items-center justify-between" style="border-top:1px solid rgba(255,255,255,0.06);">
         <span class="text-[10px]" style="color:rgba(255,255,255,0.55);">PURIST monthly retainer</span>
         <span class="text-[11px] font-bold tabular-nums" style="color:rgba(232,180,176,0.70);" id="purist-cost-display">€2,800/mo</span>
       </div>

     </div>

     <!-- ═══ RIGHT: RESULTS ═══ -->
     <div class="space-y-3">

       <!-- Hero: Annual net savings -->
       <div class="rounded-[18px] p-5 relative overflow-hidden" style="background:rgba(232,180,176,0.07);border:1px solid rgba(232,180,176,0.17);">
         <div class="flex items-start justify-between flex-wrap gap-3">
           <div>
             <p class="text-[9px] uppercase tracking-[0.22em] font-bold mb-2" style="color:rgba(232,180,176,0.60);">Net annual savings</p>
             <div class="font-display text-[2.2rem] lg:text-[2.8rem] leading-none font-medium text-white tabular-nums transition-all duration-300" id="res-annual">€47,820</div>
             <p class="text-[11px] mt-2" style="color:rgba(255,255,255,0.60);">
               After PURIST cost · <span id="res-rate-text" class="font-semibold" style="color:rgba(255,255,255,0.55);">76%</span> coverage · <span id="res-team-text">8 people</span>
             </p>
           </div>
           <div class="text-right">
             <span id="res-tier-badge" class="text-[9px] uppercase tracking-[0.16em] font-bold px-2.5 py-1 rounded-full" style="background:rgba(232,180,176,0.14);color:#E8B4B0;">Realistic</span>
             <p class="text-[9px] mt-2 uppercase tracking-[0.14em]" style="color:rgba(255,255,255,0.22);">Gross before cost</p>
             <p class="text-[13px] font-bold tabular-nums mt-0.5" style="color:rgba(255,255,255,0.50);" id="res-gross">€56,420</p>
           </div>
         </div>
       </div>


       <!-- 6 KPI CARDS -->
       <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 sm:gap-2.5">
         <div class="rounded-[14px] p-3.5" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);">
           <p class="font-display text-[1.35rem] lg:text-[1.55rem] leading-none font-medium tabular-nums mb-1" style="color:#E8B4B0;" id="kpi-hours">324 h</p>
           <p class="text-[10px]" style="color:rgba(255,255,255,0.32);">Hours saved/mo</p>
         </div>
         <div class="rounded-[14px] p-3.5" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);">
           <p class="font-display text-[1.35rem] lg:text-[1.55rem] leading-none font-medium tabular-nums mb-1 text-white" id="kpi-monthly">€3,985</p>
           <p class="text-[10px]" style="color:rgba(255,255,255,0.32);">Net savings/mo</p>
         </div>
         <div class="rounded-[14px] p-3.5" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);">
           <p class="font-display text-[1.35rem] lg:text-[1.55rem] leading-none font-medium tabular-nums mb-1" style="color:#C89840;" id="kpi-roi">8.4×</p>
           <p class="text-[10px]" style="color:rgba(255,255,255,0.32);">Gross ROI</p>
         </div>
         <div class="rounded-[14px] p-3.5" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);">
           <p class="font-display text-[1.35rem] lg:text-[1.55rem] leading-none font-medium tabular-nums mb-1" style="color:#2D5016;" id="kpi-payback">3 wks</p>
           <p class="text-[10px]" style="color:rgba(255,255,255,0.32);">Payback period</p>
         </div>
         <div class="rounded-[14px] p-3.5" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);">
           <p class="font-display text-[1.35rem] lg:text-[1.55rem] leading-none font-medium tabular-nums mb-1" style="color:#7B68EE;" id="kpi-ftes">2.1</p>
           <p class="text-[10px]" style="color:rgba(255,255,255,0.32);">FTEs freed</p>
         </div>
         <div class="rounded-[14px] p-3.5" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);">
           <p class="font-display text-[1.35rem] lg:text-[1.55rem] leading-none font-medium tabular-nums mb-1 text-white" id="kpi-tasks">487</p>
           <p class="text-[10px]" style="color:rgba(255,255,255,0.32);">Tasks/day automated</p>
         </div>
       </div>

       <!-- SAVINGS BREAKDOWN -->
       <div class="rounded-[16px] p-4 lg:p-5" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);">
         <p class="text-[9px] uppercase tracking-[0.18em] font-bold mb-4" style="color:rgba(255,255,255,0.55);">Where the savings come from</p>
         <div class="space-y-3">

           <div>
             <div class="flex items-center justify-between mb-1.5">
               <span class="flex items-center gap-2 text-[11.5px]" style="color:rgba(255,255,255,0.55);">
                 <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background:#E8B4B0;"/>Time recovered
               </span>
               <div class="flex items-center gap-2">
                 <span class="text-[9.5px] tabular-nums" style="color:rgba(255,255,255,0.55);" id="bk-time-pct">78%</span>
                 <span class="text-[11.5px] font-semibold tabular-nums" style="color:#E8B4B0;" id="bk-time-val">€3,120/mo</span>
               </div>
             </div>
             <div class="h-1 rounded-full overflow-hidden" style="background:rgba(255,255,255,0.07);">
               <div id="bk-time-bar" class="h-full rounded-full transition-all duration-500" style="width:78%;background:linear-gradient(90deg,#E8B4B0,#c4847e);"/>
             </div>
           </div>

           <div>
             <div class="flex items-center justify-between mb-1.5">
               <span class="flex items-center gap-2 text-[11.5px]" style="color:rgba(255,255,255,0.55);">
                 <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background:#2D5016;opacity:0.9;"/>Error & rework
               </span>
               <div class="flex items-center gap-2">
                 <span class="text-[9.5px] tabular-nums" style="color:rgba(255,255,255,0.55);" id="bk-error-pct">14%</span>
                 <span class="text-[11.5px] font-semibold tabular-nums" style="color:#4a8a2a;" id="bk-error-val">€548/mo</span>
               </div>
             </div>
             <div class="h-1 rounded-full overflow-hidden" style="background:rgba(255,255,255,0.07);">
               <div id="bk-error-bar" class="h-full rounded-full transition-all duration-500" style="width:14%;background:linear-gradient(90deg,#2D5016,#4a8a2a);opacity:0.85;"/>
             </div>
           </div>

           <div>
             <div class="flex items-center justify-between mb-1.5">
               <span class="flex items-center gap-2 text-[11.5px]" style="color:rgba(255,255,255,0.55);">
                 <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background:#7B68EE;"/>Tools consolidated
               </span>
               <div class="flex items-center gap-2">
                 <span class="text-[9.5px] tabular-nums" style="color:rgba(255,255,255,0.55);" id="bk-tools-pct">8%</span>
                 <span class="text-[11.5px] font-semibold tabular-nums" style="color:#7B68EE;" id="bk-tools-val">€316/mo</span>
               </div>
             </div>
             <div class="h-1 rounded-full overflow-hidden" style="background:rgba(255,255,255,0.07);">
               <div id="bk-tools-bar" class="h-full rounded-full transition-all duration-500" style="width:8%;background:linear-gradient(90deg,#7B68EE,#9b8eff);opacity:0.85;"/>
             </div>
           </div>

           <div>
             <div class="flex items-center justify-between mb-1.5">
               <span class="flex items-center gap-2 text-[11.5px]" style="color:rgba(255,255,255,0.55);">
                 <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background:#C89840;"/>Staff retention
               </span>
               <div class="flex items-center gap-2">
                 <span class="text-[9.5px] tabular-nums" style="color:rgba(255,255,255,0.55);" id="bk-staff-pct"> </span>
                 <span class="text-[11.5px] font-semibold tabular-nums" style="color:#C89840;" id="bk-staff-val">€0/mo</span>
               </div>
             </div>
             <div class="h-1 rounded-full overflow-hidden" style="background:rgba(255,255,255,0.07);">
               <div id="bk-staff-bar" class="h-full rounded-full transition-all duration-500" style="width:0%;background:linear-gradient(90deg,#C89840,#e0b050);"/>
             </div>
           </div>

         </div>

         <div class="mt-3 pt-3 flex items-center justify-between flex-wrap gap-2" style="border-top:1px solid rgba(255,255,255,0.06);">
           <span class="text-[10px]" style="color:rgba(255,255,255,0.55);">vs. hiring a specialist (€79K/yr fully loaded)</span>
           <span class="text-[11px] font-bold" style="color:#E8B4B0;" id="vs-hire-label">Save €53K/yr vs. hiring</span>
         </div>
       </div>

       <!-- COST OF WAITING + 5YR + QUICK WINS -->
       <div class="grid sm:grid-cols-3 gap-2.5">

         <div class="rounded-[16px] p-4" style="background:rgba(220,38,38,0.07);border:1px solid rgba(220,38,38,0.14);">
           <div class="flex items-center gap-2 mb-2">
             <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background:#f87171;animation:roi-pulse 1.4s ease-in-out infinite;"/>
             <p class="text-[8.5px] uppercase tracking-[0.18em] font-bold" style="color:rgba(248,113,113,0.65);">Cost of waiting</p>
           </div>
           <p class="font-display text-[1.25rem] lg:text-[1.4rem] leading-none font-medium tabular-nums mb-1" style="color:#fca5a5;">
             −€<span id="cost-ticker">0.00</span>
           </p>
           <p class="text-[9.5px]" style="color:rgba(255,255,255,0.26);">lost since page opened</p>
         </div>

         <div class="rounded-[16px] p-4" style="background:rgba(200,152,64,0.07);border:1px solid rgba(200,152,64,0.17);">
           <p class="text-[8.5px] uppercase tracking-[0.18em] font-bold mb-2" style="color:rgba(200,152,64,0.60);">5-year projection</p>
           <p class="font-display text-[1.25rem] lg:text-[1.4rem] leading-none font-medium tabular-nums mb-1" style="color:#C89840;" id="res-5yr">€239,100</p>
           <p class="text-[9.5px]" style="color:rgba(255,255,255,0.26);">net cumulative value</p>
         </div>

         <div class="rounded-[16px] p-4" style="background:rgba(45,80,22,0.08);border:1px solid rgba(45,80,22,0.22);">
           <p class="text-[8.5px] uppercase tracking-[0.18em] font-bold mb-2" style="color:rgba(74,138,42,0.70);">Deploy timeline</p>
           <div class="space-y-1.5">
             <div class="flex items-center gap-2">
               <span class="text-[9px] font-bold tabular-nums w-10 shrink-0" style="color:#4a8a2a;">Wk 1–2</span>
               <span class="text-[9px]" style="color:rgba(255,255,255,0.38);">Audit + top 3 flows</span>
             </div>
             <div class="flex items-center gap-2">
               <span class="text-[9px] font-bold tabular-nums w-10 shrink-0" style="color:#4a8a2a;">Mo 1</span>
               <span class="text-[9px]" style="color:rgba(255,255,255,0.38);">Full stack live</span>
             </div>
             <div class="flex items-center gap-2">
               <span class="text-[9px] font-bold tabular-nums w-10 shrink-0" style="color:#4a8a2a;">Mo 3</span>
               <span class="text-[9px]" style="color:rgba(255,255,255,0.38);">ROI confirmed</span>
             </div>
           </div>
         </div>

       </div>

       <!-- EMAIL CAPTURE get the full report before CTA -->
       <div id="roi-email-gate" class="rounded-[14px] p-4 lg:p-5" style="background:rgba(232,180,176,0.06);border:1px solid rgba(232,180,176,0.18);">
         <div class="flex items-start gap-3 mb-3">
           <span class="w-8 h-8 rounded-full flex items-center justify-center shrink-0 mt-0.5" style="background:rgba(232,180,176,0.15);">
             <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="#E8B4B0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
               <path d="M14 3H2a1 1 0 00-1 1v8a1 1 0 001 1h12a1 1 0 001-1V4a1 1 0 00-1-1zM1 4l7 5 7-5"/>
             </svg>
           </span>
           <div>
             <p class="text-[12px] font-semibold text-white mb-0.5">Get your full ROI report by email</p>
             <p class="text-[11px]" style="color:rgba(255,255,255,0.38);">Your personalised breakdown including 5-year projection, process list and recommended plan.</p>
           </div>
         </div>
         <form id="roi-email-form" class="flex gap-2" onsubmit="roiEmailSubmit(event)">
           <label for="roi-email-input" class="sr-only">Email address for ROI report</label>
           <input
             type="email"
             id="roi-email-input"
             placeholder="your@email.com"
             aria-label="Email address for ROI report"
             required
             class="flex-1 rounded-[10px] px-3.5 py-2.5 text-[12.5px] outline-none transition-all"
             style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);color:white;"
             onfocus="this.style.borderColor='rgba(232,180,176,0.50)'"
             onblur="this.style.borderColor='rgba(255,255,255,0.12)'"
           />
           <button
             type="submit"
             class="shrink-0 px-4 py-2.5 rounded-[10px] text-[12px] font-semibold transition-all duration-150"
             style="background:#E8B4B0;color:#0A0A0A;"
             onmouseover="this.style.background='#d9a09b'"
             onmouseout="this.style.background='#E8B4B0'"
           >Send report</button>
