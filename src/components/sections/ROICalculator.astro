         style="background:#E8B4B0;color:#0A0A0A;"
         onmouseover="this.style.background='#d9a09b'"
         onmouseout="this.style.background='#E8B4B0'"
       >
         Get my free automation plan →
         <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
           <path d="M3 8h10M9 4l4 4-4 4"/>
         </svg>
       </a>

     </div>
   </div>

   <!-- ── BENCHMARK STRIP ── -->
   <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 pt-6 mb-4" style="border-top:1px solid rgba(255,255,255,0.07);">
     {[
       { n: '40%',  l: 'of SMB time on manual tasks',           src: 'McKinsey 2024'    },
       { n: '70–80%', l: 'of repetitive tasks automatable',       src: 'Gartner 2024'     },
       { n: '€28/hr', l: 'avg. EU admin all-in hourly cost',      src: 'Eurostat 2024'  },
       { n: '2.3h', l: 'daily rework from data errors',         src: 'Forrester 2023'   },
       { n: '€185K', l: 'avg. first-year savings (PURIST)',      src: '500+ clients'     },
     ].map(b => (
       <div>
         <p class="font-display text-lg lg:text-xl font-medium mb-1 leading-none" style="color:rgba(255,255,255,0.78);">{b.n}</p>
         <p class="text-[10.5px] leading-snug mb-1" style="color:rgba(255,255,255,0.60);">{b.l}</p>
         <p class="text-[8.5px] uppercase tracking-[0.12em]" style="color:rgba(255,255,255,0.50);">{b.src}</p>
       </div>
     ))}
   </div>
   <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pb-2">
     {[
       { n: '3 wks', l: 'avg. payback period',                   src: 'PURIST 2024'      },
       { n: '312',  l: 'automation audits completed',            src: 'PURIST clients'   },
       { n: '99.5%', l: 'workflow uptime SLA',                   src: 'PURIST infra'     },
       { n: '6.2×', l: 'avg. gross ROI multiplier',             src: 'PURIST 2024'      },
     ].map(b => (
       <div>
         <p class="font-display text-lg lg:text-xl font-medium mb-1 leading-none" style="color:rgba(255,255,255,0.78);">{b.n}</p>
         <p class="text-[10.5px] leading-snug mb-1" style="color:rgba(255,255,255,0.60);">{b.l}</p>
         <p class="text-[8.5px] uppercase tracking-[0.12em]" style="color:rgba(255,255,255,0.50);">{b.src}</p>
       </div>
     ))}
   </div>

 </div>
</section>

<style>
