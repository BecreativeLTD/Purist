         <div id="roi-email-success" class="hidden items-center gap-2 mt-2">
           <svg class="w-4 h-4 shrink-0" viewBox="0 0 16 16" fill="none" stroke="#4ade80" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8l4 4 8-8"/></svg>
           <p class="text-[11.5px]" style="color:rgba(74,222,128,0.85);">Report sent check your inbox. We'll follow up within 24h.</p>
