   box-shadow: 0 0 0 3px rgba(232,180,176,0.22); cursor: pointer; transition: box-shadow .15s;
 }
 .roi-range::-webkit-slider-thumb:hover { box-shadow: 0 0 0 5px rgba(232,180,176,0.30); }
 .roi-range::-moz-range-thumb {
