<script is:inline>
(function() {

 var INDUSTRIES = {
   dental: {
     label: 'Dental / Medical', indLabel: 'dental practice',
     rates: [0.66, 0.76, 0.84],
     defaults: { team:8, hourly:26, manual:16, toolCost:750, error:12, turnover:2 },
     toolRep: 0.35,
     processes: [
       'Patient recall & reactivation campaigns',
       'Insurance pre-authorisation requests',
       'Appointment confirmations & reminders',
       'Billing statements & payment chasing',
       'Referral letter generation & dispatch',
       'Clinical stock reordering triggers',
       'CQC compliance report generation',
     ],
   },
   legal: {
     label: 'Law Firm / Legal', indLabel: 'law firm',
     rates: [0.46, 0.62, 0.74],
     defaults: { team:6, hourly:72, manual:20, toolCost:1200, error:18, turnover:1 },
     toolRep: 0.28,
     processes: [
       'Document drafting & clause formatting',
       'Court deadline tracking & calendar alerts',
       'Client matter status update emails',
       'Time recording & billing dispatch',
       'File indexing & matter management',
       'AML compliance checks & reporting',
       'Disbursements reconciliation',
     ],
   },
   agency: {
     label: 'Agency / Creative', indLabel: 'creative agency',
     rates: [0.56, 0.70, 0.82],
     defaults: { team:10, hourly:48, manual:18, toolCost:1400, error:14, turnover:3 },
     toolRep: 0.40,
     processes: [
       'Client reporting & dashboard builds',
       'Media monitoring & alert routing',
       'Invoice generation & payment chasing',
       'Project status update emails',
       'Social media scheduling & analytics',
       'New client onboarding sequences',
       'Scope-creep tracking & alerts',
     ],
   },
   ecommerce: {
     label: 'E-commerce', indLabel: 'e-commerce operation',
     rates: [0.68, 0.80, 0.88],
     defaults: { team:12, hourly:24, manual:22, toolCost:600, error:14, turnover:4 },
     toolRep: 0.45,
     processes: [
       'Order processing & fulfilment updates',
       'Inventory sync across all channels',
       'Customer support ticket routing',
       'Returns & refund processing',
       'Supplier purchase order generation',
       'Review request & UGC collection',
       'Dynamic pricing & repricing rules',
     ],
   },
   saas: {
     label: 'SaaS / Tech', indLabel: 'SaaS company',
     rates: [0.60, 0.74, 0.86],
     defaults: { team:15, hourly:58, manual:24, toolCost:2000, error:10, turnover:2 },
     toolRep: 0.50,
     processes: [
       'User onboarding sequence automation',
       'Churn risk monitoring & alerts',
       'Failed payment recovery (dunning)',
       'Support ticket categorisation & routing',
       'Usage analytics & board reporting',
       'Trial-to-paid conversion workflows',
       'Changelog & release note distribution',
     ],
   },
   realestate: {
     label: 'Real Estate', indLabel: 'estate agency',
     rates: [0.58, 0.72, 0.83],
     defaults: { team:7, hourly:38, manual:19, toolCost:800, error:11, turnover:2 },
     toolRep: 0.38,
     processes: [
       'Property listing creation & syndication',
       'Viewing appointment scheduling & reminders',
       'Offer letter & MEMORANDUM generation',
       'Tenant referencing & credit checks',
       'Rent collection & arrears chasing',
       'Maintenance request routing',
       'Landlord monthly statement dispatch',
     ],
   },
   finance: {
     label: 'Finance / Accounting', indLabel: 'finance team',
     rates: [0.52, 0.68, 0.80],
     defaults: { team:9, hourly:55, manual:21, toolCost:1600, error:16, turnover:1 },
     toolRep: 0.42,
     processes: [
       'Invoice matching & PO reconciliation',
       'Bank feed categorisation & coding',
       'Month-end close checklist automation',
       'VAT return data extraction & filing',
       'Expense claim processing & approvals',
       'Budget variance alerts & reports',
       'Audit trail documentation & archiving',
     ],
   },
 };

 var TIER_LABELS = ['Conservative', 'Realistic', 'Optimistic'];
 var currentInd = 'dental';
 var currentTier = 1;
 var tickerInterval = null;
 var openedAt = Date.now();

 var _currencySymbol = '€';
 var _currencyRate = 1;
 window.addEventListener('puristCurrency', function(e) {
   _currencySymbol = e.detail.symbol;
   _currencyRate = e.detail.rate;
   render(); // re-render with new currency
 });

 function fmtGBP(n) {
   n = Math.round(n * _currencyRate);
   var s = _currencySymbol;
   if (n >= 1000000) return s + (n/1000000).toFixed(1) + 'M';
   if (n >= 100000) return s + Math.round(n/1000) + 'K';
   return s + n.toLocaleString('en');
 }
 function fmtK(n) {
   if (n * _currencyRate >= 10000) return _currencySymbol + Math.round(n * _currencyRate / 1000) + 'K';
   return fmtGBP(n);
 }

 function getPuristCost(team) {
   if (team <= 5) return 1800;
   if (team <= 15) return 2800;
   if (team <= 30) return 4200;
   return 6500;
 }
 function getSetupCost(team) {
   if (team <= 5) return 3500;
   if (team <= 15) return 5500;
   if (team <= 30) return 8000;
   return 12000;
 }

 function calculate() {
   var ind    = INDUSTRIES[currentInd];
   var rate   = ind.rates[currentTier];
   var team   = parseInt(document.getElementById('sl-team').value);
   var hourly = parseInt(document.getElementById('sl-hourly').value);
   var manual = parseFloat(document.getElementById('sl-manual').value);
   var toolCost = parseInt(document.getElementById('sl-tools').value);
   var errRate = parseInt(document.getElementById('sl-error').value);
   var turnover = parseInt(document.getElementById('sl-turnover').value);

   var totalManualMo = team * manual * 4.33;
   var hoursSaved  = totalManualMo * rate;
   var timeSavings = hoursSaved * hourly;

   var monthlyErrors = totalManualMo * (errRate/100) * rate;
   var errorSavings = monthlyErrors * 2.4 * hourly * 0.80;

   var toolSavings = toolCost * ind.toolRep * Math.min(rate * 0.9, 0.72);

   // Staff retention: avg €7K replacement cost per leaver reduced by 40% (automation reduces burnout)
   var staffSavings = (turnover * 6000 * 0.40) / 12;

   var grossMonthly = timeSavings + errorSavings + toolSavings + staffSavings;
   var puristMonthly = getPuristCost(team);
   var setupCost   = getSetupCost(team);
   var netMonthly  = grossMonthly - puristMonthly;
   var netAnnual   = netMonthly * 12;
   var roiMult     = grossMonthly > 0 ? Math.round((grossMonthly/puristMonthly)*10)/10 : 0;
   var paybackWeeks = netMonthly > 50 ? Math.ceil(setupCost/(netMonthly/4.33)) : 0;
   var fiveYear    = Math.max(0, netMonthly * 60 - setupCost);
   var costPerDay  = Math.max(0, netMonthly/30.4);

   // FTEs freed (hoursSaved / 160 working hrs per month)
   var fteFreed    = Math.round((hoursSaved/160)*10)/10;
   // Tasks/day automated (assume avg 0.25h per task)
   var tasksDay    = Math.round(hoursSaved / 0.25 / 30.4);

   var totalGross  = Math.max(1, timeSavings + errorSavings + toolSavings + staffSavings);
   var timePct     = Math.round((timeSavings/totalGross)*100);
   var errorPct    = Math.round((errorSavings/totalGross)*100);
   var toolsPct    = Math.round((toolSavings/totalGross)*100);
   var staffPct    = Math.max(0, 100 - timePct - errorPct - toolsPct);

   var vHire = 68000 - (puristMonthly*12);

   return {
     team, hourly, manual, rate,
     hoursSaved: Math.round(hoursSaved),
     timeSavings: Math.round(timeSavings),
     errorSavings: Math.round(errorSavings),
     toolSavings: Math.round(toolSavings),
     staffSavings: Math.round(staffSavings),
     grossMonthly: Math.round(grossMonthly),
     puristMonthly,
     netMonthly: Math.round(netMonthly),
     netAnnual: Math.round(netAnnual),
     roiMult, paybackWeeks,
     fiveYear: Math.round(fiveYear),
     costPerDay, fteFreed, tasksDay,
     timePct, errorPct, toolsPct, staffPct,
     vHire: Math.round(vHire),
   };
 }

 function setText(id, v) { var el=document.getElementById(id); if(el) el.textContent=v; }
 function setWidth(id, pct) { var el=document.getElementById(id); if(el) el.style.width=Math.max(2,Math.min(100,pct))+'%'; }

 function render() {
   var d = calculate();

   setText('res-annual',  fmtGBP(d.netAnnual));
   setText('res-gross',   fmtGBP(d.grossMonthly * 12));
   setText('res-rate-text', Math.round(d.rate*100)+'%');
   setText('res-team-text', d.team+(d.team===1?' person':' people'));
   setText('res-tier-badge', TIER_LABELS[currentTier]);

   setText('kpi-hours', d.hoursSaved+' h');
   setText('kpi-monthly', fmtGBP(d.netMonthly));
   setText('kpi-roi',   d.roiMult+'×');
   setText('kpi-payback', d.paybackWeeks > 0 ? d.paybackWeeks+' wks' : '< 1 wk');
   setText('kpi-ftes',  d.fteFreed);
   setText('kpi-tasks', d.tasksDay);

   setWidth('bk-time-bar', d.timePct);
   setWidth('bk-error-bar', d.errorPct);
   setWidth('bk-tools-bar', d.toolsPct);
   setWidth('bk-staff-bar', d.staffPct);
   setText('bk-time-val', fmtGBP(d.timeSavings)+'/mo');
   setText('bk-error-val', fmtGBP(d.errorSavings)+'/mo');
   setText('bk-tools-val', fmtGBP(d.toolSavings)+'/mo');
   setText('bk-staff-val', fmtGBP(d.staffSavings)+'/mo');
   setText('bk-time-pct', d.timePct+'%');
   setText('bk-error-pct', d.errorPct+'%');
   setText('bk-tools-pct', d.toolsPct+'%');
   setText('bk-staff-pct', d.staffPct+'%');

   setText('vs-hire-label', d.vHire > 0 ? 'Save '+fmtK(d.vHire)+'/yr vs. hiring' : d.roiMult+'× return on investment');
   setText('res-5yr', fmtGBP(d.fiveYear));
   setText('purist-cost-display', '€'+d.puristMonthly.toLocaleString('en')+'/mo');

   restartTicker(d.costPerDay);
 }

 function restartTicker(costPerDay) {
   if (tickerInterval) clearInterval(tickerInterval);
   var tickerValue = costPerDay * ((Date.now()-openedAt)/86400000);
   var costPerMs = costPerDay/86400000;
   tickerInterval = setInterval(function() {
     tickerValue += costPerMs*100;
     var el = document.getElementById('cost-ticker');
     if (el) el.textContent = tickerValue.toFixed(2);
   }, 100);
 }

 function updateSliderFill(slider, color) {
   var pct = ((parseFloat(slider.value)-parseFloat(slider.min))/(parseFloat(slider.max)-parseFloat(slider.min)))*100;
   slider.style.background = 'linear-gradient(to right,'+color+' '+pct+'%,rgba(255,255,255,0.10) '+pct+'%)';
 }

 function renderProcesses() {
   var ind = INDUSTRIES[currentInd];
   var list = document.getElementById('process-list');
   var lbl = document.getElementById('proc-ind-label');
   if (!list) return;
   list.innerHTML = '';
   ind.processes.forEach(function(p) {
     var li = document.createElement('li');
     li.style.cssText = 'display:flex;align-items:flex-start;gap:7px;';
     li.innerHTML =
       '<svg style="width:11px;height:11px;flex-shrink:0;margin-top:1px;color:#2D5016;" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="2,6 5,9 10,3"/></svg>' +
       '<span style="font-size:11px;color:rgba(255,255,255,0.50);line-height:1.4;">'+p+'</span>';
     list.appendChild(li);
   });
   if (lbl) lbl.textContent = ind.indLabel;
 }

 function switchIndustry(id) {
   currentInd = id;
   var d = INDUSTRIES[id].defaults;
   var map = [['sl-team','val-team',d.team],['sl-hourly','val-hourly',d.hourly],['sl-manual','val-manual',d.manual],['sl-tools','val-tools',d.toolCost],['sl-error','val-error',d.error],['sl-turnover','val-turnover',d.turnover]];
   map.forEach(function(m) {
     var sl=document.getElementById(m[0]); if(sl){sl.value=m[2];updateSliderFill(sl,getSliderColor(m[0]));}
     setText(m[1],m[2]);
   });
   document.querySelectorAll('.ind-tab').forEach(function(btn) {
     var a=btn.dataset.ind===id;
     btn.style.background=a?'#E8B4B0':'rgba(255,255,255,0.06)';
     btn.style.color=a?'#0A0A0A':'rgba(255,255,255,0.46)';
     btn.style.border=a?'':'1px solid rgba(255,255,255,0.09)';
   });
   renderProcesses(); render();
 }

 function switchTier(tier) {
   currentTier = tier;
   document.querySelectorAll('.tier-btn').forEach(function(btn) {
     var a=parseInt(btn.dataset.tier)===tier;
     btn.style.background=a?'#E8B4B0':'rgba(255,255,255,0.06)';
     btn.style.color=a?'#0A0A0A':'rgba(255,255,255,0.44)';
     btn.style.border=a?'':'1px solid rgba(255,255,255,0.08)';
   });
   render();
 }

 function getSliderColor(id) {
   if (id==='sl-tools')  return '#7B68EE';
   if (id==='sl-error')  return '#2D5016';
   if (id==='sl-turnover') return '#C89840';
   return '#E8B4B0';
 }

 ['sl-team','sl-hourly','sl-manual','sl-tools','sl-error','sl-turnover'].forEach(function(id,i) {
   var sl=document.getElementById(id); if(!sl)return;
   var valIds=['val-team','val-hourly','val-manual','val-tools','val-error','val-turnover'];
   updateSliderFill(sl,getSliderColor(id));
   sl.addEventListener('input',function(){setText(valIds[i],this.value);updateSliderFill(this,getSliderColor(id));render();});
 });

 document.querySelectorAll('.ind-tab').forEach(function(btn){btn.addEventListener('click',function(){switchIndustry(this.dataset.ind);});});
 document.querySelectorAll('.tier-btn').forEach(function(btn){btn.addEventListener('click',function(){switchTier(parseInt(this.dataset.tier));});});

 var advToggle=document.getElementById('adv-toggle');
 var advPanel=document.getElementById('adv-panel');
 var advArrow=document.getElementById('adv-arrow');
 if(advToggle&&advPanel){
   advToggle.addEventListener('click',function(){
     var open=!advPanel.classList.contains('hidden');
     advPanel.classList.toggle('hidden',open);
     if(advArrow)advArrow.style.transform=open?'':'rotate(180deg)';
     advToggle.style.color=open?'rgba(255,255,255,0.32)':'rgba(255,255,255,0.65)';
   });
 }

 renderProcesses();

 // Start ticker only when ROI section is visible
 var roiSection = document.getElementById('cost-ticker') && document.getElementById('cost-ticker').closest('section');
 if (roiSection && 'IntersectionObserver' in window) {
   var roiObs = new IntersectionObserver(function(entries) {
     if (entries[0].isIntersecting) { render(); roiObs.disconnect(); }
   }, { threshold: 0.15 });
   roiObs.observe(roiSection);
 } else {
   render();
 }

 // Cleanup ticker on ViewTransitions navigation
 document.addEventListener('astro:before-swap', function() {
   if (tickerInterval) { clearInterval(tickerInterval); tickerInterval = null; }
 });

})();

// ROI email capture handler
function roiEmailSubmit(e) {
 e.preventDefault();
 var email = document.getElementById('roi-email-input').value;
 var form = document.getElementById('roi-email-form');
 var success = document.getElementById('roi-email-success');
 if (!email) return;
 // Store in localStorage + fire a webhook if available
 try { localStorage.setItem('purist_roi_email', email); } catch(_) {}
 // Visual feedback immediately
 form.style.display = 'none';
 success.style.display = 'flex';
 // Fire to n8n webhook (replace with real endpoint)
 var payload = {
   email: email,
   timestamp: new Date().toISOString(),
   page: location.href,
   source: 'roi_calculator'
 };
 fetch('/api/lead-capture', {
   method: 'POST',
   headers: { 'Content-Type': 'application/json' },
   body: JSON.stringify(payload)
 }).catch(function(){}); // silent fail UX not affected
}
</script>
