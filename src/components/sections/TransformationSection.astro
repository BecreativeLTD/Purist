    <!-- Header -->
    <div class="transformation-header">
      <span class="eyebrow">Before & After</span>
      <h2 class="transformation-headline">The same process.<br/>Before and after PURIST.</h2>
      <p class="transformation-subtext">We don't change what you do. We remove the friction from how you do it.</p>
    </div>

    <!-- Tab Strip -->
    <div class="tab-strip" id="industry-tabs">
      <button class="tab-btn active" data-tab="legal">Legal</button>
      <button class="tab-btn" data-tab="dental">Dental</button>
      <button class="tab-btn" data-tab="agency">Agency</button>
      <button class="tab-btn" data-tab="ecommerce">E-commerce</button>
      <button class="tab-btn" data-tab="realestate">Real Estate</button>
    </div>

    <!-- Content Panels -->
    <div class="tab-panels" id="tab-panels">
      <!-- LEGAL -->
      <div class="tab-panel active" data-panel="legal">
