              <div class="step-item"><span class="step-num">1</span><span class="step-text">Enquiry received</span><span class="time-badge before-badge">20min</span></div>
              <div class="step-item"><span class="step-num">2</span><span class="step-text">Log to CRM</span><span class="time-badge before-badge">15min</span></div>
              <div class="step-item"><span class="step-num">3</span><span class="step-text">Draft intake form</span><span class="time-badge before-badge">25min</span></div>
              <div class="step-item"><span class="step-num">4</span><span class="step-text">Chase e-signature</span><span class="time-badge before-badge">2 days</span></div>
              <div class="step-item"><span class="step-num">5</span><span class="step-text">Create matter file</span><span class="time-badge before-badge">30min</span></div>
              <div class="step-item"><span class="step-num">6</span><span class="step-text">Send retainer invoice</span><span class="time-badge before-badge">15min</span></div>
            </div>
            <div class="total-row before-total">Total: 1h 45min + 2 days</div>
          </div>
          <div class="divider"></div>
          <div class="after-col">
            <span class="after-label">AFTER PURIST</span>
            <div class="steps-list">
              <div class="step-item"><span class="check-icon"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span><span class="step-text">Form auto-captured</span><span class="time-badge after-badge">instant</span></div>
