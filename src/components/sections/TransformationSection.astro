<section class="scroll-fade tf-section">
  <div class="tf-wrap">

    <!-- Header -->
    <div class="tf-header">
      <span class="tf-eyebrow">Before &amp; After</span>
      <h2 class="tf-headline">The same process.<br/>Before and after PURIST.</h2>
      <p class="tf-sub">We do not change what you do. We remove the friction from how you do it.</p>
    </div>

    <!-- Tabs -->
    <div class="tf-tabs" id="tf-tabs">
      <button class="tf-tab tf-tab--active" data-tab="legal">Legal</button>
      <button class="tf-tab" data-tab="dental">Dental</button>
      <button class="tf-tab" data-tab="agency">Agency</button>
      <button class="tf-tab" data-tab="ecommerce">E-commerce</button>
      <button class="tf-tab" data-tab="realestate">Real Estate</button>
    </div>

    <!-- Panels -->
    <div id="tf-panels">

      <!-- LEGAL -->
      <div class="tf-panel tf-panel--active" data-panel="legal">
        <div class="tf-compare">
          <div class="tf-before">
            <span class="tf-col-label tf-col-label--before">Before</span>
            <div class="tf-steps">
              <div class="tf-step"><span class="tf-num">1</span><span class="tf-step-text">Enquiry received</span><span class="tf-badge tf-badge--before">20min</span></div>
              <div class="tf-step"><span class="tf-num">2</span><span class="tf-step-text">Log to CRM</span><span class="tf-badge tf-badge--before">15min</span></div>
              <div class="tf-step"><span class="tf-num">3</span><span class="tf-step-text">Draft intake form</span><span class="tf-badge tf-badge--before">25min</span></div>
              <div class="tf-step"><span class="tf-num">4</span><span class="tf-step-text">Chase e-signature</span><span class="tf-badge tf-badge--before">2 days</span></div>
              <div class="tf-step"><span class="tf-num">5</span><span class="tf-step-text">Create matter file</span><span class="tf-badge tf-badge--before">30min</span></div>
              <div class="tf-step"><span class="tf-num">6</span><span class="tf-step-text">Send retainer invoice</span><span class="tf-badge tf-badge--before">15min</span></div>
            </div>
            <div class="tf-total tf-total--before">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Total: 1h 45min + 2 days
            </div>
          </div>

          <div class="tf-divider">
            <div class="tf-divider-line"></div>
            <div class="tf-divider-arrow">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
            <div class="tf-divider-line"></div>
          </div>

          <div class="tf-after">
            <span class="tf-col-label tf-col-label--after">After PURIST</span>
            <div class="tf-steps">
              <div class="tf-step"><span class="tf-check"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span><span class="tf-step-text">Form auto-captured</span><span class="tf-badge tf-badge--after">instant</span></div>
              <div class="tf-step"><span class="tf-check"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span><span class="tf-step-text">CRM auto-updated</span><span class="tf-badge tf-badge--after">auto</span></div>
              <div class="tf-step"><span class="tf-check"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span><span class="tf-step-text">Intake sent instantly</span><span class="tf-badge tf-badge--after">instant</span></div>
              <div class="tf-step"><span class="tf-check"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span><span class="tf-step-text">E-sign auto-triggered</span><span class="tf-badge tf-badge--after">auto</span></div>
              <div class="tf-step"><span class="tf-check"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span><span class="tf-step-text">Matter file auto-created</span><span class="tf-badge tf-badge--after">auto</span></div>
              <div class="tf-step"><span class="tf-check"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span><span class="tf-step-text">Invoice auto-sent</span><span class="tf-badge tf-badge--after">auto</span></div>
            </div>
            <div class="tf-total tf-total--after">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              Total: 4 minutes, zero manual steps
            </div>
          </div>
        </div>
        <!-- Time saved bar -->
        <div class="tf-saved-bar">
          <div class="tf-saved-label">Time reduction</div>
          <div class="tf-saved-track"><div class="tf-saved-fill" data-pct="96"></div></div>
          <div class="tf-saved-pct">96%</div>
        </div>
        <!-- Stack -->
        <div class="tf-stack">
          <span class="tf-stack-label">Stack:</span>
          <span class="tf-stack-tag">n8n</span>
          <span class="tf-stack-tag">Claude AI</span>
          <span class="tf-stack-tag">HubSpot</span>
          <span class="tf-stack-tag">DocuSign</span>
          <span class="tf-stack-tag">Clio</span>
          <span class="tf-stack-tag">Xero</span>
        </div>
        <!-- KPIs -->
        <div class="tf-kpis">
          <div class="tf-kpi"><span class="tf-kpi-num" data-count="18" data-suffix="h">0h</span><span class="tf-kpi-label">saved per week</span></div>
          <div class="tf-kpi"><span class="tf-kpi-num" data-count="67" data-prefix="£" data-suffix="K">£0K</span><span class="tf-kpi-label">annual value</span></div>
          <div class="tf-kpi"><span class="tf-kpi-num" data-count="5" data-suffix=" days">0 days</span><span class="tf-kpi-label">to deploy</span></div>
          <div class="tf-kpi"><span class="tf-kpi-num" data-count="96" data-suffix="%">0%</span><span class="tf-kpi-label">less admin</span></div>
          <div class="tf-kpi"><span class="tf-kpi-num" data-count="6" data-suffix="">0</span><span class="tf-kpi-label">tools connected</span></div>
        </div>
        <!-- Quote -->
        <div class="tf-quote">
          <p class="tf-quote-text">"We onboard clients in 4 minutes now. Before PURIST it was a 2-day process with 6 manual steps."</p>
          <div class="tf-quote-attr">
            <span class="tf-quote-name">Sarah M.</span>
            <span class="tf-quote-role">Operations Director, Boutique Law Firm</span>
          </div>
        </div>
      </div>

