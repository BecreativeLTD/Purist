<style>
  .transformation-section {
    background: #F8F6F1;
    padding: 6rem 2rem;
  }

  .transformation-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .transformation-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .eyebrow {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #A0522D;
    display: block;
    margin-bottom: 1rem;
  }

  .transformation-headline {
    font-family: 'Fraunces Variable', serif;
    font-style: italic;
    font-size: 2.25rem;
    line-height: 1.3;
    color: #0A0A0A;
    margin: 0 0 1rem 0;
    font-weight: 400;
  }

  .transformation-subtext {
    font-family: 'Inter Variable', sans-serif;
    font-size: 1rem;
    color: rgba(10, 10, 10, 0.6);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .tab-strip {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .tab-btn {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.6rem 1.25rem;
    border-radius: 24px;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    background: transparent;
    color: rgba(10, 10, 10, 0.5);
  }

  .tab-btn:hover {
    color: #0A0A0A;
    background: rgba(10, 10, 10, 0.05);
  }

  .tab-btn.active {
    background: #0A0A0A;
    color: #F8F6F1;
    position: relative;
  }

  .tab-btn.active::after {
    content: '';
    position: absolute;
