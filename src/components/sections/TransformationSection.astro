    .tf-tabs { gap: 0.25rem; }
    .tf-tab { font-size: 0.72rem; padding: 0.45rem 0.8rem; }
    .tf-compare { grid-template-columns: 1fr; gap: 1.5rem; }
    .tf-divider { flex-direction: row; padding: 0.5rem 0; }
    .tf-divider-line { width: auto; height: 1px; flex: 1; }
    .tf-kpis { grid-template-columns: repeat(2, 1fr); gap: 0.5rem; }
    .tf-kpi:last-child { grid-column: span 2; }
    .tf-kpi-num { font-size: 1.35rem; }
    .tf-saved-bar { flex-wrap: wrap; }
  }
</style>

<script>
  (function () {
    var tabs   = document.querySelectorAll('#tf-tabs .tf-tab');
    var panels = document.querySelectorAll('#tf-panels .tf-panel');

    function animateCounters(panel) {
      var counters = panel.querySelectorAll('.tf-kpi-num[data-count]');
      counters.forEach(function (el) {
        var target = parseFloat(el.getAttribute('data-count'));
        var prefix = el.getAttribute('data-prefix') || '';
        var suffix = el.getAttribute('data-suffix') || '';
        var isFloat = target % 1 !== 0;
        var duration = 1200;
        var start = performance.now();

        function tick(now) {
          var elapsed = now - start;
          var progress = Math.min(elapsed / duration, 1);
          // Ease out cubic
          var eased = 1 - Math.pow(1 - progress, 3);
          var current = target * eased;
          if (isFloat) {
            el.textContent = prefix + current.toFixed(1) + suffix;
          } else {
            el.textContent = prefix + Math.round(current) + suffix;
          }
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      });
    }

    function animateBar(panel) {
      var fill = panel.querySelector('.tf-saved-fill');
      if (fill) {
        fill.style.width = '0';
        requestAnimationFrame(function () {
          fill.style.width = fill.getAttribute('data-pct') + '%';
        });
      }
    }

    function activate(target) {
      tabs.forEach(function (t) { t.classList.remove('tf-tab--active'); });
      panels.forEach(function (p) { p.classList.remove('tf-panel--active'); p.style.display = 'none'; });

      var btn   = document.querySelector('[data-tab="' + target + '"]');
      var panel = document.querySelector('[data-panel="' + target + '"]');
      if (btn)   btn.classList.add('tf-tab--active');
      if (panel) {
        panel.style.display = 'block';
        // Force reflow then add active class for animation
        panel.offsetHeight;
        panel.classList.add('tf-panel--active');

        // Re-trigger step stagger
        panel.querySelectorAll('.tf-step').forEach(function (step) {
          step.style.animation = 'none';
          step.offsetHeight;
          step.style.animation = '';
        });

        // Re-trigger quote animation
        var quote = panel.querySelector('.tf-quote');
        if (quote) {
          quote.style.animation = 'none';
          quote.offsetHeight;
          quote.style.animation = '';
        }

        animateCounters(panel);
        animateBar(panel);
      }
    }

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        activate(this.getAttribute('data-tab'));
      });
    });

    // Initial animation for first panel
    var first = document.querySelector('.tf-panel--active');
    if (first) {
      animateCounters(first);
      animateBar(first);
    }
  })();
</script>
