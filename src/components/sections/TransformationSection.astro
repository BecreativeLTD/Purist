            </div>
            <div class="tf-divider-line"></div>
          </div>

          <div class="tf-after">
            <span class="tf-col-label tf-col-label--after">After PURIST</span>
            <div class="tf-steps">
              <div class="tf-step"><span class="tf-check"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span><span class="tf-step-text">Form auto-captured</span><span class="tf-badge tf-badge--after">instant</span></div>
