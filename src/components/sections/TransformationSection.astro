              <div class="step-item"><span class="check-icon"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span><span class="step-text">Intake sent instantly</span><span class="time-badge after-badge">instant</span></div>
              <div class="step-item"><span class="check-icon"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span><span class="step-text">E-sign auto-triggered</span><span class="time-badge after-badge">auto</span></div>
