<style>
  .tf-section {
    background: #F8F6F1;
    padding: 6rem 2rem;
  }

  .tf-wrap {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Header */
  .tf-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .tf-eyebrow {
    display: block;
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #A0522D;
    margin-bottom: 1rem;
  }

  .tf-headline {
    font-family: 'Fraunces Variable', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.2;
    color: #0A0A0A;
    margin: 0 0 1rem;
  }

  .tf-sub {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.92rem;
    color: rgba(10,10,10,0.55);
    max-width: 460px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* Tabs */
  .tf-tabs {
    display: flex;
    justify-content: center;
    gap: 0.35rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .tf-tab {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    padding: 0.55rem 1.15rem;
    border-radius: 8px;
    border: 1px solid transparent;
    cursor: pointer;
    background: transparent;
    color: rgba(10,10,10,0.45);
    transition: all 0.25s ease;
  }
  .tf-tab:hover { color: #0A0A0A; background: rgba(10,10,10,0.04); }

  .tf-tab--active {
    background: #0A0A0A;
    color: #F8F6F1;
    border-color: #0A0A0A;
  }
  .tf-tab--active:hover { background: #0A0A0A; color: #F8F6F1; }

  /* Panels */
  .tf-panel {
    display: none;
  }

  .tf-panel--active {
    display: block;
    animation: tf-fade-in 0.4s ease-out;
  }

  /* Compare layout */
  .tf-compare {
    display: grid;
    grid-template-columns: 1fr 48px 1fr;
    gap: 0;
    margin-bottom: 2rem;
  }

  .tf-before {
    background: #0A0A0A;
    border-radius: 14px;
    padding: 2rem;
  }

  .tf-after {
    background: #fff;
    border: 1px solid rgba(10,10,10,0.07);
    border-radius: 14px;
    padding: 2rem;
    box-shadow: 0 1px 3px rgba(10,10,10,0.04);
  }

  .tf-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 0 4px;
  }

  .tf-divider-line {
    width: 1px;
    flex: 1;
    background: rgba(10,10,10,0.1);
  }

  .tf-divider-arrow {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #F8F6F1;
    border: 1px solid rgba(10,10,10,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #E8B4B0;
    flex-shrink: 0;
  }

  .tf-col-label {
    display: block;
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .tf-col-label--before { color: #E8B4B0; }
  .tf-col-label--after  { color: #2D5016; }

  .tf-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 1.25rem;
  }

  .tf-step {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(248,246,241,0.06);
    opacity: 0;
    animation: tf-step-in 0.3s ease-out forwards;
  }
  .tf-after .tf-step { border-bottom-color: rgba(10,10,10,0.05); }
  .tf-step:last-child { border-bottom: none; }

  /* Stagger delays */
  .tf-step:nth-child(1) { animation-delay: 0.05s; }
  .tf-step:nth-child(2) { animation-delay: 0.1s; }
  .tf-step:nth-child(3) { animation-delay: 0.15s; }
  .tf-step:nth-child(4) { animation-delay: 0.2s; }
  .tf-step:nth-child(5) { animation-delay: 0.25s; }
  .tf-step:nth-child(6) { animation-delay: 0.3s; }

  .tf-num {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(248,246,241,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    color: rgba(248,246,241,0.5);
    flex-shrink: 0;
  }

  .tf-check {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(45,80,22,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #2D5016;
    flex-shrink: 0;
  }

  .tf-before .tf-step-text {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.84rem;
    color: rgba(248,246,241,0.75);
    flex: 1;
  }

  .tf-after .tf-step-text {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.84rem;
    color: #0A0A0A;
    flex: 1;
  }

  .tf-badge {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.62rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .tf-badge--before {
    background: rgba(232,180,176,0.15);
    color: #E8B4B0;
  }

  .tf-badge--after {
    background: rgba(45,80,22,0.08);
    color: #2D5016;
  }

  .tf-total {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    padding-top: 1rem;
    border-top: 1px solid rgba(248,246,241,0.08);
  }

  .tf-total--before { color: #E8B4B0; border-top-color: rgba(248,246,241,0.08); }
  .tf-total--after  { color: #2D5016; border-top-color: rgba(10,10,10,0.06); }

  /* KPIs */
  .tf-kpis {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .tf-kpi {
    background: #fff;
    border: 1px solid rgba(10,10,10,0.06);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .tf-kpi:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(10,10,10,0.06);
  }

  .tf-kpi-num {
    display: block;
    font-family: 'Fraunces Variable', serif;
    font-size: 1.85rem;
    font-weight: 600;
    color: #E8B4B0;
    margin-bottom: 0.25rem;
  }

  .tf-kpi-label {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(10,10,10,0.55);
  }

  /* Animations */
  @keyframes tf-fade-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes tf-step-in {
    from { opacity: 0; transform: translateX(-6px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .tf-section { padding: 4rem 1.25rem; }
    .tf-headline { font-size: 1.6rem; }
    .tf-tabs { gap: 0.25rem; }
    .tf-tab { font-size: 0.72rem; padding: 0.45rem 0.8rem; }
    .tf-compare { grid-template-columns: 1fr; gap: 1.5rem; }
    .tf-divider { flex-direction: row; padding: 0.5rem 0; }
    .tf-divider-line { width: auto; height: 1px; flex: 1; }
    .tf-kpis { grid-template-columns: 1fr; gap: 0.75rem; }
  }
</style>

<script>
  (function () {
    var tabs   = document.querySelectorAll('#tf-tabs .tf-tab');
    var panels = document.querySelectorAll('#tf-panels .tf-panel');

    function activate(target) {
      tabs.forEach(function (t) { t.classList.remove('tf-tab--active'); });
      panels.forEach(function (p) { p.classList.remove('tf-panel--active'); });

      var btn   = document.querySelector('[data-tab="' + target + '"]');
      var panel = document.querySelector('[data-panel="' + target + '"]');
      if (btn)   btn.classList.add('tf-tab--active');
      if (panel) {
        panel.classList.add('tf-panel--active');
        // Re-trigger step stagger animation
        panel.querySelectorAll('.tf-step').forEach(function (step) {
          step.style.animation = 'none';
          step.offsetHeight;
          step.style.animation = '';
        });
      }
    }

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        activate(this.getAttribute('data-tab'));
      });
    });
  })();
</script>
