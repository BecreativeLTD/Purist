---
const bullets = [
  '30-day money-back guarantee on all plans',
  'Full documentation included',
  'Free onboarding call with every plan',
  'Cancel or pause anytime',
  'n8n, Make & Zapier certified',
];
const stats = [
  { n: '0', label: 'Refunds last 6 months' },
  { n: '4.9★', label: 'Average client rating' },
  { n: '312+', label: 'Active deployments' },
];
---

<section class="bg-white py-20 lg:py-28">
  <div class="container-x">
    <div class="bg-brand-cream rounded-card p-8 lg:p-16 grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">
      <div class="lg:col-span-3 flex justify-center">
        <div class="relative w-40 h-40 lg:w-48 lg:h-48 rounded-full bg-white flex items-center justify-center text-center">
          <div>
            <p class="font-display text-4xl lg:text-5xl leading-none">30</p>
            <p class="text-[10px] tracking-[0.2em] uppercase text-brand-gray-600 mt-1">Day guarantee</p>
            <p class="text-[10px] tracking-wider uppercase text-brand-gray-400 mt-0.5">All plans</p>
          </div>
        </div>
      </div>

      <div class="lg:col-span-9">
        <p class="eyebrow mb-3">Our promise</p>
        <h2 class="font-display text-h1 mb-4 text-balance">
          Risk-free. See the results,<br />
          <em class="font-medium">or get every dollar back.</em>
        </h2>
        <p class="text-base text-brand-gray-600 mb-6 leading-relaxed max-w-2xl text-pretty">
          One full month to experience the automations. If you do not see measurable
          time savings or operational improvement, we refund the setup fee — no
          questions asked.
        </p>
        <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm mb-8">
          {bullets.map((b) => (
            <li class="flex items-center gap-1.5 text-brand-gray-900/80">
              <span class="text-brand-green">✓</span>
              {b}
            </li>
          ))}
        </ul>

        <div class="flex flex-wrap gap-x-8 gap-y-3 pt-6 border-t border-brand-gray-200">
          {stats.map((s) => (
            <div>
              <p class="font-display text-2xl leading-none text-brand-black">{s.n}</p>
              <p class="text-[10px] tracking-[0.14em] uppercase text-brand-gray-500 mt-1">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
