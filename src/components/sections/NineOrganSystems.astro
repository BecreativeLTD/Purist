---
import ingredientsData from '~/data/ingredients.json';
const { organSystems } = ingredientsData;

const svgIcons: Record<string, string> = {
  '📥': 'M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2',
  '🔄': 'M4 12a8 8 0 0114.5-4.5M20 12a8 8 0 01-14.5 4.5M4 12l3-3m-3 3l3 3M20 12l-3-3m3 3l-3 3',
  '📧': 'M3 7a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7zm0 0l9 6 9-6',
  '💰': 'M12 2v2m0 16v2M7 8h6a3 3 0 010 6H9a3 3 0 000 6h8',
  '📊': 'M4 20h16M4 20V10m4 10V14m4 6V8m4 12V4',
  '🎯': 'M12 3a9 9 0 100 18 9 9 0 000-18zm0 4a5 5 0 100 10 5 5 0 000-10zm0 4a1 1 0 100 2 1 1 0 000-2',
  '🤖': 'M12 2a2 2 0 012 2v1h3a2 2 0 012 2v8a4 4 0 01-4 4H9a4 4 0 01-4-4V7a2 2 0 012-2h3V4a2 2 0 012-2zM9 11h.01M15 11h.01M10 15h4',
  '📅': 'M8 2v4m8-4v4M3 10h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2zm3 10h2v2H8v-2z',
  '🔒': 'M12 2a5 5 0 00-5 5v3H5a2 2 0 00-2 2v8a2 2 0 002 2h14a2 2 0 002-2v-8a2 2 0 00-2-2h-2V7a5 5 0 00-5-5zm0 2a3 3 0 013 3v3H9V7a3 3 0 013-3zm0 10a1.5 1.5 0 110 3 1.5 1.5 0 010-3',
};
---

<section class="bg-brand-cream py-20 lg:py-28">
  <div class="container-x">
    <div class="max-w-3xl mb-12">
      <p class="eyebrow mb-4">Comprehensive operations coverage</p>
      <h2 class="font-display text-h1 mb-4 text-balance">
        One deployment automates <em class="font-medium">nine core processes.</em>
      </h2>
      <p class="text-base text-brand-gray-600 max-w-xl text-pretty">
        Most businesses patch their operations together with spreadsheets and half-measures.
        One PURIST deployment gives your team the workflows it was already
        asking for, at reliability levels the ROI actually supports.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {organSystems.map((s) => (
        <article class="bg-white rounded-card p-6 lg:p-7 scroll-fade hover:shadow-sm transition">
          <div class="w-11 h-11 rounded-lg bg-brand-sand flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-rust" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={svgIcons[s.icon] || 'M12 2v20M2 12h20'}/>
            </svg>
          </div>
          <h3 class="font-display text-xl mb-2">{s.title}</h3>
          <p class="text-sm text-brand-gray-600 leading-relaxed">{s.body}</p>
        </article>
      ))}
    </div>

    <p class="mt-10 text-center text-sm text-brand-gray-600">
      12 production-ready workflows across nine core processes — in one deployment.
    </p>
  </div>
</section>
