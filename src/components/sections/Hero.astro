---
import StarRating from '~/components/ui/StarRating.astro';
import Button from '~/components/ui/Button.astro';

// ── Precision geometry: 24-tick ring at r=146 (between mid-hex r=164 and diamond r=118) ──
// Every 15°, starting from North (top), clockwise. Major ticks every 4 (= 60° → hex alignment)
const ticks24 = Array.from({ length: 24 }, (_, i) => {
  const a = (i / 24) * 2 * Math.PI;
  const s = Math.sin(a), c = Math.cos(a);
  const major = i % 4 === 0;
  const r1 = 138, r2 = major ? 153 : 146;
  return {
    x1: +(300 + r1 * s).toFixed(2), y1: +(300 - r1 * c).toFixed(2),
    x2: +(300 + r2 * s).toFixed(2), y2: +(300 - r2 * c).toFixed(2),
    major,
  };
});

// ── Pentagon inscribed at r=100 (top vertex = North) ──
const penta = Array.from({ length: 5 }, (_, i) => {
  const a = (i / 5) * 2 * Math.PI;
  return `${+(300 + 100 * Math.sin(a)).toFixed(1)},${+(300 - 100 * Math.cos(a)).toFixed(1)}`;
}).join(' ');
---

<section class="relative bg-brand-cream overflow-hidden">
  <!-- Background texture -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero/hero-bg.svg"
      alt=""
      width="1440"
      height="800"
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      role="presentation"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-brand-cream/95 via-brand-cream/50 to-transparent"></div>
  </div>

  <div class="container-x relative z-10 py-16 lg:py-24 xl:py-32 min-h-[680px] flex items-center">
    <div class="grid lg:grid-cols-2 gap-10 xl:gap-16 items-center w-full">

      <!-- Left: copy -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <span class="px-3 py-1 bg-white/90 backdrop-blur rounded-full text-[11px] tracking-wider uppercase font-medium">
            PURIST × Automation Intelligence
          </span>
        </div>

        <h1 class="font-display text-balance text-brand-black mb-6 leading-[1.05] tracking-tight text-4xl sm:text-5xl lg:text-[3.5rem] xl:text-[4rem]">
          Your business runs itself. <em class="font-medium">You focus on growth.</em>
        </h1>

        <p class="text-base lg:text-lg text-brand-gray-900/80 mb-8 max-w-xl text-pretty">
          Production-grade automations powered by 329 Claude AI skills and n8n workflows,
          trusted by dental practices, law firms and scaling agencies worldwide.
        </p>

        <div class="flex items-center gap-3 mb-8">
          <StarRating rating={4.8} showValue reviewCount={312} />
        </div>

        <div class="flex flex-wrap gap-3 mb-8">
          <Button href="/collections/all" size="lg">
            Book a free automation audit →
          </Button>
          <Button href="/pages/dashboard" variant="secondary" size="lg">
            Client dashboard →
          </Button>
        </div>

        <!-- Stats strip — count-up on load -->
        <div id="hero-stats" class="flex flex-wrap gap-x-7 gap-y-3 mb-6">
          <div>
            <p class="font-display text-lg leading-none text-brand-black hero-stat-val" data-target="312" data-suffix="+" data-decimals="0">0+</p>
            <p class="text-[9px] tracking-[0.13em] uppercase text-brand-gray-500 mt-1">Businesses automated</p>
          </div>
          <div>
            <p class="font-display text-lg leading-none text-brand-black hero-stat-val" data-target="14" data-suffix="h/wk" data-decimals="0">0h/wk</p>
            <p class="text-[9px] tracking-[0.13em] uppercase text-brand-gray-500 mt-1">Saved on average</p>
          </div>
          <div>
            <p class="font-display text-lg leading-none text-brand-black hero-stat-val" data-target="99.97" data-suffix="%" data-decimals="2">0%</p>
            <p class="text-[9px] tracking-[0.13em] uppercase text-brand-gray-500 mt-1">Uptime SLA</p>
          </div>
          <div>
            <p class="font-display text-lg leading-none text-brand-black hero-stat-val" data-target="9.4" data-suffix="×" data-decimals="1">0×</p>
            <p class="text-[9px] tracking-[0.13em] uppercase text-brand-gray-500 mt-1">Average ROI</p>
          </div>
        </div>

        <script is:inline>
        (function () {
          function easeOutExpo(t) { return t === 1 ? 1 : 1 - Math.pow(2, -10 * t); }

          function animateStat(el) {
            var target   = parseFloat(el.dataset.target);
            var suffix   = el.dataset.suffix || '';
            var decimals = parseInt(el.dataset.decimals || '0', 10);
            var duration = 1400;
            var start    = null;

            function step(ts) {
              if (!start) start = ts;
              var progress = Math.min((ts - start) / duration, 1);
              var eased    = easeOutExpo(progress);
              var val      = eased * target;
              el.textContent = val.toFixed(decimals) + suffix;
              if (progress < 1) requestAnimationFrame(step);
            }
            requestAnimationFrame(step);
          }

          function run() {
            var els = document.querySelectorAll('.hero-stat-val');
            els.forEach(function (el) { animateStat(el); });
          }

          /* Fire on first intersection (hero always visible on load, but safe) */
          var wrap = document.getElementById('hero-stats');
          if (!wrap) return;
          if ('IntersectionObserver' in window) {
            var io = new IntersectionObserver(function (entries, obs) {
              if (entries[0].isIntersecting) { run(); obs.disconnect(); }
            }, { threshold: 0.3 });
            io.observe(wrap);
          } else {
            run();
          }
        })();
        </script>

        <ul class="flex flex-wrap gap-x-6 gap-y-2 text-xs text-brand-gray-600">
          <li class="flex items-center gap-1.5">
            <span class="text-brand-green">✓</span> 329 Claude AI skills integrated
          </li>
          <li class="flex items-center gap-1.5">
            <span class="text-brand-green">✓</span> n8n, Make & Zapier certified
          </li>
          <li class="flex items-center gap-1.5">
            <span class="text-brand-green">✓</span> Deployed in 5–10 business days
          </li>
        </ul>
      </div>

      <!-- Right: inline animated SVG — viewBox 600×600 for perfect circles -->
      <div class="hidden lg:flex items-center justify-center">
        <div class="relative w-full max-w-[700px]">

          <!-- Atmospheric CSS glow behind SVG -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full pointer-events-none"
               style="background:radial-gradient(ellipse,rgba(160,82,45,0.10) 0%,transparent 65%);filter:blur(44px);"></div>

          <!--
            CENTER: cx=300 cy=300
            All ring animations use transform-origin:300px 300px in CSS.
            Static geometry computed from hex/diamond/pentagon inscribed at precise radii.
          -->
          <svg viewBox="0 0 800 764" xmlns="http://www.w3.org/2000/svg"
               class="w-full h-auto" aria-hidden="true" role="presentation">

            <defs>
              <clipPath id="hc"><rect width="600" height="600"/></clipPath>

              <!-- Dual radial glow: warm center + wide halo -->
              <radialGradient id="hfg" cx="50%" cy="50%" r="50%">
                <stop offset="0%"   stop-color="#E8B4B0" stop-opacity="0.32"/>
                <stop offset="45%"  stop-color="#E8B4B0" stop-opacity="0.10"/>
                <stop offset="100%" stop-color="#E8B4B0" stop-opacity="0"/>
              </radialGradient>
              <radialGradient id="hfg2" cx="50%" cy="50%" r="50%">
                <stop offset="0%"   stop-color="#E8B4B0" stop-opacity="0.16"/>
                <stop offset="100%" stop-color="#E8B4B0" stop-opacity="0"/>
              </radialGradient>
            </defs>

            <style>
              /* ── Base rotations ───────────────────────────────── */
              @keyframes hcw  { to { transform: rotate( 360deg); } }
              @keyframes hccw { to { transform: rotate(-360deg); } }

              /* ── Focal pulse ──────────────────────────────────── */
              @keyframes hfp { 0%,100%{r:6;   opacity:0.65} 50%{r:9.8; opacity:1.00} }
              @keyframes hmp { 0%,100%{r:3.4; opacity:0.44} 50%{r:5.4; opacity:0.90} }
              @keyframes hmp2{ 0%,100%{r:2.6; opacity:0.40} 50%{r:4.0; opacity:0.80} }

              /* ── Arc fades ────────────────────────────────────── */
              @keyframes harc  { 0%,100%{opacity:0.10} 50%{opacity:0.38} }
              @keyframes harc2 { 0%,100%{opacity:0.08} 50%{opacity:0.30} }

              /* ── Node blink (6 stagger phases) ───────────────── */
              @keyframes hnb  { 0%,100%{opacity:0.28} 50%{opacity:0.84} }

              /* ── Text groups: subtle breathe only ───────────── */
              @keyframes htx  { 0%,100%{opacity:0.85} 50%{opacity:1.0} }

              /* ── Data stream (dashes marching outward) ─────────── */
              @keyframes hds  { from{stroke-dashoffset:0} to{stroke-dashoffset:-28} }

              /* ── Expanding pulse rings ─────────────────────────── */
              @keyframes hpr  { 0%{transform:scale(0.03);opacity:0.50} 100%{transform:scale(1);opacity:0} }

              /* ── Scanline top→bottom ─────────────────────────── */
              @keyframes hsl  { 0%{transform:translateY(-258px)} 100%{transform:translateY(258px)} }

              /* ── 8 animated concentric rings ─────────────────── */
              .hr1 { transform-origin:300px 300px; animation:hcw  32s linear infinite; }
              .hr2 { transform-origin:300px 300px; animation:hccw 24s linear infinite; }
              .hr3 { transform-origin:300px 300px; animation:hccw 38s linear infinite 2s; }
              .hr4 { transform-origin:300px 300px; animation:hcw  48s linear infinite; }
              .hr5 { transform-origin:300px 300px; animation:hcw  20s linear infinite 5s; }
              .hr6 { transform-origin:300px 300px; animation:hccw 17s linear infinite; }
              .hr7 { transform-origin:300px 300px; animation:hcw  12s linear infinite; }
              .hr8 { transform-origin:300px 300px; animation:hccw  8s linear infinite; }

              /* ── Radar sweeps ────────────────────────────────── */
              .hsw  { transform-origin:300px 300px; animation:hcw  7s linear infinite; }
              .hsw2 { transform-origin:300px 300px; animation:hcw 11s linear infinite 3.5s; }

              /* ── 5 satellites ────────────────────────────────── */
              .hs1  { transform-origin: 62px  78px;  animation:hcw  36s linear infinite; }
              .hs2  { transform-origin:538px  78px;  animation:hccw 30s linear infinite; }
              .hs3  { transform-origin:300px 548px;  animation:hcw  40s linear infinite; }
              .hs4  { transform-origin: 62px 522px;  animation:hccw 34s linear infinite 6s; }
              .hs5  { transform-origin:538px 522px;  animation:hcw  28s linear infinite 11s; }

              /* ── 4 orbiting nodes (rotate trick) ─────────────── */
              .horb1 { transform-origin:300px 300px; animation:hcw  22s linear infinite; }
              .horb2 { transform-origin:300px 300px; animation:hcw  35s linear infinite 6s; }
              .horb3 { transform-origin:300px 300px; animation:hccw 28s linear infinite 12s; }
              .horb4 { transform-origin:300px 300px; animation:hcw  16s linear infinite 3s; }

              /* ── Focal / mini pulse ───────────────────────────── */
              .hfp  { animation:hfp  3.2s ease-in-out infinite; }
              .hmp  { animation:hmp  4.8s ease-in-out infinite; }
              .hmp2 { animation:hmp2 3.6s ease-in-out infinite 1.4s; }

              /* ── Arc fades (12 staggered) ────────────────────── */
              .ha1  { animation:harc   9s ease-in-out infinite; }
              .ha2  { animation:harc2 13s ease-in-out infinite 3.2s; }
              .ha3  { animation:harc   8s ease-in-out infinite 6.5s; }
              .ha4  { animation:harc2 12s ease-in-out infinite 1.8s; }
              .ha5  { animation:harc  11s ease-in-out infinite 5.0s; }
              .ha6  { animation:harc2  7s ease-in-out infinite 8.5s; }

              /* ── Node blinks (8 stagger phases) ──────────────── */
              .hn1  { animation:hnb 4.5s ease-in-out infinite; }
              .hn2  { animation:hnb 6.2s ease-in-out infinite 1.0s; }
              .hn3  { animation:hnb 5.5s ease-in-out infinite 2.5s; }
              .hn4  { animation:hnb 7.8s ease-in-out infinite 3.5s; }
              .hn5  { animation:hnb 3.8s ease-in-out infinite 0.5s; }
              .hn6  { animation:hnb 6.9s ease-in-out infinite 5.2s; }
              .hn7  { animation:hnb 5.1s ease-in-out infinite 7.0s; }
              .hn8  { animation:hnb 4.2s ease-in-out infinite 9.3s; }

              /* ── 5 text groups (20s cycle, 4s stagger each) ─── */
              .ht1  { animation:htx 20s ease-in-out infinite; }
              .ht2  { animation:htx 20s ease-in-out infinite  4.0s; }
              .ht3  { animation:htx 20s ease-in-out infinite  8.0s; }
              .ht4  { animation:htx 20s ease-in-out infinite 12.0s; }
              .ht5  { animation:htx 20s ease-in-out infinite 16.0s; }

              /* ── Data streams (6 spokes) ──────────────────────── */
              .hds1 { animation:hds 1.5s linear infinite; }
              .hds2 { animation:hds 1.9s linear infinite 0.5s; }
              .hds3 { animation:hds 2.4s linear infinite 1.1s; }
              .hds4 { animation:hds 2.1s linear infinite 0.3s; }
              .hds5 { animation:hds 1.7s linear infinite 0.8s; }
              .hds6 { animation:hds 2.7s linear infinite 1.6s; }

              /* ── Pulse rings ──────────────────────────────────── */
              .hpr  { transform-origin:300px 300px; animation:hpr 3.8s ease-out infinite; }
              .hpr2 { transform-origin:300px 300px; animation:hpr 3.8s ease-out infinite 1.27s; }
              .hpr3 { transform-origin:300px 300px; animation:hpr 3.8s ease-out infinite 2.53s; }

              /* ── Scanline ─────────────────────────────────────── */
              .hsl  { transform-origin:300px 300px; animation:hsl 10s linear infinite; }
            </style>

            <!-- ════════════════════════════════════════════════ -->
            <!-- CIRCLE DIAGRAM — scaled 1.13× to restore size    -->
            <!-- ════════════════════════════════════════════════ -->
            <g transform="translate(300,300) scale(1.13) translate(-300,-300)">

            <!-- ════════════════════════════════════════════════ -->
            <!-- BLUEPRINT GRID                                    -->
            <!-- ════════════════════════════════════════════════ -->
            <g clip-path="url(#hc)" stroke="#0A0A0A" stroke-width="0.15" opacity="0.03">
              <line x1="100" y1="0" x2="100" y2="600"/>
              <line x1="200" y1="0" x2="200" y2="600"/>
              <line x1="300" y1="0" x2="300" y2="600"/>
              <line x1="400" y1="0" x2="400" y2="600"/>
              <line x1="500" y1="0" x2="500" y2="600"/>
              <line x1="0" y1="100" x2="600" y2="100"/>
              <line x1="0" y1="200" x2="600" y2="200"/>
              <line x1="0" y1="300" x2="600" y2="300"/>
              <line x1="0" y1="400" x2="600" y2="400"/>
              <line x1="0" y1="500" x2="600" y2="500"/>
            </g>

            <!-- ════════════════════════════════════════════════ -->
            <!-- ATMOSPHERIC FOCAL GLOW                           -->
            <!-- ════════════════════════════════════════════════ -->
            <circle cx="300" cy="300" r="220" fill="url(#hfg2)" opacity="0.6"/>
            <circle cx="300" cy="300" r="130" fill="url(#hfg)"/>

            <!-- ════════════════════════════════════════════════ -->
            <!-- STATIC SCAFFOLD RINGS — precise radii            -->
            <!-- ════════════════════════════════════════════════ -->
            <g fill="none" stroke="#0A0A0A">
              <circle cx="300" cy="300" r="282" stroke-width="0.35" opacity="0.05"/>
              <circle cx="300" cy="300" r="258" stroke-width="0.20" opacity="0.04"/>
              <circle cx="300" cy="300" r="240" stroke-width="0.20" opacity="0.04"/>
              <circle cx="300" cy="300" r="215" stroke-width="0.20" opacity="0.04"/>
              <circle cx="300" cy="300" r="196" stroke-width="0.20" opacity="0.04"/>
              <circle cx="300" cy="300" r="178" stroke-width="0.25" opacity="0.06"/>
              <circle cx="300" cy="300" r="164" stroke-width="0.20" opacity="0.04"/>
              <circle cx="300" cy="300" r="146" stroke-width="0.20" opacity="0.04"/>
              <circle cx="300" cy="300" r="130" stroke-width="0.20" opacity="0.04"/>
              <circle cx="300" cy="300" r="118" stroke-width="0.30" opacity="0.08"/>
              <circle cx="300" cy="300" r="100" stroke-width="0.20" opacity="0.04"/>
              <circle cx="300" cy="300" r="84"  stroke-width="0.20" opacity="0.04"/>
              <circle cx="300" cy="300" r="62"  stroke-width="0.20" opacity="0.05"/>
              <circle cx="300" cy="300" r="44"  stroke-width="0.55" opacity="0.14"/>
              <circle cx="300" cy="300" r="26"  stroke-width="0.45" opacity="0.12"/>
              <circle cx="300" cy="300" r="14"  stroke-width="0.40" opacity="0.10"/>
            </g>

            <!-- ════════════════════════════════════════════════ -->
            <!-- 8 ANIMATED RINGS — perfect concentric circles    -->
            <!-- ════════════════════════════════════════════════ -->

            <!-- r=258 CW rust — outermost -->
            <circle class="hr1" cx="300" cy="300" r="258"
              fill="none" stroke="#E8B4B0" stroke-width="1.20" opacity="0.30"
              stroke-dasharray="28 14"/>

            <!-- r=215 CCW black -->
            <circle class="hr2" cx="300" cy="300" r="215"
              fill="none" stroke="#0A0A0A" stroke-width="0.85" opacity="0.22"
              stroke-dasharray="16 11"/>

            <!-- r=196 CCW pink — very slow outer ring -->
            <circle class="hr3" cx="300" cy="300" r="196"
              fill="none" stroke="#E8B4B0" stroke-width="0.55" opacity="0.25"
              stroke-dasharray="22 7"/>

            <!-- r=164 CW green — mid hex -->
            <circle class="hr4" cx="300" cy="300" r="164"
              fill="none" stroke="#2D5016" stroke-width="1.10" opacity="0.42"
              stroke-dasharray="11 13"/>

            <!-- r=130 CW rust — inner mid -->
            <circle class="hr5" cx="300" cy="300" r="130"
              fill="none" stroke="#E8B4B0" stroke-width="0.80" opacity="0.30"
              stroke-dasharray="9 8"/>

            <!-- r=118 CCW rust — diamond -->
            <circle class="hr6" cx="300" cy="300" r="118"
              fill="none" stroke="#E8B4B0" stroke-width="1.05" opacity="0.32"
              stroke-dasharray="7 9"/>

            <!-- r=74 CW black — inner fast -->
            <circle class="hr7" cx="300" cy="300" r="74"
              fill="none" stroke="#0A0A0A" stroke-width="0.70" opacity="0.26"
              stroke-dasharray="4 7"/>

            <!-- r=50 CCW rust — innermost fast -->
            <circle class="hr8" cx="300" cy="300" r="50"
              fill="none" stroke="#E8B4B0" stroke-width="0.80" opacity="0.28"
              stroke-dasharray="3 5"/>

            <!-- ════════════════════════════════════════════════ -->
            <!-- GEOMETRIC OVERLAYS                               -->
            <!-- ════════════════════════════════════════════════ -->

            <!-- Outer hexagon (r=258) — black, thin -->
            <polygon points="300,42 523,171 523,429 300,558 77,429 77,171"
              fill="none" stroke="#0A0A0A" stroke-width="0.50" opacity="0.11"
              stroke-dasharray="32 8"/>

            <!-- Mid hexagon (r=164) — pink/brand -->
            <polygon points="300,136 442,218 442,382 300,464 158,382 158,218"
              fill="none" stroke="#E8B4B0" stroke-width="0.62" opacity="0.26"
              stroke-dasharray="22 6"/>

            <!-- Diamond (r=118) — green, rotated 45° feel -->
            <polygon points="300,182 418,300 300,418 182,300"
              fill="none" stroke="#2D5016" stroke-width="0.56" opacity="0.24"
              stroke-dasharray="14 5"/>

            <!-- Inner pentagon (r=100) — black subtle -->
            <polygon points={penta}
              fill="none" stroke="#0A0A0A" stroke-width="0.44" opacity="0.14"
              stroke-dasharray="10 4"/>

            <!-- Star of David — two triangles, distinct colors + animated opacity -->
            <polygon points="300,136 158,382 442,382"
              fill="none" stroke="#E8B4B0" stroke-width="0.68" opacity="0.32"
              stroke-dasharray="18 6" class="hn2"/>
            <polygon points="300,464 442,218 158,218"
              fill="none" stroke="#2D5016" stroke-width="0.68" opacity="0.32"
              stroke-dasharray="18 6" class="hn5"/>

            <!-- ════════════════════════════════════════════════ -->
            <!-- RADIAL SPOKES — 6-fold (all through center)      -->
            <!-- ════════════════════════════════════════════════ -->
            <g stroke="#0A0A0A" stroke-width="0.32" opacity="0.10">
              <line x1="300" y1="300" x2="300" y2="42"/>   <!-- N  -->
              <line x1="300" y1="300" x2="523" y2="171"/>  <!-- NE -->
              <line x1="300" y1="300" x2="523" y2="429"/>  <!-- SE -->
              <line x1="300" y1="300" x2="300" y2="558"/>  <!-- S  -->
              <line x1="300" y1="300" x2="77"  y2="429"/>  <!-- SW -->
              <line x1="300" y1="300" x2="77"  y2="171"/>  <!-- NW -->
            </g>
            <!-- Color accent spokes -->
            <line x1="300" y1="300" x2="523" y2="171" stroke="#E8B4B0" stroke-width="0.45" opacity="0.18"/>
            <line x1="300" y1="300" x2="77"  y2="429" stroke="#2D5016" stroke-width="0.45" opacity="0.18"/>
            <line x1="300" y1="300" x2="300" y2="42"  stroke="#0A0A0A" stroke-width="0.42" opacity="0.14"/>
            <line x1="300" y1="300" x2="523" y2="429" stroke="#E8B4B0" stroke-width="0.32" opacity="0.12"/>
            <line x1="300" y1="300" x2="77"  y2="171" stroke="#2D5016" stroke-width="0.32" opacity="0.12"/>
            <line x1="300" y1="300" x2="300" y2="558" stroke="#0A0A0A" stroke-width="0.32" opacity="0.10"/>

            <!-- ════════════════════════════════════════════════ -->
            <!-- RADAR SWEEP 1 — rust, 7s, with comet trail       -->
            <!-- ════════════════════════════════════════════════ -->
            <g class="hsw">
              <!-- Main sweep -->
              <line x1="300" y1="300" x2="300" y2="44"
                stroke="#E8B4B0" stroke-width="1.25" opacity="0.30" stroke-linecap="round"/>
              <!-- Comet trail (static offsets = CCW from sweep head) -->
              <line transform="rotate(-5,300,300)"  x1="300" y1="300" x2="300" y2="44"
                stroke="#E8B4B0" stroke-width="0.90" opacity="0.20" stroke-linecap="round"/>
              <line transform="rotate(-12,300,300)" x1="300" y1="300" x2="300" y2="44"
                stroke="#E8B4B0" stroke-width="0.65" opacity="0.12" stroke-linecap="round"/>
              <line transform="rotate(-24,300,300)" x1="300" y1="300" x2="300" y2="44"
                stroke="#E8B4B0" stroke-width="0.40" opacity="0.07" stroke-linecap="round"/>
              <line transform="rotate(-42,300,300)" x1="300" y1="300" x2="300" y2="44"
                stroke="#E8B4B0" stroke-width="0.22" opacity="0.03" stroke-linecap="round"/>
