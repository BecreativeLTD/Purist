              <div class="flex items-baseline gap-1.5">
                <span class="text-[9px] uppercase tracking-[0.15em] text-white/25 font-medium">{c.role}</span>
                <span class="text-[10px] text-white/50">{c.name}</span>
                {i < credits.length - 1 && (
