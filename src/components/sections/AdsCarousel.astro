            <span class="w-1 h-1 rounded-full bg-brand-pink inline-block"></span>
            {badge}
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- Marquee track -->
  <div class="relative mb-12">
    <div class="pointer-events-none absolute inset-y-0 left-0 w-24 z-10 bg-gradient-to-r from-brand-black to-transparent"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 w-24 z-10 bg-gradient-to-l from-brand-black to-transparent"></div>

    <div class="ads-track flex gap-5">
      {[...ads, ...ads].map((ad, i) => (
        <div
          class="ads-card shrink-0 rounded-2xl overflow-hidden"
          style="width: 220px; aspect-ratio: 9/16;"
          aria-hidden={i >= ads.length ? 'true' : undefined}
        >
          <img
            src={ad.src}
            alt={ad.alt}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
          />
        </div>
      ))}
    </div>
  </div>

  <!-- Credits strip -->
  <div class="container-x">
    <div class="max-w-5xl mx-auto">
      <div class="border-t border-white/8 pt-8">
        <div class="flex items-start justify-between gap-6">
