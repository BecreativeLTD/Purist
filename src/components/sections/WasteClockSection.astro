---

<section class="scroll-fade wc-section">
  <div class="wc-wrap">

    <!-- LEFT: Context -->
    <div class="wc-left">
      <span class="wc-eyebrow">The cost of waiting</span>
      <h2 class="wc-headline">Every second you delay,<br/>your competitors pull ahead.</h2>
      <p class="wc-body">Businesses across the US, UK and Europe waste over 4.8 billion admin hours per year on tasks that could be fully automated. That number is climbing right now.</p>
      <a href="#roi-calc" class="wc-link">
        Calculate your waste
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>

    <!-- RIGHT: 6 Live Metric Cards -->
    <div class="wc-right">
      <p class="wc-grid-label">Since you arrived on this page</p>
      <div class="wc-grid">

        <div class="wc-card">
          <div class="wc-card-val" id="wc-hours-wasted">0</div>
          <div class="wc-card-name">Admin hours wasted</div>
          <div class="wc-card-desc">Across US, UK &amp; EU SMBs</div>
        </div>

        <div class="wc-card">
          <div class="wc-card-val" id="wc-revenue-lost">0</div>
          <div class="wc-card-name">Revenue lost</div>
          <div class="wc-card-desc">At avg. £35/hr labour cost</div>
        </div>

        <div class="wc-card">
          <div class="wc-card-val" id="wc-emails-missed">0</div>
          <div class="wc-card-name">Follow-ups missed</div>
          <div class="wc-card-desc">Leads gone cold</div>
        </div>

        <div class="wc-card">
          <div class="wc-card-val" id="wc-invoices-delayed">0</div>
          <div class="wc-card-name">Invoices delayed</div>
          <div class="wc-card-desc">Cash flow impact</div>
        </div>

        <div class="wc-card">
          <div class="wc-card-val" id="wc-data-errors">0</div>
          <div class="wc-card-name">Data entry errors</div>
          <div class="wc-card-desc">Manual input mistakes</div>
        </div>

        <div class="wc-card">
          <div class="wc-card-val" id="wc-tasks-manual">0</div>
          <div class="wc-card-name">Repetitive tasks done</div>
          <div class="wc-card-desc">That automation would handle</div>
        </div>

      </div>

      <div class="wc-live-strip">
        <span class="wc-dot"></span>
        <span class="wc-live-text">All counters live since page load</span>
      </div>
    </div>

  </div>
</section>

<style>
  .wc-section {
    background: #0A0A0A;
    padding: 6rem 2rem;
    border-top: 1px solid rgba(248,246,241,0.06);
  }

  .wc-wrap {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 4rem;
    align-items: center;
  }

  /* ---- LEFT ---- */
  .wc-left {
    padding-right: 2rem;
    border-right: 1px solid rgba(248,246,241,0.08);
  }

  .wc-eyebrow {
    display: block;
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #E8B4B0;
    margin-bottom: 1.25rem;
  }

  .wc-headline {
    font-family: 'Fraunces Variable', serif;
    font-style: italic;
    font-size: clamp(1.5rem, 2.2vw, 2.1rem);
    font-weight: 300;
    line-height: 1.25;
    color: #F8F6F1;
    margin: 0 0 1.25rem;
  }

  .wc-body {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.9rem;
    line-height: 1.75;
    color: rgba(248,246,241,0.55);
    margin: 0 0 1.75rem;
  }

  .wc-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.82rem;
    color: #E8B4B0;
    text-decoration: none;
    border-bottom: 1px solid rgba(232,180,176,0.3);
    padding-bottom: 2px;
    transition: border-color 0.2s, gap 0.2s;
  }
  .wc-link:hover { border-color: #E8B4B0; gap: 0.6rem; }

  /* ---- RIGHT: 6-card grid ---- */
  .wc-right {
    padding-left: 1rem;
  }

  .wc-grid-label {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(248,246,241,0.35);
    margin: 0 0 1.25rem;
    text-align: center;
  }

  .wc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(248,246,241,0.07);
    border: 1px solid rgba(248,246,241,0.07);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .wc-card {
    background: #0A0A0A;
    padding: 1.35rem 1.25rem;
    text-align: center;
    transition: background 0.2s;
  }
  .wc-card:hover { background: rgba(248,246,241,0.03); }

  .wc-card-val {
    font-family: 'Fraunces Variable', serif;
    font-size: 1.65rem;
    font-weight: 600;
    color: #E8B4B0;
    line-height: 1.15;
    margin-bottom: 0.35rem;
    font-variant-numeric: tabular-nums;
    min-height: 2rem;
  }

  .wc-card-name {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.76rem;
    font-weight: 600;
    color: rgba(248,246,241,0.7);
    margin-bottom: 0.15rem;
  }

  .wc-card-desc {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.65rem;
    color: rgba(248,246,241,0.3);
  }

  .wc-live-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
  }

  .wc-dot {
    width: 6px;
    height: 6px;
    background: #4ADE80;
    border-radius: 50%;
    animation: wc-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .wc-live-text {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(248,246,241,0.28);
  }

  @keyframes wc-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(0.6); }
  }

  @media (max-width: 900px) {
    .wc-wrap {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .wc-left {
      padding-right: 0;
      border-right: none;
      border-bottom: 1px solid rgba(248,246,241,0.08);
      padding-bottom: 2.5rem;
    }
    .wc-right { padding-left: 0; }
    .wc-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  (function () {
    // Rates per second (US 33M + UK 5.5M + EU 25M SMBs = ~63.5M total)
    // Conservative: 63.5M × 2h/day automatable ÷ 86400s ≈ 1,470 hrs/sec
    // Use 1,470 for hours, derive others proportionally
    var RATES = {
      hours:    1470,       // admin hours wasted/sec
      revenue:  51450,      // £ lost/sec (hours × £35)
      emails:   892,        // follow-ups missed/sec
      invoices: 347,        // invoices delayed/sec
      errors:   214,        // data entry errors/sec
      tasks:    4120        // repetitive manual tasks/sec
    };

    var start = Date.now();

    var els = {
      hours:    document.getElementById('wc-hours-wasted'),
      revenue:  document.getElementById('wc-revenue-lost'),
      emails:   document.getElementById('wc-emails-missed'),
      invoices: document.getElementById('wc-invoices-delayed'),
      errors:   document.getElementById('wc-data-errors'),
      tasks:    document.getElementById('wc-tasks-manual')
    };

    function fmt(n) {
      if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
      return Math.floor(n).toLocaleString('en-GB');
    }

    function fmtCurrency(n) {
      if (n >= 1000000) return '\u00A3' + (n / 1000000).toFixed(1) + 'M';
      if (n >= 1000) return '\u00A3' + Math.floor(n / 1000).toLocaleString('en-GB') + 'K';
      return '\u00A3' + Math.floor(n).toLocaleString('en-GB');
    }

    function tick() {
      var elapsed = (Date.now() - start) / 1000;
      if (els.hours)    els.hours.textContent    = fmt(elapsed * RATES.hours);
      if (els.revenue)  els.revenue.textContent  = fmtCurrency(elapsed * RATES.revenue);
      if (els.emails)   els.emails.textContent   = fmt(elapsed * RATES.emails);
      if (els.invoices) els.invoices.textContent = fmt(elapsed * RATES.invoices);
      if (els.errors)   els.errors.textContent   = fmt(elapsed * RATES.errors);
      if (els.tasks)    els.tasks.textContent    = fmt(elapsed * RATES.tasks);
    }

    setInterval(tick, 120);
    tick();
  })();
</script>
