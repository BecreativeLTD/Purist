<style>
  /* Flow lines dashoffset */
  @keyframes vflow { from{stroke-dashoffset:0} to{stroke-dashoffset:-34} }
  .vflow { animation:vflow 2s linear infinite; }
  .vfd0  { animation-delay:0s; }
  .vfd1  { animation-delay:0.5s; }
  .vfd2  { animation-delay:1s; }
  .vfd3  { animation-delay:1.5s; }

  /* Live dot */
  @keyframes vpulse { 0%,100%{opacity:.4;} 50%{opacity:1;} }
  .vlive-dot { animation:vpulse 1.6s ease-in-out infinite; }

  /* SVG container — adapts height to viewBox aspect ratio on mobile */
  .vsvg-wrap {
    position: relative;
    overflow: hidden;
    /* mobile: let SVG define height via aspect-ratio of viewBox 660×710 */
    aspect-ratio: 660 / 710;
    max-height: 90vw;       /* cap on small screens */
  }
  @media (min-width: 1024px) {
    .vsvg-wrap {
      aspect-ratio: unset;
      height: clamp(500px, 62vw, 700px);
      max-height: none;
    }
  }

  /* Right panel border: top on mobile, left on desktop */
  .vpanel {
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  @media (min-width: 1024px) {
    .vpanel {
      border-top: none;
      border-left: 1px solid rgba(255,255,255,0.06);
    }
  }
</style>

<script is:inline>
(function () {
  var tasks = 142847, saved = 168420;
  var iv1, iv2, iv3;
  var started = false;

  var actions = [
    {t:'CRM',      m:'Contact "J. Holloway" scored \u2014 High intent'},
    {t:'EMAIL',    m:'Recall sent to 14 patients'                      },
    {t:'INVOICE',  m:'\u00a31,240 invoice auto-dispatched'             },
    {t:'SLACK',    m:'Low stock alert \u2192 #ops-channel'             },
    {t:'BILLING',  m:'Payment \u00a3880 reconciled in Xero'            },
    {t:'REPORT',   m:'Weekly PDF sent to 6 clients'                    },
    {t:'CALENDAR', m:'Appointment confirmed \u2192 rescheduled'        },
    {t:'API',      m:'Webhook delivered in 142 ms'                     },
    {t:'DATABASE', m:'38 records indexed \u2192 search updated'        },
    {t:'NOTIFY',   m:'SMS confirmation sent to client'                 },
    {t:'FORMS',    m:'New lead \u2192 nurture sequence triggered'       },
    {t:'DASHBOARD',m:'KPI board refreshed \u2014 38 metrics'           },
  ];

  var idx = 0;
  var feed = document.getElementById('e-feed');

  function addAction() {
    if (!feed) return;
    var a = actions[idx++ % actions.length];
    var el = document.createElement('div');
    el.style.cssText = 'display:flex;align-items:baseline;gap:6px;opacity:0;transition:opacity 0.32s;';
    el.innerHTML =
      '<span style="font-size:7px;font-weight:700;font-family:ui-monospace,monospace;' +
      'color:rgba(232,180,176,0.58);white-space:nowrap;flex-shrink:0;">' + a.t + '</span>' +
      '<span style="font-size:9px;color:rgba(255,255,255,0.50);overflow:hidden;' +
      'text-overflow:ellipsis;white-space:nowrap;">' + a.m + '</span>';
    feed.insertBefore(el, feed.firstChild);
    requestAnimationFrame(function () {
      requestAnimationFrame(function () { el.style.opacity = '1'; });
    });
    while (feed.children.length > 4) {
      var last = feed.lastChild;
      if (last) feed.removeChild(last);
    }
  }

  function startIntervals() {
    if (started) return;
    started = true;
    addAction();
    iv1 = setInterval(function () {
      tasks += Math.floor(Math.random() * 3) + 1;
      saved += Math.floor(Math.random() * 9) + 3;
      var t = document.getElementById('e-tasks'), s = document.getElementById('e-saved');
      if (t) t.textContent = tasks.toLocaleString('en-GB');
      if (s) s.textContent = '\u00a3' + saved.toLocaleString('en-GB');
    }, 440);
    iv2 = setInterval(function () {
      var el = document.getElementById('e-ms');
      if (el) el.textContent = (172 + Math.floor(Math.random() * 26)) + 'ms';
    }, 950);
    iv3 = setInterval(addAction, 2200);
  }

  function stopIntervals() {
    clearInterval(iv1); clearInterval(iv2); clearInterval(iv3);
    started = false;
  }

  // Start only when section enters viewport, pause when it leaves
  var section = document.getElementById('e-feed') && document.getElementById('e-feed').closest('section');
  if (section && 'IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function (entries) {
      entries[0].isIntersecting ? startIntervals() : stopIntervals();
    }, { threshold: 0.1 });
    obs.observe(section);
  } else {
    startIntervals();
  }

  // Cleanup on ViewTransitions navigation
  document.addEventListener('astro:before-swap', stopIntervals);
})();
</script>
