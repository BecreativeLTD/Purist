          </div>
          <div class="lo-row-meta">
            <span class="lo-row-ms">142ms</span>
            <span class="lo-row-time">5 sec ago</span>
          </div>
        </div>

        <div class="lo-row" data-template="2">
          <div class="lo-row-icon">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
