---
---

<section class="scroll-fade lo-section">
  <div class="lo-wrap">

    <!-- Header -->
    <div class="lo-header">
      <div class="lo-badge">
        <span class="lo-badge-dot"></span>
        <span class="lo-badge-text">System Live</span>
      </div>
      <h2 class="lo-headline">312 workflows running.<br/>Right now, for real businesses.</h2>
      <p class="lo-sub">Every metric below reflects live production data. This is what automation at scale looks like.</p>
    </div>

    <!-- Two-column: Metrics + Sparkline | Event Feed -->
    <div class="lo-main">

      <!-- LEFT: Metrics grid + sparkline -->
      <div class="lo-left">
        <div class="lo-metrics">
          <div class="lo-metric lo-metric--accent">
            <div class="lo-metric-val" id="lo-events">47,293</div>
            <div class="lo-metric-name">Events today</div>
          </div>
          <div class="lo-metric">
            <div class="lo-metric-val">312</div>
            <div class="lo-metric-name">Active workflows</div>
          </div>
          <div class="lo-metric">
            <div class="lo-metric-val lo-metric-val--green"><span class="lo-green-dot"></span>99.97%</div>
            <div class="lo-metric-name">Uptime (30d)</div>
          </div>
          <div class="lo-metric">
            <div class="lo-metric-val" id="lo-exec">127ms</div>
            <div class="lo-metric-name">Avg execution</div>
          </div>
          <div class="lo-metric">
            <div class="lo-metric-val lo-metric-val--green"><span class="lo-green-dot"></span>0</div>
            <div class="lo-metric-name">Errors (30d)</div>
          </div>
          <div class="lo-metric">
            <div class="lo-metric-val" id="lo-week">1,847</div>
            <div class="lo-metric-name">This week</div>
          </div>
        </div>

        <!-- Mini sparkline chart -->
        <div class="lo-chart-wrap">
          <div class="lo-chart-header">
            <span class="lo-chart-title">Events / hour (last 24h)</span>
            <span class="lo-chart-peak">Peak: 3,412/hr</span>
          </div>
          <svg class="lo-chart" viewBox="0 0 480 100" preserveAspectRatio="none" id="lo-sparkline">
            <defs>
              <linearGradient id="lo-grad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#E8B4B0" stop-opacity="0.2"/>
                <stop offset="100%" stop-color="#E8B4B0" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <!-- Horizontal grid lines -->
            <line x1="4" y1="25" x2="476" y2="25" stroke="rgba(248,246,241,0.04)" stroke-width="0.5"/>
            <line x1="4" y1="50" x2="476" y2="50" stroke="rgba(248,246,241,0.04)" stroke-width="0.5"/>
            <line x1="4" y1="75" x2="476" y2="75" stroke="rgba(248,246,241,0.04)" stroke-width="0.5"/>
            <!-- Vertical grid lines -->
            <line x1="120" y1="8" x2="120" y2="92" stroke="rgba(248,246,241,0.03)" stroke-width="0.5" stroke-dasharray="2,4"/>
            <line x1="240" y1="8" x2="240" y2="92" stroke="rgba(248,246,241,0.03)" stroke-width="0.5" stroke-dasharray="2,4"/>
            <line x1="360" y1="8" x2="360" y2="92" stroke="rgba(248,246,241,0.03)" stroke-width="0.5" stroke-dasharray="2,4"/>
            <!-- Chart elements -->
            <path class="lo-chart-area" fill="url(#lo-grad)"/>
            <path class="lo-chart-line" fill="none" stroke="#E8B4B0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <!-- Live dot — clean, small -->
            <circle class="lo-chart-dot" r="2.5" fill="#E8B4B0"/>
          </svg>
          <div class="lo-chart-labels">
            <span>00:00</span><span>06:00</span><span>12:00</span><span>18:00</span><span>Now</span>
          </div>
        </div>

        <!-- Tech Row -->
        <div class="lo-tech">
          <span class="lo-tech-label">Stack</span>
          <div class="lo-tech-pills">
            <span class="lo-pill">n8n Cloud</span>
            <span class="lo-pill">Claude Opus 4.5</span>
            <span class="lo-pill">Vercel Edge</span>
            <span class="lo-pill">PostgreSQL</span>
            <span class="lo-pill">Twilio</span>
            <span class="lo-pill">Stripe</span>
          </div>
        </div>
      </div>

      <!-- RIGHT: Live event feed -->
      <div class="lo-right">
        <div class="lo-log-wrap">
          <div class="lo-log-header">
            <span class="lo-log-title">Live Event Feed</span>
            <div class="lo-log-badge"><span class="lo-badge-dot lo-badge-dot--sm"></span><span>Live</span></div>
          </div>
          <div id="lo-feed" class="lo-feed">

            <div class="lo-row" data-template="0">
              <div class="lo-row-icon"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg></div>
              <div class="lo-row-body"><span class="lo-row-title">New lead captured</span><span class="lo-row-sep">&middot;</span><span class="lo-row-detail">CRM + welcome email</span></div>
              <div class="lo-row-meta"><span class="lo-row-ms">87ms</span><span class="lo-row-time">2s</span></div>
            </div>

            <div class="lo-row" data-template="1">
              <div class="lo-row-icon"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
              <div class="lo-row-body"><span class="lo-row-title">Invoice auto-generated</span><span class="lo-row-sep">&middot;</span><span class="lo-row-detail">QuickBooks synced</span></div>
              <div class="lo-row-meta"><span class="lo-row-ms">142ms</span><span class="lo-row-time">5s</span></div>
            </div>

            <div class="lo-row" data-template="2">
              <div class="lo-row-icon"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
              <div class="lo-row-body"><span class="lo-row-title">Appointment confirmed</span><span class="lo-row-sep">&middot;</span><span class="lo-row-detail">SMS reminder queued</span></div>
              <div class="lo-row-meta"><span class="lo-row-ms">63ms</span><span class="lo-row-time">9s</span></div>
            </div>

            <div class="lo-row" data-template="3">
              <div class="lo-row-icon"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
              <div class="lo-row-body"><span class="lo-row-title">Review request sent</span><span class="lo-row-sep">&middot;</span><span class="lo-row-detail">Google review ask</span></div>
              <div class="lo-row-meta"><span class="lo-row-ms">94ms</span><span class="lo-row-time">12s</span></div>
            </div>

            <div class="lo-row" data-template="4">
              <div class="lo-row-icon"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
              <div class="lo-row-body"><span class="lo-row-title">Cold lead reactivated</span><span class="lo-row-sep">&middot;</span><span class="lo-row-detail">Re-engagement started</span></div>
              <div class="lo-row-meta"><span class="lo-row-ms">118ms</span><span class="lo-row-time">16s</span></div>
            </div>

            <div class="lo-row" data-template="5">
              <div class="lo-row-icon"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
              <div class="lo-row-body"><span class="lo-row-title">Contract e-signed</span><span class="lo-row-sep">&middot;</span><span class="lo-row-detail">Matter file created</span></div>
              <div class="lo-row-meta"><span class="lo-row-ms">76ms</span><span class="lo-row-time">21s</span></div>
            </div>

            <div class="lo-row" data-template="6">
              <div class="lo-row-icon"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
              <div class="lo-row-body"><span class="lo-row-title">Form submitted</span><span class="lo-row-sep">&middot;</span><span class="lo-row-detail">Lead scored + routed</span></div>
              <div class="lo-row-meta"><span class="lo-row-ms">51ms</span><span class="lo-row-time">27s</span></div>
            </div>

            <div class="lo-row" data-template="7">
              <div class="lo-row-icon"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg></div>
              <div class="lo-row-body"><span class="lo-row-title">Report generated</span><span class="lo-row-sep">&middot;</span><span class="lo-row-detail">PDF to 3 stakeholders</span></div>
              <div class="lo-row-meta"><span class="lo-row-ms">223ms</span><span class="lo-row-time">33s</span></div>
            </div>

            <div class="lo-row" data-template="8">
              <div class="lo-row-icon"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
              <div class="lo-row-body"><span class="lo-row-title">Missed call logged</span><span class="lo-row-sep">&middot;</span><span class="lo-row-detail">Callback SMS in 90s</span></div>
              <div class="lo-row-meta"><span class="lo-row-ms">89ms</span><span class="lo-row-time">38s</span></div>
            </div>

            <div class="lo-row" data-template="9">
              <div class="lo-row-icon"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div>
              <div class="lo-row-body"><span class="lo-row-title">Stripe payment</span><span class="lo-row-sep">&middot;</span><span class="lo-row-detail">Receipt + onboarding</span></div>
              <div class="lo-row-meta"><span class="lo-row-ms">134ms</span><span class="lo-row-time">44s</span></div>
            </div>

            <div class="lo-row" data-template="10">
              <div class="lo-row-icon"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
              <div class="lo-row-body"><span class="lo-row-title">Overdue flagged</span><span class="lo-row-sep">&middot;</span><span class="lo-row-detail">CRM task created</span></div>
              <div class="lo-row-meta"><span class="lo-row-ms">71ms</span><span class="lo-row-time">51s</span></div>
            </div>

            <div class="lo-row" data-template="11">
              <div class="lo-row-icon"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
              <div class="lo-row-body"><span class="lo-row-title">Error retried</span><span class="lo-row-sep">&middot;</span><span class="lo-row-detail">Auto-retry attempt 2 OK</span></div>
              <div class="lo-row-meta"><span class="lo-row-ms">198ms</span><span class="lo-row-time">58s</span></div>
            </div>

          </div>
        </div>
      </div>

    </div><!-- /lo-main -->
  </div>
</section>

<style>
  .lo-section {
    background: #0A0A0A;
    background-image: radial-gradient(ellipse at 50% -10%, rgba(232,180,176,0.05) 0%, transparent 50%);
    padding: 6rem 2rem;
    border-top: 1px solid rgba(248,246,241,0.06);
  }
  .lo-wrap { max-width: 1200px; margin: 0 auto; }

  /* Header */
  .lo-header { text-align: center; margin-bottom: 3.5rem; }
  .lo-badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: rgba(74,222,128,0.08); border: 1px solid rgba(74,222,128,0.18);
    border-radius: 20px; padding: 0.3rem 0.85rem; margin-bottom: 1.25rem;
  }
  .lo-badge-dot {
    width: 7px; height: 7px; background: #4ADE80; border-radius: 50%;
    animation: lo-pulse 2s ease-in-out infinite; flex-shrink: 0;
  }
  .lo-badge-dot--sm { width: 5px; height: 5px; }
  .lo-badge-text {
    font-family: 'Inter Variable', sans-serif; font-size: 0.65rem;
    font-weight: 600; letter-spacing: 0.08em; color: #4ADE80; text-transform: uppercase;
  }
  .lo-headline {
    font-family: 'Fraunces Variable', serif; font-style: italic; font-weight: 300;
    font-size: clamp(1.75rem, 3vw, 2.5rem); line-height: 1.25; color: #F8F6F1; margin: 0 0 1rem;
  }
  .lo-sub {
    font-family: 'Inter Variable', sans-serif; font-size: 0.9rem;
    color: rgba(248,246,241,0.42); max-width: 480px; margin: 0 auto; line-height: 1.6;
  }

  /* Main two-column */
  .lo-main {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  /* LEFT */
  .lo-left { display: flex; flex-direction: column; gap: 1.25rem; }

  /* Metrics Grid */
  .lo-metrics {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
    background: rgba(248,246,241,0.06); border: 1px solid rgba(248,246,241,0.06);
    border-radius: 12px; overflow: hidden;
  }
  .lo-metric {
    background: #0A0A0A; padding: 1.15rem 1rem; transition: background 0.15s;
  }
  .lo-metric:hover { background: rgba(248,246,241,0.025); }
  .lo-metric--accent .lo-metric-val { color: #E8B4B0; }

  .lo-metric-val {
    font-family: 'Fraunces Variable', serif; font-size: 1.35rem; font-weight: 600;
    color: #F8F6F1; margin-bottom: 0.2rem; font-variant-numeric: tabular-nums;
    line-height: 1.2; display: flex; align-items: center; gap: 0.35rem;
  }
  .lo-metric-val--green { color: #4ADE80; font-size: 1.1rem; }
  .lo-green-dot { width: 5px; height: 5px; background: #4ADE80; border-radius: 50%; flex-shrink: 0; }

  .lo-metric-name {
    font-family: 'Inter Variable', sans-serif; font-size: 0.68rem;
    color: rgba(248,246,241,0.4); font-weight: 500;
  }

  /* Sparkline chart */
  .lo-chart-wrap {
    background: rgba(248,246,241,0.025); border: 1px solid rgba(248,246,241,0.06);
    border-radius: 12px; padding: 1rem 1.25rem 0.75rem;
  }
  .lo-chart-header {
    display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.6rem;
  }
  .lo-chart-title {
    font-family: 'Inter Variable', sans-serif; font-size: 0.65rem;
    letter-spacing: 0.08em; text-transform: uppercase; color: rgba(248,246,241,0.35); font-weight: 600;
  }
  .lo-chart-peak {
    font-family: 'Inter Variable', sans-serif; font-size: 0.62rem;
    color: #E8B4B0; font-weight: 500;
  }
  .lo-chart {
    width: 100%; height: 80px; display: block;
  }
  .lo-chart-labels {
    display: flex; justify-content: space-between; margin-top: 0.35rem;
    font-family: 'Inter Variable', sans-serif; font-size: 0.58rem;
    color: rgba(248,246,241,0.2);
  }

  /* Tech Row */
  .lo-tech { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .lo-tech-label {
    font-family: 'Inter Variable', sans-serif; font-size: 0.62rem;
    letter-spacing: 0.1em; text-transform: uppercase; color: rgba(248,246,241,0.22); flex-shrink: 0;
  }
  .lo-tech-pills { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .lo-pill {
    font-family: 'Inter Variable', sans-serif; font-size: 0.62rem;
    color: rgba(248,246,241,0.35); background: rgba(248,246,241,0.04);
    border: 1px solid rgba(248,246,241,0.06); padding: 0.2rem 0.55rem; border-radius: 5px;
  }

  /* RIGHT: Event Log */
  .lo-log-wrap {
    border: 1px solid rgba(248,246,241,0.07); border-radius: 12px;
    overflow: hidden; background: rgba(248,246,241,0.02); height: 100%;
    display: flex; flex-direction: column;
  }
  .lo-log-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.7rem 1.15rem; border-bottom: 1px solid rgba(248,246,241,0.05);
    background: rgba(248,246,241,0.025); flex-shrink: 0;
  }
  .lo-log-title {
    font-family: 'Inter Variable', sans-serif; font-size: 0.62rem;
    letter-spacing: 0.1em; text-transform: uppercase; color: rgba(248,246,241,0.45); font-weight: 600;
  }
  .lo-log-badge {
    display: flex; align-items: center; gap: 0.3rem;
    font-family: 'Inter Variable', sans-serif; font-size: 0.58rem;
    font-weight: 600; letter-spacing: 0.08em; color: #4ADE80; text-transform: uppercase;
  }
  .lo-feed { overflow: hidden; flex: 1; }

  /* ===== Event rows — :global() for cloneNode compat ===== */
  :global(.lo-row) {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.5rem 1.15rem; border-bottom: 1px solid rgba(248,246,241,0.03);
    transition: background 0.12s;
  }
  :global(.lo-row:last-child) { border-bottom: none; }
  :global(.lo-row:hover) { background: rgba(248,246,241,0.025); }
  :global(.lo-row.lo-new) { animation: lo-slide-in 0.3s ease-out forwards; }

  :global(.lo-row-icon) {
    flex-shrink: 0; width: 26px; height: 26px;
    background: rgba(232,180,176,0.08); border-radius: 6px;
    display: flex; align-items: center; justify-content: center; color: #E8B4B0;
  }

  :global(.lo-row-body) {
    flex: 1; min-width: 0; display: flex; align-items: center; gap: 0.3rem;
    overflow: hidden;
  }
  :global(.lo-row-title) {
    font-family: 'Inter Variable', sans-serif; font-size: 0.74rem;
    font-weight: 500; color: rgba(248,246,241,0.85); white-space: nowrap;
  }
  :global(.lo-row-sep) {
    font-size: 0.6rem; color: rgba(248,246,241,0.2); flex-shrink: 0;
  }
  :global(.lo-row-detail) {
    font-family: 'Inter Variable', sans-serif; font-size: 0.68rem;
    color: rgba(248,246,241,0.35); white-space: nowrap; overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.lo-row-meta) {
    display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0;
  }
  :global(.lo-row-ms) {
    font-family: 'Inter Variable', sans-serif; font-size: 0.6rem; font-weight: 600;
    color: #4ADE80; background: rgba(74,222,128,0.08);
    padding: 0.15rem 0.4rem; border-radius: 3px; font-variant-numeric: tabular-nums;
  }
  :global(.lo-row-time) {
    font-family: 'Inter Variable', sans-serif; font-size: 0.6rem;
    color: rgba(248,246,241,0.22); white-space: nowrap; min-width: 2rem;
    text-align: right; font-variant-numeric: tabular-nums;
  }

  @keyframes lo-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(0.6); }
  }
  @keyframes lo-slide-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 900px) {
    .lo-section { padding: 4rem 1.25rem; }
    .lo-headline { font-size: 1.6rem; }
    .lo-main { grid-template-columns: 1fr; }
    .lo-metrics { grid-template-columns: repeat(2, 1fr); }
    .lo-tech { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  (function () {
    /* ---- Counters ---- */
    var eventsEl = document.getElementById('lo-events');
    var execEl   = document.getElementById('lo-exec');
    var weekEl   = document.getElementById('lo-week');
    var eventsCount = 47293, weekCount = 1847;

    setInterval(function () {
      eventsCount += Math.floor(Math.random() * 7) + 8;
      if (eventsEl) eventsEl.textContent = eventsCount.toLocaleString('en-GB');
    }, 900);
    setInterval(function () {
      if (execEl) execEl.textContent = (Math.floor(Math.random() * 135) + 51) + 'ms';
    }, 1800);
    setInterval(function () {
      if (Math.random() < 0.06) { weekCount++; if (weekEl) weekEl.textContent = weekCount.toLocaleString('en-GB'); }
    }, 1000);

    /* ---- Sparkline with smooth bezier curves ---- */
    var W = 480, H = 100, PAD = 8;
    // 48 data points (every 30 min) — realistic with micro-variations
    var base = [780,820,690,640,580,510,430,380,340,320,360,420,620,890,1240,1640,2080,2480,2840,3120,3280,3380,3410,3412,3390,3290,3180,3100,2960,2870,2750,2640,2510,2380,2260,2120,1990,1860,1720,1580,1440,1320,1200,1080,1000,940,880,860];
    var data = base.map(function(v) { return v + Math.floor((Math.random() - 0.5) * v * 0.06); });
    var maxV = Math.max.apply(null, data);
    var pts = data.map(function (v, i) {
      return { x: PAD + i * ((W - PAD * 2) / (data.length - 1)), y: H - PAD - (v / maxV) * (H - PAD * 2) };
    });

    // Smooth cubic bezier spline through all points
    function catmullRom(points, tension) {
      tension = tension || 0.3;
      var d = 'M' + points[0].x.toFixed(1) + ' ' + points[0].y.toFixed(1);
      for (var i = 0; i < points.length - 1; i++) {
        var p0 = points[Math.max(0, i - 1)];
        var p1 = points[i];
        var p2 = points[i + 1];
        var p3 = points[Math.min(points.length - 1, i + 2)];
        var cp1x = p1.x + (p2.x - p0.x) * tension;
        var cp1y = p1.y + (p2.y - p0.y) * tension;
        var cp2x = p2.x - (p3.x - p1.x) * tension;
        var cp2y = p2.y - (p3.y - p1.y) * tension;
        d += ' C' + cp1x.toFixed(1) + ' ' + cp1y.toFixed(1) + ',' + cp2x.toFixed(1) + ' ' + cp2y.toFixed(1) + ',' + p2.x.toFixed(1) + ' ' + p2.y.toFixed(1);
      }
      return d;
    }

    var lineD = catmullRom(pts, 0.25);
    var lastPt = pts[pts.length - 1], firstPt = pts[0];
    var areaD = lineD + ' L' + lastPt.x.toFixed(1) + ' ' + (H - PAD) + ' L' + firstPt.x.toFixed(1) + ' ' + (H - PAD) + ' Z';

    var svgLine = document.querySelector('.lo-chart-line');
    var svgArea = document.querySelector('.lo-chart-area');
    var svgDot  = document.querySelector('.lo-chart-dot');

    if (svgLine) svgLine.setAttribute('d', lineD);
    if (svgArea) svgArea.setAttribute('d', areaD);
    if (svgDot) { svgDot.setAttribute('cx', lastPt.x); svgDot.setAttribute('cy', lastPt.y); }

    /* ---- Event feed ---- */
    var feed = document.getElementById('lo-feed');
    if (!feed) return;
    var templates = Array.from(feed.querySelectorAll('[data-template]'))
      .sort(function (a, b) { return +a.getAttribute('data-template') - +b.getAttribute('data-template'); });
    templates.forEach(function (t) { t.remove(); });

    var displayed = [], nextIdx = 0, MAX = 9;

    for (var i = 0; i < Math.min(MAX, templates.length); i++) {
      var cl = templates[i % templates.length].cloneNode(true);
      cl.removeAttribute('data-template');
      feed.appendChild(cl);
      displayed.push({ el: cl, sec: 2 + i * 4 });
    }
    nextIdx = MAX;

    setInterval(function () {
      if (!feed) return;
      var tmpl = templates[nextIdx % templates.length]; nextIdx++;
      var clone = tmpl.cloneNode(true); clone.removeAttribute('data-template');

      var tEl = clone.querySelector('.lo-row-time');
      if (tEl) tEl.textContent = '1s';
      var msEl = clone.querySelector('.lo-row-ms');
      if (msEl) {
        var base = parseInt(msEl.textContent) || 100;
        msEl.textContent = Math.max(40, base + Math.floor((Math.random()-0.5)*30)) + 'ms';
      }

      clone.classList.add('lo-new');
      feed.insertBefore(clone, feed.firstChild);
      displayed.unshift({ el: clone, sec: 1 });

      while (displayed.length > MAX) {
        var old = displayed.pop();
        if (old && old.el && old.el.parentNode) old.el.remove();
      }

      displayed.forEach(function (item) {
        item.sec += Math.floor(Math.random() * 3) + 2;
        var t = item.el.querySelector('.lo-row-time');
        if (t) t.textContent = item.sec + 's';
      });
    }, 2500);
  })();
</script>
