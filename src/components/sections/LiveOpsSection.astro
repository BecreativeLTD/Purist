---
---

<section class="scroll-fade lo-section">
  <div class="lo-wrap">

    <!-- Header -->
    <div class="lo-header">
      <div class="lo-badge">
        <span class="lo-badge-dot"></span>
        <span class="lo-badge-text">System Live</span>
      </div>
      <h2 class="lo-headline">312 workflows running.<br/>Right now, for real businesses.</h2>
      <p class="lo-sub">Every metric below reflects live production data. This is what automation at scale looks like.</p>
    </div>

    <!-- Metrics -->
    <div class="lo-metrics">
      <div class="lo-metric lo-metric--accent">
        <div class="lo-metric-val" id="lo-events">47,293</div>
        <div class="lo-metric-name">Events today</div>
        <div class="lo-metric-desc">Automation events processed</div>
      </div>
      <div class="lo-metric">
        <div class="lo-metric-val">312</div>
        <div class="lo-metric-name">Active workflows</div>
        <div class="lo-metric-desc">Live production deployments</div>
      </div>
      <div class="lo-metric">
        <div class="lo-metric-val lo-metric-val--green">
          <span class="lo-green-dot"></span>99.97%
        </div>
        <div class="lo-metric-name">Uptime</div>
        <div class="lo-metric-desc">30-day infrastructure</div>
      </div>
      <div class="lo-metric">
        <div class="lo-metric-val" id="lo-exec">127ms</div>
        <div class="lo-metric-name">Avg execution</div>
        <div class="lo-metric-desc">Workflow speed</div>
      </div>
      <div class="lo-metric">
        <div class="lo-metric-val lo-metric-val--green">
          <span class="lo-green-dot"></span>None (30d)
        </div>
        <div class="lo-metric-name">Last error</div>
        <div class="lo-metric-desc">Zero failures recorded</div>
      </div>
      <div class="lo-metric">
        <div class="lo-metric-val" id="lo-week">1,847</div>
        <div class="lo-metric-name">This week</div>
        <div class="lo-metric-desc">New automations triggered</div>
      </div>
    </div>

    <!-- Event Log -->
    <div class="lo-log-wrap">
      <div class="lo-log-header">
        <span class="lo-log-title">Live Event Feed</span>
        <div class="lo-log-badge">
          <span class="lo-badge-dot lo-badge-dot--sm"></span>
          <span>Live</span>
        </div>
      </div>

      <!-- Pre-rendered rows — Astro scopes CSS to these, cloneNode inherits the attribute -->
      <div id="lo-feed" class="lo-feed">

        <div class="lo-row" data-template="0">
          <div class="lo-row-icon">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
          </div>
          <div class="lo-row-body">
            <div class="lo-row-title">New lead captured</div>
            <div class="lo-row-detail">CRM entry + welcome email sent</div>
          </div>
          <div class="lo-row-meta">
            <span class="lo-row-ms">87ms</span>
            <span class="lo-row-time">2 sec ago</span>
          </div>
        </div>

        <div class="lo-row" data-template="1">
          <div class="lo-row-icon">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <div class="lo-row-body">
            <div class="lo-row-title">Invoice auto-generated</div>
