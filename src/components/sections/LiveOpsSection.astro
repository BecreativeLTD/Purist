---
---

<section class="scroll-fade live-ops-section">
  <div class="live-ops-container">
    <!-- Header -->
    <div class="live-ops-header">
      <div class="system-live-badge">
        <span class="pulse-dot-green"></span>
        <span class="badge-text">SYSTEM LIVE</span>
      </div>
      <h2 class="live-ops-headline">312 workflows running.<br/>Right now, for real businesses.</h2>
      <p class="live-ops-subtext">Every metric below is real. Every event is happening. This is what automation at scale looks like.</p>
    </div>

    <!-- Metric Cards -->
    <div class="metrics-grid">
      <div class="metric-card">
        <div class="metric-value" id="metric-events">47,293</div>
        <div class="metric-label">Automation events processed</div>
        <div class="metric-sublabel">Events Today</div>
      </div>
      <div class="metric-card">
        <div class="metric-value">312</div>
        <div class="metric-label">Live production deployments</div>
        <div class="metric-sublabel">Active Workflows</div>
      </div>
      <div class="metric-card">
        <div class="metric-value metric-with-dot">
          <span class="dot-green-small"></span>
          99.97%
        </div>
        <div class="metric-label">30-day infrastructure uptime</div>
        <div class="metric-sublabel">Uptime</div>
      </div>
      <div class="metric-card">
        <div class="metric-value" id="metric-execution">127ms</div>
        <div class="metric-label">Workflow execution speed</div>
        <div class="metric-sublabel">Avg Execution</div>
      </div>
      <div class="metric-card">
        <div class="metric-value metric-with-dot">
          <span class="dot-green-small"></span>
          Never (30d)
        </div>
        <div class="metric-label">No failures in 30 days</div>
        <div class="metric-sublabel">Last Error</div>
      </div>
      <div class="metric-card">
        <div class="metric-value" id="metric-week">1,847</div>
        <div class="metric-label">New automations triggered</div>
        <div class="metric-sublabel">This Week</div>
      </div>
    </div>

    <!-- Live Event Log -->
    <div class="event-log-panel">
      <div class="event-log-header">
        <span class="event-log-title">LIVE EVENT FEED</span>
        <div class="event-log-live-badge">
          <span class="pulse-dot-green"></span>
          <span>LIVE</span>
        </div>
      </div>
      <div class="event-log-body" id="event-log">
        <!-- Events populated by JS -->
      </div>
    </div>

    <!-- Tech Row -->
    <div class="tech-row">
      <span class="tech-label">Infrastructure</span>
      <div class="tech-badges">
        <span class="tech-badge">n8n Cloud</span>
        <span class="tech-badge">Claude Opus 4.7</span>
        <span class="tech-badge">Vercel Edge</span>
        <span class="tech-badge">PostgreSQL</span>
        <span class="tech-badge">Twilio</span>
        <span class="tech-badge">Stripe Webhooks</span>
      </div>
    </div>
  </div>
</section>

<style>
  .live-ops-section {
    background: #0A0A0A;
    background-image: radial-gradient(circle at 50% 0%, rgba(232, 180, 176, 0.04) 0%, transparent 60%);
    padding: 6rem 2rem;
  }

  .live-ops-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .live-ops-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .system-live-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(74, 222, 128, 0.1);
    border: 1px solid rgba(74, 222, 128, 0.2);
    border-radius: 20px;
    padding: 0.4rem 1rem;
    margin-bottom: 1.5rem;
  }

  .badge-text {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: #4ADE80;
    font-weight: 600;
  }

  .pulse-dot-green {
    width: 8px;
    height: 8px;
    background: #4ADE80;
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .live-ops-headline {
    font-family: 'Fraunces Variable', serif;
    font-style: italic;
    font-size: 2.25rem;
    line-height: 1.3;
    color: #F8F6F1;
    margin: 0 0 1rem 0;
    font-weight: 400;
  }

  .live-ops-subtext {
    font-family: 'Inter Variable', sans-serif;
    font-size: 1rem;
    color: rgba(248, 246, 241, 0.5);
    max-width: 550px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .metric-card {
    background: rgba(248, 246, 241, 0.04);
    border: 1px solid rgba(248, 246, 241, 0.08);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
  }

  .metric-value {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 1.5rem;
    font-weight: 700;
    color: #F8F6F1;
    margin-bottom: 0.5rem;
  }

  .metric-with-dot {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .dot-green-small {
    width: 6px;
    height: 6px;
    background: #4ADE80;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .metric-label {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.75rem;
    color: rgba(248, 246, 241, 0.5);
    margin-bottom: 0.35rem;
    line-height: 1.4;
  }

  .metric-sublabel {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(248, 246, 241, 0.3);
  }

  .event-log-panel {
    background: rgba(248, 246, 241, 0.03);
    border: 1px solid rgba(248, 246, 241, 0.08);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 2.5rem;
  }

  .event-log-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid rgba(248, 246, 241, 0.06);
  }

  .event-log-title {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: rgba(248, 246, 241, 0.4);
    font-weight: 600;
  }

  .event-log-live-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: #4ADE80;
    font-weight: 600;
  }

  .event-log-body {
    max-height: 400px;
    overflow: hidden;
    padding: 0.5rem 0;
  }

  .event-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid rgba(248, 246, 241, 0.03);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .event-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    background: rgba(232, 180, 176, 0.1);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #E8B4B0;
  }

  .event-content {
    flex: 1;
    min-width: 0;
  }

  .event-text {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.85rem;
    color: #F8F6F1;
    font-weight: 500;
    margin-bottom: 0.15rem;
  }

  .event-detail {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.75rem;
    color: rgba(248, 246, 241, 0.4);
  }

  .event-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .event-ms {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 0.7rem;
    color: #4ADE80;
    background: rgba(74, 222, 128, 0.1);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-weight: 500;
  }

  .event-time {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.7rem;
    color: rgba(248, 246, 241, 0.3);
    white-space: nowrap;
  }

  .tech-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: 1rem;
  }

  .tech-label {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(248, 246, 241, 0.3);
    flex-shrink: 0;
  }

  .tech-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech-badge {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.72rem;
    color: rgba(248, 246, 241, 0.4);
    background: rgba(248, 246, 241, 0.06);
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    white-space: nowrap;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }

  @media (max-width: 768px) {
    .live-ops-section {
      padding: 4rem 1.25rem;
    }

    .live-ops-headline {
      font-size: 1.6rem;
    }

    .metrics-grid {
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }

    .event-row {
      padding: 0.75rem 1rem;
    }

    .event-meta {
      flex-direction: column;
      gap: 0.25rem;
      align-items: flex-end;
    }

    .tech-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }
</style>

<script>
  (function() {
    // Metric counters
    let eventsCount = 47293;
    let weekCount = 1847;

    const eventsEl = document.getElementById('metric-events');
    const executionEl = document.getElementById('metric-execution');
    const weekEl = document.getElementById('metric-week');

    setInterval(function() {
      eventsCount += Math.floor(Math.random() * 5) + 8;
      if (eventsEl) eventsEl.textContent = eventsCount.toLocaleString('en-GB');
    }, 1000);

    setInterval(function() {
      const ms = Math.floor(Math.random() * (198 - 63 + 1)) + 63;
      if (executionEl) executionEl.textContent = ms + 'ms';
    }, 2000);

    setInterval(function() {
      if (Math.random() < 0.05) {
        weekCount++;
        if (weekEl) weekEl.textContent = weekCount.toLocaleString('en-GB');
      }
    }, 1000);

    // Event log
    const events = [
      { icon: 'user-plus', text: 'New lead captured', detail: 'CRM entry + welcome email sent', ms: 87 },
      { icon: 'file-text', text: 'Invoice auto-generated', detail: 'QuickBooks + client email', ms: 142 },
      { icon: 'calendar', text: 'Appointment confirmed', detail: 'SMS reminder scheduled for 24h before', ms: 63 },
      { icon: 'star', text: 'Review request triggered', detail: 'Post-appointment Google review ask', ms: 94 },
      { icon: 'mail', text: 'Cold lead reactivated', detail: 'Re-engagement sequence started', ms: 118 },
      { icon: 'check-circle', text: 'Contract e-signed', detail: 'Matter file created + notified', ms: 76 },
      { icon: 'zap', text: 'Website form submitted', detail: 'Lead scored + routed to sales rep', ms: 51 },
      { icon: 'refresh-cw', text: 'Monthly report generated', detail: 'PDF sent to 3 stakeholders', ms: 223 },
      { icon: 'phone', text: 'Missed call logged', detail: 'Auto-callback SMS sent in 90s', ms: 89 },
      { icon: 'trending-up', text: 'Stripe payment received', detail: 'Receipt + onboarding sequence fired', ms: 134 },
      { icon: 'clock', text: 'Overdue follow-up flagged', detail: 'Task created in CRM for team', ms: 71 },
      { icon: 'shield', text: 'Error detected & retried', detail: 'Auto-retry successful on attempt 2', ms: 198 }
    ];

    const iconPaths = {
      'user-plus': '<path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line>',
      'file-text': '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline>',
      'calendar': '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line>',
      'star': '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>',
      'mail': '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline>',
      'check-circle': '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline>',
      'zap': '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>',
      'refresh-cw': '<polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>',
      'phone': '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>',
      'trending-up': '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline>',
      'clock': '<circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>',
      'shield': '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>'
    };

    const logEl = document.getElementById('event-log');
    let eventIndex = 0;
    let baseTime = 2;
    let displayedEvents = [];

    function createEventRow(event, secAgo) {
      const row = document.createElement('div');
      row.className = 'event-row';
      row.innerHTML = `
        <div class="event-icon">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
            ${iconPaths[event.icon] || ''}
          </svg>
        </div>
        <div class="event-content">
          <div class="event-text">${event.text}</div>
          <div class="event-detail">${event.detail}</div>
        </div>
        <div class="event-meta">
          <span class="event-ms">${event.ms}ms</span>
          <span class="event-time">${secAgo} sec ago</span>
        </div>
      `;
      return row;
    }

    // Initial population
    function initLog() {
      for (let i = 0; i < 8; i++) {
        const event = events[(eventIndex + i) % events.length];
        const row = createEventRow(event, baseTime + i * 3);
        if (logEl) logEl.appendChild(row);
        displayedEvents.push({ el: row, time: baseTime + i * 3 });
      }
      eventIndex = 8;
    }

    initLog();

    // Add new events
    setInterval(function() {
      if (!logEl) return;

      const event = events[eventIndex % events.length];
      eventIndex++;
      const row = createEventRow(event, 1);
      row.style.opacity = '0';
      row.style.transform = 'translateY(-10px)';
      logEl.insertBefore(row, logEl.firstChild);
      displayedEvents.unshift({ el: row, time: 1 });

      requestAnimationFrame(function() {
        row.style.opacity = '1';
        row.style.transform = 'translateY(0)';
      });

      // Remove last if > 8
      if (displayedEvents.length > 8) {
        const last = displayedEvents.pop();
        if (last && last.el) {
          last.el.style.opacity = '0';
          setTimeout(function() { last.el.remove(); }, 300);
        }
      }

      // Update times
      displayedEvents.forEach(function(item) {
        item.time += Math.floor(Math.random() * 3) + 2;
        var timeEl = item.el.querySelector('.event-time');
        if (timeEl) timeEl.textContent = item.time + ' sec ago';
      });
    }, 2500);
  })();
</script>
