<style>
  .lo-section {
    background: #0A0A0A;
    background-image: radial-gradient(ellipse at 50% -10%, rgba(232,180,176,0.06) 0%, transparent 55%);
    padding: 6rem 2rem;
    border-top: 1px solid rgba(248,246,241,0.06);
  }

  .lo-wrap {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Header */
  .lo-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .lo-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: rgba(74,222,128,0.08);
    border: 1px solid rgba(74,222,128,0.18);
    border-radius: 20px;
    padding: 0.35rem 0.9rem;
    margin-bottom: 1.5rem;
  }

  .lo-badge-dot {
    width: 7px;
    height: 7px;
    background: #4ADE80;
    border-radius: 50%;
    animation: lo-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  .lo-badge-dot--sm {
    width: 6px;
    height: 6px;
  }

  .lo-badge-text {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #4ADE80;
    text-transform: uppercase;
  }

  .lo-headline {
    font-family: 'Fraunces Variable', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.25;
    color: #F8F6F1;
    margin: 0 0 1rem;
  }

  .lo-sub {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.92rem;
    color: rgba(248,246,241,0.45);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* Metrics Grid */
  .lo-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(248,246,241,0.07);
    border: 1px solid rgba(248,246,241,0.07);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .lo-metric {
    background: #0A0A0A;
    padding: 1.5rem 1.75rem;
    transition: background 0.2s;
  }
  .lo-metric:hover { background: rgba(248,246,241,0.03); }
  .lo-metric--accent .lo-metric-val { color: #E8B4B0; }

  .lo-metric-val {
    font-family: 'Inter Variable', sans-serif;
    font-size: 1.45rem;
    font-weight: 700;
    color: #F8F6F1;
    margin-bottom: 0.3rem;
    font-variant-numeric: tabular-nums;
    line-height: 1.2;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .lo-metric-val--green { color: #4ADE80; font-size: 1.1rem; font-weight: 600; }

  .lo-green-dot {
    width: 6px;
    height: 6px;
    background: #4ADE80;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .lo-metric-name {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    color: rgba(248,246,241,0.7);
    margin-bottom: 0.2rem;
  }

  .lo-metric-desc {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.7rem;
    color: rgba(248,246,241,0.3);
  }

  /* Event Log */
  .lo-log-wrap {
    border: 1px solid rgba(248,246,241,0.08);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 2rem;
    background: rgba(248,246,241,0.025);
  }

  .lo-log-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.9rem 1.5rem;
    border-bottom: 1px solid rgba(248,246,241,0.06);
    background: rgba(248,246,241,0.03);
  }

  .lo-log-title {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(248,246,241,0.5);
    font-weight: 600;
  }

  .lo-log-badge {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #4ADE80;
    text-transform: uppercase;
  }

  .lo-feed {
    overflow: hidden;
    max-height: 420px;
  }

  /* ===== THESE use :global() so cloneNode copies apply correctly ===== */
  :global(.lo-row) {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.5rem;
    border-bottom: 1px solid rgba(248,246,241,0.04);
    transition: background 0.15s;
  }
  :global(.lo-row:last-child) { border-bottom: none; }
  :global(.lo-row:hover) { background: rgba(248,246,241,0.03); }
  :global(.lo-row.lo-new) {
    animation: lo-slide-in 0.35s ease-out forwards;
  }

  :global(.lo-row-icon) {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    background: rgba(232,180,176,0.1);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #E8B4B0;
  }

  :global(.lo-row-body) {
    flex: 1;
    min-width: 0;
  }

  :global(.lo-row-title) {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.84rem;
    font-weight: 500;
    color: #F8F6F1;
    margin-bottom: 0.15rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.lo-row-detail) {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.74rem;
    color: rgba(248,246,241,0.4);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.lo-row-meta) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  :global(.lo-row-ms) {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    color: #4ADE80;
    background: rgba(74,222,128,0.1);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-variant-numeric: tabular-nums;
  }

  :global(.lo-row-time) {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.68rem;
    color: rgba(248,246,241,0.28);
    white-space: nowrap;
  }

  /* Tech Row */
  .lo-tech {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .lo-tech-label {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(248,246,241,0.25);
    flex-shrink: 0;
  }

  .lo-tech-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .lo-pill {
    font-family: 'Inter Variable', sans-serif;
    font-size: 0.7rem;
    color: rgba(248,246,241,0.4);
    background: rgba(248,246,241,0.05);
    border: 1px solid rgba(248,246,241,0.07);
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
  }

  @keyframes lo-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(0.6); }
  }

  @keyframes lo-slide-in {
    from { opacity: 0; transform: translateY(-12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .lo-section { padding: 4rem 1.25rem; }
    .lo-headline { font-size: 1.6rem; }
    .lo-metrics { grid-template-columns: repeat(2, 1fr); }
    .lo-tech { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  (function () {
    // Counters
    var eventsEl = document.getElementById('lo-events');
    var execEl   = document.getElementById('lo-exec');
    var weekEl   = document.getElementById('lo-week');

    var eventsCount = 47293;
    var weekCount   = 1847;

    setInterval(function () {
      eventsCount += Math.floor(Math.random() * 7) + 8;
      if (eventsEl) eventsEl.textContent = eventsCount.toLocaleString('en-GB');
    }, 900);

    setInterval(function () {
      var ms = Math.floor(Math.random() * 135) + 51;
      if (execEl) execEl.textContent = ms + 'ms';
    }, 1800);

    setInterval(function () {
      if (Math.random() < 0.06) {
        weekCount++;
        if (weekEl) weekEl.textContent = weekCount.toLocaleString('en-GB');
      }
    }, 1000);

    // Event log — clone pre-rendered templates
    var feed = document.getElementById('lo-feed');
    if (!feed) return;

    // Gather all 12 template rows (they're pre-rendered in HTML with Astro CSS scope)
    var templates = Array.from(feed.querySelectorAll('[data-template]'))
      .sort(function (a, b) {
        return parseInt(a.getAttribute('data-template')) - parseInt(b.getAttribute('data-template'));
      });

    // Remove from DOM (we'll re-insert clones)
    templates.forEach(function (t) { t.remove(); });

    var displayed   = [];
    var nextIndex   = 0;
    var MAX_VISIBLE = 7;

    // Insert first batch
    for (var i = 0; i < Math.min(MAX_VISIBLE, templates.length); i++) {
      var clone = templates[i % templates.length].cloneNode(true);
      clone.removeAttribute('data-template');
      feed.appendChild(clone);
      displayed.push({ el: clone, sec: 2 + i * 5 });
    }
    nextIndex = MAX_VISIBLE;

    // Cycle new events every 2.8s
    setInterval(function () {
      if (!feed) return;

      var tmpl  = templates[nextIndex % templates.length];
      nextIndex++;

      var clone = tmpl.cloneNode(true);
      clone.removeAttribute('data-template');

      // Reset time label to "just now"
      var timeEl = clone.querySelector('.lo-row-time');
      if (timeEl) timeEl.textContent = 'just now';

      // Randomise ms slightly
      var msEl = clone.querySelector('.lo-row-ms');
      if (msEl) {
        var base = parseInt(msEl.textContent) || 100;
        var jitter = Math.floor((Math.random() - 0.5) * 30);
        msEl.textContent = Math.max(40, base + jitter) + 'ms';
      }

      clone.classList.add('lo-new');
      feed.insertBefore(clone, feed.firstChild);
      displayed.unshift({ el: clone, sec: 1 });

      // Trim excess
      while (displayed.length > MAX_VISIBLE) {
        var old = displayed.pop();
        if (old && old.el && old.el.parentNode) old.el.remove();
      }

      // Age all timestamps
      displayed.forEach(function (item) {
        item.sec += Math.floor(Math.random() * 3) + 2;
        var t = item.el.querySelector('.lo-row-time');
        if (t) t.textContent = item.sec + ' sec ago';
      });
    }, 2800);
  })();
</script>
