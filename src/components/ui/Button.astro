---
export interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
  size?: 'sm' | 'md' | 'lg';
  full?: boolean;
}

const {
  variant = 'primary',
  href,
  type = 'button',
  class: extra = '',
  size = 'md',
  full = false,
} = Astro.props;

const variantClasses: Record<string, string> = {
  primary: 'bg-brand-black text-white hover:bg-brand-gray-900',
  secondary: 'bg-white text-brand-black border border-brand-black hover:bg-brand-black hover:text-white',
  ghost: 'text-brand-black hover:opacity-70',
};

const sizeClasses: Record<string, string> = {
  sm: 'px-4 py-2 text-xs',
  md: 'px-6 py-3 text-sm',
  lg: 'px-8 py-4 text-base',
};

const base = `inline-flex items-center justify-center gap-2 rounded-button font-medium transition-all duration-300 ease-out ${sizeClasses[size]} ${variantClasses[variant]} ${full ? 'w-full' : ''} ${extra}`;
---

{href ? (
  <a href={href} class={base}><slot /></a>
) : (
  <button type={type} class={base}><slot /></button>
)}
