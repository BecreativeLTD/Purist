    row.style.cssText = 'display:grid;grid-template-columns:repeat(' + stats.length + ',1fr);gap:5px;margin-top:2px;';
    stats.forEach(function(s){
      var c = document.createElement('div');
      c.style.cssText = 'background:rgba(232,180,176,0.07);border:1px solid rgba(232,180,176,0.14);border-radius:9px;padding:7px 9px;';
      c.innerHTML = '<div style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.90);letter-spacing:-0.01em;line-height:1.1;">' + s[0] + '</div><div style="font-size:8px;text-transform:uppercase;letter-spacing:0.10em;color:rgba(232,180,176,0.55);margin-top:3px;line-height:1.2;">' + s[1] + '</div>';
