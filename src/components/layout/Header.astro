  /* ── LANGUAGE DETECT ─────────────────────── */
  function isFr(t) {
    var lower = t.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
    return /\b(je|j ai|j'ai|besoin|bonjour|salut|merci|comment|combien|quel|quelle|automatisation|automatiser|workflow|entreprise|cout|prix|delai|delais|devis|audit|gratuit|fonctionn|utilis|secteur|medecin|medecins|dentiste|dentistes|agence|agences|immobilier|cabinet|clinique|avocat|comptable|logistique|recrutement|pharmacie|architecte|notaire|oui|non|et|pour|avec|dans|sur|pas|mais|aussi|donc|car|nous|vous|mon|ton|son|notre|votre|ils|est|sont|une|les|des)\b/.test(lower);
  }

  /* ── INTENT CLASSIFIER ────────────────────── */
  function classify(text) {
    var t = text.toLowerCase();
    // Industry — FR + EN
    if (/dental|health|clinic|patient|nhs|appointment|dentiste|médecin|clinique|santé/.test(t)) return { intent:'industry', key:'dental' };
    if (/real.?estate|property|letting|agent|rightmove|landlord|tenant|immobil|agence immob|locataire/.test(t)) return { intent:'industry', key:'real estate' };
    if (/agency|agenc|consult|marketing|freelance|client report|agence|conseil|consultant/.test(t)) return { intent:'industry', key:'agency' };
    if (/ecommerce|e.?commerce|shop|shopify|woocommerce|retail|order|boutique|commande/.test(t)) return { intent:'industry', key:'ecommerce' };
    // Product
    if (/full.?stack|founder|complete|complet/.test(t)) return { intent:'product', key:'full stack' };
    if (/automation.?pro|workflow|foundation/.test(t)) return { intent:'product', key:'automation pro' };
    if (/ai.?agent|agent|claude|artificial|intelligence artificielle/.test(t)) return { intent:'product', key:'ai agent' };
    if (/enterprise|dedicated|sla|scale|grande entreprise/.test(t)) return { intent:'product', key:'enterprise' };
    // Topics — FR + EN
    if (/price|pric|cost|how.?much|£|gbp|monthly|subscription|prix|coût|combien|tarif|abonnement/.test(t)) return { intent:'pricing' };
    if (/roi|return|saving|save|payback|invest|économie|économiser|rentabilité|retour/.test(t)) return { intent:'roi' };
    if (/how.?long|deploy|timeline|days|week|setup|délai|combien de temps|livraison|mise en place/.test(t)) return { intent:'deploy' };
    if (/tech|stack|n8n|make|zapier|crm|integrat|outil|technologie/.test(t)) return { intent:'tech' };
    if (/guarantee|refund|cancel|risk|commitment|garantie|remboursement|annul|risque/.test(t)) return { intent:'guarantee' };
    if (/audit|free|call|book|demo|gratuit|réserver|consultation|appel/.test(t)) return { intent:'audit' };
    if (/referral|partner|refer|commission|parrainage|partenaire/.test(t)) return { intent:'referral' };
    if (/uptime|reliable|downtime|monitor|disponibilité|fiabilité/.test(t)) return { intent:'uptime' };
    if (/addon|add.?on|extra|training|migration|supplément|formation/.test(t)) return { intent:'addons' };
    if (/hello|hi|hey|bonjour|salut|coucou/.test(t)) return { intent:'greet' };
    // Generic automation request in FR
    if (/automati|besoin d|j ai besoin|aide|aider|comment/.test(t)) return { intent:'automate' };
    return { intent:'unknown' };
  }

