---
import MegaMenu from './MegaMenu.astro';
import CountrySelector from './CountrySelector.astro';
import CartIcon from '~/components/cart/CartIcon.tsx';
import MobileMenu from './MobileMenu.tsx';

const discoverLinks = [
  { name: 'Live Demo',             href: '/pages/demo',             badge: 'Interactive',    desc: 'Watch automation run — trigger it yourself' },
  { name: 'Workflow Library',      href: '/pages/workflow-library', badge: '60+ templates', desc: 'Browse production-ready automations' },
  { name: 'AI Readiness Quiz',     href: '/pages/ai-readiness',     badge: 'Free · 2 min',  desc: 'Get your personalised score' },
  { name: 'System Status',         href: '/pages/status',           badge: 'Live',           desc: 'Real-time infrastructure health' },
  { name: 'Automation Glossary',   href: '/pages/glossary',         badge: null,             desc: '20+ terms explained plainly' },
  { name: 'Stack DNA',             href: '/pages/stack-dna',        badge: null,             desc: 'Our full technology stack' },
  { name: 'About us',              href: '/pages/about-us',         badge: null,             desc: null },
  { name: 'The Automation Blog',   href: '/pages/blog',             badge: null,             desc: null },
];

const navLinks = [
  { name: 'Services', href: '/collections/all', kind: 'mega' },
  { name: 'How it works', href: '/pages/science' },
  { name: 'The Full Stack', href: '/products/founder-stack' },
  { name: 'Get started', href: '/pages/welcome' },
  { name: 'Client stories', href: '/pages/wall-of-health' },
  { name: 'Industries', href: '/pages/ingredients' },
  { name: 'Discover', href: '#', kind: 'discover' },
];
---

<header class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-brand-gray-100 overflow-visible">
  <div class="container-x flex items-center justify-between h-16">
    <button
      type="button"
      aria-label="Open menu"
      class="lg:hidden p-2 -ml-2"
      data-mobile-menu-trigger
    >
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"></path>
      </svg>
    </button>

    <a href="/" class="font-display text-2xl tracking-tight" aria-label="PURIST home">
      <span class="font-medium">PURIST</span>
    </a>

    <nav class="hidden lg:flex items-stretch gap-7 xl:gap-8 h-16" aria-label="Primary">
      {navLinks.map((l) => (
        <div class="relative group flex items-stretch">
          <a
            href={l.href}
            class="flex items-center gap-1 text-sm hover:opacity-70 transition px-0 h-full"
          >
            {l.name}
            {(l.kind === 'mega' || l.kind === 'discover') && (
              <svg class="w-3 h-3 opacity-60 transition-transform group-hover:rotate-180" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 4.5L6 7.5L9 4.5" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            )}
          </a>
          {l.kind === 'mega' && <MegaMenu />}
          {l.kind === 'discover' && (
            <div class="absolute top-full right-0 hidden group-hover:block group-focus-within:block bg-white border border-brand-gray-100 rounded-[18px] shadow-xl z-40 w-[320px] py-3 before:content-[''] before:absolute before:-top-2 before:left-0 before:right-0 before:h-2">
              {discoverLinks.map((d) => (
                <a
                  href={d.href}
                  class="flex items-start justify-between gap-3 px-4 py-2.5 hover:bg-brand-cream transition rounded-[10px] mx-1 group/item"
                >
                  <div class="flex-1 min-w-0">
                    <p class="text-[13px] font-medium text-brand-black leading-snug">{d.name}</p>
                    {d.desc && <p class="text-[11px] text-brand-gray-500 mt-0.5 leading-snug">{d.desc}</p>}
                  </div>
                  {d.badge && (
                    <span class="shrink-0 text-[9px] uppercase tracking-wider font-bold px-2 py-0.5 rounded-full mt-0.5"
                      style={d.badge === 'Live'
                        ? 'background:rgba(45,80,22,0.10);color:#2D5016;'
                        : 'background:rgba(232,180,176,0.15);color:#c4847e;'}>
                      {d.badge === 'Live' && <span style="display:inline-block;width:5px;height:5px;border-radius:50%;background:#2D5016;margin-right:3px;vertical-align:middle;animation:hd-pulse 2s ease-in-out infinite;"></span>}{d.badge}
                    </span>
                  )}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>

    <div class="flex items-center gap-2 sm:gap-4">
      <div class="hidden sm:block">
        <CountrySelector />
      </div>

      <button
        type="button"
        aria-label="Search"
        class="p-2 hover:opacity-70 transition"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="M20 20l-3.5-3.5" stroke-linecap="round"></path>
        </svg>
      </button>

      <a
        href="/pages/login"
        aria-label="My account"
        class="p-2 hover:opacity-70 transition hidden sm:flex items-center"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
        </svg>
      </a>

      <CartIcon client:load />
    </div>
  </div>

  <!-- ── CHAT PILL ── -->
  <div class="absolute left-1/2 -translate-x-1/2 bottom-0 translate-y-full z-40 pointer-events-none" style="padding-top:5px;">
    <button id="chat-pill" type="button" aria-label="Open AI assistant"
            class="pointer-events-auto flex items-center gap-2 px-3 py-1 rounded-full transition-all duration-200 select-none"
            style="background:#0A0A0A;box-shadow:0 2px 16px rgba(0,0,0,0.22),0 0 0 1px rgba(255,255,255,0.07);">
      <span class="relative flex items-center justify-center w-3 h-3 shrink-0">
        <span class="absolute w-full h-full rounded-full" style="background:#E8B4B0;opacity:0.25;animation:cpulse 2s ease-in-out infinite;"/>
        <span class="relative w-1.5 h-1.5 rounded-full" style="background:#E8B4B0;"/>
      </span>
      <span class="text-[10.5px] font-semibold tracking-[0.05em]" style="color:rgba(255,255,255,0.75);">Ask PURIST AI</span>
      <svg id="chat-chevron" class="w-2.5 h-2.5 transition-transform duration-200" style="color:rgba(255,255,255,0.30);" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M2.5 3.5L5 6.5L7.5 3.5"/>
      </svg>
    </button>
  </div>
</header>

<!-- ══════════════════════════════════════════
     CHAT PANEL
══════════════════════════════════════════ -->
<div id="chat-panel" style="position:fixed;left:50%;top:64px;z-index:35;width:100%;max-width:460px;transform:translateX(-50%) translateY(-10px);opacity:0;pointer-events:none;transition:opacity 0.22s ease,transform 0.22s ease;padding:0 12px;">
  <div style="background:#0C0C0C;border:1px solid rgba(255,255,255,0.08);border-radius:16px;overflow:hidden;box-shadow:0 24px 64px rgba(0,0,0,0.50),0 0 0 1px rgba(255,255,255,0.03);">

    <!-- ── TOP STATS STRIP ── -->
    <div style="display:flex;align-items:center;gap:0;border-bottom:1px solid rgba(255,255,255,0.06);">
      {[
        { label:'Clients automated', val:'312+' },
        { label:'Avg time saved', val:'14 h/wk' },
        { label:'Uptime SLA', val:'99.97%' },
        { label:'Deploy time', val:'< 7 days' },
      ].map((s,i) => (
        <div style={`flex:1;padding:8px 12px;text-align:center;${i<3?'border-right:1px solid rgba(255,255,255,0.06);':''}`}>
          <div style="font-size:11.5px;font-weight:600;color:rgba(255,255,255,0.82);font-variant-numeric:tabular-nums;letter-spacing:-0.01em;">{s.val}</div>
          <div style="font-size:8.5px;text-transform:uppercase;letter-spacing:0.12em;color:rgba(255,255,255,0.22);margin-top:1px;">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- ── HEADER ── -->
    <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid rgba(255,255,255,0.06);">
      <div style="display:flex;align-items:center;gap:8px;">
        <div style="width:28px;height:28px;border-radius:8px;background:rgba(232,180,176,0.08);border:1px solid rgba(232,180,176,0.16);display:flex;align-items:center;justify-content:center;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#E8B4B0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.09 6.43H21l-5.47 3.97 2.09 6.43L12 14.87l-5.62 3.96 2.09-6.43L3 8.43h6.91L12 2z"/></svg>
        </div>
        <div>
          <div style="font-size:12px;font-weight:600;color:#fff;letter-spacing:0.02em;">PURIST AI</div>
          <div style="font-size:9px;color:rgba(255,255,255,0.30);display:flex;align-items:center;gap:4px;margin-top:1px;">
            <span style="width:5px;height:5px;border-radius:50%;background:#4ade80;box-shadow:0 0 4px rgba(74,222,128,0.6);display:inline-block;"/>
            <span>Claude Opus 4.7 · n8n v1.71 · &lt;80ms</span>
          </div>
        </div>
      </div>
      <button id="chat-close" type="button" aria-label="Close"
              style="width:24px;height:24px;border-radius:50%;background:rgba(255,255,255,0.05);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.35);transition:color 0.15s;"
              onmouseover="this.style.color='rgba(255,255,255,0.70)'"
              onmouseout="this.style.color='rgba(255,255,255,0.35)'">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2 2l6 6M8 2l-6 6"/></svg>
      </button>
    </div>

    <!-- ── MESSAGES ── -->
    <div id="chat-messages" style="display:flex;flex-direction:column;gap:10px;padding:16px;overflow-y:auto;max-height:240px;scroll-behavior:smooth;">
      <!-- Greeting -->
      <div style="display:flex;flex-direction:column;gap:6px;">
        <div style="font-size:11.5px;line-height:1.55;color:rgba(255,255,255,0.68);background:rgba(255,255,255,0.05);padding:10px 13px;border-radius:4px 12px 12px 12px;max-width:340px;">
          What type of business are you running? I'll show you exactly which processes we'd automate first and your estimated ROI.
        </div>
      </div>
    </div>

    <!-- ── QUICK REPLIES ── -->
    <div id="chat-quick" style="display:flex;gap:6px;padding:0 16px 12px;overflow-x:auto;scrollbar-width:none;">
      {['Dental & Healthcare','Real Estate','Agency','E-commerce'].map(q => (
        <button type="button" data-quick={q}
                style="flex-shrink:0;font-size:10px;font-weight:500;letter-spacing:0.03em;padding:5px 12px;border-radius:20px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);color:rgba(255,255,255,0.45);cursor:pointer;white-space:nowrap;transition:all 0.15s;"
                onmouseover="this.style.borderColor='rgba(232,180,176,0.35)';this.style.color='rgba(232,180,176,0.85)';this.style.background='rgba(232,180,176,0.06)'"
                onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.color='rgba(255,255,255,0.45)';this.style.background='rgba(255,255,255,0.04)'">
          {q}
        </button>
      ))}
    </div>

    <!-- ── INPUT ── -->
    <div style="display:flex;align-items:center;gap:8px;padding:0 12px 12px;">
      <input id="chat-input" type="text" placeholder="Ask anything about automation…" autocomplete="off"
             style="flex:1;font-size:12px;padding:9px 13px;border-radius:10px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);color:rgba(255,255,255,0.80);caret-color:#E8B4B0;outline:none;transition:border-color 0.15s;"
             onfocus="this.style.borderColor='rgba(232,180,176,0.35)'"
             onblur="this.style.borderColor='rgba(255,255,255,0.08)'"/>
      <button id="chat-send" type="button"
              style="width:32px;height:32px;border-radius:9px;background:#E8B4B0;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background 0.15s;"
              onmouseover="this.style.background='#d9a09b'"
              onmouseout="this.style.background='#E8B4B0'">
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="#0A0A0A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7h10M8 3l4 4-4 4"/></svg>
      </button>
    </div>

    <!-- ── FOOTER ── -->
    <div style="padding:8px 16px;border-top:1px solid rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:space-between;">
      <span style="font-size:9px;color:rgba(255,255,255,0.18);letter-spacing:0.08em;text-transform:uppercase;">Powered by n8n + Claude Opus 4.7</span>
      <a href="/pages/welcome" style="font-size:9px;color:rgba(232,180,176,0.55);text-decoration:none;font-weight:500;letter-spacing:0.04em;" onmouseover="this.style.color='#E8B4B0'" onmouseout="this.style.color='rgba(232,180,176,0.55)'">Book free audit →</a>
    </div>

  </div>
</div>

<style>
  @keyframes cpulse { 0%,100%{opacity:0.25;transform:scale(1)} 50%{opacity:0.55;transform:scale(1.6)} }
  @keyframes tdot { 0%,80%,100%{opacity:0.25;transform:translateY(0)} 40%{opacity:1;transform:translateY(-3px)} }
  @keyframes hd-pulse { 0%,100%{opacity:0.5;transform:scale(1)} 50%{opacity:1;transform:scale(1.5)} }
  #chat-quick::-webkit-scrollbar { display:none }
</style>

<script is:inline>
(function () {
  var pill  = document.getElementById('chat-pill');
  var panel = document.getElementById('chat-panel');
  var closeBtn = document.getElementById('chat-close');
  var input = document.getElementById('chat-input');
  var send  = document.getElementById('chat-send');
  var msgs  = document.getElementById('chat-messages');
  var chev  = document.getElementById('chat-chevron');
  var quick = document.getElementById('chat-quick');
  var open  = false;
  var history = []; // conversation context

  /* ── OPEN / CLOSE ─────────────────────────── */
  function show() {
    open = true;
    panel.style.opacity = '1';
    panel.style.transform = 'translateX(-50%) translateY(0)';
    panel.style.pointerEvents = 'auto';
    chev.style.transform = 'rotate(180deg)';
    setTimeout(function(){ input && input.focus(); }, 250);
  }
  function hide() {
    open = false;
    panel.style.opacity = '0';
    panel.style.transform = 'translateX(-50%) translateY(-10px)';
    panel.style.pointerEvents = 'none';
    chev.style.transform = '';
  }
  pill     && pill.addEventListener('click', function(){ open ? hide() : show(); });
  closeBtn && closeBtn.addEventListener('click', hide);
  document.addEventListener('click', function(e){
    if (open && !panel.contains(e.target) && !pill.contains(e.target)) hide();
  });

  /* ── KNOWLEDGE BASE ───────────────────────── */
  var KB = {
    industries: {
      'dental': {
        label: 'Dental & Healthcare',
        summary: 'Dental practices running PURIST save 12–18 hours per week on admin. We automate the full patient lifecycle: from appointment booking to billing reconciliation.',
        workflows: ['Appointment reminder sequences (SMS + email)', 'Recall & re-engagement campaigns', 'Insurance pre-auth form collection', 'Billing reconciliation with your PMS', 'Patient feedback collection', 'Staff rota notifications'],
        stats: [['14 h/wk', 'avg saved per clinic'],['£2,800/mo', 'staff cost equivalent'],['95%', 'less manual data entry']],
      },
      'real estate': {
        label: 'Real Estate',
        summary: 'Real estate teams close 40% more deals with the same headcount by automating the entire lead-to-contract pipeline.',
        workflows: ['Portal lead capture → CRM sync (Rightmove, Zoopla, OnTheMarket)', 'Automated follow-up sequences by lead temperature', 'Offer document generation', 'Viewing confirmation & reminder flows', 'Landlord/tenant onboarding packs', 'Commission invoice generation'],
        stats: [['40%', 'more deals closed'],['9 h/wk', 'saved per agent'],['85%', 'faster lead response']],
      },
      'agency': {
        label: 'Agencies & Consulting',
        summary: 'Agencies eliminate 3–4 manual tools and deliver client work 60% faster by automating onboarding, reporting, and billing.',
        workflows: ['Client onboarding (contracts, briefing, access)', 'Automated weekly/monthly reporting', 'Project status Slack notifications', 'Invoice generation on milestone hit', 'Lead qualification from contact forms', 'Internal task routing from client requests'],
        stats: [['60%', 'faster delivery'],['£3,400/mo', 'tool savings'],['3–4 tools', 'replaced on day 1']],
      },
      'ecommerce': {
        label: 'E-commerce & Retail',
        summary: 'E-commerce brands cut support tickets by 70% and recover abandoned revenue automatically — 24/7, no extra headcount.',
        workflows: ['Order confirmation & fulfilment updates', 'Inventory alert → reorder trigger', 'Abandoned cart recovery sequences', 'Post-purchase review requests', 'AI support triage (classify & auto-resolve Tier-1)', 'Return & refund processing'],
        stats: [['70%', 'fewer support tickets'],['99.7%', 'fulfilment accuracy'],['24/7', 'AI support coverage']],
      },
    },
    products: {
      'automation pro': { price: '£799/mo', setup: '£1,299 one-time', workflows: 12, desc: 'Production-ready workflows — lead capture, CRM sync, invoicing, onboarding, reporting.' },
      'ai agent': { price: '£999/mo', setup: '£1,799 one-time', workflows: 0, desc: 'Custom AI agents for support, lead qualification, document processing and smart scheduling.' },
      'full stack': { price: '£1,499/mo', setup: '£2,499 one-time', workflows: 12, desc: 'Automation Pro + AI Agents combined. The complete system. Best value.' },
      'enterprise': { price: '£3,499/mo', setup: '£4,999', sla: '99.97%', desc: 'Dedicated n8n instance, SLA guarantee, 20h/mo dedicated engineer, unlimited workflows.' },
    },
    addons: [
      { name: 'Extra Workflow', price: '£299', unit: 'one-time' },
      { name: 'Quarterly Audit', price: '£499', unit: '/quarter' },
      { name: 'Team Training', price: '£799', unit: 'one-time' },
      { name: 'Zapier/Make Migration', price: '£1,499', unit: 'one-time' },
    ],
    tech: 'Self-hosted n8n v1.71 on a dedicated VPS. Claude Opus 4.7 for AI inference (~80ms). Stripe for billing. All data stays in your infrastructure.',
    deploy: 'After your free audit we deploy in under 7 days: Day 0 = audit, Week 1–2 = deploy top 3 workflows, Month 1 = full stack live, Month 3 = ROI confirmed.',
    roi: 'Clients typically see 9.2× ROI within 90 days. Average annual saving: £168k. Payback period: under 30 days.',
    guarantee: '30-day money-back guarantee on all plans. No lock-in after that — month-to-month.',
    audit: 'The free audit is a 60-minute video call. We map every manual process, score each one by ROI potential, and give you a deployment plan — live on the call. Zero commitment.',
    referral: 'Refer a client, earn 15% of their setup fee — paid within 48h of signing. No quotas, no complexity.',
    uptime: '99.97% uptime SLA with financial guarantee on Enterprise. All systems monitored 24/7 with 90-second error alerts.',
  };

  /* ── INTENT CLASSIFIER ────────────────────── */
  function classify(text) {
    var t = text.toLowerCase();
    // Industry
    if (/dental|health|clinic|patient|nhs|appointment/.test(t)) return { intent:'industry', key:'dental' };
    if (/real.?estate|property|letting|agent|rightmove|landlord|tenant/.test(t)) return { intent:'industry', key:'real estate' };
    if (/agency|agenc|consult|marketing|freelance|client report/.test(t)) return { intent:'industry', key:'agency' };
    if (/ecommerce|e.?commerce|shop|shopify|woocommerce|retail|order/.test(t)) return { intent:'industry', key:'ecommerce' };
    // Product
    if (/full.?stack|founder|complete/.test(t)) return { intent:'product', key:'full stack' };
    if (/automation.?pro|workflow|foundation/.test(t)) return { intent:'product', key:'automation pro' };
    if (/ai.?agent|agent|claude|artificial/.test(t)) return { intent:'product', key:'ai agent' };
    if (/enterprise|dedicated|sla|scale/.test(t)) return { intent:'product', key:'enterprise' };
    // Topics
    if (/price|pric|cost|how.?much|£|gbp|monthly|subscription/.test(t)) return { intent:'pricing' };
    if (/roi|return|saving|save|payback|invest/.test(t)) return { intent:'roi' };
    if (/how.?long|deploy|timeline|days|week|setup/.test(t)) return { intent:'deploy' };
    if (/tech|stack|n8n|make|zapier|crm|integrat/.test(t)) return { intent:'tech' };
    if (/guarantee|refund|cancel|risk|commitment/.test(t)) return { intent:'guarantee' };
    if (/audit|free|call|book|demo/.test(t)) return { intent:'audit' };
    if (/referral|partner|refer|commission/.test(t)) return { intent:'referral' };
    if (/uptime|reliable|downtime|monitor/.test(t)) return { intent:'uptime' };
    if (/addon|add.?on|extra|training|migration/.test(t)) return { intent:'addons' };
    if (/hello|hi|hey|bonjour|salut/.test(t)) return { intent:'greet' };
    return { intent:'unknown' };
  }

  /* ── RESPONSE BUILDER ─────────────────────── */
  function buildReply(classified, raw) {
    switch (classified.intent) {
      case 'greet':
        return { text: "Hi — I know everything about PURIST's automation stack, pricing, and results. What are you trying to automate?", stats: null };
      case 'industry': {
        var ind = KB.industries[classified.key];
        return {
          text: ind.summary + '\n\nWorkflows we typically deploy first:\n' + ind.workflows.slice(0,4).map(function(w){ return '· ' + w; }).join('\n'),
          stats: ind.stats,
          followUp: 'Want to see the ROI estimate for ' + ind.label + '? Or shall I show you which plan fits best?',
        };
      }
      case 'product': {
        var p = KB.products[classified.key];
        return {
          text: p.desc + '\n\nPricing: ' + p.price + (p.setup ? ' · Setup: ' + p.setup : '') + (p.sla ? ' · Uptime SLA: ' + p.sla : '') + (p.workflows ? ' · ' + p.workflows + ' workflows included' : ''),
          stats: null,
          followUp: 'Want to compare all plans or book an audit to see which fits your workflow volume?',
        };
      }
      case 'pricing':
        return {
          text: 'Three plans:\n· Automation Pro — £799/mo (£1,299 one-time setup)\n· AI Agent Deploy — £999/mo (£1,799 one-time)\n· The Full Stack — £1,499/mo (£2,499 one-time)\n· Enterprise — £3,499/mo (dedicated infra + SLA)\n\nAll include a 30-day money-back guarantee.',
          stats: [['£799/mo', 'Automation Pro'],['£1,499/mo', 'Full Stack'],['£3,499/mo', 'Enterprise']],
        };
      case 'roi':
        return {
          text: KB.roi + '\n\nExample: A dental clinic paying £799/mo saves ~£2,800/mo in staff time = 3.5× ROI in month one.',
          stats: [['9.2×', 'avg ROI at 90 days'],['£168k', 'avg annual saving'],['< 30 days', 'payback period']],
        };
      case 'deploy':
        return { text: KB.deploy, stats: [['< 7 days', 'to first workflow live'],['Month 1', 'full stack operational'],['Month 3', 'ROI confirmed']] };
      case 'tech':
        return { text: KB.tech + '\n\nWe support n8n, Make and Zapier — and can migrate your existing Zapier/Make workflows to n8n (faster, cheaper, self-hosted).', stats: null };
      case 'guarantee':
        return { text: KB.guarantee + '\n\nEnterprise plans include a financial uptime SLA — if we miss 99.97%, you get a credit.', stats: null };
      case 'audit':
        return { text: KB.audit, stats: [['60 min', 'free audit call'],['Zero', 'commitment required'],['Same day', 'ROI estimate delivered']] };
      case 'referral':
        return { text: KB.referral + '\n\nIdeal for accountants, n8n/Make consultants, and business coaches who see clients drowning in manual work.', stats: [['15%', 'of setup fee'],['48h', 'payment on signing'],['No quotas', 'ever']] };
      case 'uptime':
        return { text: KB.uptime, stats: [['99.97%', 'uptime SLA'],['90 sec', 'error alert'],['24/7', 'monitoring']] };
      case 'addons':
        return { text: 'Add-ons available on any plan:\n· Extra Workflow — £299 one-time\n· Quarterly Audit — £499/quarter\n· Team Training — £799 one-time\n· Zapier/Make Migration — £1,499 one-time', stats: null };
      default:
        return { text: 'Good question. I\'m trained on everything PURIST does — automation, AI agents, pricing, deployment, ROI, and integrations.\n\nWhat specifically would help you most right now?', stats: null };
    }
  }

  /* ── DOM HELPERS ──────────────────────────── */
  function addMsg(html, isUser) {
    var row = document.createElement('div');
    row.style.cssText = 'display:flex;' + (isUser ? 'justify-content:flex-end;' : '');
    var bubble = document.createElement('div');
    // Convert \n to <br>
    var safe = html.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>').replace(/·/g,'<span style="opacity:0.5;">·</span> ');
    bubble.style.cssText = isUser
      ? 'font-size:11.5px;line-height:1.6;color:rgba(255,255,255,0.85);background:rgba(232,180,176,0.14);padding:9px 13px;border-radius:12px 12px 3px 12px;max-width:310px;word-break:break-word;'
      : 'font-size:11.5px;line-height:1.6;color:rgba(255,255,255,0.70);background:rgba(255,255,255,0.05);padding:9px 13px;border-radius:3px 12px 12px 12px;max-width:340px;word-break:break-word;';
    bubble.innerHTML = safe;
    row.appendChild(bubble);
    msgs.appendChild(row);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function addCards(stats) {
    if (!stats) return;
    var row = document.createElement('div');
    row.style.cssText = 'display:grid;grid-template-columns:repeat(' + stats.length + ',1fr);gap:5px;margin-top:2px;';
    stats.forEach(function(s){
      var c = document.createElement('div');
      c.style.cssText = 'background:rgba(232,180,176,0.07);border:1px solid rgba(232,180,176,0.14);border-radius:9px;padding:7px 9px;';
      c.innerHTML = '<div style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.90);letter-spacing:-0.01em;line-height:1.1;">' + s[0] + '</div><div style="font-size:8px;text-transform:uppercase;letter-spacing:0.10em;color:rgba(232,180,176,0.55);margin-top:3px;line-height:1.2;">' + s[1] + '</div>';
      row.appendChild(c);
    });
    msgs.appendChild(row);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function addCTA() {
    var row = document.createElement('div');
    row.style.cssText = 'display:flex;gap:6px;align-items:center;flex-wrap:wrap;margin-top:2px;';
    row.innerHTML = '<a href="/pages/welcome" style="display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:8px;font-size:11px;font-weight:600;background:#E8B4B0;color:#0A0A0A;text-decoration:none;white-space:nowrap;" onmouseover="this.style.background=\'#d9a09b\'" onmouseout="this.style.background=\'#E8B4B0\'">Book free audit <svg width="10" height="10" viewBox="0 0 14 14" fill="none" stroke="#0A0A0A" stroke-width="2.2" stroke-linecap="round"><path d="M2 7h10M8 3l4 4-4 4"/></svg></a><a href="/collections/all" style="display:inline-flex;align-items:center;padding:7px 12px;border-radius:8px;font-size:11px;font-weight:500;background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.50);border:1px solid rgba(255,255,255,0.09);text-decoration:none;white-space:nowrap;" onmouseover="this.style.color=\'rgba(255,255,255,0.80)\'" onmouseout="this.style.color=\'rgba(255,255,255,0.50)\'">View plans</a>';
    msgs.appendChild(row);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function addTyping() {
    var row = document.createElement('div');
    row.id = 'tind';
    row.style.cssText = 'display:flex;';
    row.innerHTML = '<div style="background:rgba(255,255,255,0.05);padding:9px 13px;border-radius:3px 12px 12px 12px;display:flex;gap:4px;align-items:center;"><span style="width:4px;height:4px;border-radius:50%;background:rgba(255,255,255,0.30);animation:tdot 1.1s ease-in-out infinite;display:inline-block;"></span><span style="width:4px;height:4px;border-radius:50%;background:rgba(255,255,255,0.30);animation:tdot 1.1s ease-in-out 0.18s infinite;display:inline-block;"></span><span style="width:4px;height:4px;border-radius:50%;background:rgba(255,255,255,0.30);animation:tdot 1.1s ease-in-out 0.36s infinite;display:inline-block;"></span></div>';
    msgs.appendChild(row);
    msgs.scrollTop = msgs.scrollHeight;
  }
  function removeTyping() { var t = document.getElementById('tind'); if(t) t.remove(); }

  /* ── SEND FLOW ────────────────────────────── */
  function sendMsg(text) {
    if (!text.trim()) return;
    addMsg(text, true);
    if (quick) quick.style.display = 'none';
    history.push({ role: 'user', text: text });

    var classified = classify(text);
    var delay = 600 + Math.random() * 500;
    addTyping();

    setTimeout(function(){
      removeTyping();
      var reply = buildReply(classified, text);
      addMsg(reply.text, false);
      if (reply.stats) {
        setTimeout(function(){
          addCards(reply.stats);
          if (reply.followUp) {
            setTimeout(function(){
              addMsg(reply.followUp, false);
            }, 400);
          } else {
            setTimeout(addCTA, 500);
          }
        }, 300);
      } else if (reply.followUp) {
        setTimeout(function(){ addMsg(reply.followUp, false); }, 400);
      } else {
        setTimeout(addCTA, 600);
      }
      history.push({ role: 'ai', text: reply.text });
    }, delay);
  }

  /* ── EVENT LISTENERS ──────────────────────── */
  document.addEventListener('click', function(e){
    var qr = e.target.closest('[data-quick]');
    if (qr) sendMsg(qr.dataset.quick);
  });
  send  && send.addEventListener('click',  function(){ var v=input.value; input.value=''; sendMsg(v); });
  input && input.addEventListener('keydown', function(e){
    if(e.key==='Enter' && !e.shiftKey){ e.preventDefault(); var v=input.value; input.value=''; sendMsg(v); }
  });
})();
</script>

