  /* ── OPEN / CLOSE ─────────────────────────── */
  function show() {
    open = true;
    panel.style.opacity = '1';
    panel.style.pointerEvents = 'auto';
    panel.classList.add('chat-open');
    if (backdrop) { backdrop.classList.add('chat-open'); }
    chev.style.transform = 'rotate(180deg)';
    // Lock body scroll on mobile to prevent page floating when keyboard opens
    if (window.innerWidth < 640) {
      document.body.style.overflow = 'hidden';
      document.body.style.position = 'fixed';
      document.body.style.width = '100%';
    }
    setTimeout(function(){ input && input.focus(); }, 300);
  }
  function hide() {
    open = false;
    panel.style.opacity = '0';
    panel.style.pointerEvents = 'none';
    panel.classList.remove('chat-open');
    if (backdrop) { backdrop.classList.remove('chat-open'); }
    chev.style.transform = '';
    // Restore body scroll
    document.body.style.overflow = '';
    document.body.style.position = '';
    document.body.style.width = '';
  }
  pill     && pill.addEventListener('click', function(){ open ? hide() : show(); });
  closeBtn && closeBtn.addEventListener('click', hide);
  if (backdrop) backdrop.addEventListener('click', hide);
  document.addEventListener('click', function(e){
    if (open && !panel.contains(e.target) && !pill.contains(e.target) && e.target !== backdrop) hide();
  });

