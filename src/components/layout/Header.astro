  function removeTyping() { var t = document.getElementById('tind'); if(t) t.remove(); }

  /* ── SEND FLOW (real AI via OpenRouter) ──── */
  function sendMsg(text) {
    if (!text.trim()) return;
    addMsg(text, true);
    if (quick) quick.style.display = 'none';
    history.push({ role: 'user', content: text });
    addTyping();

    fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages: history }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      removeTyping();
      if (data.fallback) {
        // API unavailable — fall back to local KB
        var classified = classify(text);
        var reply = buildReply(classified, text);
        addMsg(reply.text, false);
        if (reply.stats) setTimeout(function(){ addCards(reply.stats); }, 300);
        setTimeout(addCTA, 700);
        history.push({ role: 'assistant', content: reply.text });
        return;
      }
      var reply = data.reply || '';
      addMsg(reply, false);
      history.push({ role: 'assistant', content: reply });
      setTimeout(addCTA, 900);
    })
    .catch(function() {
      removeTyping();
      // Network error — fall back to local KB
      var classified = classify(text);
      var reply = buildReply(classified, text);
      addMsg(reply.text, false);
      if (reply.stats) setTimeout(function(){ addCards(reply.stats); }, 300);
      setTimeout(addCTA, 700);
      history.push({ role: 'assistant', content: reply.text });
    });
  }

  /* ── EVENT LISTENERS ──────────────────────── */
  document.addEventListener('click', function(e){
    var qr = e.target.closest('[data-quick]');
    if (qr) { var q = qr.dataset.quick; setTimeout(function(){ sendMsg(q); }, 0); }
  });
  send  && send.addEventListener('click',  function(){ var v=input.value; input.value=''; setTimeout(function(){ sendMsg(v); }, 0); });
  input && input.addEventListener('keydown', function(e){
    if(e.key==='Enter' && !e.shiftKey){ e.preventDefault(); var v=input.value; input.value=''; setTimeout(function(){ sendMsg(v); }, 0); }
  });
})();
</script>

