  /* ── DOM HELPERS ──────────────────────────── */
  function addMsg(html, isUser) {
    var row = document.createElement('div');
    row.style.cssText = 'display:flex;' + (isUser ? 'justify-content:flex-end;' : '');
    var bubble = document.createElement('div');
    // Convert \n to <br>
    var safe = html.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>').replace(/·/g,'<span style="opacity:0.5;">·</span> ');
    bubble.style.cssText = isUser
      ? 'font-size:11.5px;line-height:1.6;color:rgba(255,255,255,0.85);background:rgba(232,180,176,0.14);padding:9px 13px;border-radius:12px 12px 3px 12px;max-width:310px;word-break:break-word;'
      : 'font-size:11.5px;line-height:1.6;color:rgba(255,255,255,0.70);background:rgba(255,255,255,0.05);padding:9px 13px;border-radius:3px 12px 12px 12px;max-width:340px;word-break:break-word;';
    bubble.innerHTML = safe;
    row.appendChild(bubble);
    msgs.appendChild(row);
    requestAnimationFrame(function(){ msgs.scrollTop = msgs.scrollHeight; });
  }

