{
  "framework": "astro",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/nurture",
      "schedule": "0 9 * * *"
    }
  ],
  "buildCommand": "npm run build",
  "installCommand": "npm ci --legacy-peer-deps",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "permanent": true
    },
    {
      "source": "/pages/purist-vs-green-powders",
      "destination": "/pages/purist-vs-zapier",
      "permanent": true
    },
    {
      "source": "/pages/purist-vs-multivitamins",
      "destination": "/pages/purist-vs-make",
      "permanent": true
    },
    {
      "source": "/pages/purist-vs-meal-replacements",
      "destination": "/pages/purist-vs-inhouse-hire",
      "permanent": true
    },
    {
      "source": "/pages/purist-vs-integromat",
      "destination": "/pages/purist-vs-make",
      "permanent": true
    },
    {
      "source": "/pages/purist-vs-hiring",
      "destination": "/pages/purist-vs-inhouse-hire",
      "permanent": true
    },
    {
      "source": "/pages/purist-vs-hiring-in-house",
      "destination": "/pages/purist-vs-inhouse-hire",
      "permanent": true
    },
    { "source": "/pages/ingredients", "destination": "/pages/integrations", "permanent": true },
    { "source": "/pages/quality", "destination": "/pages/our-standards", "permanent": true },
    { "source": "/pages/science", "destination": "/pages/methodology", "permanent": true },
    { "source": "/pages/wall-of-health", "destination": "/pages/client-results", "permanent": true },
    { "source": "/collections/all", "destination": "/pages/pricing", "permanent": true },
    { "source": "/collections/core-services", "destination": "/pages/packages", "permanent": true },
    { "source": "/collections/merchandise", "destination": "/pages/add-ons", "permanent": true },
    { "source": "/products/foundation-pro", "destination": "/plans/automation-pro", "permanent": true },
    { "source": "/products/longevity-protocol", "destination": "/plans/ai-agent-deploy", "permanent": true },
    { "source": "/products/founder-stack", "destination": "/plans/full-stack", "permanent": true }
  ]
}
