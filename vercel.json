{
  "framework": "astro",
  "buildCommand": "npm run build",
  "installCommand": "npm ci --legacy-peer-deps",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.purist.online" }],
      "destination": "https://purist.online/:path*",
      "permanent": true
    },
    {
      "source": "/:path+/",
      "destination": "https://purist.online/:path*",
      "permanent": true
    }
  ]
}
